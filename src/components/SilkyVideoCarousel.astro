---
const videos = [
  {
    number: "01",
    src: "/video/szkolenia-pmu-autorska-metoda-natural.mp4",
    poster: "/video/szkolenia-pmu-autorska-metoda-natural-poster.webp",
    title: "Naturalny kierunek włosa",
    text: "Lekka, uporządkowana praca nad włosem maszynowym i naturalnym rytmem brwi.",
  },
  {
    number: "02",
    src: "/video/szkolenia-pmu-autorska-metoda-soft-glam.mp4",
    poster: "/video/szkolenia-pmu-autorska-metoda-soft-glam-poster.webp",
    title: "Miękkość efektu Silky",
    text: "Subtelna oprawa oka bez ciężkiej, graficznej formy i bez efektu maski.",
  },
  {
    number: "03",
    src: "/video/metamorfozy-pmu-boguslawa-herda.mp4",
    poster: "/video/metamorfozy-pmu-boguslawa-herda-poster.webp",
    title: "Silky na twarzy klientki",
    text: "Efekt oglądany w ruchu: proporcje, lekkość i naturalne współgranie z mimiką.",
  },
];
---

<section
  class="silky-video-carousel"
  aria-labelledby="silky-video-carousel-title"
  data-silky-video-carousel
>
  <div class="silky-video-carousel__heading">
    <div>
      <p class="silky-video-carousel__kicker">Silky w ruchu</p>

      <h4 id="silky-video-carousel-title">
        Zobacz kierunek włosa, miękkość linii i naturalny efekt w filmie.
      </h4>

      <p class="silky-video-carousel__lead">
        Filmy pokazują technikę i efekt w ruchu — bez ciężkiej, graficznej formy.
      </p>
    </div>

    <div class="silky-video-carousel__controls" aria-label="Przewijanie filmów Silky">
      <button
        type="button"
        class="silky-video-carousel__arrow"
        aria-label="Przewiń filmy Silky w lewo"
        data-silky-video-prev
      >
        ←
      </button>

      <button
        type="button"
        class="silky-video-carousel__arrow"
        aria-label="Przewiń filmy Silky w prawo"
        data-silky-video-next
      >
        →
      </button>
    </div>
  </div>

  <div class="silky-video-carousel__track" data-silky-video-track>
    {videos.map((item) => (
      <article
        class="silky-video-carousel__card"
        data-silky-video-card
        data-playing="false"
      >
        <div class="silky-video-carousel__media" data-silky-video-media>
          <video
            class="silky-video-carousel__video"
            playsinline
            muted
            preload="metadata"
            poster={item.poster}
            aria-label={`${item.title} — film Silky Hairstroke Brows`}
            data-silky-video
          >
            <source src={item.src} type="video/mp4" />
            Twoja przeglądarka nie obsługuje odtwarzania filmu.
          </video>

          <button
            type="button"
            class="silky-video-carousel__hit-area"
            aria-label={`Odtwórz film: ${item.title}`}
            data-silky-video-toggle
          >
            <span
              class="silky-video-carousel__main-icon"
              aria-hidden="true"
              data-silky-main-icon
            >
              ▶
            </span>
          </button>

          <div class="silky-video-carousel__toolbar">
            <button
              type="button"
              class="silky-video-carousel__control-button"
              aria-label={`Odtwórz film: ${item.title}`}
              data-silky-video-toggle
            >
              <span aria-hidden="true" data-silky-play-icon>▶</span>
            </button>

            <button
              type="button"
              class="silky-video-carousel__control-button"
              aria-label={`Włącz dźwięk filmu: ${item.title}`}
              data-silky-video-mute
            >
              <span aria-hidden="true" data-silky-mute-icon>🔇</span>
            </button>

            <button
              type="button"
              class="silky-video-carousel__control-button"
              aria-label={`Otwórz film na pełnym ekranie: ${item.title}`}
              data-silky-video-fullscreen
            >
              <span aria-hidden="true">⛶</span>
            </button>
          </div>
        </div>

        <div class="silky-video-carousel__copy">
          <span>{item.number}</span>
          <h5>{item.title}</h5>
          <p>{item.text}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .silky-video-carousel {
    position: relative;
    z-index: 5;
    grid-column: 1 / -1;
    width: 100%;
    min-width: 0;
    margin-top: clamp(30px, 4vw, 52px);
    padding-top: clamp(26px, 3vw, 38px);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    box-sizing: border-box;
    pointer-events: auto;
  }

  .silky-video-carousel,
  .silky-video-carousel * {
    box-sizing: border-box;
  }

  .silky-video-carousel__heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    margin-bottom: 22px;
  }

  .silky-video-carousel__kicker {
    display: inline-flex;
    width: fit-content;
    min-height: 30px;
    align-items: center;
    margin: 0 0 14px;
    padding: 0 12px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .silky-video-carousel h4 {
    max-width: 850px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.8rem, 3vw, 3.2rem);
    font-weight: 780;
    line-height: 0.98;
    letter-spacing: -0.07em;
  }

  .silky-video-carousel__lead {
    max-width: 720px;
    margin: 14px 0 0;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.96rem;
    line-height: 1.62;
  }

  .silky-video-carousel__controls {
    position: relative;
    z-index: 20;
    display: flex;
    gap: 10px;
  }

  .silky-video-carousel button {
    appearance: none;
    -webkit-appearance: none;
    font: inherit;
    cursor: pointer;
    touch-action: manipulation;
    pointer-events: auto;
  }

  .silky-video-carousel__arrow {
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
    box-shadow:
      0 14px 34px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
    font-size: 1.12rem;
    font-weight: 760;
    line-height: 1;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition:
      transform 180ms ease,
      background 180ms ease,
      border-color 180ms ease;
  }

  .silky-video-carousel__arrow:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.58);
    background: rgba(255, 255, 255, 0.22);
  }

  .silky-video-carousel__track {
    position: relative;
    z-index: 10;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(270px, 320px);
    gap: 16px;
    width: 100%;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 4px 4px 10px;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 4px;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    pointer-events: auto;
  }

  .silky-video-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .silky-video-carousel__card {
    position: relative;
    z-index: 1;
    min-width: 0;
    overflow: hidden;
    scroll-snap-align: start;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.13);
    box-shadow:
      0 18px 46px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    pointer-events: auto;
  }

  .silky-video-carousel__media {
    position: relative;
    z-index: 2;
    margin: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 24px;
    background: rgba(13, 106, 103, 0.82);
    isolation: isolate;
    pointer-events: auto;
  }

  .silky-video-carousel__media::after {
    content: "";
    position: absolute;
    inset: 10px;
    z-index: 2;
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 18px;
    pointer-events: none;
  }

  .silky-video-carousel__video {
    position: relative;
    z-index: 0;
    display: block;
    width: 100%;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    background: #0d6a67;
    pointer-events: none;
    user-select: none;
  }

  .silky-video-carousel__hit-area {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: #ffffff;
  }

  .silky-video-carousel__main-icon {
    display: inline-flex;
    width: 68px;
    height: 68px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.54);
    border-radius: 999px;
    background: rgba(15, 119, 115, 0.7);
    color: #ffffff;
    box-shadow:
      0 18px 46px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
    font-size: 1.45rem;
    line-height: 1;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      background 180ms ease;
  }

  .silky-video-carousel__hit-area:hover .silky-video-carousel__main-icon {
    background: rgba(26, 165, 160, 0.84);
    transform: scale(1.04);
  }

  .silky-video-carousel__card[data-playing="true"]
    .silky-video-carousel__main-icon {
    opacity: 0;
    transform: scale(0.9);
  }

  .silky-video-carousel__toolbar {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    z-index: 8;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    padding: 9px;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 999px;
    background: rgba(9, 69, 68, 0.6);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    pointer-events: auto;
  }

  .silky-video-carousel__control-button {
    position: relative;
    z-index: 9;
    display: inline-flex;
    width: 38px;
    height: 38px;
    padding: 0;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    font-size: 1rem;
    line-height: 1;
    transition:
      transform 160ms ease,
      background 160ms ease,
      border-color 160ms ease;
  }

  .silky-video-carousel__control-button:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.48);
    background: rgba(255, 255, 255, 0.24);
  }

  .silky-video-carousel__copy {
    position: relative;
    z-index: 2;
    padding: 18px 20px 22px;
  }

  .silky-video-carousel__copy > span {
    display: inline-flex;
    margin-bottom: 13px;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.18em;
  }

  .silky-video-carousel__copy h5 {
    margin: 0;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .silky-video-carousel__copy p {
    margin: 10px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.88rem;
    line-height: 1.54;
  }

  @media (min-width: 1180px) {
    .silky-video-carousel__track {
      grid-auto-columns: calc((100% - 32px) / 3);
    }
  }

  @media (min-width: 761px) and (max-width: 1179px) {
    .silky-video-carousel__track {
      grid-auto-columns: calc((100% - 16px) / 2);
    }
  }

  @media (max-width: 760px) {
    .silky-video-carousel {
      margin-top: 28px;
      padding-top: 24px;
    }

    .silky-video-carousel__heading {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .silky-video-carousel h4 {
      font-size: clamp(1.55rem, 7.6vw, 2.25rem);
      line-height: 1.02;
    }

    .silky-video-carousel__controls {
      justify-content: flex-end;
    }

    .silky-video-carousel__arrow {
      width: 40px;
      height: 40px;
      font-size: 1rem;
    }

    .silky-video-carousel__track {
      grid-auto-columns: minmax(255px, 84vw);
      gap: 14px;
      padding-right: 0;
    }

    .silky-video-carousel__card {
      border-radius: 26px;
    }

    .silky-video-carousel__media {
      border-radius: 21px;
    }

    .silky-video-carousel__media::after {
      inset: 8px;
      border-radius: 15px;
    }

    .silky-video-carousel__main-icon {
      width: 62px;
      height: 62px;
      font-size: 1.3rem;
    }

    .silky-video-carousel__toolbar {
      left: 10px;
      right: 10px;
      bottom: 10px;
      padding: 8px;
    }

    .silky-video-carousel__control-button {
      width: 36px;
      height: 36px;
    }
  }

  @media (hover: none) {
    .silky-video-carousel__arrow:hover,
    .silky-video-carousel__control-button:hover {
      transform: none;
    }

    .silky-video-carousel__hit-area:hover .silky-video-carousel__main-icon {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .silky-video-carousel__track {
      scroll-behavior: auto;
    }

    .silky-video-carousel__arrow,
    .silky-video-carousel__control-button,
    .silky-video-carousel__main-icon {
      transition: none;
    }
  }
</style>

<script>
  const initializeSilkyVideoCarousels = () => {
    document.querySelectorAll("[data-silky-video-carousel]").forEach((carousel) => {
      if (carousel.dataset.silkyInitialized === "true") return;
      carousel.dataset.silkyInitialized = "true";

      const track = carousel.querySelector("[data-silky-video-track]");
      const previousButton = carousel.querySelector("[data-silky-video-prev]");
      const nextButton = carousel.querySelector("[data-silky-video-next]");
      const cards = Array.from(
        carousel.querySelectorAll("[data-silky-video-card]")
      );

      const videos = cards
        .map((card) => card.querySelector("[data-silky-video]"))
        .filter(Boolean);

      const getScrollAmount = () => {
        const firstCard = track?.querySelector("[data-silky-video-card]");
        if (!firstCard) return 320;

        const gap = Number.parseFloat(getComputedStyle(track).columnGap || "16");
        return firstCard.getBoundingClientRect().width + gap;
      };

      previousButton?.addEventListener("click", () => {
        track?.scrollBy({
          left: -getScrollAmount(),
          behavior: "smooth",
        });
      });

      nextButton?.addEventListener("click", () => {
        track?.scrollBy({
          left: getScrollAmount(),
          behavior: "smooth",
        });
      });

      const pauseOtherVideos = (activeVideo) => {
        videos.forEach((video) => {
          if (video !== activeVideo && !video.paused) {
            video.pause();
          }
        });
      };

      const updateCardState = (card, video) => {
        const playing = !video.paused && !video.ended;
        const toggleButtons = card.querySelectorAll("[data-silky-video-toggle]");
        const playIcon = card.querySelector("[data-silky-play-icon]");
        const muteButton = card.querySelector("[data-silky-video-mute]");
        const muteIcon = card.querySelector("[data-silky-mute-icon]");

        card.dataset.playing = playing ? "true" : "false";

        toggleButtons.forEach((button) => {
          button.setAttribute(
            "aria-label",
            playing ? "Wstrzymaj film" : "Odtwórz film"
          );
        });

        if (playIcon) {
          playIcon.textContent = playing ? "❚❚" : "▶";
        }

        if (muteButton) {
          muteButton.setAttribute(
            "aria-label",
            video.muted ? "Włącz dźwięk filmu" : "Wycisz film"
          );
        }

        if (muteIcon) {
          muteIcon.textContent = video.muted ? "🔇" : "🔊";
        }
      };

      cards.forEach((card) => {
        const video = card.querySelector("[data-silky-video]");
        const toggleButtons = card.querySelectorAll("[data-silky-video-toggle]");
        const muteButton = card.querySelector("[data-silky-video-mute]");
        const fullscreenButton = card.querySelector(
          "[data-silky-video-fullscreen]"
        );
        const media = card.querySelector("[data-silky-video-media]");

        if (!video) return;

        const togglePlayback = async () => {
          if (video.paused || video.ended) {
            pauseOtherVideos(video);

            try {
              await video.play();
            } catch (error) {
              console.warn("Nie udało się uruchomić filmu Silky:", error);
            }
          } else {
            video.pause();
          }

          updateCardState(card, video);
        };

        toggleButtons.forEach((button) => {
          button.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();
            togglePlayback();
          });
        });

        muteButton?.addEventListener("click", (event) => {
          event.preventDefault();
          event.stopPropagation();
          video.muted = !video.muted;
          updateCardState(card, video);
        });

        fullscreenButton?.addEventListener("click", async (event) => {
          event.preventDefault();
          event.stopPropagation();

          try {
            if (video.requestFullscreen) {
              await video.requestFullscreen();
            } else if (video.webkitEnterFullscreen) {
              video.webkitEnterFullscreen();
            } else if (media?.requestFullscreen) {
              await media.requestFullscreen();
            }
          } catch (error) {
            console.warn(
              "Tryb pełnoekranowy filmu Silky jest niedostępny:",
              error
            );
          }
        });

        video.addEventListener("play", () => {
          pauseOtherVideos(video);
          updateCardState(card, video);
        });

        video.addEventListener("pause", () => {
          updateCardState(card, video);
        });

        video.addEventListener("ended", () => {
          video.currentTime = 0;
          updateCardState(card, video);
        });

        video.addEventListener("volumechange", () => {
          updateCardState(card, video);
        });

        updateCardState(card, video);
      });

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const video = entry.target;

              if (!entry.isIntersecting && video instanceof HTMLVideoElement) {
                video.pause();
              }
            });
          },
          { threshold: 0.18 }
        );

        videos.forEach((video) => observer.observe(video));
      }
    });
  };

  initializeSilkyVideoCarousels();
  document.addEventListener(
    "astro:page-load",
    initializeSilkyVideoCarousels
  );
</script>
