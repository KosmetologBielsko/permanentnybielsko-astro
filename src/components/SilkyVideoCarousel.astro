---
const videos = [
  {
    number: "01",
    src: "/video/szkolenia-pmu-autorska-metoda-natural.mp4",
    poster: "/video/szkolenia-pmu-autorska-metoda-natural-poster.webp",
    title: "Naturalny kierunek włosa",
    text: "Lekka, uporządkowana praca nad włosem maszynowym i naturalnym rytmem brwi.",
  },
  {
    number: "02",
    src: "/video/szkolenia-pmu-autorska-metoda-soft-glam.mp4",
    poster: "/video/szkolenia-pmu-autorska-metoda-soft-glam-poster.webp",
    title: "Miękkość efektu Silky",
    text: "Subtelna oprawa oka bez ciężkiej, graficznej formy i bez efektu maski.",
  },
  {
    number: "03",
    src: "/video/metamorfozy-pmu-boguslawa-herda.mp4",
    poster: "/video/metamorfozy-pmu-boguslawa-herda-poster.webp",
    title: "Silky na twarzy klientki",
    text: "Efekt oglądany w ruchu: proporcje, lekkość i naturalne współgranie z mimiką.",
  },
];
---

<section
  class="silky-video-carousel"
  aria-labelledby="silky-video-carousel-title"
  data-silky-video-carousel
>
  <div class="silky-video-carousel__heading">
    <div>
      <p class="silky-video-carousel__kicker">Silky w ruchu</p>

      <h4 id="silky-video-carousel-title">
        Zobacz kierunek włosa, miękkość linii i naturalny efekt w filmie.
      </h4>

      <p class="silky-video-carousel__lead">
        Filmy pokazują technikę i efekt w ruchu — bez ciężkiej, graficznej formy.
      </p>
    </div>

    <div class="silky-video-carousel__controls" aria-label="Przewijanie filmów Silky">
      <button
        type="button"
        class="silky-video-carousel__arrow"
        aria-label="Przewiń filmy Silky w lewo"
        data-silky-video-prev
      >
        ←
      </button>

      <button
        type="button"
        class="silky-video-carousel__arrow"
        aria-label="Przewiń filmy Silky w prawo"
        data-silky-video-next
      >
        →
      </button>
    </div>
  </div>

  <div class="silky-video-carousel__track" data-silky-video-track>
    {videos.map((item, index) => (
      <article
        class="silky-video-carousel__card"
        data-silky-video-card
        data-video-index={String(index)}
        data-playing="false"
      >
        <div class="silky-video-carousel__media">
          <video
            class="silky-video-carousel__video"
            playsinline
            preload="metadata"
            poster={item.poster}
            aria-label={`${item.title} — film Silky Hairstroke Brows`}
            data-silky-card-video
          >
            <source src={item.src} type="video/mp4" />
            Twoja przeglądarka nie obsługuje odtwarzania filmu.
          </video>

          <button
            type="button"
            class="silky-video-carousel__hit-area"
            aria-label={`Odtwórz film: ${item.title}`}
            data-silky-card-toggle
          >
            <span class="silky-video-carousel__main-icon" aria-hidden="true">
              ▶
            </span>
          </button>

          <div class="silky-video-carousel__toolbar">
            <button
              type="button"
              class="silky-video-carousel__control-button"
              aria-label={`Odtwórz film: ${item.title}`}
              data-silky-card-toggle
            >
              <span aria-hidden="true" data-silky-card-play-icon>▶</span>
            </button>

            <button
              type="button"
              class="silky-video-carousel__control-button"
              aria-label={`Otwórz film na pełnym ekranie: ${item.title}`}
              data-silky-dialog-open
            >
              <span aria-hidden="true">⛶</span>
            </button>
          </div>
        </div>

        <div class="silky-video-carousel__copy">
          <span>{item.number}</span>
          <h5>{item.title}</h5>
          <p>{item.text}</p>
        </div>

        <dialog
          class="silky-video-carousel__dialog"
          aria-label={`Pełny ekran filmu: ${item.title}`}
          data-silky-dialog
        >
          <div class="silky-video-carousel__dialog-shell">
            <div class="silky-video-carousel__dialog-media">
              <video
                class="silky-video-carousel__dialog-video"
                playsinline
                preload="metadata"
                poster={item.poster}
                aria-label={`${item.title} — pełny ekran`}
                data-silky-dialog-video
              >
                <source src={item.src} type="video/mp4" />
                Twoja przeglądarka nie obsługuje odtwarzania filmu.
              </video>

              <button
                type="button"
                class="silky-video-carousel__dialog-hit-area"
                aria-label={`Odtwórz film: ${item.title}`}
                data-silky-dialog-toggle
              >
                <span class="silky-video-carousel__dialog-main-icon" aria-hidden="true">
                  ▶
                </span>
              </button>

              <button
                type="button"
                class="silky-video-carousel__dialog-close"
                aria-label="Zamknij pełny ekran"
                data-silky-dialog-close
              >
                ×
              </button>

              <div class="silky-video-carousel__dialog-toolbar">
                <button
                  type="button"
                  class="silky-video-carousel__dialog-control"
                  aria-label={`Odtwórz film: ${item.title}`}
                  data-silky-dialog-toggle
                >
                  <span aria-hidden="true" data-silky-dialog-play-icon>▶</span>
                </button>

                <button
                  type="button"
                  class="silky-video-carousel__dialog-control"
                  aria-label="Zamknij pełny ekran"
                  data-silky-dialog-close
                >
                  <span aria-hidden="true">×</span>
                </button>
              </div>
            </div>
          </div>
        </dialog>
      </article>
    ))}
  </div>
</section>

<style>
  .silky-video-carousel,
  .silky-video-carousel * {
    box-sizing: border-box;
  }

  .silky-video-carousel {
    position: relative;
    z-index: 5;
    grid-column: 1 / -1;
    width: 100%;
    min-width: 0;
    margin-top: clamp(30px, 4vw, 52px);
    padding-top: clamp(26px, 3vw, 38px);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .silky-video-carousel__heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    margin-bottom: 22px;
  }

  .silky-video-carousel__kicker {
    display: inline-flex;
    width: fit-content;
    min-height: 30px;
    align-items: center;
    margin: 0 0 14px;
    padding: 0 12px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .silky-video-carousel h4 {
    max-width: 850px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.8rem, 3vw, 3.2rem);
    font-weight: 780;
    line-height: 0.98;
    letter-spacing: -0.07em;
  }

  .silky-video-carousel__lead {
    max-width: 720px;
    margin: 14px 0 0;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.96rem;
    line-height: 1.62;
  }

  .silky-video-carousel__controls {
    display: flex;
    gap: 10px;
  }

  .silky-video-carousel button {
    appearance: none;
    -webkit-appearance: none;
    font: inherit;
    cursor: pointer;
    touch-action: manipulation;
  }

  .silky-video-carousel__arrow,
  .silky-video-carousel__control-button,
  .silky-video-carousel__dialog-control,
  .silky-video-carousel__dialog-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: #ffffff;
  }

  .silky-video-carousel__arrow {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 14px 34px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
    font-size: 1.12rem;
    font-weight: 760;
    line-height: 1;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .silky-video-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(270px, 320px);
    gap: 16px;
    width: 100%;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 4px 4px 10px;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 4px;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .silky-video-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .silky-video-carousel__card {
    min-width: 0;
    overflow: hidden;
    scroll-snap-align: start;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.13);
    box-shadow:
      0 18px 46px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .silky-video-carousel__media {
    position: relative;
    margin: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 24px;
    background: rgba(13, 106, 103, 0.82);
    isolation: isolate;
  }

  .silky-video-carousel__media::after {
    content: "";
    position: absolute;
    inset: 10px;
    z-index: 2;
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 18px;
    pointer-events: none;
  }

  .silky-video-carousel__video,
  .silky-video-carousel__dialog-video {
    display: block;
    width: 100%;
    object-fit: cover;
    background: #0d6a67;
    pointer-events: none;
    user-select: none;
  }

  .silky-video-carousel__video {
    aspect-ratio: 9 / 16;
  }

  .silky-video-carousel__hit-area,
  .silky-video-carousel__dialog-hit-area {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    background: transparent;
    color: #ffffff;
  }

  .silky-video-carousel__main-icon,
  .silky-video-carousel__dialog-main-icon {
    display: inline-flex;
    width: 68px;
    height: 68px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.54);
    border-radius: 999px;
    background: rgba(15, 119, 115, 0.72);
    color: #ffffff;
    box-shadow:
      0 18px 46px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
    font-size: 1.45rem;
    line-height: 1;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .silky-video-carousel__card[data-playing="true"]
    .silky-video-carousel__main-icon,
  .silky-video-carousel__dialog[data-playing="true"]
    .silky-video-carousel__dialog-main-icon {
    opacity: 0;
  }

  .silky-video-carousel__toolbar {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    z-index: 8;
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    padding: 9px;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 999px;
    background: rgba(9, 69, 68, 0.62);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .silky-video-carousel__control-button {
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.14);
    font-size: 1rem;
    line-height: 1;
  }

  .silky-video-carousel__copy {
    padding: 18px 20px 22px;
  }

  .silky-video-carousel__copy > span {
    display: inline-flex;
    margin-bottom: 13px;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.18em;
  }

  .silky-video-carousel__copy h5 {
    margin: 0;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .silky-video-carousel__copy p {
    margin: 10px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.88rem;
    line-height: 1.54;
  }

  .silky-video-carousel__dialog {
    width: 100vw;
    width: 100dvw;
    max-width: none;
    height: 100vh;
    height: 100dvh;
    max-height: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
    border: 0;
    background: #031f20;
  }

  .silky-video-carousel__dialog::backdrop {
    background: rgba(0, 18, 19, 0.96);
  }

  .silky-video-carousel__dialog-shell {
    width: 100%;
    height: 100%;
    padding:
      max(12px, env(safe-area-inset-top))
      max(12px, env(safe-area-inset-right))
      max(12px, env(safe-area-inset-bottom))
      max(12px, env(safe-area-inset-left));
    background:
      radial-gradient(circle at 50% 20%, rgba(26, 165, 160, 0.24), transparent 34rem),
      #031f20;
  }

  .silky-video-carousel__dialog-media {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 24px;
    background: #031f20;
    isolation: isolate;
  }

  .silky-video-carousel__dialog-video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: transparent;
  }

  .silky-video-carousel__dialog-close {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 12;
    width: 48px;
    height: 48px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.42);
    background: rgba(4, 48, 49, 0.82);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.24);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .silky-video-carousel__dialog-toolbar {
    position: absolute;
    left: 50%;
    bottom: max(18px, calc(env(safe-area-inset-bottom) + 10px));
    z-index: 12;
    display: flex;
    gap: 10px;
    padding: 10px;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    background: rgba(3, 42, 43, 0.82);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .silky-video-carousel__dialog-control {
    width: 42px;
    height: 42px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.14);
    font-size: 1.1rem;
    line-height: 1;
  }

  @media (min-width: 1180px) {
    .silky-video-carousel__track {
      grid-auto-columns: calc((100% - 32px) / 3);
    }
  }

  @media (min-width: 761px) and (max-width: 1179px) {
    .silky-video-carousel__track {
      grid-auto-columns: calc((100% - 16px) / 2);
    }
  }

  @media (max-width: 760px) {
    .silky-video-carousel {
      margin-top: 28px;
      padding-top: 24px;
    }

    .silky-video-carousel__heading {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .silky-video-carousel h4 {
      font-size: clamp(1.55rem, 7.6vw, 2.25rem);
      line-height: 1.02;
    }

    .silky-video-carousel__controls {
      justify-content: flex-end;
    }

    .silky-video-carousel__arrow {
      width: 40px;
      height: 40px;
      font-size: 1rem;
    }

    .silky-video-carousel__track {
      grid-auto-columns: minmax(255px, 84vw);
      gap: 14px;
      padding-right: 0;
    }

    .silky-video-carousel__card {
      border-radius: 26px;
    }

    .silky-video-carousel__media {
      border-radius: 21px;
    }

    .silky-video-carousel__media::after {
      inset: 8px;
      border-radius: 15px;
    }

    .silky-video-carousel__main-icon {
      width: 62px;
      height: 62px;
      font-size: 1.3rem;
    }

    .silky-video-carousel__toolbar {
      left: 10px;
      right: 10px;
      bottom: 10px;
      padding: 8px;
    }

    .silky-video-carousel__control-button {
      width: 36px;
      height: 36px;
    }

    .silky-video-carousel__dialog-close {
      top: max(12px, env(safe-area-inset-top));
      right: max(12px, env(safe-area-inset-right));
      width: 46px;
      height: 46px;
    }

    .silky-video-carousel__dialog-control {
      width: 40px;
      height: 40px;
    }
  }
</style>

<script>
  const initializeSilkyVideoCarousels = () => {
    document.querySelectorAll("[data-silky-video-carousel]").forEach((carousel) => {
      if (carousel.dataset.silkyInitialized === "true") return;
      carousel.dataset.silkyInitialized = "true";

      const track = carousel.querySelector("[data-silky-video-track]");
      const previousButton = carousel.querySelector("[data-silky-video-prev]");
      const nextButton = carousel.querySelector("[data-silky-video-next]");
      const cards = Array.from(carousel.querySelectorAll("[data-silky-video-card]"));

      const allVideos = cards.flatMap((card) => [
        card.querySelector("[data-silky-card-video]"),
        card.querySelector("[data-silky-dialog-video]"),
      ]).filter(Boolean);

      const pauseAllExcept = (activeVideo) => {
        allVideos.forEach((video) => {
          if (video !== activeVideo && !video.paused) {
            video.pause();
          }
        });
      };

      const setPlaybackState = (container, video, iconSelector) => {
        const playing = !video.paused && !video.ended;
        container.dataset.playing = playing ? "true" : "false";

        const icon = container.querySelector(iconSelector);
        if (icon) icon.textContent = playing ? "❚❚" : "▶";

        container.querySelectorAll(
          container.matches("dialog")
            ? "[data-silky-dialog-toggle]"
            : "[data-silky-card-toggle]"
        ).forEach((button) => {
          button.setAttribute(
            "aria-label",
            playing ? "Wstrzymaj film" : "Odtwórz film"
          );
        });
      };

      const toggleVideo = async (container, video, iconSelector) => {
        if (video.paused || video.ended) {
          pauseAllExcept(video);

          try {
            await video.play();
          } catch (error) {
            console.warn("Nie udało się uruchomić filmu Silky:", error);
          }
        } else {
          video.pause();
        }

        setPlaybackState(container, video, iconSelector);
      };

      const getScrollAmount = () => {
        const firstCard = track?.querySelector("[data-silky-video-card]");
        if (!firstCard) return 320;

        const gap = Number.parseFloat(getComputedStyle(track).columnGap || "16");
        return firstCard.getBoundingClientRect().width + gap;
      };

      previousButton?.addEventListener("click", () => {
        track?.scrollBy({ left: -getScrollAmount(), behavior: "smooth" });
      });

      nextButton?.addEventListener("click", () => {
        track?.scrollBy({ left: getScrollAmount(), behavior: "smooth" });
      });

      cards.forEach((card) => {
        const cardVideo = card.querySelector("[data-silky-card-video]");
        const dialog = card.querySelector("[data-silky-dialog]");
        const dialogVideo = card.querySelector("[data-silky-dialog-video]");
        const openButton = card.querySelector("[data-silky-dialog-open]");
        const closeButtons = card.querySelectorAll("[data-silky-dialog-close]");

        if (!cardVideo || !dialog || !dialogVideo) return;

        card.querySelectorAll("[data-silky-card-toggle]").forEach((button) => {
          button.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();
            toggleVideo(card, cardVideo, "[data-silky-card-play-icon]");
          });
        });

        dialog.querySelectorAll("[data-silky-dialog-toggle]").forEach((button) => {
          button.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();
            toggleVideo(dialog, dialogVideo, "[data-silky-dialog-play-icon]");
          });
        });

        openButton?.addEventListener("click", async (event) => {
          event.preventDefault();
          event.stopPropagation();

          const shouldContinuePlaying = !cardVideo.paused && !cardVideo.ended;

          pauseAllExcept(null);

          try {
            if (Number.isFinite(cardVideo.currentTime)) {
              dialogVideo.currentTime = cardVideo.currentTime;
            }
          } catch {}

          if (typeof dialog.showModal === "function") {
            dialog.showModal();
          } else {
            dialog.setAttribute("open", "");
          }

          if (shouldContinuePlaying) {
            try {
              await dialogVideo.play();
            } catch {}
          }

          setPlaybackState(dialog, dialogVideo, "[data-silky-dialog-play-icon]");
        });

        const closeDialog = () => {
          try {
            if (Number.isFinite(dialogVideo.currentTime)) {
              cardVideo.currentTime = dialogVideo.currentTime;
            }
          } catch {}

          dialogVideo.pause();

          if (dialog.open && typeof dialog.close === "function") {
            dialog.close();
          } else {
            dialog.removeAttribute("open");
          }

          setPlaybackState(dialog, dialogVideo, "[data-silky-dialog-play-icon]");
          setPlaybackState(card, cardVideo, "[data-silky-card-play-icon]");
        };

        closeButtons.forEach((button) => {
          button.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();
            closeDialog();
          });
        });

        dialog.addEventListener("cancel", (event) => {
          event.preventDefault();
          closeDialog();
        });

        dialog.addEventListener("click", (event) => {
          if (event.target === dialog) closeDialog();
        });

        cardVideo.addEventListener("play", () => {
          pauseAllExcept(cardVideo);
          setPlaybackState(card, cardVideo, "[data-silky-card-play-icon]");
        });

        cardVideo.addEventListener("pause", () => {
          setPlaybackState(card, cardVideo, "[data-silky-card-play-icon]");
        });

        cardVideo.addEventListener("ended", () => {
          cardVideo.currentTime = 0;
          setPlaybackState(card, cardVideo, "[data-silky-card-play-icon]");
        });

        dialogVideo.addEventListener("play", () => {
          pauseAllExcept(dialogVideo);
          setPlaybackState(dialog, dialogVideo, "[data-silky-dialog-play-icon]");
        });

        dialogVideo.addEventListener("pause", () => {
          setPlaybackState(dialog, dialogVideo, "[data-silky-dialog-play-icon]");
        });

        dialogVideo.addEventListener("ended", () => {
          dialogVideo.currentTime = 0;
          setPlaybackState(dialog, dialogVideo, "[data-silky-dialog-play-icon]");
        });

        setPlaybackState(card, cardVideo, "[data-silky-card-play-icon]");
        setPlaybackState(dialog, dialogVideo, "[data-silky-dialog-play-icon]");
      });

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const video = entry.target;
              if (
                !entry.isIntersecting &&
                video instanceof HTMLVideoElement &&
                !video.closest("dialog[open]")
              ) {
                video.pause();
              }
            });
          },
          { threshold: 0.18 }
        );

        cards.forEach((card) => {
          const video = card.querySelector("[data-silky-card-video]");
          if (video) observer.observe(video);
        });
      }
    });
  };

  initializeSilkyVideoCarousels();
  document.addEventListener("astro:page-load", initializeSilkyVideoCarousels);
</script>
