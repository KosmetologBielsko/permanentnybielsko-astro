---
const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";
const phoneHref = "tel:+48730900125";

const starters = [
  "Chcę dobrać zabieg",
  "Brwi permanentne",
  "Usta permanentne",
  "Kreski permanentne",
  "Mam stary makijaż permanentny",
  "Cena i rezerwacja",
  "Przeciwwskazania",
  "Szkolenia PMU",
];
---

<div class="pmu-assistant" data-pmu-assistant>
  <button class="pmu-assistant__launcher" type="button" aria-expanded="false" aria-controls="pmu-assistant-panel">
    <span class="pmu-assistant__launcher-glow"></span>
    <span class="pmu-assistant__launcher-icon">AI</span>
    <span class="pmu-assistant__launcher-copy">
      <strong>Dobierz zabieg</strong>
      <small>AI Asystent PMU</small>
    </span>
  </button>

  <section class="pmu-assistant__panel" id="pmu-assistant-panel" aria-hidden="true">
    <header class="pmu-assistant__header">
      <div class="pmu-assistant__header-main">
        <p>AI Asystent PMU</p>
        <h2>Dobierz właściwy kierunek</h2>
        <span>Brwi · Usta · Kreski · Korekta PMU</span>
      </div>

      <div class="pmu-assistant__header-actions">
        <button class="pmu-assistant__clear" type="button" data-clear aria-label="Wyczyść rozmowę">
          Wyczyść
        </button>
        <button class="pmu-assistant__close" type="button" aria-label="Zamknij asystenta">
          ×
        </button>
      </div>
    </header>

    <div class="pmu-assistant__body" data-body>
      <div class="pmu-assistant__intro">
        <div class="pmu-assistant__consult-card">
          <div class="pmu-assistant__consult-kicker">Konsultacyjny pomocnik</div>
          <p>
            Pomogę Pani wybrać kierunek zabiegu, znaleźć właściwą podstronę
            i przejść do rezerwacji lub kontaktu z gabinetem.
          </p>
          <small>Na podstawie standardu gabinetu Bogusława Herda.</small>
        </div>

        <div class="pmu-assistant__starters" aria-label="Szybkie tematy">
          {starters.map((starter) => (
            <button type="button" data-starter={starter}>{starter}</button>
          ))}
        </div>
      </div>

      <div class="pmu-assistant__messages" data-messages></div>
    </div>

    <form class="pmu-assistant__form" data-form>
      <label class="sr-only" for="pmu-assistant-input">Wpisz pytanie do asystenta PMU</label>
      <textarea
        id="pmu-assistant-input"
        name="message"
        rows="2"
        maxlength="1200"
        placeholder="Np. mam stare brwi permanentne — co wybrać?"
        data-input
      ></textarea>

      <button type="submit">Wyślij</button>
    </form>

    <footer class="pmu-assistant__footer">
      <a href={booksyUrl} target="_blank" rel="noopener noreferrer" data-track="assistant_booksy_click">
        Booksy
      </a>
      <a href={phoneHref} data-track="assistant_phone_click">
        Zadzwoń
      </a>
    </footer>
  </section>
</div>

<style is:global>
  .pmu-assistant {
    --pmu-gold: #c8a35f;
    --pmu-gold-light: #e7d19a;
    --pmu-gold-deep: #9d7331;
    --pmu-turquoise: #22a8b7;
    --pmu-turquoise-deep: #0f7773;
    --pmu-turquoise-soft: #eefbfc;
    --pmu-pink: #d46d9b;
    --pmu-pink-deep: #bd527f;
    --pmu-pink-soft: #fff4f8;
    --pmu-ink: #182d31;
    --pmu-muted: #667a80;
    --pmu-line: rgba(15, 119, 115, 0.14);
    --pmu-line-strong: rgba(15, 119, 115, 0.24);
    --pmu-shadow: 0 34px 90px rgba(24, 45, 49, 0.22);
    --pmu-soft-shadow: 0 14px 34px rgba(24, 45, 49, 0.08);

    position: fixed;
    right: clamp(16px, 2vw, 28px);
    bottom: clamp(16px, 2vw, 28px);
    z-index: 10000;
    font-family: inherit;
  }

  .pmu-assistant * {
    box-sizing: border-box;
  }

  .pmu-assistant__launcher {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    isolation: isolate;
    min-height: 62px;
    padding: 10px 18px 10px 10px;
    border: 1px solid rgba(231, 209, 154, 0.58);
    border-radius: 999px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(255, 248, 236, 0.9)),
      radial-gradient(circle at 8% 0%, rgba(231, 209, 154, 0.38), transparent 45%),
      radial-gradient(circle at 100% 100%, rgba(34, 168, 183, 0.18), transparent 42%);
    color: var(--pmu-ink);
    box-shadow:
      0 18px 42px rgba(24, 45, 49, 0.15),
      0 0 0 1px rgba(200, 163, 95, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .pmu-assistant__launcher:hover {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(255, 248, 236, 0.9)),
      radial-gradient(circle at 8% 0%, rgba(231, 209, 154, 0.42), transparent 45%),
      radial-gradient(circle at 100% 100%, rgba(34, 168, 183, 0.22), transparent 42%);
    transform: translateY(-2px);
    box-shadow:
      0 22px 52px rgba(24, 45, 49, 0.2),
      0 0 0 1px rgba(200, 163, 95, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .pmu-assistant__launcher-glow {
    position: absolute;
    inset: -10px;
    z-index: -1;
    border-radius: inherit;
    background:
      radial-gradient(circle at 16% 8%, rgba(200, 163, 95, 0.22), transparent 42%),
      radial-gradient(circle at 90% 78%, rgba(34, 168, 183, 0.18), transparent 45%);
    filter: blur(10px);
    opacity: 0.72;
  }

  .pmu-assistant__launcher-icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--pmu-gold-deep), var(--pmu-gold-light));
    color: #fff;
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    box-shadow:
      0 12px 24px rgba(200, 163, 95, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.38);
  }

  .pmu-assistant__launcher-copy strong,
  .pmu-assistant__launcher-copy small {
    display: block;
    text-align: left;
    line-height: 1.12;
  }

  .pmu-assistant__launcher-copy strong {
    color: var(--pmu-ink);
    font-size: 0.94rem;
    font-weight: 850;
  }

  .pmu-assistant__launcher-copy small {
    margin-top: 4px;
    color: var(--pmu-turquoise-deep);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .pmu-assistant__panel {
    position: absolute;
    right: 0;
    bottom: 78px;
    display: none;
    width: min(456px, calc(100vw - 32px));
    max-height: min(780px, calc(100vh - 110px));
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.82);
    border-radius: 34px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(255, 247, 250, 0.76)),
      radial-gradient(circle at 0% 0%, rgba(34, 168, 183, 0.12), transparent 38%),
      radial-gradient(circle at 100% 12%, rgba(212, 109, 155, 0.12), transparent 40%),
      radial-gradient(circle at 50% 100%, rgba(200, 163, 95, 0.11), transparent 38%);
    box-shadow:
      var(--pmu-shadow),
      0 0 0 1px rgba(15, 119, 115, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(22px) saturate(1.12);
    -webkit-backdrop-filter: blur(22px) saturate(1.12);
  }

  .pmu-assistant__panel::before {
    content: "";
    position: absolute;
    inset: 9px;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.52);
    border-radius: 26px;
    box-shadow:
      inset 0 0 0 1px rgba(15, 119, 115, 0.07),
      inset 0 20px 60px rgba(255, 255, 255, 0.34);
  }

  .pmu-assistant.is-open .pmu-assistant__panel {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto auto;
  }

  .pmu-assistant.is-open .pmu-assistant__launcher {
    display: none;
  }

  .pmu-assistant__header {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 24px 18px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.72), rgba(255, 245, 249, 0.62)),
      radial-gradient(circle at 0% 0%, rgba(34, 168, 183, 0.14), transparent 40%),
      radial-gradient(circle at 100% 0%, rgba(200, 163, 95, 0.13), transparent 42%);
    border-bottom: 1px solid var(--pmu-line);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .pmu-assistant__header::after {
    content: "";
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: -1px;
    height: 1px;
    background: linear-gradient(90deg, rgba(38, 169, 186, 0.32), rgba(212, 109, 155, 0.18), transparent);
  }

  .pmu-assistant__header-main p {
    margin: 0 0 8px;
    color: var(--pmu-turquoise-deep);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .pmu-assistant__header-main h2 {
    margin: 0;
    color: var(--pmu-ink);
    font-size: clamp(1.15rem, 2vw, 1.34rem);
    line-height: 1.12;
    font-weight: 850;
    letter-spacing: -0.03em;
  }

  .pmu-assistant__header-main span {
    display: block;
    margin-top: 9px;
    color: var(--pmu-muted);
    font-size: 0.78rem;
    line-height: 1.25;
    font-weight: 650;
  }

  .pmu-assistant__header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .pmu-assistant__clear,
  .pmu-assistant__close {
    border: 1px solid rgba(15, 119, 115, 0.12);
    background: rgba(255, 255, 255, 0.72);
    color: var(--pmu-turquoise-deep);
    cursor: pointer;
    box-shadow:
      0 8px 18px rgba(24, 45, 49, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.72);
    transition: background 160ms ease, border-color 160ms ease, transform 160ms ease;
  }

  .pmu-assistant__clear:hover,
  .pmu-assistant__close:hover {
    background: rgba(255, 255, 255, 0.92);
    color: var(--pmu-turquoise-deep);
    border-color: rgba(15, 119, 115, 0.24);
    transform: translateY(-1px);
  }

  .pmu-assistant__clear {
    height: 36px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 850;
  }

  .pmu-assistant__close {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    font-size: 1.5rem;
    line-height: 1;
  }

  .pmu-assistant__body {
    overflow-y: auto;
    padding: 18px;
    background:
      radial-gradient(circle at 100% 22%, rgba(38, 169, 186, 0.045), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(252, 253, 253, 0.96));
  }

  .pmu-assistant__body::-webkit-scrollbar {
    width: 9px;
  }

  .pmu-assistant__body::-webkit-scrollbar-thumb {
    border: 3px solid transparent;
    border-radius: 999px;
    background-clip: content-box;
    background-color: rgba(15, 119, 115, 0.28);
  }

  .pmu-assistant__intro {
    display: grid;
    gap: 14px;
    margin-bottom: 14px;
  }

  .pmu-assistant__consult-card {
    position: relative;
    overflow: hidden;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.74);
    border-radius: 26px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 251, 253, 0.84)),
      radial-gradient(circle at 100% 0%, rgba(34, 168, 183, 0.08), transparent 38%);
    box-shadow:
      0 14px 34px rgba(24, 45, 49, 0.08),
      0 0 0 1px rgba(15, 119, 115, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .pmu-assistant__consult-card::after {
    content: "";
    position: absolute;
    width: 150px;
    height: 150px;
    right: -80px;
    bottom: -92px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(212, 109, 155, 0.12), transparent 64%);
  }

  .pmu-assistant__consult-kicker {
    margin-bottom: 9px;
    color: var(--pmu-turquoise-deep);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pmu-assistant__consult-card p {
    position: relative;
    margin: 0;
    color: var(--pmu-ink);
    font-size: 0.9rem;
    line-height: 1.52;
  }

  .pmu-assistant__consult-card small {
    position: relative;
    display: block;
    margin-top: 11px;
    color: var(--pmu-muted);
    font-size: 0.74rem;
    line-height: 1.35;
  }

  .pmu-assistant__starters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pmu-assistant__starters button {
    min-height: 36px;
    border: 1px solid rgba(15, 119, 115, 0.13);
    border-radius: 999px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--pmu-turquoise-deep);
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 780;
    line-height: 1.1;
    transition: background 160ms ease, border-color 160ms ease, transform 160ms ease;
  }

  .pmu-assistant__starters button:hover {
    background: rgba(255, 255, 255, 0.96);
    color: var(--pmu-turquoise-deep);
    border-color: rgba(15, 119, 115, 0.24);
    transform: translateY(-1px);
  }

  .pmu-assistant__messages {
    display: grid;
    gap: 12px;
  }

  .pmu-assistant__message {
    max-width: 92%;
    border-radius: 24px;
    padding: 15px 16px;
    font-size: 0.88rem;
    line-height: 1.58;
  }

  .pmu-assistant__message--assistant {
    border-top-left-radius: 11px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 251, 253, 0.84)),
      radial-gradient(circle at 100% 0%, rgba(34, 168, 183, 0.08), transparent 38%);
    border: 1px solid rgba(255, 255, 255, 0.74);
    box-shadow:
      0 14px 34px rgba(24, 45, 49, 0.08),
      0 0 0 1px rgba(15, 119, 115, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.84);
    color: var(--pmu-ink);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .pmu-assistant__message--user {
    margin-left: auto;
    border-top-right-radius: 11px;
    background: linear-gradient(135deg, var(--pmu-turquoise-deep), var(--pmu-turquoise));
    color: #fff;
    box-shadow:
      0 14px 30px rgba(15, 119, 115, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .pmu-assistant__message--loading {
    color: var(--pmu-muted);
    font-style: italic;
  }

  .pmu-assistant__text {
    display: grid;
    gap: 10px;
  }

  .pmu-assistant__text p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.58;
    color: inherit;
  }

  .pmu-assistant__message--assistant .pmu-assistant__text strong {
    color: var(--pmu-turquoise-deep);
    font-weight: 850;
  }

  .pmu-assistant__message--user .pmu-assistant__text strong {
    color: #fff;
    font-weight: 850;
  }

  .pmu-assistant__text a {
    color: var(--pmu-pink);
    font-weight: 850;
    text-decoration: none;
    border-bottom: 1px solid rgba(212, 109, 155, 0.34);
  }

  .pmu-assistant__text a:hover {
    border-bottom-color: currentColor;
  }

  .pmu-assistant__actions {
    display: flex;
    margin-top: 12px;
  }

  .pmu-assistant__action {
    min-height: 34px;
    width: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--pmu-turquoise-deep);
    border: 1px solid rgba(15, 119, 115, 0.16);
    box-shadow: none;
    font-size: 0.74rem;
    font-weight: 800;
    line-height: 1.15;
    text-align: center;
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .pmu-assistant__action:hover {
    background: rgba(255, 255, 255, 0.98);
    color: var(--pmu-turquoise-deep);
    border-color: rgba(15, 119, 115, 0.28);
    transform: translateY(-1px);
  }

  .pmu-assistant__form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    padding: 14px 16px 12px;
    border-top: 1px solid var(--pmu-line);
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .pmu-assistant__form textarea {
    width: 100%;
    min-height: 56px;
    resize: none;
    border: 1px solid rgba(34, 168, 183, 0.28);
    border-radius: 22px;
    padding: 12px 14px;
    color: var(--pmu-ink);
    background: rgba(255, 255, 255, 0.9);
    font: inherit;
    font-size: 0.88rem;
    line-height: 1.35;
    outline: none;
    box-shadow:
      inset 0 1px 2px rgba(24, 45, 49, 0.03),
      0 0 0 1px rgba(255, 255, 255, 0.52);
  }

  .pmu-assistant__form textarea::placeholder {
    color: rgba(102, 122, 128, 0.92);
  }

  .pmu-assistant__form textarea:focus {
    border-color: rgba(38, 169, 186, 0.72);
    box-shadow: 0 0 0 4px rgba(38, 169, 186, 0.11);
  }

  .pmu-assistant__form button {
    align-self: end;
    min-height: 48px;
    padding: 0 18px;
    border: 0;
    border-radius: 18px;
    background: linear-gradient(135deg, var(--pmu-gold-deep), var(--pmu-gold-light));
    color: #fff;
    cursor: pointer;
    font-size: 0.94rem;
    font-weight: 850;
    box-shadow:
      0 14px 28px rgba(200, 163, 95, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.32);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .pmu-assistant__form button:hover {
    background: linear-gradient(135deg, var(--pmu-gold-deep), var(--pmu-gold-light));
    color: #fff;
    transform: translateY(-1px);
    box-shadow:
      0 18px 34px rgba(200, 163, 95, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.34);
  }

  .pmu-assistant__form button:disabled {
    opacity: 0.7;
    cursor: wait;
    transform: none;
  }

  .pmu-assistant__footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 9px;
    padding: 0 16px 16px;
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .pmu-assistant__footer a {
    display: grid;
    place-items: center;
    min-height: 42px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 850;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .pmu-assistant__footer a:hover {
    transform: translateY(-1px);
  }

  .pmu-assistant__footer a:first-child,
  .pmu-assistant__footer a:first-child:hover {
    background: linear-gradient(135deg, var(--pmu-turquoise-deep), var(--pmu-turquoise));
    color: #fff;
    box-shadow:
      0 12px 24px rgba(15, 119, 115, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .pmu-assistant__footer a:last-child,
  .pmu-assistant__footer a:last-child:hover {
    background: linear-gradient(135deg, var(--pmu-pink), var(--pmu-pink-deep));
    color: #fff;
    border: 0;
    box-shadow:
      0 12px 24px rgba(212, 109, 155, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .pmu-assistant {
      left: auto;
      right: 14px;
      bottom: calc(env(safe-area-inset-bottom, 0px) + 84px);
      width: auto;
    }

    .pmu-assistant__launcher {
      margin-left: 0;
      margin-right: 0;
    }

    .pmu-assistant.is-open {
      left: 12px;
      right: 12px;
      bottom: calc(env(safe-area-inset-bottom, 0px) + 14px);
      width: auto;
    }

    .pmu-assistant.is-open .pmu-assistant__panel {
      right: 0;
      left: 0;
      bottom: 0;
      width: 100%;
      max-height: min(700px, calc(100svh - 28px));
      border-radius: 28px;
    }

    .pmu-assistant__header {
      padding: 18px 18px 15px;
    }

    .pmu-assistant__header-main h2 {
      font-size: 1.12rem;
    }

    .pmu-assistant__header-main span {
      display: none;
    }

    .pmu-assistant__clear {
      display: none;
    }

    .pmu-assistant__body {
      padding: 14px;
    }

    .pmu-assistant__form {
      grid-template-columns: 1fr;
      padding: 12px 14px;
    }

    .pmu-assistant__form button {
      width: 100%;
    }

    .pmu-assistant__message {
      max-width: 96%;
    }
  }
    /* V2 mobile assistant launcher: circle only + hide under hamburger menu */
  @media (max-width: 640px) {
    .pmu-assistant {
      transition:
        opacity 180ms ease,
        visibility 180ms ease,
        transform 180ms ease;
    }

    .pmu-assistant:not(.is-open) {
      right: 14px;
      bottom: calc(env(safe-area-inset-bottom, 0px) + 84px);
      width: auto;
    }

    .pmu-assistant:not(.is-open) .pmu-assistant__launcher {
      width: 58px;
      height: 58px;
      min-height: 58px;
      justify-content: center;
      gap: 0;
      padding: 0;
      border-radius: 999px;
    }

    .pmu-assistant:not(.is-open) .pmu-assistant__launcher-copy {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      overflow: hidden !important;
      clip: rect(0, 0, 0, 0) !important;
      clip-path: inset(50%) !important;
      white-space: nowrap !important;
    }

    .pmu-assistant:not(.is-open) .pmu-assistant__launcher-icon {
      width: 48px;
      height: 48px;
      font-size: 0.74rem;
      letter-spacing: 0.08em;
    }

    .pmu-assistant:not(.is-open) .pmu-assistant__launcher-glow {
      inset: -8px;
      opacity: 0.58;
      filter: blur(9px);
    }

    .pmu-assistant.is-mobile-menu-open:not(.is-open) {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(8px) scale(0.94);
    }
  }
    /* V3 mobile assistant under hamburger menu */
  @media (max-width: 900px) {
    .pmu-assistant:not(.is-open) {
      z-index: 30 !important;
    }

    .pmu-assistant.is-open {
      z-index: 9999 !important;
    }

    .pmu-assistant:not(.is-open) .pmu-assistant__launcher {
      z-index: 30 !important;
    }
  }
    /* V4 mobile assistant hidden when hamburger menu is open */
  @media (max-width: 900px) {
    .pmu-assistant.is-mobile-menu-open {
      opacity: 0 !important;
      visibility: hidden !important;
      pointer-events: none !important;
      transform: translateY(12px) scale(0.88) !important;
    }

    .pmu-assistant.is-mobile-menu-open .pmu-assistant__launcher {
      pointer-events: none !important;
    }

    .pmu-assistant.is-open {
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: auto !important;
      transform: none !important;
      z-index: 10000 !important;
    }
  }
</style>

<script is:inline>
  // @ts-nocheck

  const STORAGE_KEY = "pmu_assistant_messages_v1";

  const root = document.querySelector("[data-pmu-assistant]");
  const launcher = root?.querySelector(".pmu-assistant__launcher");
  const closeButton = root?.querySelector(".pmu-assistant__close");
  const clearButton = root?.querySelector("[data-clear]");
  const panel = root?.querySelector(".pmu-assistant__panel");
  const body = root?.querySelector("[data-body]");
  const form = root?.querySelector("[data-form]");
  const input = root?.querySelector("[data-input]");
  const messages = root?.querySelector("[data-messages]");
  const starterButtons = root?.querySelectorAll("[data-starter]") ?? [];

  const booksyUrl =
    "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

  const serviceLinks = [
    {
      path: "/makijaz-permanentny-brwi/",
      label: "Zobacz brwi permanentne",
    },
    {
      path: "/makijaz-permanentny-ust/",
      label: "Zobacz usta permanentne",
    },
    {
      path: "/makijaz-permanentny-oczu/",
      label: "Zobacz kreski permanentne",
    },
    {
      path: "/usuwanie-makijazu-permanentnego/",
      label: "Zobacz usuwanie PMU",
    },
    {
      path: "/cennik-makijaz-permanentny/",
      label: "Zobacz cennik",
    },
    {
      path: "/galeria/",
      label: "Zobacz galerię",
    },
    {
      path: "/kontakt/",
      label: "Kontakt z gabinetem",
    },
    {
      path: "/szkolenia/",
      label: "Zobacz szkolenia",
    },
    {
      path: "/sercemmalowane/",
      label: "Sercem Malowane",
    },
    {
      path: "https://kosmetologiabielsko.com",
      label: "Kosmetologia Bielsko",
      external: true,
    },
  ];

  let history = [];
  let savedMessages = [];

  function track(eventName, payload = {}) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: eventName, ...payload });

    if (window.va && typeof window.va.track === "function") {
      window.va.track(eventName, payload);
    }
  }

  function saveMessages() {
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(savedMessages.slice(-20)));
    } catch (error) {}
  }

  function loadMessages() {
    try {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed : [];
    } catch (error) {
      return [];
    }
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function getServiceLinkFromText(text) {
    return serviceLinks.find((item) => text.includes(item.path)) || null;
  }

  function getParagraphs(text) {
    let clean = String(text || "").trim();

    clean = clean
      .replace(booksyUrl, "")
      .replace(/https:\/\/booksy\.com\/[^\s)]+/g, "")
      .replace(/https:\/\/kosmetologiabielsko\.com\/?/g, "")
      .replace(/\bPodstrona:\s*/gi, "")
      .replace(/\bTelefon:\s*/gi, "")
      .replace(/\bBooksy:\s*/gi, "")
      .replace(
        /\bAktualną cenę najlepiej sprawdzić w cenniku lub przy usłudze w Booksy\.\s*/gi,
        "Aktualną cenę najlepiej sprawdzić w cenniku lub przy usłudze w Booksy."
      )
      .trim();

    for (const item of serviceLinks) {
      clean = clean.replaceAll(item.path, "");
    }

    clean = clean
      .replace(/\s+([,.!?;:])/g, "$1")
      .replace(/\s{2,}/g, " ")
      .replace(/\s+\./g, ".")
      .replace(/\s+,/g, ",")
      .trim();

    clean = clean.replace(
      /([.!?])\s+(Najlepiej|Może Pani|Warto|Ostateczną|Przy|Jeżeli|Jeśli|Ten kierunek|Najwłaściwszy|To dobry moment|W takiej sytuacji|Jeśli nie jest|Aktualne ceny)/g,
      "$1\n\n$2"
    );

    return clean
      .split(/\n{2,}/)
      .map((part) => part.trim())
      .filter(Boolean)
      .slice(0, 4);
  }

  function createSafeAssistantHtml(text) {
    const paragraphs = getParagraphs(text);

    return paragraphs
      .map((paragraph) => {
        let html = escapeHtml(paragraph);
        html = html.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");

        html = html.replace(
          /\bBooksy\b/g,
          `<a href="${booksyUrl}" target="_blank" rel="noopener noreferrer" data-assistant-link="booksy">Booksy</a>`
        );

        html = html.replace(
          /\+48 730 900 125|730 900 125/g,
          `<a href="tel:+48730900125" data-assistant-link="phone">+48 730 900 125</a>`
        );

        return `<p>${html}</p>`;
      })
      .join("");
  }

  function createActionsForAnswer(text) {
    const actions = [];
    const serviceLink = getServiceLinkFromText(text);

    if (serviceLink) {
      actions.push({
        href: serviceLink.path,
        label: serviceLink.label,
        external: Boolean(serviceLink.external),
        kind: "service",
      });
    }

    return actions.slice(0, 1);
  }

  function appendActions(messageElement, actions) {
    if (!actions.length) return;

    const wrapper = document.createElement("div");
    wrapper.className = "pmu-assistant__actions";

    for (const action of actions) {
      const link = document.createElement("a");
      link.className = "pmu-assistant__action";
      link.href = action.href;
      link.textContent = action.label;

      if (action.external) {
        link.target = "_blank";
        link.rel = "noopener noreferrer";
      }

      link.addEventListener("click", () => {
        track("assistant_service_link_click", { href: action.href });
      });

      wrapper.appendChild(link);
    }

    messageElement.appendChild(wrapper);
  }

  function setOpen(isOpen) {
    root?.classList.toggle("is-open", isOpen);
    launcher?.setAttribute("aria-expanded", String(isOpen));
    panel?.setAttribute("aria-hidden", String(!isOpen));

    if (isOpen) {
      track("assistant_open");
      setTimeout(() => input?.focus(), 100);
    }
  }

  function addMessage(role, text, extraClass = "", shouldSave = true) {
    const item = document.createElement("div");
    item.className = `pmu-assistant__message pmu-assistant__message--${role} ${extraClass}`.trim();

    const content = document.createElement("div");
    content.className = "pmu-assistant__text";

    if (role === "assistant") {
      content.innerHTML = createSafeAssistantHtml(text);
    } else {
      content.innerHTML = `<p>${escapeHtml(text)}</p>`;
    }

    item.appendChild(content);

    if (role === "assistant" && !extraClass.includes("loading")) {
      appendActions(item, createActionsForAnswer(text));
    }

    messages?.appendChild(item);
    body?.scrollTo({ top: body.scrollHeight, behavior: "smooth" });

    item.querySelectorAll("[data-assistant-link='booksy']").forEach((link) => {
      link.addEventListener("click", () => track("assistant_booksy_click"));
    });

    item.querySelectorAll("[data-assistant-link='phone']").forEach((link) => {
      link.addEventListener("click", () => track("assistant_phone_click"));
    });

    item.querySelectorAll("[data-assistant-link='service']").forEach((link) => {
      link.addEventListener("click", () =>
        track("assistant_service_link_click", { href: link.getAttribute("href") })
      );
    });

    if (shouldSave && !extraClass.includes("loading")) {
      savedMessages.push({ role, text });
      saveMessages();
    }

    return item;
  }

  async function askAssistant(question) {
    const cleanQuestion = String(question || "").trim();

    if (!cleanQuestion) return;

    addMessage("user", cleanQuestion);
    history.push({ role: "user", content: cleanQuestion });
    track("assistant_question_sent", { question_length: cleanQuestion.length });

    const loading = addMessage("assistant", "Piszę odpowiedź…", "pmu-assistant__message--loading", false);

    try {
      const response = await fetch("/api/assistant", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          message: cleanQuestion,
          history: history.slice(-4),
        }),
      });

      const data = await response.json();

      loading.remove();

      if (!response.ok) {
        const errorMessage =
          data?.error ||
          "Asystent chwilowo nie może odpowiedzieć. Proszę skorzystać z Booksy albo zadzwonić do gabinetu.";

        addMessage("assistant", errorMessage);
        track("assistant_error");
        return;
      }

      const answer = data?.answer || "Nie udało mi się przygotować odpowiedzi.";
      addMessage("assistant", answer);
      history.push({ role: "assistant", content: answer });
      track("assistant_answer_received");
    } catch (error) {
      loading.remove();
      addMessage(
        "assistant",
        "Asystent chwilowo nie może odpowiedzieć. Proszę skorzystać z Booksy albo zadzwonić do gabinetu."
      );
      track("assistant_error");
    }
  }

  function restoreConversation() {
    savedMessages = loadMessages();

    for (const message of savedMessages) {
      if (!message || !message.role || !message.text) continue;

      addMessage(message.role, message.text, "", false);

      if (message.role === "user" || message.role === "assistant") {
        history.push({ role: message.role, content: message.text });
      }
    }
  }

  launcher?.addEventListener("click", () => setOpen(true));
  closeButton?.addEventListener("click", () => setOpen(false));

  clearButton?.addEventListener("click", () => {
    savedMessages = [];
    history = [];
    sessionStorage.removeItem(STORAGE_KEY);
    if (messages) messages.innerHTML = "";
    track("assistant_clear");
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const question = input?.value || "";
    input.value = "";

    const submitButton = form.querySelector("button[type='submit']");
    if (submitButton) submitButton.disabled = true;

    await askAssistant(question);

    if (submitButton) submitButton.disabled = false;
    input?.focus();
  });

  input?.addEventListener("keydown", (event) => {
    if (event.key === "Enter" && !event.shiftKey) {
      event.preventDefault();
      form?.requestSubmit();
    }
  });

  starterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const question = button.getAttribute("data-starter") || button.textContent || "";
      askAssistant(question);
    });
  });

  root?.querySelectorAll("[data-track]").forEach((element) => {
    element.addEventListener("click", () => {
      const eventName = element.getAttribute("data-track");
      if (eventName) track(eventName);
    });
  });
  function isMobileAssistantViewport() {
    return window.matchMedia?.("(max-width: 900px)").matches ?? window.innerWidth <= 900;
  }

  function hasOpenMobileMenuBySelector() {
    const selectors = [
      "body.menu-open",
      "body.nav-open",
      "body.is-menu-open",
      "body.mobile-menu-open",
      "html.menu-open",
      "html.nav-open",
      "html.is-menu-open",
      "html.mobile-menu-open",
      ".mobile-menu.is-open",
      ".mobile-menu[aria-hidden='false']",
      ".mobile-nav.is-open",
      ".mobile-nav[aria-hidden='false']",
      ".nav-drawer.is-open",
      ".menu-drawer.is-open",
      ".site-header.is-open",
      "[data-mobile-menu].is-open",
      "[data-menu].is-open",
      "[data-nav].is-open",
      "[data-menu-open='true']",
      "[data-state='open'][data-mobile-menu]",
      "[data-state='open'][data-menu]",
    ];

    return selectors.some((selector) => {
      try {
        const element = document.querySelector(selector);
        return Boolean(element && !root?.contains(element));
      } catch (error) {
        return false;
      }
    });
  }

  function hasExpandedMobileMenuButton() {
    const buttons = Array.from(
      document.querySelectorAll("button[aria-expanded='true'], [role='button'][aria-expanded='true']")
    );

    return buttons.some((button) => {
      if (root?.contains(button)) return false;

      const text = [
        button.id,
        button.className,
        button.getAttribute("aria-controls"),
        button.getAttribute("aria-label"),
        button.getAttribute("data-menu-button"),
        button.getAttribute("data-mobile-menu-button"),
      ]
        .filter(Boolean)
        .join(" ")
        .toLowerCase();

      return /menu|nav|hamburger|nawigac|mobile|header/.test(text);
    });
  }

  function isMobileMenuOpen() {
    if (!isMobileAssistantViewport()) return false;
    return hasOpenMobileMenuBySelector() || hasExpandedMobileMenuButton();
  }

  function syncAssistantWithMobileMenu() {
    const menuOpen = isMobileMenuOpen();

    if (menuOpen && root?.classList.contains("is-open")) {
      setOpen(false);
    }

    root?.classList.toggle("is-mobile-menu-open", menuOpen);
  }

    function setupMobileMenuWatcher() {
    const mobileMenuLabels = new Set([
      "PMU",
      "BRWI",
      "USTA",
      "KRESKI",
      "USUWANIE",
      "SZKOLENIA",
      "PORADNIK",
      "GALERIA",
      "CENNIK",
      "KONTAKT",
    ]);

    function isMobileViewport() {
      return window.matchMedia?.("(max-width: 900px)").matches ?? window.innerWidth <= 900;
    }

    function normalizeText(value) {
      return String(value || "")
        .replace(/\s+/g, " ")
        .trim()
        .toUpperCase();
    }

    function isElementVisible(element) {
      if (!element || root?.contains(element)) return false;

      const style = window.getComputedStyle(element);
      if (
        style.display === "none" ||
        style.visibility === "hidden" ||
        Number(style.opacity) < 0.05
      ) {
        return false;
      }

      const rect = element.getBoundingClientRect();

      return (
        rect.width > 100 &&
        rect.height > 40 &&
        rect.bottom > 0 &&
        rect.top < window.innerHeight
      );
    }

    function visibleMobileMenuCardsCount() {
      const elements = Array.from(document.querySelectorAll("a, button"));

      return elements.filter((element) => {
        const text = normalizeText(element.textContent);
        if (!mobileMenuLabels.has(text)) return false;
        if (!isElementVisible(element)) return false;

        const rect = element.getBoundingClientRect();

        return rect.width > 140 && rect.height > 55;
      }).length;
    }

    function hasExpandedHeaderButton() {
      const buttons = Array.from(document.querySelectorAll("button[aria-expanded='true']"));

      return buttons.some((button) => {
        if (root?.contains(button)) return false;

        const rect = button.getBoundingClientRect();

        return (
          rect.width > 20 &&
          rect.height > 20 &&
          rect.top >= 0 &&
          rect.top < 160 &&
          rect.right > window.innerWidth - 180
        );
      });
    }

    function isMobileMenuOpenNow() {
      if (!isMobileViewport()) return false;

      return visibleMobileMenuCardsCount() >= 4 || hasExpandedHeaderButton();
    }

    function syncAssistantWithMobileMenu() {
      const menuOpen = isMobileMenuOpenNow();

      if (menuOpen && root?.classList.contains("is-open")) {
        setOpen(false);
      }

      root?.classList.toggle("is-mobile-menu-open", menuOpen);
    }

    syncAssistantWithMobileMenu();

    const observer = new MutationObserver(() => {
      window.requestAnimationFrame(syncAssistantWithMobileMenu);
    });

    observer.observe(document.documentElement, {
      subtree: true,
      childList: true,
      attributes: true,
      attributeFilter: ["class", "style", "aria-expanded", "aria-hidden", "data-state", "data-open"],
    });

    document.addEventListener("click", () => {
      window.setTimeout(syncAssistantWithMobileMenu, 80);
      window.setTimeout(syncAssistantWithMobileMenu, 220);
    });

    document.addEventListener("touchend", () => {
      window.setTimeout(syncAssistantWithMobileMenu, 80);
      window.setTimeout(syncAssistantWithMobileMenu, 220);
    });

    window.addEventListener("resize", syncAssistantWithMobileMenu);
    window.addEventListener("scroll", syncAssistantWithMobileMenu, { passive: true });

        window.setInterval(syncAssistantWithMobileMenu, 350);
  }

  restoreConversation();
  setupMobileMenuWatcher();
</script>