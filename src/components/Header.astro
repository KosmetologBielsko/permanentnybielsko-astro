---
const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const instagramUrl = "https://www.instagram.com/permanentnybielsko";
const facebookUrl = "https://www.facebook.com/PermanentnyBielsko";
const googleUrl = "https://share.google/r1H8ZLwSZMdRIflO9";

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: "PMU", href: "/makijaz-permanentny-bielsko/" },
  { label: "Brwi", href: "/makijaz-permanentny-brwi/" },
  { label: "Usta", href: "/makijaz-permanentny-ust/" },
  { label: "Kreski", href: "/makijaz-permanentny-oczu/" },
  { label: "Usuwanie", href: "/usuwanie-makijazu-permanentnego/" },
  { label: "Szkolenia", href: "/szkolenie-makijaz-permanentny/" },
  { label: "Galeria", href: "/galeria/" },
  { label: "Cennik", href: "/cennik-makijaz-permanentny/" },
  { label: "Kontakt", href: "/kontakt/" }
];

const mobileQuickLinks = [
  { label: "Regulamin salonu", href: "/regulamin-salonu/" },
  { label: "Polityka prywatności", href: "/rodo-polityka-prywatnosci-regulamin/" }
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath === href.replace(/\/$/, "");
};
---

<header class="site-header" data-site-header>
  <div class="header-shell">
    <a class="header-logo header-logo-image-link" href="/" aria-label="Bogusława Herda Makijaż Permanentny — strona główna">
      <img
        src="/images/logo-boguslawa-herda-pmu-header.webp"
        alt="Bogusława Herda Makijaż Permanentny"
        width="2058"
        height="247"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <nav class="desktop-nav" aria-label="Menu główne">
      {navLinks.map((link) => (
        <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <nav class="header-socials" aria-label="Profile online">
        <a
          class="header-social-orb header-orb-instagram"
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram PermanentnyBielsko"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3.2" y="3.2" width="17.6" height="17.6" rx="5.2"></rect>
            <circle cx="12" cy="12" r="4.2"></circle>
            <circle cx="17.25" cy="6.75" r="1.15"></circle>
          </svg>
        </a>

        <a
          class="header-social-orb header-orb-facebook"
          href={facebookUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook PermanentnyBielsko"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.05 8.2V6.7c0-.72.24-1.2 1.31-1.2H17V2.7c-.8-.1-1.58-.16-2.38-.16-2.36 0-3.98 1.44-3.98 4.08V8.2H8v3.14h2.64v10.12h3.41V11.34h2.67l.42-3.14h-3.09Z"></path>
          </svg>
        </a>

        <a
          class="header-social-orb header-orb-google"
          href={googleUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Google mapa i opinie"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path class="g-blue" d="M21.6 12.23c0-.72-.06-1.42-.18-2.08H12v3.94h5.38a4.6 4.6 0 0 1-2 3.02v2.51h3.24c1.9-1.75 2.98-4.32 2.98-7.39Z"></path>
            <path class="g-green" d="M12 22c2.7 0 4.96-.9 6.62-2.38l-3.24-2.51c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.06v2.6A10 10 0 0 0 12 22Z"></path>
            <path class="g-yellow" d="M6.41 13.95A6.02 6.02 0 0 1 6.1 12c0-.68.11-1.34.31-1.95v-2.6H3.06A10 10 0 0 0 2 12c0 1.61.39 3.13 1.06 4.55l3.35-2.6Z"></path>
            <path class="g-red" d="M12 5.93c1.47 0 2.79.5 3.82 1.5l2.87-2.87C16.95 2.94 14.7 2 12 2a10 10 0 0 0-8.94 5.45l3.35 2.6C7.2 7.69 9.4 5.93 12 5.93Z"></path>
          </svg>
        </a>
      </nav>

      <a class="header-booksy" href={booksyUrl} target="_blank" rel="noopener noreferrer">
        Umów wizytę
      </a>

      <button
        class="mobile-menu-button"
        type="button"
        aria-label="Otwórz menu"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        data-menu-button
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu-backdrop" data-menu-backdrop></div>

  <aside class="mobile-menu-panel" id="mobile-menu-panel" aria-label="Menu mobilne" data-mobile-menu>
    <div class="mobile-menu-head">
      <p>Menu</p>
      <span>Naturalny PMU • Bielsko-Biała</span>
    </div>

    <nav class="mobile-nav" aria-label="Menu mobilne">
      {navLinks.map((link, index) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
          class:list={[index === navLinks.length - 1 && "mobile-nav-wide"]}
        >
          <span>{String(index + 1).padStart(2, "0")}</span>
          {link.label}
        </a>
      ))}
    </nav>

    <section class="mobile-social-section" aria-label="Media społecznościowe i profile online">
      <p>Online</p>

      <div class="mobile-social-orbs" aria-label="Profile online">
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-orb mobile-orb-instagram"
          aria-label="Instagram PermanentnyBielsko"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3.2" y="3.2" width="17.6" height="17.6" rx="5.2"></rect>
            <circle cx="12" cy="12" r="4.2"></circle>
            <circle cx="17.25" cy="6.75" r="1.15"></circle>
          </svg>
        </a>

        <a
          href={facebookUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-orb mobile-orb-facebook"
          aria-label="Facebook PermanentnyBielsko"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.05 8.2V6.7c0-.72.24-1.2 1.31-1.2H17V2.7c-.8-.1-1.58-.16-2.38-.16-2.36 0-3.98 1.44-3.98 4.08V8.2H8v3.14h2.64v10.12h3.41V11.34h2.67l.42-3.14h-3.09Z"></path>
          </svg>
        </a>

        <a
          href={googleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-orb mobile-orb-google"
          aria-label="Google mapa i opinie"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path class="g-blue" d="M21.6 12.23c0-.72-.06-1.42-.18-2.08H12v3.94h5.38a4.6 4.6 0 0 1-2 3.02v2.51h3.24c1.9-1.75 2.98-4.32 2.98-7.39Z"></path>
            <path class="g-green" d="M12 22c2.7 0 4.96-.9 6.62-2.38l-3.24-2.51c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.06v2.6A10 10 0 0 0 12 22Z"></path>
            <path class="g-yellow" d="M6.41 13.95A6.02 6.02 0 0 1 6.1 12c0-.68.11-1.34.31-1.95v-2.6H3.06A10 10 0 0 0 2 12c0 1.61.39 3.13 1.06 4.55l3.35-2.6Z"></path>
            <path class="g-red" d="M12 5.93c1.47 0 2.79.5 3.82 1.5l2.87-2.87C16.95 2.94 14.7 2 12 2a10 10 0 0 0-8.94 5.45l3.35 2.6C7.2 7.69 9.4 5.93 12 5.93Z"></path>
          </svg>
        </a>

        <a
          href={booksyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-orb mobile-orb-booksy"
          aria-label="Booksy rezerwacja wizyty"
        >
          <span>B</span>
        </a>
      </div>
    </section>

    <nav class="mobile-formal-links" aria-label="Linki formalne">
      {mobileQuickLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </aside>
</header>

<script>
  const header = document.querySelector("[data-site-header]");
  const button = document.querySelector("[data-menu-button]");
  const panel = document.querySelector("[data-mobile-menu]");
  const backdrop = document.querySelector("[data-menu-backdrop]");

  const closeMenu = () => {
    if (!header || !button) return;

    header.classList.remove("is-menu-open");
    button.setAttribute("aria-expanded", "false");
    button.setAttribute("aria-label", "Otwórz menu");
    document.documentElement.classList.remove("mobile-menu-open");
  };

  const openMenu = () => {
    if (!header || !button) return;

    header.classList.add("is-menu-open");
    button.setAttribute("aria-expanded", "true");
    button.setAttribute("aria-label", "Zamknij menu");
    document.documentElement.classList.add("mobile-menu-open");
  };

  button?.addEventListener("click", () => {
    if (header?.classList.contains("is-menu-open")) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  backdrop?.addEventListener("click", closeMenu);

  panel?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMenu();
    }
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth > 1080) {
      closeMenu();
    }
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 12px;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 0 12px;
    pointer-events: none;
  }

  .header-shell {
    width: min(1480px, 100%);
    min-height: 76px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    padding: 10px 12px 10px 16px;
    border: 1px solid rgba(183, 101, 118, 0.13);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 20px 60px rgba(72, 42, 55, 0.12);
    backdrop-filter: blur(22px);
    pointer-events: auto;
  }

  .header-logo,
  .desktop-nav a,
  .header-booksy,
  .mobile-menu-button,
  .mobile-nav a,
  .mobile-formal-links a,
  .header-social-orb,
  .header-logo-mark {
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }

  .header-logo:focus,
  .header-logo:focus-visible,
  .desktop-nav a:focus,
  .desktop-nav a:focus-visible,
  .header-booksy:focus,
  .header-booksy:focus-visible,
  .mobile-menu-button:focus,
  .mobile-menu-button:focus-visible,
  .mobile-nav a:focus,
  .mobile-nav a:focus-visible,
  .mobile-formal-links a:focus,
  .mobile-formal-links a:focus-visible,
  .header-social-orb:focus,
  .header-social-orb:focus-visible {
    outline: none;
    box-shadow: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .header-logo:focus-visible,
    .desktop-nav a:focus-visible,
    .header-booksy:focus-visible,
    .mobile-menu-button:focus-visible,
    .mobile-nav a:focus-visible,
    .mobile-formal-links a:focus-visible,
    .header-social-orb:focus-visible {
      box-shadow: 0 0 0 3px rgba(56, 187, 181, 0.18);
    }
  }

  .header-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    color: var(--color-text, #17151d);
    text-decoration: none;
  }

  .header-logo-mark {
    display: grid;
    width: 48px;
    height: 48px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 17px;
    color: #ffffff;
    font-size: 1.05rem;
    font-weight: 850;
    letter-spacing: -0.08em;
    background:
      radial-gradient(circle at 24% 24%, rgba(255, 255, 255, 0.3), transparent 3rem),
      linear-gradient(145deg, #9d4f68 0%, #d7899f 45%, #7f344d 100%);
    box-shadow: 0 16px 38px rgba(157, 79, 104, 0.22);
  }

  .header-logo-copy {
    display: grid;
    min-width: 0;
    gap: 2px;
  }

  .header-logo-copy strong {
    color: var(--color-text, #17151d);
    font-size: clamp(1rem, 1.35vw, 1.35rem);
    font-weight: 790;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .header-logo-copy em {
    color: #b76576;
    font-size: 0.58rem;
    font-style: normal;
    font-weight: 730;
    line-height: 1;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .desktop-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    min-width: 0;
  }

  .desktop-nav a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    border-radius: 999px;
    padding: 0 clamp(10px, 0.82vw, 15px);
    color: #17151d;
    font-size: clamp(0.88rem, 0.82vw, 0.99rem);
    font-weight: 760;
    line-height: 1;
    letter-spacing: -0.014em;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .desktop-nav a:hover {
    color: #17151d;
    background: rgba(255, 255, 255, 0.68);
    transform: translateY(-1px);
  }

  .desktop-nav a[aria-current="page"] {
    color: #17151d;
    background: rgba(219, 246, 243, 0.78);
    box-shadow: inset 0 0 0 1px rgba(56, 187, 181, 0.12);
  }

  .header-actions {
    display: inline-flex;
    justify-content: flex-end;
    align-items: center;
    gap: 9px;
  }

  .header-socials {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .header-social-orb {
    position: relative;
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    overflow: hidden;
    border-radius: 999px;
    background:
      radial-gradient(circle at 26% 20%, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.54) 34%, rgba(255, 255, 255, 0.18) 68%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(255, 247, 250, 0.52));
    border: 1px solid rgba(183, 101, 118, 0.13);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 12px 30px rgba(72, 42, 55, 0.10);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .header-social-orb::after {
    content: "";
    position: absolute;
    inset: 4px 6px auto 6px;
    height: 11px;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.8), transparent);
    pointer-events: none;
  }

  .header-social-orb:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 16px 38px rgba(72, 42, 55, 0.15);
  }

  .header-social-orb svg {
    position: relative;
    z-index: 2;
    width: 20px;
    height: 20px;
    display: block;
  }

  .header-orb-instagram svg rect,
  .header-orb-instagram svg circle {
    fill: none;
    stroke: #d62976;
    stroke-width: 1.9;
  }

  .header-orb-facebook svg {
    fill: #1877f2;
  }

  .header-orb-google svg .g-blue {
    fill: #4285f4;
  }

  .header-orb-google svg .g-green {
    fill: #34a853;
  }

  .header-orb-google svg .g-yellow {
    fill: #fbbc05;
  }

  .header-orb-google svg .g-red {
    fill: #ea4335;
  }

  .header-booksy {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 18px;
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 810;
    text-decoration: none;
    white-space: nowrap;
    background:
      radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.24), transparent 4rem),
      linear-gradient(135deg, #0f7773 0%, #1aa5a0 100%);
    box-shadow: 0 14px 36px rgba(35, 156, 150, 0.2);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .header-booksy:hover {
    transform: translateY(-1px);
    box-shadow: 0 18px 44px rgba(35, 156, 150, 0.24);
  }

  .mobile-menu-button {
    display: none;
    width: 48px;
    height: 48px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgba(183, 101, 118, 0.16);
    border-radius: 999px;
    padding: 0;
    background: rgba(255, 255, 255, 0.68);
    cursor: pointer;
  }

  .mobile-menu-button span {
    display: block;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: var(--color-text, #17151d);
    transition:
      transform 0.24s ease,
      opacity 0.24s ease;
  }

  .mobile-menu-button span + span {
    margin-top: -10px;
    transform: translateY(10px);
  }

  .is-menu-open .mobile-menu-button span:first-child {
    transform: translateY(5px) rotate(45deg);
  }

  .is-menu-open .mobile-menu-button span:last-child {
    transform: translateY(5px) rotate(-45deg);
  }

  .mobile-menu-backdrop {
    position: fixed;
    inset: 0;
    z-index: -2;
    opacity: 0;
    pointer-events: none;
    background: rgba(25, 18, 24, 0.26);
    backdrop-filter: blur(4px);
    transition: opacity 0.24s ease;
  }

  .mobile-menu-panel {
    position: fixed;
    top: 94px;
    right: 12px;
    z-index: -1;
    width: min(430px, calc(100vw - 24px));
    max-height: calc(100vh - 112px);
    overflow: auto;
    padding: 14px;
    border: 1px solid rgba(183, 101, 118, 0.16);
    border-radius: 28px;
    background:
      radial-gradient(circle at 94% 10%, rgba(56, 187, 181, 0.16), transparent 14rem),
      radial-gradient(circle at 10% 88%, rgba(201, 127, 143, 0.14), transparent 14rem),
      rgba(255, 255, 255, 0.9);
    box-shadow: 0 24px 80px rgba(72, 42, 55, 0.24);
    backdrop-filter: blur(22px);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-10px) scale(0.98);
    transform-origin: top right;
    transition:
      opacity 0.24s ease,
      transform 0.24s ease;
    scrollbar-width: thin;
  }

  .is-menu-open .mobile-menu-backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  .is-menu-open .mobile-menu-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .mobile-menu-head {
    padding: 8px 8px 18px;
    text-align: center;
  }

  .mobile-menu-head p {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    margin: 0;
    padding: 0 13px;
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.64);
    color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .mobile-menu-head span {
    display: block;
    max-width: 270px;
    margin: 10px auto 0;
    color: rgba(23, 21, 29, 0.74);
    font-size: 1.04rem;
    font-weight: 730;
    line-height: 1.28;
    letter-spacing: -0.035em;
  }

  .mobile-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
  }

  .mobile-nav a {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
    min-height: 76px;
    align-content: center;
    justify-items: center;
    padding: 12px 10px;
    border: 1px solid rgba(56, 187, 181, 0.13);
    border-radius: 19px;
    color: var(--color-text, #17151d);
    font-size: 1rem;
    font-weight: 780;
    line-height: 1.08;
    text-align: center;
    text-decoration: none;
    background:
      radial-gradient(circle at 85% 10%, rgba(219, 246, 243, 0.5), transparent 5rem),
      rgba(255, 255, 255, 0.66);
  }

  .mobile-nav a[aria-current="page"] {
    background: rgba(219, 246, 243, 0.86);
  }

  .mobile-nav span {
    color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.64rem;
    font-weight: 860;
    line-height: 1;
    letter-spacing: 0.12em;
  }

  .mobile-nav-wide {
    grid-column: 1 / -1;
  }

  .mobile-social-section {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid rgba(183, 101, 118, 0.12);
  }

  .mobile-social-section p {
    margin: 0 0 12px;
    color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.7rem;
    font-weight: 850;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .mobile-social-orbs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    align-items: center;
    justify-items: center;
    padding: 4px 8px 0;
  }

  .mobile-orb {
    position: relative;
    display: grid;
