---
const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const instagramUrl = "https://www.instagram.com/permanentnybielsko";
const facebookUrl = "https://www.facebook.com/PermanentnyBielsko";
const googleUrl = "https://share.google/r1H8ZLwSZMdRIflO9";

const mainLinks = [
  { label: "Makijaż permanentny", href: "/makijaz-permanentny-bielsko/" },
  { label: "Brwi permanentne", href: "/makijaz-permanentny-brwi/" },
  { label: "Usta permanentne", href: "/makijaz-permanentny-ust/" },
  { label: "Kreski permanentne", href: "/makijaz-permanentny-oczu/" },
  { label: "Usuwanie PMU", href: "/usuwanie-makijazu-permanentnego/" },
  { label: "Cennik PMU", href: "/cennik-makijaz-permanentny/" }
];

const expertLinks = [
  { label: "Szkolenie makijaż permanentny", href: "/szkolenie-makijaz-permanentny/" },
  { label: "Szkolenia PMU", href: "/szkolenia/" },
  { label: "Galeria", href: "/galeria/" },
  { label: "#SercemMalowane", href: "/sercemmalowane/" },
  { label: "Kontakt", href: "/kontakt/" }
];

const formalLinks = [
  { label: "Regulamin salonu", href: "/regulamin-salonu/" },
  { label: "RODO / Polityka prywatności", href: "/rodo-polityka-prywatnosci-regulamin/" },
  { label: "Mapa strony", href: "/sitemap.xml" }
];
---

<footer class="site-footer">
  <div class="footer-glow footer-glow-one"></div>
  <div class="footer-glow footer-glow-two"></div>

  <div class="container footer-container">
    <section class="footer-top-card" aria-label="Stopka strony">
      <div class="footer-brand">
        <p class="footer-eyebrow">Bogusława Herda Makijaż Permanentny</p>

        <h2>
          Naturalny PMU,
          <span>spokojna decyzja</span>
          i efekt dopasowany do twarzy.
        </h2>

        <p class="footer-description">
          W gabinecie w centrum Bielska-Białej makijaż permanentny traktujemy jako
          precyzyjną pracę z urodą, skórą i proporcjami. Brwi, usta, kreski,
          korekty oraz szkolenia PMU prowadzone są w oparciu o doświadczenie,
          estetykę i zasadę „Powrót do natury”.
        </p>

        <div class="footer-proof-row" aria-label="Najważniejsze wyróżniki gabinetu">
          <span>Naturalny efekt</span>
          <span>Rysunek wstępny</span>
          <span>Long-Time-Liner®</span>
          <span>Szkolenia PMU</span>
        </div>

        <div class="footer-actions">
          <a class="footer-primary-link" href={booksyUrl} target="_blank" rel="noopener noreferrer">
            Umów wizytę przez Booksy
          </a>

          <a class="footer-secondary-link" href="/makijaz-permanentny-bielsko/">
            Zobacz ofertę PMU
          </a>
        </div>
      </div>

      <div class="footer-contact-card">
        <p>Kontakt i lokalizacja</p>

        <h2>Gabinet w centrum Bielska-Białej</h2>

        <div class="footer-contact-list">
          <a href="tel:+48730900125">
            <span>Telefon</span>
            +48 730 900 125
          </a>

          <a href="mailto:bogusia@permanentnybielsko.com">
            <span>E-mail</span>
            bogusia@permanentnybielsko.com
          </a>

          <address>
            <span>Adres gabinetu</span>
            ul. Barlickiego 5/23<br />
            43-300 Bielsko-Biała
          </address>
        </div>

        <div class="footer-location-note">
          <strong>Wygodna lokalizacja</strong>
          <span>
            Centrum Bielska-Białej, blisko Galerii Sfera i Ratusza.
            To dobre miejsce na konsultację, zabieg i spokojny powrót po wizycie.
          </span>
        </div>

        <a class="footer-map-link" href={googleUrl} target="_blank" rel="noopener noreferrer">
          Otwórz mapę i opinie Google
        </a>
      </div>
    </section>

    <section class="footer-links-grid" aria-label="Linki w stopce">
      <div class="footer-link-column">
        <h2>Oferta PMU</h2>

        <nav aria-label="Oferta makijażu permanentnego">
          {mainLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>

      <div class="footer-link-column">
        <h2>Ekspercko</h2>

        <nav aria-label="Szkolenia, galeria i kontakt">
          {expertLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>

      <div class="footer-link-column footer-online-column">
        <h2>Online</h2>

        <nav aria-label="Profile online">
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer">
            Instagram
            <span>@permanentnybielsko</span>
          </a>

          <a href={facebookUrl} target="_blank" rel="noopener noreferrer">
            Facebook
            <span>PermanentnyBielsko</span>
          </a>

          <a href={booksyUrl} target="_blank" rel="noopener noreferrer">
            Booksy
            <span>Rezerwacja wizyty</span>
          </a>

          <a href={googleUrl} target="_blank" rel="noopener noreferrer">
            Google
            <span>Mapa i opinie</span>
          </a>
        </nav>
      </div>

      <div class="footer-link-column footer-formal-column">
        <h2>Formalnie</h2>

        <nav aria-label="Dokumenty formalne">
          {formalLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <div class="footer-sister-site">
          <p>Kosmetologia estetyczna</p>
          <a href="https://kosmetologiabielsko.com" target="_blank" rel="noopener noreferrer">
            kosmetologiabielsko.com
          </a>
        </div>
      </div>
    </section>

    <section class="footer-bottom">
      <p>
        © 2026 Bogusława Herda — Makijaż Permanentny Bielsko-Biała.
      </p>

      <p>
        Oficjalna strona makijażu permanentnego, szkoleń PMU i naturalnej pigmentacji.
      </p>
    </section>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    padding: 90px 0 28px;
    background:
      radial-gradient(circle at 84% 10%, rgba(56, 187, 181, 0.14), transparent 28rem),
      radial-gradient(circle at 12% 38%, rgba(201, 127, 143, 0.13), transparent 25rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), #fff7fa 100%);
    border-top: 1px solid rgba(183, 101, 118, 0.12);
  }

  .footer-glow {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
  }

  .footer-glow-one {
    right: -12rem;
    top: -14rem;
    width: 34rem;
    height: 34rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.16), transparent 68%);
  }

  .footer-glow-two {
    left: -10rem;
    bottom: -16rem;
    width: 34rem;
    height: 34rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.14), transparent 68%);
  }

  .footer-container {
    position: relative;
    z-index: 2;
  }

  .footer-top-card {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    gap: 18px;
    margin-bottom: 18px;
  }

  .footer-brand,
  .footer-contact-card,
  .footer-link-column,
  .footer-bottom {
    border: 1px solid rgba(183, 101, 118, 0.16);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .footer-brand,
  .footer-contact-card {
    border-radius: 36px;
    background: rgba(255, 255, 255, 0.78);
  }

  .footer-brand {
    position: relative;
    overflow: hidden;
    min-height: 390px;
    padding: clamp(32px, 4vw, 54px);
  }

  .footer-brand::after {
    content: "PMU";
    position: absolute;
    right: clamp(18px, 3vw, 42px);
    top: clamp(18px, 3vw, 34px);
    color: rgba(56, 187, 181, 0.1);
    font-size: clamp(4rem, 8vw, 8rem);
    font-weight: 850;
    line-height: 0.8;
    letter-spacing: -0.12em;
    pointer-events: none;
  }

  .footer-eyebrow,
  .footer-contact-card > p,
  .footer-link-column h2,
  .footer-sister-site p {
    position: relative;
    z-index: 2;
    margin: 0 0 18px;
    color: var(--color-turquoise-dark);
    font-size: 0.74rem;
    font-weight: 820;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .footer-brand h2,
  .footer-contact-card h2 {
    position: relative;
    z-index: 2;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(2.2rem, 4.5vw, 4.7rem);
    font-weight: 820;
    line-height: 0.95;
    letter-spacing: -0.075em;
  }

  .footer-brand h2 span {
    color: #b76576;
  }

  .footer-description {
    position: relative;
    z-index: 2;
    max-width: 760px;
    margin: 22px 0 0;
    color: var(--color-muted);
    font-size: 1.02rem;
    line-height: 1.68;
  }

  .footer-proof-row {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 24px;
  }

  .footer-proof-row span {
    display: inline-flex;
    min-height: 36px;
    align-items: center;
    border-radius: 999px;
    padding: 0 14px;
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 760;
    background:
      radial-gradient(circle at 90% 10%, rgba(219, 246, 243, 0.55), transparent 4rem),
      rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(56, 187, 181, 0.13);
  }

  .footer-actions {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .footer-primary-link,
  .footer-secondary-link,
  .footer-map-link {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 20px;
    font-size: 0.88rem;
    font-weight: 780;
    text-decoration: none;
  }

  .footer-primary-link {
    color: #ffffff;
    background: linear-gradient(135deg, #b76576, #8f344d);
    box-shadow: 0 14px 36px rgba(183, 101, 118, 0.18);
  }

  .footer-secondary-link,
  .footer-map-link {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid rgba(183, 101, 118, 0.18);
  }

  .footer-contact-card {
    position: relative;
    overflow: hidden;
    min-height: 390px;
    padding: clamp(30px, 4vw, 46px);
  }

  .footer-contact-card::after {
    content: "";
    position: absolute;
    right: -5rem;
    top: -5rem;
    width: 17rem;
    height: 17rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(219, 246, 243, 0.9), transparent 68%);
    pointer-events: none;
  }

  .footer-contact-card h2 {
    max-width: 520px;
    font-size: clamp(2rem, 3.4vw, 3.65rem);
  }

  .footer-contact-list {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 14px;
    margin-top: 26px;
  }

  .footer-contact-list a,
  .footer-contact-list address {
    display: block;
    margin: 0;
    padding: 16px 18px;
    border-radius: 22px;
    color: var(--color-text);
    font-style: normal;
    font-size: clamp(1rem, 1.55vw, 1.22rem);
    font-weight: 780;
    line-height: 1.35;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(56, 187, 181, 0.12);
  }

  .footer-contact-list span {
    display: block;
    margin-bottom: 5px;
    color: var(--color-muted);
    font-size: 0.68rem;
    font-weight: 820;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .footer-location-note {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 6px;
    margin-top: 18px;
    padding: 18px;
    border-radius: 24px;
    background:
      radial-gradient(circle at 92% 8%, rgba(219, 246, 243, 0.62), transparent 7rem),
      rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(183, 101, 118, 0.12);
  }

  .footer-location-note strong {
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 820;
  }

  .footer-location-note span {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .footer-map-link {
    position: relative;
    z-index: 2;
    width: 100%;
    margin-top: 16px;
    min-height: 52px;
    color: var(--color-turquoise-dark);
    background: rgba(219, 246, 243, 0.52);
    border-color: rgba(56, 187, 181, 0.18);
  }

  .footer-links-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .footer-link-column {
    position: relative;
    overflow: hidden;
    min-height: 280px;
    padding: 28px;
    border-radius: 30px;
    background:
      radial-gradient(circle at 92% 10%, rgba(219, 246, 243, 0.62), transparent 7rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(255, 250, 252, 0.82));
  }

  .footer-link-column::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid rgba(56, 187, 181, 0.32);
    pointer-events: none;
  }

  .footer-link-column nav {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 11px;
  }

  .footer-link-column a {
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 660;
    line-height: 1.3;
    text-decoration: none;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .footer-link-column a:hover {
    color: var(--color-turquoise-dark);
    transform: translateX(3px);
  }

  .footer-online-column a,
  .footer-formal-column a {
    display: grid;
    gap: 4px;
  }

  .footer-online-column span {
    color: var(--color-muted);
    font-size: 0.77rem;
    font-weight: 620;
  }

  .footer-formal-column::before {
    border-top-color: rgba(201, 127, 143, 0.32);
  }

  .footer-sister-site {
    position: relative;
    z-index: 2;
    margin-top: 28px;
    padding-top: 22px;
    border-top: 1px solid rgba(183, 101, 118, 0.14);
  }

  .footer-sister-site p {
    margin-bottom: 10px;
    color: #b76576;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-top: 18px;
    padding: 18px 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.66);
  }

  .footer-bottom p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  @media (max-width: 1180px) {
    .footer-links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 980px) {
    .footer-top-card {
      grid-template-columns: 1fr;
    }

    .footer-brand,
    .footer-contact-card {
      min-height: auto;
    }
  }

  @media (max-width: 760px) {
    .site-footer {
      padding: 64px 0 22px;
    }

    .footer-top-card,
    .footer-links-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .footer-brand,
    .footer-contact-card,
    .footer-link-column,
    .footer-bottom {
      border-radius: 26px;
    }

    .footer-brand,
    .footer-contact-card,
    .footer-link-column {
      padding: 24px;
    }

    .footer-brand::after {
      right: 14px;
      top: 16px;
      font-size: clamp(3.5rem, 18vw, 5.2rem);
    }

    .footer-brand h2,
    .footer-contact-card h2 {
      font-size: clamp(2rem, 12vw, 3.2rem);
      letter-spacing: -0.075em;
    }

    .footer-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .footer-primary-link,
    .footer-secondary-link {
      width: 100%;
      min-height: 52px;
      white-space: normal;
      text-align: center;
    }

    .footer-proof-row span {
      min-height: 34px;
      font-size: 0.74rem;
    }

    .footer-contact-list a,
    .footer-contact-list address {
      padding: 15px 16px;
      border-radius: 20px;
      font-size: 0.98rem;
    }

    .footer-link-column {
      min-height: auto;
    }

    .footer-bottom {
      display: grid;
    }
  }

  /* V4 — footer: zielone nagłówki jako turkusowe kapsuły */
  .footer-eyebrow,
  .footer-contact-card > p,
  .footer-link-column h2,
  .footer-sister-site p {
    display: inline-flex !important;
    width: fit-content !important;
    max-width: 100% !important;
    min-height: 32px !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0 0 18px !important;
    padding: 0 13px !important;
    border-radius: 999px !important;
    color: var(--color-turquoise-dark, #0f7773) !important;
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773) !important;
    background: rgba(219, 246, 243, 0.72) !important;
    border: 1px solid rgba(56, 187, 181, 0.16) !important;
    font-size: 0.7rem !important;
    font-weight: 850 !important;
    line-height: 1 !important;
    letter-spacing: 0.17em !important;
    text-transform: uppercase !important;
  }

  .footer-sister-site p {
    color: #b76576 !important;
    -webkit-text-fill-color: #b76576 !important;
    background: rgba(255, 242, 246, 0.82) !important;
    border-color: rgba(201, 127, 143, 0.18) !important;
  }

  @media (max-width: 760px) {
    .footer-eyebrow,
    .footer-contact-card > p,
    .footer-link-column h2,
    .footer-sister-site p {
      min-height: 30px !important;
      margin-bottom: 16px !important;
      padding: 0 11px !important;
      font-size: 0.64rem !important;
      letter-spacing: 0.13em !important;
      line-height: 1 !important;
    }
  }

</style>
