<div class="cookie-consent" data-cookie-consent hidden>
  <div class="cookie-consent__content">
    <p class="cookie-consent__title">Dbamy o Twoją prywatność</p>
    <p class="cookie-consent__text">
      Używamy plików cookies i podobnych technologii, aby mierzyć działanie strony oraz skuteczność reklam Google.
      Możesz zaakceptować pomiar analityczny i marketingowy albo pozostać przy ustawieniach niezbędnych.
    </p>
  </div>

  <div class="cookie-consent__actions">
    <button type="button" class="cookie-consent__button cookie-consent__button--secondary" data-cookie-reject>
      Tylko niezbędne
    </button>

    <button type="button" class="cookie-consent__button cookie-consent__button--primary" data-cookie-accept>
      Akceptuję
    </button>
  </div>
</div>

<style>
  .cookie-consent {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 9999;
    width: min(440px, calc(100vw - 32px));
    padding: 18px;
    border: 1px solid rgba(197, 154, 95, 0.35);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 24px 80px rgba(39, 31, 24, 0.18);
    backdrop-filter: blur(18px);
    color: #2b211b;
  }

  .cookie-consent__title {
    margin: 0 0 6px;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .cookie-consent__text {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: rgba(43, 33, 27, 0.78);
  }

  .cookie-consent__actions {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }

  .cookie-consent__button {
    border: 0;
    border-radius: 999px;
    padding: 11px 15px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
  }

  .cookie-consent__button--primary {
    background: #2b211b;
    color: #fff;
  }

  .cookie-consent__button--secondary {
    background: rgba(43, 33, 27, 0.08);
    color: #2b211b;
  }

  @media (max-width: 560px) {
    .cookie-consent {
      right: 12px;
      bottom: 12px;
      width: calc(100vw - 24px);
      border-radius: 20px;
    }

    .cookie-consent__actions {
      flex-direction: column-reverse;
    }

    .cookie-consent__button {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (function () {
    var banner = document.querySelector('[data-cookie-consent]');
    var acceptButton = document.querySelector('[data-cookie-accept]');
    var rejectButton = document.querySelector('[data-cookie-reject]');

    if (!banner || !acceptButton || !rejectButton) return;

    var storageKey = 'pb_cookie_consent';
    var currentChoice = null;

    try {
      currentChoice = window.localStorage.getItem(storageKey);
    } catch (error) {
      currentChoice = null;
    }

    if (!currentChoice) {
      banner.hidden = false;
    }

    function updateGoogleConsent(status) {
      if (typeof window.gtag !== 'function') return;

      var granted = status === 'accepted';

      window.gtag('consent', 'update', {
        ad_storage: granted ? 'granted' : 'denied',
        ad_user_data: granted ? 'granted' : 'denied',
        ad_personalization: granted ? 'granted' : 'denied',
        analytics_storage: granted ? 'granted' : 'denied'
      });
    }

    acceptButton.addEventListener('click', function () {
      try {
        window.localStorage.setItem(storageKey, 'accepted');
      } catch (error) {}

      updateGoogleConsent('accepted');
      banner.hidden = true;
    });

    rejectButton.addEventListener('click', function () {
      try {
        window.localStorage.setItem(storageKey, 'rejected');
      } catch (error) {}

      updateGoogleConsent('rejected');
      banner.hidden = true;
    });
  })();
</script>