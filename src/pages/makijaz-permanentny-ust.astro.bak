---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/makijaz-permanentny-ust/";
const pageTitle = "Makijaż permanentny ust Bielsko-Biała | Naturalny kolor ust";
const pageDescription =
  "Makijaż permanentny ust Bielsko-Biała: naturalne odświeżenie koloru, wyrównanie czerwieni wargowej, miękki kontur i subtelny efekt bez przerysowania u Bogusława Herda.";

const lipsGalleryImages = Array.from({ length: 18 }, (_, index) => {
  const number = String(index + 1).padStart(2, "0");

  return {
    src: `/images/makijaz-permanentny-ust-bielsko-biala-efekt-${number}.webp`,
    alt: `Makijaż permanentny ust Bielsko-Biała — efekt pigmentacji ust ${number}`,
  };
});

const forWhoItems = [
  {
    title: "Blade usta",
    text: "gdy naturalna czerwień wargowa jest mało widoczna albo z czasem straciła świeżość",
  },
  {
    title: "Nierówny kontur",
    text: "gdy granica ust wymaga uporządkowania, ale bez efektu ostrej konturówki",
  },
  {
    title: "Asymetria",
    text: "gdy usta potrzebują delikatnej korekty proporcji i optycznej równowagi",
  },
  {
    title: "Codzienna pomadka",
    text: "gdy klientka codziennie poprawia kolor ust i chce skrócić poranną rutynę",
  },
  {
    title: "Utrata koloru",
    text: "gdy kolor czerwieni wargowej jest nierówny, chłodny, blady albo miejscami zanika",
  },
  {
    title: "Naturalna zmiana",
    text: "gdy celem jest świeży wygląd ust bez przerysowania i bez ciężkiego makijażu",
  },
];

const methodItems = [
  {
    title: "Natural Lips",
    text: "delikatne odświeżenie koloru ust z miękkim, codziennym efektem",
  },
  {
    title: "Kontur z cieniowaniem",
    text: "uporządkowanie granicy czerwieni wargowej bez twardej obrysówki",
  },
  {
    title: "Pełniejsze nasycenie",
    text: "bardziej widoczny kolor dla klientek, które lubią efekt zadbanej pomadki",
  },
  {
    title: "Korekta koloru",
    text: "indywidualna praca przy nierównym odcieniu albo wcześniejszej pigmentacji",
  },
  {
    title: "Odświeżenie czerwieni",
    text: "przywrócenie świeżości ustom, które z czasem straciły naturalny kolor",
  },
];

const processItems = [
  {
    title: "Konsultacja",
    text: "rozmowa o oczekiwaniach, naturalnym kolorze ust, wcześniejszych zabiegach i stylu klientki",
  },
  {
    title: "Analiza ust",
    text: "ocena czerwieni wargowej, konturu, asymetrii, koloru skóry i warunków do pigmentacji",
  },
  {
    title: "Rysunek wstępny",
    text: "omówienie kształtu i granicy pigmentacji przed rozpoczęciem zabiegu",
  },
  {
    title: "Dobór koloru",
    text: "kolor dobierany do urody, naturalnych ust i oczekiwanego poziomu intensywności",
  },
  {
    title: "Pigmentacja",
    text: "precyzyjna praca warstwowa z kontrolą nasycenia, symetrii i reakcji skóry",
  },
  {
    title: "Gojenie",
    text: "etap stabilizacji koloru i skóry, w którym usta stopniowo pokazują finalny kierunek efektu",
  },
  {
    title: "Dopigmentowanie",
    text: "finalne dopracowanie koloru, równomierności i detalu po wygojeniu ust",
  },
];

const avoidItems = [
  {
    title: "Nie powiększamy ust pigmentem",
    text: "pigmentacja może uporządkować kolor i kontur, ale nie zastępuje zabiegów wolumetrycznych",
  },
  {
    title: "Nie robimy ostrej obrysówki",
    text: "kontur ma wspierać naturalny kształt ust, a nie tworzyć ciężką ramę",
  },
  {
    title: "Nie dobieramy koloru z katalogu",
    text: "kolor wynika z urody, czerwieni wargowej, skóry i oczekiwanego efektu po wygojeniu",
  },
  {
    title: "Nie robimy każdej klientce mocnej pomadki",
    text: "intensywność musi pasować do twarzy, wieku, stylu i codziennego wyglądu",
  },
  {
    title: "Nie przykrywamy problemu bez oceny",
    text: "wcześniejsze pigmentacje, opryszczka, przesuszenie albo stan skóry wymagają kwalifikacji",
  },
];

const faqItems = [
  {
    question: "Czy makijaż permanentny ust powiększa usta?",
    answer:
      "Nie. Pigmentacja ust nie jest zabiegiem powiększania ust. Może optycznie uporządkować kontur i odświeżyć kolor, ale nie zastępuje zabiegów wolumetrycznych.",
  },
  {
    question: "Czy efekt może wyglądać naturalnie?",
    answer:
      "Tak. Naturalny efekt zależy od właściwego koloru, miękkiego konturu, stopnia nasycenia i dopasowania pigmentacji do urody klientki.",
  },
  {
    question: "Czy przed zabiegiem wykonywany jest rysunek wstępny?",
    answer:
      "Tak. Rysunek wstępny pozwala omówić kształt, kontur i zakres pigmentacji przed rozpoczęciem zabiegu.",
  },
  {
    question: "Czy kolor po zabiegu jest finalny?",
    answer:
      "Nie. Bezpośrednio po zabiegu kolor może być intensywniejszy. Finalny efekt ocenia się po wygojeniu i stabilizacji pigmentu.",
  },
  {
    question: "Czy usta wymagają dopigmentowania?",
    answer:
      "Zazwyczaj dopigmentowanie jest etapem finalnego dopracowania koloru i równomierności po wygojeniu.",
  },
  {
    question: "Czy można wykonać PMU na ustach po wcześniejszym powiększaniu?",
    answer:
      "To wymaga indywidualnej oceny. Ważny jest czas od zabiegu, stan tkanek, symetria ust i aktualny efekt.",
  },
  {
    question: "Czy opryszczka ma znaczenie przy pigmentacji ust?",
    answer:
      "Tak. Skłonność do opryszczki należy omówić przed zabiegiem, ponieważ może mieć znaczenie dla przygotowania i gojenia ust.",
  },
  {
    question: "Gdzie wykonywany jest makijaż permanentny ust?",
    answer:
      "Zabieg wykonywany jest w gabinecie Bogusława Herda w Bielsku-Białej. Aktualne terminy i rezerwacje dostępne są przez Booksy.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: {
      "@id": "https://permanentnybielsko.com/#website",
    },
    about: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: "https://permanentnybielsko.com/images/makijaz-permanentny-ust-bielsko-biala-efekt-01.webp",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Makijaż permanentny Bielsko-Biała",
        item: "https://permanentnybielsko.com/makijaz-permanentny-bielsko/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Makijaż permanentny ust",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${pageUrl}#service`,
    name: "Makijaż permanentny ust Bielsko-Biała",
    serviceType: "Makijaż permanentny ust",
    description:
      "Makijaż permanentny ust w Bielsku-Białej: naturalne odświeżenie koloru, wyrównanie czerwieni wargowej, miękki kontur i efekt bez przerysowania.",
    areaServed: [
      {
        "@type": "City",
        name: "Bielsko-Biała",
      },
      {
        "@type": "AdministrativeArea",
        name: "województwo śląskie",
      },
    ],
    provider: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    brand: {
      "@type": "Brand",
      name: "Bogusława Herda Makijaż Permanentny",
    },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Zakres pigmentacji ust",
      itemListElement: [
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Odświeżenie koloru ust",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Wyrównanie konturu ust",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Pełniejszy efekt koloru ust",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Korekta lub odświeżenie makijażu permanentnego ust",
          },
        },
      ],
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/makijaz-permanentny-ust/"
  structuredData={structuredData}
>
  <div class="lips-page">
    <Header />

    <main>
      <section class="lips-hero">
        <div class="lips-glow lips-glow-one"></div>
        <div class="lips-glow lips-glow-two"></div>

        <div class="container lips-hero-grid">
          <div class="lips-hero-copy">
            <p class="section-kicker">Makijaż permanentny ust Bielsko-Biała</p>

            <h1>
              <span class="pmu-hero-rose-text">Makijaż permanentny ust</span>, który odświeża kolor bez efektu przerysowania.
            </h1>

            <p class="lips-hero-lead">
              Permanentny makijaż ust może subtelnie wyrównać czerwień wargową,
              podkreślić kontur i nadać ustom świeższy wygląd. Celem nie jest
              powiększanie ust, tylko naturalne wydobycie ich koloru, kształtu
              i proporcji twarzy.
            </p>

            <div class="lips-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację
              </a>

              <a class="button-secondary" href="#zakres-ust">
                Zobacz zakres
              </a>
            </div>
          </div>

          <aside class="lips-hero-card" aria-label="Makijaż permanentny ust">
            <p class="lips-card-label">Lips</p>
            <h2>Naturalny kolor, miękki kontur i spokojny efekt.</h2>
            <p>
              W gabinecie Bogusława Herda makijaż permanentny ust planowany jest indywidualnie:
              od bardzo delikatnego odświeżenia po bardziej widoczne, ale nadal eleganckie podkreślenie.
            </p>
          </aside>
        </div>
      </section>

      <section class="lips-proof-section" aria-label="Najważniejsze elementy makijażu permanentnego ust">
        <div class="container lips-proof-grid">
          <div>
            <strong>Dobór koloru</strong>
            <span>pigment dopasowany do urody i naturalnych ust</span>
          </div>

          <div>
            <strong>Rysunek wstępny</strong>
            <span>kształt omawiany przed pigmentacją</span>
          </div>

          <div>
            <strong>Miękki kontur</strong>
            <span>bez efektu sztucznej obrysówki</span>
          </div>

          <div>
            <strong>Dopigmentowanie</strong>
            <span>finalne dopracowanie po wygojeniu</span>
          </div>
        </div>
      </section>

      <section class="lips-intro-section">
        <div class="container lips-natural-look-card">
          <figure class="lips-natural-look-media">
            <img
              src="/images/makijaz-permanentny-ust-bielsko-biala-efekt-17.webp"
              alt="Makijaż permanentny ust Bielsko-Biała — naturalny kolor, miękki kontur i świeży efekt"
              width="1400"
              height="1400"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="lips-natural-look-copy">
            <p class="section-kicker">Naturalny kolor</p>

            <h2>Usta permanentne nie muszą wyglądać ciężko.</h2>

            <p>
              Najlepszy efekt to taki, który odświeża czerwień wargową, porządkuje kontur
              i nadal wygląda lekko, świeżo oraz naturalnie. Pigmentacja ust nie powinna
              tworzyć przerysowanej ramy ani efektu przypadkowej pomadki.
            </p>

            <p>
              W dobrze wykonanym makijażu permanentnym ust liczy się miękkość przejścia,
              dobór koloru do urody, naturalny odcień czerwieni wargowej i sposób, w jaki
              usta pracują razem z całą twarzą.
            </p>
          </div>
        </div>

        <div class="container lips-for-who-heading">
          <p class="section-kicker">Dla kogo?</p>
          <h2>Makijaż permanentny ust dla kobiet, które chcą świeższego koloru i bardziej zadbanego wyglądu ust.</h2>
        </div>

        <div class="container lips-for-who-grid" aria-label="Dla kogo jest makijaż permanentny ust">
          {forWhoItems.map((item, index) => (
            <article class="lips-mini-card">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

                <section class="lips-types-section lips-methods-premium-section" id="zakres-ust">
        <div class="container">
          <div class="lips-methods-heading">
            <p class="section-kicker">Zakres pigmentacji ust</p>

            <h2>
              Kolor, kontur i świeżość muszą wynikać z urody, skóry i oczekiwanego efektu.
            </h2>

            <p>
              Nie każda klientka potrzebuje tego samego efektu. Inaczej pracuje się przy
              delikatnym odświeżeniu czerwieni wargowej, inaczej przy mocniejszym nasyceniu,
              a jeszcze inaczej przy korekcie wcześniejszej pigmentacji ust.
            </p>
          </div>

          <figure class="lips-methods-collage-card">
            <img
              src="/images/makijaz-permanentny-ust-metody-kolaz.webp"
              alt="Kolaż efektów makijażu permanentnego ust pokazujący różne odcienie i metody pigmentacji"
              width="1672"
              height="941"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="lips-methods-controls" aria-label="Przewijanie metod pigmentacji ust">
            <button
              class="lips-methods-arrow"
              type="button"
              aria-label="Przewiń metody ust w lewo"
              onclick="document.querySelector('.lips-methods-track')?.scrollBy({ left: -430, behavior: 'smooth' })"
            >
              ←
            </button>

            <button
              class="lips-methods-arrow"
              type="button"
              aria-label="Przewiń metody ust w prawo"
              onclick="document.querySelector('.lips-methods-track')?.scrollBy({ left: 430, behavior: 'smooth' })"
            >
              →
            </button>
          </div>
        </div>

        <div class="lips-methods-track" aria-label="Metody pigmentacji ust">
          <article class="lips-method-premium-card">
            <span>01</span>
            <h3>Natural Lips</h3>
            <p>
              Delikatne odświeżenie koloru ust z miękkim, codziennym efektem.
              Dobre rozwiązanie, gdy usta mają wyglądać świeżo, ale nadal bardzo naturalnie.
            </p>
          </article>

          <article class="lips-method-premium-card lips-method-premium-card-rose">
            <span>02</span>
            <h3>Kontur z cieniowaniem</h3>
            <p>
              Uporządkowanie granicy czerwieni wargowej bez twardej obrysówki.
              Kontur ma wspierać kształt ust, a nie tworzyć ciężką ramę.
            </p>
          </article>

          <article class="lips-method-premium-card">
            <span>03</span>
            <h3>Pełniejsze nasycenie</h3>
            <p>
              Bardziej widoczny kolor dla klientek, które lubią efekt zadbanej pomadki,
              ale nadal oczekują eleganckiego i kontrolowanego rezultatu.
            </p>
          </article>

          <article class="lips-method-premium-card lips-method-premium-card-rose">
            <span>04</span>
            <h3>Korekta koloru</h3>
            <p>
              Indywidualna praca przy nierównym odcieniu albo wcześniejszej pigmentacji.
              Najpierw oceniamy kolor, nasycenie i możliwości skóry.
            </p>
          </article>

          <article class="lips-method-premium-card lips-method-premium-card-strong">
            <span>05</span>
            <h3>Odświeżenie czerwieni</h3>
            <p>
              Przywrócenie świeżości ustom, które z czasem straciły naturalny kolor.
              Efekt ma wyglądać lekko, czysto i spójnie z twarzą.
            </p>
          </article>
        </div>
      </section>

      <section class="lips-signature-section">
        <div class="container lips-signature-card">
          <div class="lips-signature-copy">
            <p class="section-kicker section-kicker-light">Kolor i kształt</p>
            <h2>Kolor ust dobrany do urody, nie do chwilowego trendu.</h2>
            <p class="lips-signature-lead">
              Makijaż permanentny ust nie polega na przerysowaniu konturu ani stworzeniu
              efektu ciężkiej pomadki. Celem jest świeżość, równowaga koloru i naturalny wygląd
              ust dopasowany do twarzy.
            </p>
          </div>

          <figure class="lips-signature-media lips-media-frame">
            <img
              src="/images/makijaz-permanentny-ust-bielsko-biala-efekt-03.webp"
              alt="Naturalny kolor ust po makijażu permanentnym"
              width="900"
              height="1200"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="lips-signature-points" aria-label="Cechy naturalnego makijażu permanentnego ust">
            <div>
              <span>01</span>
              <strong>Miękki kontur</strong>
              <p>granica ust ma wyglądać czysto, ale bez ciężkiej obrysówki</p>
            </div>

            <div>
              <span>02</span>
              <strong>Kolor z urody</strong>
              <p>odcień wynika z czerwieni wargowej, skóry i codziennego stylu</p>
            </div>

            <div>
              <span>03</span>
              <strong>Naturalna intensywność</strong>
              <p>efekt może być subtelny albo bardziej widoczny, ale nie przypadkowy</p>
            </div>

            <div>
              <span>04</span>
              <strong>Wygojenie</strong>
              <p>finalny kolor oceniamy po stabilizacji pigmentu i skóry</p>
            </div>
          </div>
        </div>
      </section>

      <section class="lips-gallery-section" id="efekty-ust">
        <div class="container">
          <div class="lips-section-heading lips-gallery-heading">
            <p class="section-kicker">Efekty ust</p>
            <h2>Różne odcienie, jeden standard: usta mają pasować do twarzy.</h2>
            <p>
              Galeria pokazuje różne kierunki pigmentacji ust: od delikatnego odświeżenia
              po bardziej widoczny kolor. Zdjęcia traktujemy jako inspirację — finalny efekt
              zawsze dobierany jest indywidualnie.
            </p>
          </div>
        </div>

        <div class="lips-gallery-viewport" aria-label="Galeria efektów makijażu permanentnego ust">
          <div class="lips-gallery-track">
            {lipsGalleryImages.map((image) => (
              <figure class="lips-gallery-card lips-media-frame">
                <img src={image.src} alt={image.alt} width="900" height="1200" loading="lazy" decoding="async" />
              </figure>
            ))}
          </div>
        </div>
      </section>

      <section class="lips-process-section">
        <div class="container">
          <div class="lips-two-column lips-process-intro">
            <div>
              <p class="section-kicker">Proces zabiegu</p>
              <h2>Najpierw rysunek wstępny i dobór koloru. Dopiero później pigmentacja.</h2>
            </div>

            <div class="lips-text-card">
              <p>
                Usta wymagają szczególnej ostrożności, ponieważ ich kolor, kontur i symetria
                wpływają na odbiór całej twarzy. Przed zabiegiem omawiany jest rysunek wstępny,
                zakres pigmentacji i intensywność efektu.
              </p>
            </div>
          </div>

          <div class="lips-process-grid">
            {processItems.map((item, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="lips-avoid-section">
        <div class="container lips-avoid-grid">
          <div class="lips-avoid-heading">
            <p class="section-kicker">Czego nie robimy</p>
            <h2>Naturalny efekt ust wymaga dobrego planu, nie mocnego koloru na siłę.</h2>
            <p>
              Przy pigmentacji ust ważny jest stan skóry, skłonność do opryszczki,
              wcześniejsze pigmentacje i oczekiwany efekt. Czasem lepszy jest spokojny,
              etapowy plan niż zbyt intensywna pigmentacja wykonana od razu.
            </p>
          </div>

          <div class="premium-points-list premium-points-list--rose" aria-label="Zasady bezpiecznego makijażu permanentnego ust">
            {avoidItems.map((item) => (
              <div class="premium-point">
                <span class="premium-point__dot" aria-hidden="true"></span>
                <div class="premium-point__content">
                  <strong class="premium-point__title">{item.title}</strong>
                  <span class="premium-point__text">{item.text}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="lips-related-section">
        <div class="container">
          <div class="lips-section-heading">
            <p class="section-kicker">Oferta PMU</p>
            <h2>Zobacz również inne podstrony makijażu permanentnego.</h2>
          </div>

          <div class="lips-related-grid">
            <a href="/makijaz-permanentny-bielsko/" class="lips-related-card">
              <span>PMU</span>
              <h3>Makijaż permanentny Bielsko-Biała</h3>
              <p>Główna podstrona o makijażu permanentnym: brwi, usta, kreski, konsultacja i naturalny efekt.</p>
            </a>

            <a href="/makijaz-permanentny-brwi/" class="lips-related-card lips-related-card-turquoise">
              <span>Brwi</span>
              <h3>Brwi permanentne</h3>
              <p>Naturalne brwi, metoda włoskowa, włos z cieniem i Silky Hairstroke Brows.</p>
            </a>

            <a href="/makijaz-permanentny-oczu/" class="lips-related-card">
              <span>Kreski</span>
              <h3>Makijaż permanentny oczu</h3>
              <p>Kreski permanentne, zagęszczenie linii rzęs i subtelne podkreślenie spojrzenia.</p>
            </a>

            <a href="/usuwanie-makijazu-permanentnego/" class="lips-related-card lips-related-card-rose">
              <span>Usuwanie</span>
              <h3>Usuwanie PMU</h3>
              <p>Rozjaśnianie starego makijażu permanentnego i przygotowanie do korekty.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="lips-faq-section">
        <div class="container">
          <div class="lips-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Co warto wiedzieć przed makijażem permanentnym ust?</h2>
          </div>

          <div class="lips-faq-grid">
            {faqItems.map((item) => (
              <article>
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="lips-final-cta" id="kontakt">
        <div class="container lips-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Chcesz sprawdzić, jaki kolor ust będzie najlepszy dla Twojej urody?</h2>
          <p>
            Umów konsultację i zobacz, jak może wyglądać naturalny efekt ust dopasowany
            do Twojego koloru skóry, czerwieni wargowej i codzienności.
          </p>

          <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
            Umów wizytę przez Booksy
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .lips-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.12), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.12), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .lips-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    padding: 0 13px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .lips-page .section-kicker-light {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
  }

  .lips-hero {
    position: relative;
    padding: 150px 0 88px;
    overflow: hidden;
  }

  .lips-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .lips-glow-one {
    right: -12rem;
    top: 4rem;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.2), transparent 68%);
  }

  .lips-glow-two {
    left: -10rem;
    bottom: -12rem;
    width: 38rem;
    height: 38rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.18), transparent 68%);
  }

  .lips-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.98fr);
    gap: 24px;
    align-items: stretch;
  }

  .lips-hero-copy,
  .lips-hero-card,
  .lips-text-card,
  .lips-mini-card,
  .lips-method-card,
  .lips-process-grid article,
  .lips-related-card,
  .lips-faq-grid article,
  .lips-final-card,
  .lips-media-frame {
    border: 1px solid rgba(183, 101, 118, 0.16);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .lips-hero-copy {
    display: flex;
    min-height: 620px;
    flex-direction: column;
    justify-content: center;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    background:
      radial-gradient(circle at 92% 14%, rgba(56, 187, 181, 0.10), transparent 16rem),
      rgba(255, 255, 255, 0.78);
  }

  .lips-hero-copy h1 {
    max-width: 1080px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(3.05rem, 5.45vw, 6.35rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .pmu-hero-rose-text {
    color: #b76576;
    background: linear-gradient(120deg, #7f344d 0%, #b76576 24%, #d7899f 48%, #9d4f68 72%, #6f3046 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .lips-hero-lead {
    max-width: 780px;
    margin: 28px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: 1.12rem;
    line-height: 1.68;
  }

  .lips-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .lips-hero-card {
    position: relative;
    display: flex;
    min-height: 620px;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.34), transparent 13rem),
      radial-gradient(circle at 82% 84%, rgba(127, 52, 77, 0.22), transparent 18rem),
      linear-gradient(145deg, #d992a7 0%, #c97894 36%, #b76576 72%, #9c4e68 100%);
    box-shadow: 0 28px 76px rgba(183, 101, 118, 0.22);
  }

  .lips-hero-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        110deg,
        transparent 0%,
        rgba(255, 255, 255, 0.06) 22%,
        rgba(255, 255, 255, 0.24) 47%,
        rgba(255, 255, 255, 0.06) 72%,
        transparent 100%
      );
    transform: translateX(-72%);
    animation: lips-panel-shine 8s ease-in-out infinite;
    pointer-events: none;
  }

  .lips-hero-card > * {
    position: relative;
    z-index: 2;
  }

  .lips-card-label {
    position: absolute;
    top: clamp(34px, 3.4vw, 54px);
    left: clamp(52px, 5.4vw, 88px);
    margin: 0;
    color: rgba(255, 255, 255, 0.24);
    font-size: clamp(6.2rem, 9vw, 11.8rem);
    font-weight: 850;
    line-height: 0.78;
    letter-spacing: -0.085em;
    text-transform: none;
  }

  .lips-hero-card h2 {
    max-width: 620px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.15rem, 3.7vw, 4.35rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.075em;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.24);
  }

  .lips-hero-card p:not(.lips-card-label) {
    max-width: 620px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  @keyframes lips-panel-shine {
    0%,
    45% {
      transform: translateX(-72%);
    }

    100% {
      transform: translateX(72%);
    }
  }

  .lips-media-frame {
    position: relative;
    overflow: hidden;
    padding: 8px;
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.92);
  }

  .lips-media-frame::after {
    content: "";
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(255, 255, 255, 0.54);
    border-radius: 24px;
    pointer-events: none;
  }

  .lips-media-frame img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    object-fit: cover;
    object-position: center;
  }

  .lips-signature-media,
  .lips-gallery-card {
    margin: 0;
  }

  .lips-proof-section {
    border-top: 1px solid rgba(183, 101, 118, 0.10);
    border-bottom: 1px solid rgba(183, 101, 118, 0.10);
    background: rgba(255, 255, 255, 0.74);
  }

  .lips-proof-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .lips-proof-grid div {
    min-height: 112px;
    padding: 24px 22px;
    border-right: 1px solid rgba(183, 101, 118, 0.12);
  }

  .lips-proof-grid div:last-child {
    border-right: 0;
  }

  .lips-proof-grid strong {
    display: block;
    margin-bottom: 8px;
    color: var(--color-text, #17151d);
    font-size: 0.92rem;
    font-weight: 780;
    letter-spacing: -0.02em;
  }

  .lips-proof-grid span {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 650;
    line-height: 1.55;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .lips-intro-section,
  .lips-types-section,
  .lips-process-section,
  .lips-avoid-section,
  .lips-related-section,
  .lips-faq-section,
  .lips-final-cta {
    padding: 88px 0;
  }

  .lips-two-column,
  .lips-avoid-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 54px;
    align-items: start;
  }

  .lips-natural-look-card {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    gap: clamp(34px, 4vw, 64px);
    align-items: center;
    overflow: hidden;
    padding: clamp(22px, 2.8vw, 34px);
    border: 1px solid rgba(183, 101, 118, 0.14);
    border-radius: 46px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.10), transparent 18rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 248, 251, 0.92));
    box-shadow: 0 22px 68px rgba(89, 53, 67, 0.08);
  }

  .lips-natural-look-media {
    position: relative;
    min-height: clamp(420px, 42vw, 620px);
    margin: 0;
    overflow: hidden;
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow:
      0 22px 54px rgba(89, 53, 67, 0.12),
      0 0 0 1px rgba(255, 255, 255, 0.64) inset;
  }

  .lips-natural-look-media::after {
    content: "";
    position: absolute;
    inset: 18px;
    border: 1.5px solid rgba(255, 255, 255, 0.58);
    border-radius: 26px;
    pointer-events: none;
  }

  .lips-natural-look-media img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: clamp(420px, 42vw, 620px);
    object-fit: cover;
    object-position: center;
  }

  .lips-natural-look-copy {
    padding: clamp(8px, 1.4vw, 18px);
  }

  .lips-natural-look-copy h2,
  .lips-two-column h2,
  .lips-section-heading h2,
  .lips-avoid-heading h2,
  .lips-final-card h2 {
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.45rem, 4.2vw, 4.45rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .lips-natural-look-copy h2 {
    max-width: 720px;
    font-size: clamp(2.55rem, 4.45vw, 5rem);
    font-weight: 780;
    line-height: 0.98;
    letter-spacing: -0.078em;
  }

  .lips-natural-look-copy p:not(.section-kicker) {
    max-width: 760px;
    margin: 24px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.04rem, 1.28vw, 1.22rem);
    line-height: 1.72;
  }

  .lips-for-who-heading {
    max-width: 1120px;
    margin-top: 72px;
    margin-bottom: 34px;
  }

  .lips-for-who-heading h2 {
    max-width: 980px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.35rem, 4vw, 4.2rem);
    font-weight: 760;
    line-height: 1.03;
    letter-spacing: -0.074em;
  }

  .lips-text-card {
    padding: 34px;
    border-radius: 34px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 14rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 252, 0.88));
  }

  .lips-text-card p,
  .lips-section-heading p,
  .lips-avoid-heading p,
  .lips-final-card p:not(.signature) {
    color: var(--color-muted, #6e6670);
    font-weight: 450;
    line-height: 1.65;
  }

  .lips-text-card p:first-child {
    margin-top: 0;
  }

  .lips-for-who-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 0;
  }

  .lips-mini-card,
  .lips-method-card,
  .lips-process-grid article,
  .lips-related-card,
  .lips-faq-grid article {
    position: relative;
    min-height: 236px;
    overflow: hidden;
    padding: 28px;
    border-radius: 32px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 14rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 252, 0.88));
  }

  .lips-mini-card::before,
  .lips-method-card::before,
  .lips-process-grid article::before,
  .lips-related-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid rgba(56, 187, 181, 0.34);
    pointer-events: none;
  }

  .lips-mini-card::after,
  .lips-method-card::after,
  .lips-process-grid article::after,
  .lips-related-card::after {
    content: "";
    position: absolute;
    right: -58px;
    top: -58px;
    width: 138px;
    height: 138px;
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.68);
    pointer-events: none;
  }

  .lips-method-card-rose::before,
  .lips-related-card-rose::before {
    border-top-color: rgba(201, 127, 143, 0.34);
  }

  .lips-method-card-rose::after,
  .lips-related-card-rose::after {
    background: rgba(246, 220, 227, 0.76);
  }

  .lips-mini-card span,
  .lips-method-card span,
  .lips-process-grid span,
  .lips-related-card span {
    position: relative;
    z-index: 2;
    display: inline-flex;
    margin-bottom: 44px;
    color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.72rem;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .lips-mini-card h3,
  .lips-method-card h3,
  .lips-process-grid h3,
  .lips-related-card h3,
  .lips-faq-grid h3 {
    position: relative;
    z-index: 2;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(1.45rem, 1.9vw, 2.1rem);
    font-weight: 760;
    line-height: 1;
    letter-spacing: -0.065em;
  }

  .lips-mini-card p,
  .lips-method-card p,
  .lips-process-grid p,
  .lips-related-card p,
  .lips-faq-grid p {
    position: relative;
    z-index: 2;
    margin: 14px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: 0.95rem;
    line-height: 1.62;
  }

  .lips-section-heading {
    max-width: 980px;
    margin-bottom: 38px;
  }

  .lips-method-grid,
  .lips-process-grid,
  .lips-related-grid,
  .lips-faq-grid {
    display: grid;
    gap: 18px;
  }

  .lips-method-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .lips-signature-section {
    padding: 92px 0;
  }

  .lips-signature-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.8fr);
    gap: 38px;
    overflow: hidden;
    padding: clamp(34px, 5vw, 64px);
    border-radius: 46px;
    color: #ffffff;
    background:
      radial-gradient(circle at 92% 14%, rgba(255, 255, 255, 0.26), transparent 17rem),
      radial-gradient(circle at 18% 88%, rgba(56, 187, 181, 0.20), transparent 18rem),
      linear-gradient(145deg, #8a3650 0%, #c46b86 42%, #d58b9d 64%, #802f48 100%);
    box-shadow: 0 28px 76px rgba(183, 101, 118, 0.22);
  }

  .lips-signature-copy h2 {
    max-width: 900px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.5rem, 4.5vw, 5.2rem);
    font-weight: 780;
    line-height: 0.98;
    letter-spacing: -0.08em;
  }

  .lips-signature-lead {
    max-width: 860px;
    margin: 24px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .lips-signature-media {
    align-self: start;
    aspect-ratio: 4 / 5;
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.16);
    box-shadow: 0 26px 64px rgba(45, 24, 35, 0.18);
  }

  .lips-signature-points {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-top: 8px;
  }

  .lips-signature-points div {
    min-height: 160px;
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.12);
  }

  .lips-signature-points span {
    display: block;
    margin-bottom: 18px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.18em;
  }

  .lips-signature-points strong {
    display: block;
    color: #ffffff;
    font-size: 1.14rem;
    font-weight: 780;
    letter-spacing: -0.04em;
  }

  .lips-signature-points p {
    margin: 10px 0 0;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.55;
  }

  .lips-gallery-section {
    padding: 88px 0;
    overflow: hidden;
  }

  .lips-gallery-heading {
    margin-bottom: 22px;
  }

  .lips-gallery-viewport {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 8px max(18px, calc((100vw - 1440px) / 2)) 26px;
    scroll-snap-type: x mandatory;
  }

  .lips-gallery-viewport::-webkit-scrollbar {
    height: 10px;
  }

  .lips-gallery-viewport::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: rgba(201, 127, 143, 0.34);
  }

  .lips-gallery-track {
    display: grid;
    width: max-content;
    grid-auto-columns: minmax(240px, 320px);
    grid-auto-flow: column;
    gap: 16px;
  }

  .lips-gallery-card {
    aspect-ratio: 4 / 5;
    scroll-snap-align: start;
  }

  .lips-process-intro {
    margin-bottom: 38px;
  }

  .lips-process-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .lips-process-grid article {
    min-height: 255px;
  }

  .lips-avoid-section {
    background:
      radial-gradient(circle at 12% 20%, rgba(56, 187, 181, 0.1), transparent 24rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 247, 250, 0.72));
  }

  .lips-avoid-heading {
    padding: 34px;
    border: 1px solid rgba(183, 101, 118, 0.14);
    border-radius: 34px;
    background:
      radial-gradient(circle at 92% 20%, rgba(201, 127, 143, 0.14), transparent 16rem),
      rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .premium-points-list {
    overflow: hidden;
    border: 1px solid rgba(183, 101, 118, 0.18);
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .premium-point {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    padding: 24px;
    border-bottom: 1px solid rgba(183, 101, 0.14);
    transition: background 180ms ease, transform 180ms ease;
  }

  .premium-point:last-child {
    border-bottom: 0;
  }

  .premium-point:hover {
    background: rgba(219, 246, 243, 0.60);
    transform: translateX(3px);
  }

  .premium-point__dot {
    width: 28px;
    height: 28px;
    margin-top: 3px;
    border-radius: 999px;
    background:
      radial-gradient(circle, rgba(183, 101, 118, 0.88) 0 22%, rgba(183, 101, 118, 0.18) 23% 100%);
    box-shadow: 0 0 0 11px rgba(201, 127, 143, 0.10);
  }

  .premium-point__title {
    display: block;
    color: var(--color-text, #17151d);
    font-size: 1rem;
    font-weight: 780;
    letter-spacing: -0.04em;
  }

  .premium-point__text {
    display: block;
    margin-top: 7px;
    color: var(--color-muted, #6e6670);
    line-height: 1.55;
  }

  .lips-related-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .lips-related-card {
    min-height: 275px;
    color: inherit;
    text-decoration: none;
  }

  .lips-related-card-turquoise {
    border-color: rgba(56, 187, 181, 0.3);
    background: linear-gradient(145deg, rgba(219, 246, 243, 0.88), rgba(255, 255, 255, 0.92));
  }

  .lips-faq-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .lips-faq-grid article {
    min-height: auto;
  }

  .lips-faq-grid article::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid rgba(201, 127, 143, 0.24);
    pointer-events: none;
  }

  .lips-final-card {
    padding: clamp(34px, 6vw, 70px);
    border-radius: 42px;
    text-align: center;
    background:
      linear-gradient(145deg, rgba(219, 246, 243, 0.7), rgba(255, 242, 246, 0.82)),
      rgba(255, 255, 255, 0.7);
  }

  .lips-final-card p:not(.signature) {
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .lips-final-card .button-primary {
    margin-top: 18px;
  }

  @media (max-width: 1260px) {
    .lips-proof-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .lips-proof-grid div:nth-child(2) {
      border-right: 0;
    }

    .lips-method-grid,
    .lips-process-grid,
    .lips-related-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .lips-signature-points {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 1080px) {
    .lips-hero-grid,
    .lips-two-column,
    .lips-avoid-grid,
    .lips-signature-card,
    .lips-natural-look-card {
      grid-template-columns: 1fr;
    }

    .lips-hero-card {
      min-height: 520px;
    }

    .lips-natural-look-media,
    .lips-natural-look-media img {
      min-height: 470px;
    }

    .lips-signature-media {
      width: min(100%, 460px);
      justify-self: center;
    }
  }

  @media (max-width: 760px) {
    .lips-hero {
      padding: 112px 0 58px;
    }

    .lips-hero-grid {
      gap: 16px;
      padding-left: 8px;
      padding-right: 8px;
      box-sizing: border-box;
    }

    .lips-hero-copy,
    .lips-hero-card,
    .lips-text-card,
    .lips-mini-card,
    .lips-method-card,
    .lips-process-grid article,
    .lips-related-card,
    .lips-faq-grid article,
    .lips-final-card,
    .lips-media-frame,
    .lips-signature-card,
    .lips-avoid-heading,
    .premium-points-list {
      border-radius: 28px;
    }

    .lips-hero-copy {
      min-height: auto;
      padding: 28px 22px;
    }

    .lips-hero-copy h1 {
      font-size: clamp(2.55rem, 11.6vw, 3.85rem);
      line-height: 1.04;
      letter-spacing: -0.068em;
    }

    .lips-hero-lead {
      font-size: 1rem;
    }

    .lips-hero-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .lips-hero-actions a {
      width: 100%;
      text-align: center;
    }

    .lips-hero-card {
      min-height: 430px;
      padding: 30px 24px;
    }

    .lips-card-label {
      top: 24px;
      left: 26px;
      font-size: clamp(4.8rem, 22vw, 7rem);
    }

    .lips-hero-card h2 {
      font-size: clamp(2rem, 9vw, 2.8rem);
    }

    .lips-hero-card p:not(.lips-card-label) {
      font-size: 1rem;
    }

    .lips-media-frame img,
    .lips-media-frame::after {
      border-radius: 20px;
    }

    .lips-media-frame {
      padding: 7px;
    }

    .lips-media-frame::after {
      inset: 7px;
    }

    .lips-intro-section,
    .lips-types-section,
    .lips-signature-section,
    .lips-gallery-section,
    .lips-process-section,
    .lips-avoid-section,
    .lips-related-section,
    .lips-faq-section,
    .lips-final-cta {
      padding: 58px 0;
    }

    .lips-natural-look-card {
      gap: 24px;
      padding: 16px;
      border-radius: 28px;
    }

    .lips-natural-look-media {
      border-radius: 24px;
    }

    .lips-natural-look-media,
    .lips-natural-look-media img {
      min-height: 320px;
    }

    .lips-natural-look-media::after {
      inset: 12px;
      border-radius: 18px;
    }

    .lips-natural-look-copy {
      padding: 6px 4px 8px;
    }

    .lips-natural-look-copy h2,
    .lips-two-column h2,
    .lips-section-heading h2,
    .lips-avoid-heading h2,
    .lips-final-card h2,
    .lips-signature-copy h2 {
      font-size: clamp(2.15rem, 9.4vw, 3.15rem);
      line-height: 1.04;
      letter-spacing: -0.066em;
    }

    .lips-natural-look-copy p:not(.section-kicker) {
      margin-top: 16px;
      font-size: 1rem;
      line-height: 1.68;
    }

    .lips-for-who-heading {
      margin-top: 44px;
      margin-bottom: 24px;
    }

    .lips-for-who-heading h2 {
      font-size: clamp(2.05rem, 9vw, 3rem);
      line-height: 1.04;
      letter-spacing: -0.066em;
    }

    .lips-for-who-grid,
    .lips-method-grid,
    .lips-process-grid,
    .lips-related-grid,
    .lips-faq-grid,
    .lips-proof-grid,
    .lips-signature-points {
      grid-template-columns: 1fr;
    }

    .lips-proof-grid div,
    .lips-proof-grid div:nth-child(2) {
      border-right: 0;
      border-bottom: 1px solid rgba(183, 101, 118, 0.12);
    }

    .lips-proof-grid div:last-child {
      border-bottom: 0;
    }

    .lips-mini-card,
    .lips-method-card,
    .lips-process-grid article,
    .lips-related-card {
      min-height: auto;
      padding: 26px;
    }

    .lips-mini-card span,
    .lips-method-card span,
    .lips-process-grid span,
    .lips-related-card span {
      margin-bottom: 32px;
    }

    .lips-gallery-track {
      grid-auto-columns: minmax(218px, 74vw);
    }

    .premium-point {
      padding: 22px;
    }
  }

  @media (max-width: 420px) {
    .lips-hero-grid {
      padding-left: 6px;
      padding-right: 6px;
    }

    .lips-hero-copy,
    .lips-hero-card {
      width: calc(100% - 10px);
      max-width: calc(100% - 10px);
      margin-left: auto;
      margin-right: auto;
    }
  }
    /* FINAL — usta: napis Lips w górnym lewym rogu kafla */
  .lips-hero-card .lips-card-label {
    position: absolute !important;
    top: clamp(26px, 3vw, 46px) !important;
    left: clamp(30px, 4vw, 58px) !important;
    margin: 0 !important;
    color: rgba(255, 255, 255, 0.24) !important;
    font-size: clamp(6.2rem, 9vw, 11.8rem) !important;
    font-weight: 850 !important;
    line-height: 0.78 !important;
    letter-spacing: -0.085em !important;
    text-transform: none !important;
  }

  @media (max-width: 760px) {
    .lips-hero-card .lips-card-label {
      top: 24px !important;
      left: 24px !important;
      font-size: clamp(4.7rem, 22vw, 7rem) !important;
    }
  }
    /* FINAL — usta: zakres pigmentacji jak metody brwi */
  .lips-methods-premium-section {
    padding: 96px 0 104px !important;
