---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageTitle = "Nie znaleziono strony | Bogusława Herda PMU";
const pageDescription =
  "Nie znaleziono tej strony. Wybierz aktualną ofertę makijażu permanentnego, poradnik PMU, szkolenia, galerię albo kontakt z gabinetem Bogusława Herda.";

const helpfulLinks = [
  {
    number: "01",
    label: "Oferta",
    title: "Makijaż permanentny Bielsko-Biała",
    text: "Główna oferta PMU: naturalne brwi, usta, kreski, konsultacja i dopasowanie efektu do urody.",
    href: "/makijaz-permanentny-bielsko/",
    featured: true
  },
  {
    number: "02",
    label: "Brwi",
    title: "Brwi permanentne",
    text: "Naturalny efekt, metoda włosa, Silky Hairstroke Brows i świadoma praca z rysunkiem wstępnym.",
    href: "/makijaz-permanentny-brwi/"
  },
  {
    number: "03",
    label: "Poradnik",
    title: "Poradnik PMU",
    text: "Ważne tematy makijażu permanentnego: przygotowanie, gojenie, korekty, szkolenia i wydarzenia branżowe.",
    href: "/poradnik/"
  },
  {
    number: "04",
    label: "Szkolenia",
    title: "Szkolenia PMU",
    text: "Step by Step, Masterclass, Silky Hairstroke Brows i rozwój techniki pod okiem trenerki Long-Time-Liner®.",
    href: "/szkolenie-makijaz-permanentny/"
  },
  {
    number: "05",
    label: "Galeria",
    title: "Galeria",
    text: "Galeria ma pokazywać styl pracy, estetykę efektów i charakter marki — nie przypadkowe zdjęcia.",
    href: "/galeria/"
  },
  {
    number: "06",
    label: "Kontakt",
    title: "Kontakt z gabinetem",
    text: "Dane gabinetu, lokalizacja, rezerwacja wizyty i najprostsza droga do konsultacji.",
    href: "/kontakt/"
  }
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/404/"
  robots="noindex, follow, noarchive"
>
  <div class="not-found-page">
    <Header />

    <main>
      <section class="not-found-hero">
        <div class="not-found-orb not-found-orb-one"></div>
        <div class="not-found-orb not-found-orb-two"></div>

        <div class="container not-found-grid">
          <div class="not-found-copy">
            <p class="section-kicker">Nie znaleziono strony</p>

            <h1>Ta strona nie jest już dostępna, ale możesz przejść dalej.</h1>

            <p class="not-found-lead">
              Adres, który otwierasz, mógł pochodzić ze starszej wersji strony. Wybierz jedną
              z aktualnych podstron: ofertę makijażu permanentnego, brwi, poradnik PMU,
              szkolenia albo kontakt z gabinetem.
            </p>

            <p class="not-found-lead not-found-lead-small">
              Nowa strona permanentnybielsko.com jest porządkowana wokół makijażu permanentnego:
              naturalnych brwi, ust, kresek, usuwania PMU, szkoleń i doświadczenia Bogusława Herda.
            </p>

            <div class="not-found-actions">
              <a class="button-primary" href="/makijaz-permanentny-bielsko/">
                Przejdź do oferty PMU
              </a>

              <a class="button-secondary" href="/kontakt/">
                Kontakt z gabinetem
              </a>
            </div>
          </div>

          <aside class="not-found-card" aria-label="Strona nie znaleziona">
            <span class="not-found-big-mark" aria-hidden="true">404</span>
            <p class="not-found-label">Aktualna strona</p>
            <h2>Wróć do właściwego miejsca.</h2>
            <p>
              Najlepszy punkt startowy to aktualna oferta makijażu permanentnego Bogusława Herda
              w Bielsku-Białej.
            </p>

            <a class="not-found-card-link" href="/makijaz-permanentny-bielsko/">
              permanentnybielsko.com/makijaz-permanentny-bielsko/
            </a>
          </aside>
        </div>
      </section>

      <section class="not-found-links-section">
        <div class="container">
          <div class="not-found-section-heading">
            <p class="section-kicker">Wybierz aktualną podstronę</p>
            <h2>Najważniejsze miejsca na stronie.</h2>
            <p>
              Poniżej znajdziesz aktywne linki do głównych obszarów nowej strony PMU.
            </p>
          </div>

          <div class="not-found-link-grid">
            {helpfulLinks.map((item) => (
              <a
                class:list={["not-found-link-card", { "not-found-link-card-featured": item.featured }]}
                href={item.href}
              >
                {item.featured && (
                  <span class="not-found-card-mark" aria-hidden="true">PMU</span>
                )}

                <span class="not-found-card-number">{item.number}</span>
                <p class="not-found-card-label">{item.label}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="not-found-final-cta">
        <div class="container not-found-final-card">
          <p class="section-kicker">Rezerwacja wizyty</p>
          <h2>Nie wiesz, gdzie przejść? Zacznij od kontaktu lub Booksy.</h2>
          <p>
            Jeżeli szukasz konkretnej usługi albo terminu, najprościej przejść do kontaktu
            lub sprawdzić dostępność wizyt przez Booksy.
          </p>

          <div class="not-found-actions">
            <a class="button-primary" href="/kontakt/">
              Przejdź do kontaktu
            </a>

            <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
              Umów wizytę przez Booksy
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .not-found-page,
  .not-found-page * {
    box-sizing: border-box;
  }

  .not-found-page {
    overflow-x: clip;
    background:
      radial-gradient(circle at 8% 12%, rgba(56, 187, 181, 0.11), transparent 27rem),
      radial-gradient(circle at 92% 14%, rgba(243, 199, 211, 0.20), transparent 29rem),
      linear-gradient(180deg, #ffffff 0%, #fff9fb 46%, #ffffff 100%);
  }

  .not-found-hero {
    position: relative;
    min-height: 74vh;
    padding: 154px 0 86px;
  }

  .not-found-orb {
    position: absolute;
    z-index: 0;
    border-radius: 999px;
    filter: blur(12px);
    pointer-events: none;
  }

  .not-found-orb-one {
    top: 10%;
    left: -9%;
    width: 34vw;
    height: 34vw;
    background: rgba(56, 187, 181, 0.12);
  }

  .not-found-orb-two {
    right: -8%;
    bottom: 3%;
    width: 38vw;
    height: 38vw;
    background: rgba(243, 199, 211, 0.24);
  }

  .not-found-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(340px, 0.72fr);
    gap: clamp(26px, 4vw, 54px);
    align-items: stretch;
  }

  .not-found-copy,
  .not-found-card,
  .not-found-link-card,
  .not-found-final-card {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    border: 1px solid rgba(183, 101, 118, 0.13);
    box-shadow: 0 24px 70px rgba(51, 31, 44, 0.07);
  }

  .not-found-copy {
    padding: clamp(30px, 5vw, 58px);
    border-radius: 42px;
    background:
      radial-gradient(circle at 90% 10%, rgba(56, 187, 181, 0.08), transparent 15rem),
      rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(16px);
  }

  .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    padding: 0 13px;
    border-radius: 999px;
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    background: rgba(219, 246, 243, 0.72);
    border: 1px solid rgba(56, 187, 181, 0.16);
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .not-found-copy h1 {
    max-width: 1080px;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(3.05rem, 5.45vw, 6.25rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .not-found-lead {
    max-width: 840px;
    margin: 24px 0 0;
    color: var(--color-muted);
    font-size: 1.08rem;
    line-height: 1.72;
  }

  .not-found-lead-small {
    margin-top: 14px;
    font-size: 1.02rem;
  }

  .not-found-copy h1,
  .not-found-card h2,
  .not-found-section-heading h2,
  .not-found-final-card h2,
  .not-found-link-card h3,
  .not-found-lead,
  .not-found-section-heading p,
  .not-found-final-card p,
  .not-found-link-card p {
    max-width: 100%;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: normal;
    hyphens: auto;
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .not-found-card {
    position: relative;
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(34px, 4vw, 56px);
    border-radius: 42px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 22%, #74e0d7 40%, #138a86 56%, #33c1bb 74%, #bff6f1 88%, #0d6a67 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: not-found-turquoise-flow 13s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(35, 156, 150, 0.22);
  }

  .not-found-card::before,
  .not-found-link-card-featured::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.06) 22%, rgba(255, 255, 255, 0.24) 47%, rgba(255, 255, 255, 0.06) 72%, transparent 100%);
    transform: translateX(-72%);
    animation: not-found-panel-shine 8s ease-in-out infinite;
    pointer-events: none;
  }

  .not-found-big-mark {
    position: absolute;
    right: 22px;
    top: 22px;
    z-index: 1;
    color: rgba(255, 255, 255, 0.16);
    font-size: clamp(5rem, 8.2vw, 9.2rem);
    font-weight: 900;
    line-height: 0.78;
    letter-spacing: -0.12em;
    pointer-events: none;
  }

  .not-found-label,
  .not-found-card h2,
  .not-found-card p,
  .not-found-card-link {
    position: relative;
    z-index: 2;
  }

  .not-found-label {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 32px;
    align-items: center;
    margin: 0 0 auto;
    padding: 0 13px;
    border-radius: 999px;
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.22);
  }

  .not-found-card h2 {
    margin: 58px 0 0;
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
    font-size: clamp(1.55rem, 2.2vw, 2.55rem);
    font-weight: 740;
    line-height: 1.02;
    letter-spacing: -0.055em;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.24);
  }

  .not-found-card p:not(.not-found-label) {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.88);
    -webkit-text-fill-color: rgba(255, 255, 255, 0.88);
    line-height: 1.62;
  }

  .not-found-card-link {
    width: fit-content;
    max-width: 100%;
    margin-top: 18px;
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
    font-size: 0.92rem;
    font-weight: 820;
    line-height: 1.35;
    text-decoration: none;
    overflow-wrap: anywhere;
    border-bottom: 1px solid rgba(255, 255, 255, 0.38);
  }

  .not-found-links-section,
  .not-found-final-cta {
    padding: 88px 0;
  }

  .not-found-section-heading {
    max-width: 980px;
    margin-bottom: 38px;
  }

  .not-found-section-heading h2,
  .not-found-final-card h2 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(2.05rem, 3.45vw, 3.75rem);
    font-weight: 760;
    line-height: 1.04;
    letter-spacing: -0.066em;
  }

  .not-found-section-heading p,
  .not-found-final-card p {
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.68;
  }

  .not-found-link-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .not-found-link-card {
    position: relative;
    min-height: 290px;
    padding: 30px;
    border-radius: 34px;
    color: inherit;
    text-decoration: none;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 14rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 252, 0.88));
  }

  .not-found-link-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid rgba(56, 187, 181, 0.34);
    pointer-events: none;
  }

  .not-found-link-card-featured {
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 22%, #74e0d7 40%, #138a86 56%, #33c1bb 74%, #bff6f1 88%, #0d6a67 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: not-found-turquoise-flow 13s ease-in-out infinite alternate;
  }

  .not-found-link-card > *:not(.not-found-card-mark) {
    position: relative;
    z-index: 2;
  }

  .not-found-card-mark {
    position: absolute;
    right: 18px;
    top: 16px;
    z-index: 1;
    color: rgba(255, 255, 255, 0.13);
    font-size: clamp(4.8rem, 7.2vw, 7.8rem);
    font-weight: 900;
    line-height: 0.78;
    letter-spacing: -0.12em;
    pointer-events: none;
  }

  .not-found-card-number {
    display: inline-flex;
    margin-bottom: 18px;
    color: var(--color-turquoise-dark);
    font-size: 0.72rem;
    font-weight: 860;
    letter-spacing: 0.18em;
  }

  .not-found-card-label {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    margin: 0 0 18px;
    padding: 0 11px;
    border-radius: 999px;
    color: var(--color-turquoise-dark);
    -webkit-text-fill-color: var(--color-turquoise-dark);
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    background: rgba(219, 246, 243, 0.72);
    border: 1px solid rgba(56, 187, 181, 0.16);
  }

  .not-found-link-card h3 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.28rem, 2vw, 1.52rem);
    font-weight: 760;
    line-height: 1.06;
    letter-spacing: -0.045em;
  }

  .not-found-link-card p:not(.not-found-card-label) {
    margin: 16px 0 0;
    color: var(--color-muted);
    font-size: 0.94rem;
    line-height: 1.58;
  }

  .not-found-link-card-featured,
  .not-found-link-card-featured * {
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
  }

  .not-found-link-card-featured .not-found-card-label {
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .not-found-link-card-featured p:not(.not-found-card-label) {
    color: rgba(255, 255, 255, 0.86);
    -webkit-text-fill-color: rgba(255, 255, 255, 0.86);
  }

  .not-found-final-card {
    padding: clamp(28px, 4vw, 46px);
    border-radius: 36px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 14rem),
      rgba(255, 255, 255, 0.9);
  }

  @keyframes not-found-turquoise-flow {
    0% {
      background-position: 0% 50%, 0% 50%, 0% 50%;
    }

    100% {
      background-position: 0% 50%, 0% 50%, 100% 50%;
    }
  }

  @keyframes not-found-panel-shine {
    0%,
    35% {
      transform: translateX(-72%);
      opacity: 0;
    }

    52% {
      opacity: 1;
    }

    100% {
      transform: translateX(72%);
      opacity: 0;
    }
  }

  @media (max-width: 1080px) {
    .not-found-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .not-found-link-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .not-found-page .container {
      width: 100%;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      padding-left: 18px;
      padding-right: 18px;
    }

    .not-found-hero {
      padding: 112px 0 58px;
    }

    .not-found-grid,
    .not-found-link-grid {
      width: 100%;
      max-width: 100%;
      grid-template-columns: minmax(0, 1fr) !important;
      justify-items: stretch;
    }

    .not-found-copy,
    .not-found-card,
    .not-found-link-card,
    .not-found-final-card {
      width: 100%;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      border-radius: 28px;
      padding-left: 22px;
      padding-right: 22px;
    }

    .not-found-copy h1 {
      font-size: clamp(2rem, 9vw, 2.95rem);
      line-height: 1.08;
      letter-spacing: -0.052em;
    }

    .not-found-card {
      min-height: 340px;
    }

    .not-found-card h2 {
      font-size: clamp(1.45rem, 7.4vw, 2.28rem);
      line-height: 1.06;
      letter-spacing: -0.048em;
    }

    .not-found-section-heading h2,
    .not-found-final-card h2 {
      font-size: clamp(1.82rem, 8.2vw, 2.62rem);
      line-height: 1.08;
      letter-spacing: -0.052em;
    }

    .not-found-link-card h3 {
      font-size: clamp(1.28rem, 6.4vw, 1.72rem);
      line-height: 1.08;
      letter-spacing: -0.038em;
    }

    .not-found-lead,
    .not-found-section-heading p,
    .not-found-final-card p,
    .not-found-link-card p:not(.not-found-card-label) {
      font-size: 0.98rem;
      line-height: 1.62;
    }

    .not-found-links-section,
    .not-found-final-cta {
      padding: 58px 0;
    }

    .not-found-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .not-found-actions a,
    .not-found-final-card .button-primary,
    .not-found-final-card .button-secondary {
      width: 100%;
      max-width: 100%;
      justify-content: center;
      text-align: center;
    }

    .section-kicker,
    .not-found-card-label,
    .not-found-label {
      white-space: normal;
      min-height: 30px;
      height: auto;
      padding-top: 8px;
      padding-bottom: 8px;
      line-height: 1.15;
      text-align: center;
    }
  }

  @media (max-width: 380px) {
    .not-found-page .container {
      padding-left: 14px;
      padding-right: 14px;
    }

    .not-found-copy,
    .not-found-card,
    .not-found-link-card,
    .not-found-final-card {
      padding-left: 18px;
      padding-right: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .not-found-card,
    .not-found-card::before,
    .not-found-link-card-featured,
    .not-found-link-card-featured::after {
      animation: none;
    }
  }


  /* V2 — stonowany znak PMU w kafelku 404 */
  .not-found-link-card-featured .not-found-card-mark {
    color: rgba(255, 255, 255, 0.13) !important;
    -webkit-text-fill-color: rgba(255, 255, 255, 0.13) !important;
    opacity: 1 !important;
    text-shadow: none !important;
  }

  @media (max-width: 760px) {
    .not-found-link-card-featured .not-found-card-mark {
      right: 14px !important;
      top: 16px !important;
      font-size: clamp(4rem, 20vw, 5.8rem) !important;
    }
  }

</style>
