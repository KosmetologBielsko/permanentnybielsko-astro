---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/poradnik/";
const pageTitle = "Poradnik PMU Bielsko-Biała | Makijaż permanentny brwi, ust i oczu";
const pageDescription =
  "Poradnik PMU Bogusława Herda: brwi, usta, kreski, gojenie, pielęgnacja po zabiegu, opryszczka, metody brwi, usuwanie PMU i szkolenia PMU.";

const articleCards = [
  {
    "number": "01",
    "category": "Brwi permanentne",
    "title": "Jak przygotować się do makijażu permanentnego brwi?",
    "text": "Konsultacja, przeciwwskazania, skóra przed zabiegiem, rysunek wstępny, kawa, alkohol i naturalny efekt bez przerysowania.",
    "href": "/poradnik/jak-przygotowac-sie-do-makijazu-permanentnego-brwi/",
    "featured": true
  },
  {
    "number": "02",
    "category": "Gojenie PMU",
    "title": "Jak goją się brwi permanentne?",
    "text": "Etapy gojenia dzień po dniu, kolor po zabiegu, łuszczenie, strupki i moment, w którym można ocenić pigment.",
    "href": "/poradnik/jak-goja-sie-brwi-permanentne/",
    "featured": false
  },
  {
    "number": "03",
    "category": "Pielęgnacja po PMU",
    "title": "Czego nie wolno po makijażu permanentnym brwi?",
    "text": "Mycie brwi, smarowanie, strupki, sauna, basen, słońce i najważniejsze zasady pielęgnacji po pigmentacji.",
    "href": "/poradnik/czego-nie-wolno-po-makijazu-permanentnym-brwi/",
    "featured": true
  },
  {
    "number": "04",
    "category": "Silky Hairstroke Brows",
    "title": "Silky Hairstroke Brows — naturalny włos maszynowy",
    "text": "Autorska technika, kierunek włosa, miękkość linii, praca ze skórą i efekt brwi bez ciężkiej ramy.",
    "href": "/poradnik/silky-hairstroke-brows-naturalny-wlos-maszynowy/",
    "featured": false
  },
  {
    "number": "05",
    "category": "Metody brwi PMU",
    "title": "Metody brwi permanentnych — ombre, pudrowe, włoskowe i microblading",
    "text": "Porównanie metod brwi permanentnych i wyjaśnienie, dlaczego technikę dobiera się do skóry, nie do samej nazwy.",
    "href": "/poradnik/metody-brwi-permanentnych-ombre-pudrowe-wloskowe/",
    "featured": false
  },
  {
    "number": "06",
    "category": "Rysunek wstępny",
    "title": "Rysunek wstępny przed makijażem permanentnym",
    "text": "Dlaczego projekt brwi, ust albo kreski jest jednym z najważniejszych etapów przed pigmentacją.",
    "href": "/poradnik/rysunek-wstepny-przed-makijazem-permanentnym/",
    "featured": false
  },
  {
    "number": "07",
    "category": "Usuwanie PMU",
    "title": "Kiedy nie poprawiać starego PMU, tylko najpierw je rozjaśnić?",
    "text": "Stary pigment, zbyt ciemne brwi, chłodny odcień, laser, remover i plan etapowy przed nową pigmentacją.",
    "href": "/poradnik/kiedy-usuwac-stary-makijaz-permanentny/",
    "featured": false
  },
  {
    "number": "08",
    "category": "Nieudany PMU",
    "title": "Nieudany makijaż permanentny brwi — co zrobić?",
    "text": "Kiedy korygować, kiedy rozjaśniać, czego nie robić domowymi sposobami i jak zaplanować bezpieczną poprawę.",
    "href": "/poradnik/nieudany-makijaz-permanentny-brwi-co-zrobic/",
    "featured": true
  },
  {
    "number": "09",
    "category": "Usta permanentne",
    "title": "Makijaż permanentny ust — jak wybrać kolor?",
    "text": "Naturalne odświeżenie czerwieni wargowej, dobór pigmentu, opryszczka, gojenie i pielęgnacja po zabiegu.",
    "href": "/poradnik/makijaz-permanentny-ust-jak-wybrac-kolor/",
    "featured": false
  },
  {
    "number": "10",
    "category": "Gojenie ust",
    "title": "Makijaż permanentny ust — gojenie dzień po dniu",
    "text": "Etapy gojenia ust, pielęgnacja, mycie zębów, suchość, złuszczanie i ocena koloru po wygojeniu.",
    "href": "/poradnik/makijaz-permanentny-ust-gojenie-dzien-po-dniu/",
    "featured": false
  },
  {
    "number": "11",
    "category": "Opryszczka i PMU ust",
    "title": "Opryszczka a makijaż permanentny ust",
    "text": "Kiedy przełożyć zabieg, co powiedzieć przed wizytą i dlaczego profilaktykę lekową ustala się z lekarzem.",
    "href": "/poradnik/opryszczka-a-makijaz-permanentny-ust/",
    "featured": false
  },
  {
    "number": "12",
    "category": "Kreski permanentne",
    "title": "Kreska permanentna — jak wybrać rodzaj?",
    "text": "Zagęszczenie linii rzęs, kreska górna, dolna, dekoracyjna i decyzja dopasowana do budowy oka.",
    "href": "/poradnik/kreska-permanentna-jak-wybrac-rodzaj/",
    "featured": false
  },
  {
    "number": "13",
    "category": "Opadająca powieka",
    "title": "Kreska permanentna przy opadającej powiece",
    "text": "Kiedy wybrać zagęszczenie linii rzęs, kiedy unikać ciężkiej kreski i jak dobrać efekt do oka.",
    "href": "/poradnik/kreska-permanentna-przy-opadajacej-powiece/",
    "featured": false
  },
  {
    "number": "14",
    "category": "Szkolenia PMU",
    "title": "Jak wybrać szkolenie PMU?",
    "text": "Rysunek wstępny, technika włosa, praca ze skórą, praktyka, Long-Time-Liner® i świadomy rozwój linergistki.",
    "href": "/poradnik/jak-wybrac-szkolenie-pmu/",
    "featured": false
  }
];

const situationCards = [
  {
    "number": "01",
    "title": "Przed pierwszym zabiegiem",
    "text": "Przygotowanie skóry, przeciwwskazania, rysunek wstępny, wybór metody i świadoma decyzja."
  },
  {
    "number": "02",
    "title": "W czasie gojenia",
    "text": "Gojenie brwi i ust, mycie, smarowanie, strupki, łuszczenie, pielęgnacja oraz moment oceny efektu."
  },
  {
    "number": "03",
    "title": "Przy starym lub nieudanym PMU",
    "text": "Korekta, rozjaśnianie, laser, remover, zbyt ciemny pigment i decyzja, kiedy nie przykrywać problemu."
  },
  {
    "number": "04",
    "title": "Przy kreskach i powiece",
    "text": "Zagęszczenie linii rzęs, kreska dekoracyjna, opadająca powieka i dobór efektu do anatomii oka."
  }
];

const categoryCards = [
  {
    "number": "01",
    "label": "Brwi",
    "title": "Brwi permanentne",
    "text": "Przygotowanie, metody, gojenie, pielęgnacja, Silky Hairstroke Brows i korekta starego pigmentu.",
    "href": "/makijaz-permanentny-brwi/"
  },
  {
    "number": "02",
    "label": "Usta",
    "title": "Makijaż permanentny ust",
    "text": "Kolor, gojenie, opryszczka, pielęgnacja i naturalne odświeżenie czerwieni wargowej.",
    "href": "/makijaz-permanentny-ust/"
  },
  {
    "number": "03",
    "label": "Kreski",
    "title": "Makijaż permanentny oczu",
    "text": "Zagęszczenie linii rzęs, kreska dekoracyjna, opadająca powieka i analiza oka.",
    "href": "/makijaz-permanentny-oczu/"
  },
  {
    "number": "04",
    "label": "Usuwanie",
    "title": "Usuwanie i korekta PMU",
    "text": "Stary pigment, laser, remover, rozjaśnianie i etapowy plan korekty.",
    "href": "/usuwanie-makijazu-permanentnego/"
  }
];

const faqItems = [
  {
    "question": "Od którego poradnika najlepiej zacząć?",
    "answer": "Jeśli planujesz pierwszy zabieg, zacznij od przygotowania do makijażu permanentnego brwi. Jeśli jesteś po zabiegu, wybierz temat o gojeniu albo pielęgnacji. Przy starym lub nieudanym PMU zacznij od tekstu o rozjaśnianiu pigmentu."
  },
  {
    "question": "Czy poradnik dotyczy tylko brwi permanentnych?",
    "answer": "Nie. Poradnik obejmuje brwi, usta, kreski, gojenie, pielęgnację po zabiegu, opryszczkę, metody brwi, usuwanie starego PMU oraz szkolenia PMU."
  },
  {
    "question": "Czy makijaż permanentny może wyglądać naturalnie?",
    "answer": "Tak, ale naturalny efekt zależy od skóry, rysunku wstępnego, techniki, pigmentu, doświadczenia linergistki i tego, jak efekt wygoi się po zabiegu."
  },
  {
    "question": "Co zrobić, jeśli mam stary makijaż permanentny?",
    "answer": "Nie zawsze warto od razu przykrywać stary pigment. Przy zbyt ciemnym, chłodnym lub nierównym PMU bezpieczniejszym pierwszym krokiem może być rozjaśnianie laserem albo removerem."
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${pageUrl}#collection`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: { "@id": "https://permanentnybielsko.com/#website" },
    about: { "@id": "https://permanentnybielsko.com/#localbusiness" },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${pageUrl}#articles`,
    name: "Poradniki PMU Bogusława Herda",
    itemListElement: articleCards.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      url: `https://permanentnybielsko.com${item.href}`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/poradnik/"
  structuredData={structuredData}
>
  <div class="guide-page">
    <Header />

    <main>
      <section class="guide-hero">
        <div class="container guide-hero-grid">
          <div class="guide-hero-copy">
            <p class="section-kicker">Poradnik PMU</p>
            <h1><span>Poradnik PMU</span> dla osób, które chcą podjąć spokojną i świadomą decyzję.</h1>
            <p class="guide-lead">
              Zanim zdecydujesz się na makijaż permanentny brwi, ust, kresek albo korektę starej pigmentacji,
              warto wiedzieć, co naprawdę wpływa na efekt: skóra, rysunek wstępny, technika, pigment,
              gojenie, pielęgnacja po zabiegu i spokojna kwalifikacja.
            </p>
            <p class="guide-lead guide-lead-small">
              Ten poradnik porządkuje najważniejsze pytania przed wizytą i po zabiegu: jak przygotować się do PMU,
              jak wygląda gojenie brwi i ust, czego nie wolno po zabiegu, co zrobić przy opryszczce,
              jak dobrać metodę brwi, jaka kreska pasuje do oka i kiedy starego pigmentu nie warto przykrywać kolejną pigmentacją.
            </p>
            <div class="guide-actions">
              <a class="button-primary" href="#poradniki-pmu">Zobacz poradniki</a>
              <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę przez Booksy</a>
            </div>
          </div>

          <aside class="guide-hero-card">
            <span class="guide-big-mark" aria-hidden="true">PMU</span>
            <div>
              <p class="section-kicker section-kicker-light">Centrum wiedzy</p>
              <h2>Jedno miejsce na pytania, które warto zadać przed zabiegiem.</h2>
              <p>Brwi, usta, kreski, gojenie, pielęgnacja, usuwanie PMU i szkolenia — opisane spokojnie, po ludzku i z perspektywy praktyki gabinetowej.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="guide-proof-section">
        <div class="container guide-proof-grid">
          <div><strong>Brwi</strong><span>przygotowanie, metody i gojenie</span></div>
          <div><strong>Usta</strong><span>kolor, opryszczka i pielęgnacja</span></div>
          <div><strong>Kreski</strong><span>zagęszczenie rzęs i analiza powieki</span></div>
          <div><strong>Usuwanie</strong><span>laser, remover i plan etapowy</span></div>
        </div>
      </section>

      <section class="guide-situation-section">
        <div class="container guide-situation-grid">
          <div class="guide-situation-copy">
            <p class="section-kicker">Najczęstsze sytuacje</p>
            <h2>Jedno pytanie zwykle prowadzi do kolejnego.</h2>
            <p>Jedna osoba chce wiedzieć, czy brwi permanentne będą wyglądały naturalnie. Druga martwi się strupkami, myciem albo smarowaniem po zabiegu. Ktoś inny ma stary, zbyt ciemny pigment i nie wie, czy można go poprawić, czy najpierw trzeba go rozjaśnić.</p>
          </div>

          <div class="guide-situation-list">
            {situationCards.map((item) => (
              <article class="guide-situation-item">
                <span>{item.number}</span>
                <div>
                  <strong>{item.title}</strong>
                  <p>{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-articles-section" id="poradniki-pmu">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Najważniejsze poradniki PMU</p>
            <h2>Wybierz temat, który najlepiej pasuje do Twojej sytuacji.</h2>
            <p>Każdy poradnik prowadzi przez konkretny problem: przygotowanie do zabiegu, gojenie i pielęgnację, metody brwi, opryszczkę, kreski, opadającą powiekę, usuwanie starego PMU albo wybór szkolenia PMU.</p>
          </div>

          <div class="guide-article-grid">
            {articleCards.map((article) => (
              <a class:list={["guide-article-card", { "guide-article-card--strong": article.featured }]} href={article.href}>
                <span class="guide-article-number">{article.number}</span>
                <p class="guide-article-category">{article.category}</p>
                <h3>{article.title}</h3>
                <p>{article.text}</p>
                <strong>Czytaj poradnik</strong>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-categories-section">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Oferta i tematy powiązane</p>
            <h2>Poradnik prowadzi dalej do konkretnych usług i decyzji.</h2>
            <p>Po przeczytaniu poradnika możesz przejść do pełnego opisu zabiegu, metody pracy, usuwania PMU albo szkoleń.</p>
          </div>

          <div class="guide-category-grid">
            {categoryCards.map((item) => (
              <a class="guide-category-card" href={item.href}>
                <span>{item.number}</span>
                <p>{item.label}</p>
                <h3>{item.title}</h3>
                <em>{item.text}</em>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-faq-section">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Od czego zacząć w poradniku PMU?</h2>
          </div>

          <div class="guide-faq-grid">
            {faqItems.map((item) => (
              <article class="guide-faq-card">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-final-cta">
        <div class="container guide-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Nie wiesz, od którego tematu zacząć?</h2>
          <p>Jeśli planujesz pierwszy zabieg, zacznij od przygotowania do makijażu permanentnego brwi. Jeśli jesteś już po pigmentacji, wybierz temat o gojeniu albo pielęgnacji. A jeśli masz stary makijaż permanentny, sprawdź najpierw, kiedy korekta jest możliwa, a kiedy lepiej rozpocząć od rozjaśniania pigmentu.</p>
          <a class="button-primary" href="/poradnik/jak-przygotowac-sie-do-makijazu-permanentnego-brwi/">Zacznij od przygotowania do brwi</a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .guide-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.12), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.12), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .guide-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    padding: 0 13px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .guide-page .section-kicker-light {
    border-color: rgba(255,255,255,0.24);
    background: rgba(255,255,255,0.14);
    color: #fff;
    -webkit-text-fill-color: #fff;
  }

  .guide-hero {
    padding: 150px 0 88px;
  }

  .guide-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: 24px;
    align-items: stretch;
  }

  .guide-hero-copy,
  .guide-hero-card,
  .guide-situation-copy,
  .guide-situation-list,
  .guide-article-card,
  .guide-category-card,
  .guide-faq-card,
  .guide-final-card {
    border: 1px solid rgba(183, 101, 118, 0.16);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .guide-hero-copy {
    min-height: 620px;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    background: rgba(255,255,255,0.78);
  }

  .guide-hero-copy h1 {
    max-width: 1080px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(3.05rem, 5.45vw, 6.35rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .guide-hero-copy h1 span {
    background: linear-gradient(120deg, #0d6a67 0%, #0f7773 22%, #1aa5a0 46%, #74e0d7 68%, #138a86 86%, #0d6a67 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .guide-lead {
    max-width: 840px;
    margin: 28px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: 1.12rem;
    line-height: 1.68;
  }

  .guide-lead-small {
    margin-top: 14px;
    font-size: 1.02rem;
  }

  .guide-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .guide-hero-card {
    position: relative;
    display: flex;
    min-height: 620px;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 14%, rgba(255,255,255,0.34), transparent 13rem),
      linear-gradient(145deg, #74e0d7 0%, #38bbb5 26%, #159a96 58%, #0f7773 100%);
  }

  .guide-big-mark {
    position: absolute;
    top: clamp(24px, 3vw, 46px);
    left: clamp(28px, 4vw, 58px);
    color: rgba(255,255,255,0.18);
    font-size: clamp(5.6rem, 9vw, 11rem);
    font-weight: 850;
    line-height: 0.78;
    letter-spacing: -0.085em;
  }

  .guide-hero-card > div {
    position: relative;
    z-index: 2;
  }

  .guide-hero-card h2,
  .guide-situation-copy h2,
  .guide-section-heading h2,
  .guide-final-card h2 {
    margin: 0;
    font-size: clamp(2.35rem, 4vw, 4.45rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

