const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${pageUrl}#collection`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: {
      "@id": "https://permanentnybielsko.com/#website",
    },
    about: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${pageUrl}#article-plan`,
    name: "Najczęściej szukane tematy poradnika PMU",
    itemListElement: mainArticleIdeas.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: guideFaqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/poradnik/"
  structuredData={structuredData}
>
  <div class="guide-page">
    <Header />

    <main>
      <section class="guide-hero">
        <div class="guide-orb guide-orb-one"></div>
        <div class="guide-orb guide-orb-two"></div>

        <div class="container guide-hero-grid">
          <div class="guide-hero-copy">
            <p class="section-kicker">Poradnik PMU</p>

            <h1>
              <span class="pmu-hero-turquoise-text">Poradnik PMU</span> dla osób, które chcą podjąć spokojną i świadomą decyzję.
            </h1>

            <p class="guide-lead">
              Zanim zdecydujesz się na makijaż permanentny brwi, ust, kresek albo korektę starej pigmentacji,
              warto wiedzieć, co naprawdę wpływa na efekt: skóra, rysunek wstępny, technika, pigment,
              gojenie, pielęgnacja po zabiegu i spokojna kwalifikacja.
            </p>

            <p class="guide-lead guide-lead-small">
              Tutaj znajdziesz odpowiedzi na pytania, które najczęściej pojawiają się przed wizytą i po zabiegu:
              jak przygotować się do PMU, kiedy można myć brwi, czym je smarować, jak wygląda gojenie,
              co zrobić przy opryszczce ust i kiedy starego pigmentu nie warto przykrywać kolejną pigmentacją.
            </p>

            <div class="guide-actions">
              <a class="button-primary" href="#plan-artykulow">
                Zobacz najważniejsze tematy
              </a>

              <a class="button-secondary" href="/makijaz-permanentny-bielsko/">
                Wróć do oferty PMU
              </a>
            </div>
          </div>

          <aside class="guide-hero-card guide-shine-card" aria-label="Poradnik PMU">
            <span class="guide-big-mark" aria-hidden="true">PMU</span>

            <div class="guide-hero-card-content">
              <p class="section-kicker section-kicker-light">Ekspercki hub</p>
              <h2>Jedno miejsce na pytania, które warto zadać przed zabiegiem.</h2>
              <p>
                Brwi, usta, kreski, gojenie, dopigmentowanie, usuwanie PMU i szkolenia — wszystko opisane spokojnie, po ludzku i z perspektywy praktyki gabinetowej.
              </p>
            </div>
          </aside>
        </div>
      </section>

      <section class="guide-proof-section" aria-label="Zakres poradnika PMU">
        <div class="container guide-proof-grid">
          <div>
            <strong>PMU</strong>
            <span>brwi, usta, kreski i naturalny efekt</span>
          </div>

          <div>
            <strong>Gojenie</strong>
            <span>pielęgnacja, dopigmentowanie i realne oczekiwania</span>
          </div>

          <div>
            <strong>Usuwanie</strong>
            <span>laser, remover, korekta i plan etapowy</span>
          </div>

          <div>
            <strong>Szkolenia</strong>
            <span>technika, rysunek wstępny i standard pracy</span>
          </div>
        </div>
      </section>


      <section class="guide-intent-section">
        <div class="container guide-intent-grid">
          <div class="guide-intent-copy">
            <p class="section-kicker">Najczęstsze sytuacje</p>
            <h2>Jedno pytanie zwykle prowadzi do kolejnego: przed zabiegiem, w czasie gojenia albo przy korekcie.</h2>
            <p>
              Jedna osoba chce wiedzieć, czy makijaż permanentny brwi będzie wyglądał naturalnie.
              Druga martwi się gojeniem, strupkami albo tym, kiedy można umyć brwi po zabiegu.
              Ktoś inny ma stary, zbyt ciemny pigment i nie wie, czy można go poprawić,
              czy najpierw trzeba go rozjaśnić.
            </p>
            <p>
              Dlatego poradnik prowadzi przez konkretne sytuacje krok po kroku.
              Pomaga zrozumieć, kiedy potrzebna jest konsultacja, kiedy wystarczy spokojnie poczekać
              na wygojenie, kiedy warto zaplanować dopigmentowanie, a kiedy przy starym PMU
              bezpieczniejszy będzie laser, remover albo plan etapowy.
            </p>
          </div>

          <div class="guide-intent-list">
            {searchIntentGroups.map((item) => (
              <article class="guide-intent-item">
                <span>{item.number}</span>
                <div>
                  <strong>{item.title}</strong>
                  <p>{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-categories-section">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Kategorie poradnika</p>
            <h2>Wybierz temat, który najlepiej pasuje do Twojej sytuacji.</h2>
            <p>
              Makijaż permanentny to nie tylko sam zabieg. To także przygotowanie, rysunek wstępny,
              gojenie, pielęgnacja po pigmentacji, dopigmentowanie, korekta albo decyzja,
              czy stary pigment można przykryć, czy najpierw trzeba go rozjaśnić.
            </p>
          </div>
        </div>

        <div class="guide-category-viewport" aria-label="Kategorie poradnika PMU">
          <div class="guide-category-track">
            {guideCategories.map((item) => (
              <a
                class:list={["guide-category-card", { "guide-category-card--strong": item.featured }]}
                href={item.href}
              >
                <span class="guide-category-number">{item.number}</span>
                <p class="guide-category-label">{item.label}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-articles-section" id="plan-artykulow">
        <div class="container guide-articles-heading-row">
          <div class="guide-section-heading">
            <p class="section-kicker">Najczęściej szukane tematy</p>
            <h2>Tu zaczynają się pytania, które naprawdę wpisują klientki przed wizytą i po zabiegu.</h2>
            <p>
              Przygotowanie do makijażu permanentnego brwi, gojenie brwi dzień po dniu, mycie i smarowanie po zabiegu,
              opryszczka przy pigmentacji ust, kreski permanentne, usuwanie starego PMU, przeciwwskazania,
              cena oraz wybór dobrej linergistki — to tematy, które będą prowadzić cały poradnik.
            </p>
          </div>

          <div class="guide-articles-controls" aria-label="Przewijanie planu artykułów">
            <button
              class="guide-articles-arrow"
              type="button"
              aria-label="Przewiń artykuły w lewo"
              onclick="document.querySelector('[data-guide-article-track]')?.scrollBy({ left: -560, behavior: 'smooth' })"
            >
              ←
            </button>

            <button
              class="guide-articles-arrow"
              type="button"
              aria-label="Przewiń artykuły w prawo"
              onclick="document.querySelector('[data-guide-article-track]')?.scrollBy({ left: 560, behavior: 'smooth' })"
            >
              →
            </button>
          </div>
        </div>

        <div class="guide-article-viewport" data-guide-article-track aria-label="Planowane artykuły poradnika PMU">
          <div class="guide-article-track">
