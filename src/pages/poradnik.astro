---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/poradnik/";
const pageTitle = "Poradnik PMU Bielsko-Biała | Makijaż permanentny brwi, ust i oczu";
const pageDescription =
  "Poradnik PMU Bogusława Herda: makijaż permanentny brwi, ust i oczu, gojenie, rysunek wstępny, dopigmentowanie, usuwanie PMU i szkolenia PMU.";

const articleCards = [
  {
    "number": "01",
    "category": "Brwi permanentne",
    "title": "Jak przygotować się do makijażu permanentnego brwi?",
    "text": "Konsultacja, przeciwwskazania, skóra przed zabiegiem, rysunek wstępny, kawa, alkohol i naturalny efekt bez przerysowania.",
    "href": "/poradnik/jak-przygotowac-sie-do-makijazu-permanentnego-brwi/",
    "featured": true
  },
  {
    "number": "02",
    "category": "Gojenie PMU",
    "title": "Jak goją się brwi permanentne?",
    "text": "Kolor po zabiegu, łuszczenie, strupki, jaśniejszy efekt po wygojeniu i moment, w którym można spokojnie ocenić pigment.",
    "href": "/poradnik/jak-goja-sie-brwi-permanentne/",
    "featured": false
  },
  {
    "number": "03",
    "category": "Silky Hairstroke Brows",
    "title": "Silky Hairstroke Brows — naturalny włos maszynowy",
    "text": "Autorska technika, kierunek włosa, miękkość linii, praca ze skórą i efekt brwi bez ciężkiej ramy.",
    "href": "/poradnik/silky-hairstroke-brows-naturalny-wlos-maszynowy/",
    "featured": false
  },
  {
    "number": "04",
    "category": "Rysunek wstępny",
    "title": "Rysunek wstępny przed makijażem permanentnym",
    "text": "Dlaczego projekt brwi, ust albo kreski jest jednym z najważniejszych etapów przed pigmentacją.",
    "href": "/poradnik/rysunek-wstepny-przed-makijazem-permanentnym/",
    "featured": false
  },
  {
    "number": "05",
    "category": "Usuwanie PMU",
    "title": "Kiedy nie poprawiać starego PMU, tylko najpierw je rozjaśnić?",
    "text": "Stary pigment, zbyt ciemne brwi, chłodny odcień, laser, remover i plan etapowy przed nową pigmentacją.",
    "href": "/poradnik/kiedy-usuwac-stary-makijaz-permanentny/",
    "featured": false
  },
  {
    "number": "06",
    "category": "Usta permanentne",
    "title": "Makijaż permanentny ust — jak wybrać kolor?",
    "text": "Naturalne odświeżenie czerwieni wargowej, dobór pigmentu, opryszczka, gojenie i pielęgnacja po zabiegu.",
    "href": "/poradnik/makijaz-permanentny-ust-jak-wybrac-kolor/",
    "featured": false
  },
  {
    "number": "07",
    "category": "Kreski permanentne",
    "title": "Kreska permanentna — jak wybrać rodzaj?",
    "text": "Zagęszczenie linii rzęs, kreska górna, dolna, dekoracyjna i decyzja dopasowana do budowy oka.",
    "href": "/poradnik/kreska-permanentna-jak-wybrac-rodzaj/",
    "featured": false
  },
  {
    "number": "08",
    "category": "Szkolenia PMU",
    "title": "Jak wybrać szkolenie PMU?",
    "text": "Rysunek wstępny, technika włosa, praca ze skórą, praktyka, Long-Time-Liner® i świadomy rozwój linergistki.",
    "href": "/poradnik/jak-wybrac-szkolenie-pmu/",
    "featured": false
  }
];

const situationCards = [
  {
    number: "01",
    title: "Przed pierwszym zabiegiem",
    text: "Dowiesz się, jak przygotować skórę, o czym powiedzieć przed wizytą, czego unikać i dlaczego rysunek wstępny jest tak ważny.",
  },
  {
    number: "02",
    title: "W czasie gojenia",
    text: "Znajdziesz odpowiedzi o kolorze po zabiegu, strupkach, myciu, smarowaniu, pielęgnacji i momencie, w którym można oceniać efekt.",
  },
  {
    number: "03",
    title: "Przy starym PMU",
    text: "Sprawdzisz, kiedy można poprawiać wcześniejszą pigmentację, a kiedy rozsądniej zacząć od rozjaśniania laserem albo removerem.",
  },
  {
    number: "04",
    title: "Dla osób z branży",
    text: "Poradnik prowadzi też przez tematy szkoleniowe: technikę, rysunek, standard pracy, praktykę i świadomy rozwój linergistki.",
  },
];

const categoryCards = [
  {
    number: "01",
    label: "Brwi",
    title: "Brwi permanentne",
    text: "Przygotowanie, metoda włosa, cieniowanie, Silky Hairstroke Brows, gojenie i dopigmentowanie.",
    href: "/makijaz-permanentny-brwi/",
  },
  {
    number: "02",
    label: "Usta",
    title: "Makijaż permanentny ust",
    text: "Kolor, kontur, opryszczka, gojenie, pielęgnacja i naturalne odświeżenie czerwieni wargowej.",
    href: "/makijaz-permanentny-ust/",
  },
  {
    number: "03",
    label: "Kreski",
    title: "Makijaż permanentny oczu",
    text: "Zagęszczenie linii rzęs, kreska dekoracyjna, analiza powieki i subtelne podkreślenie spojrzenia.",
    href: "/makijaz-permanentny-oczu/",
  },
  {
    number: "04",
    label: "Usuwanie",
    title: "Usuwanie i korekta PMU",
    text: "Stary pigment, laser, remover, rozjaśnianie i decyzja, kiedy nie przykrywać problemu nową pigmentacją.",
    href: "/usuwanie-makijazu-permanentnego/",
  },
];

const faqItems = [
  {
    question: "Od którego poradnika najlepiej zacząć?",
    answer:
      "Jeśli planujesz pierwszy zabieg, zacznij od przygotowania do makijażu permanentnego brwi. Jeśli jesteś po zabiegu, wybierz temat o gojeniu. Przy starym PMU najlepiej zacząć od tekstu o rozjaśnianiu pigmentu.",
  },
  {
    question: "Czy poradnik dotyczy tylko brwi permanentnych?",
    answer:
      "Nie. Poradnik obejmuje brwi, usta, kreski, gojenie, dopigmentowanie, przeciwwskazania, usuwanie starego PMU oraz szkolenia makijażu permanentnego.",
  },
  {
    question: "Czy makijaż permanentny może wyglądać naturalnie?",
    answer:
      "Tak, ale naturalny efekt zależy od skóry, rysunku wstępnego, techniki, pigmentu, doświadczenia linergistki i tego, jak efekt wygoi się po zabiegu.",
  },
  {
    question: "Co zrobić, jeśli mam stary makijaż permanentny?",
    answer:
      "Nie zawsze warto od razu przykrywać stary pigment. Przy zbyt ciemnym, chłodnym lub nierównym PMU bezpieczniejszym pierwszym krokiem może być rozjaśnianie laserem albo removerem.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${pageUrl}#collection`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: {
      "@id": "https://permanentnybielsko.com/#website",
    },
    about: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${pageUrl}#articles`,
    name: "Poradniki PMU Bogusława Herda",
    itemListElement: articleCards.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      url: `https://permanentnybielsko.com${item.href}`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/poradnik/"
  structuredData={structuredData}
>
  <div class="guide-page">
    <Header />

    <main>
      <section class="guide-hero">
        <div class="guide-orb guide-orb-one"></div>
        <div class="guide-orb guide-orb-two"></div>

        <div class="container guide-hero-grid">
          <div class="guide-hero-copy">
            <p class="section-kicker">Poradnik PMU</p>

            <h1>
              <span class="pmu-hero-turquoise-text">Poradnik PMU</span> dla osób, które chcą podjąć spokojną i świadomą decyzję.
            </h1>

            <p class="guide-lead">
              Zanim zdecydujesz się na makijaż permanentny brwi, ust, kresek albo korektę starej pigmentacji,
              warto wiedzieć, co naprawdę wpływa na efekt: skóra, rysunek wstępny, technika, pigment,
              gojenie, pielęgnacja po zabiegu i spokojna kwalifikacja.
            </p>

            <p class="guide-lead guide-lead-small">
              Ten poradnik porządkuje najważniejsze pytania przed wizytą i po zabiegu:
              jak przygotować się do PMU, jak wygląda gojenie, kiedy potrzebne jest dopigmentowanie,
              jak dobrać kolor ust, jaka kreska pasuje do oka i kiedy starego pigmentu nie warto przykrywać kolejną pigmentacją.
            </p>

            <div class="guide-actions">
              <a class="button-primary" href="#poradniki-pmu">
                Zobacz poradniki
              </a>

              <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów wizytę przez Booksy
              </a>
            </div>
          </div>

          <aside class="guide-hero-card guide-shine-card" aria-label="Poradnik PMU">
            <span class="guide-big-mark" aria-hidden="true">PMU</span>

            <div class="guide-hero-card-content">
              <p class="section-kicker section-kicker-light">Centrum wiedzy</p>
              <h2>Jedno miejsce na pytania, które warto zadać przed zabiegiem.</h2>
              <p>
                Brwi, usta, kreski, gojenie, dopigmentowanie, usuwanie PMU i szkolenia —
                wszystko opisane spokojnie, po ludzku i z perspektywy praktyki gabinetowej.
              </p>
            </div>
          </aside>
        </div>
      </section>

      <section class="guide-proof-section" aria-label="Zakres poradnika PMU">
        <div class="container guide-proof-grid">
          <div>
            <strong>Brwi</strong>
            <span>przygotowanie, metody i gojenie</span>
          </div>

          <div>
            <strong>Usta</strong>
            <span>kolor, opryszczka i pielęgnacja</span>
          </div>

          <div>
            <strong>Kreski</strong>
            <span>zagęszczenie rzęs i analiza powieki</span>
          </div>

          <div>
            <strong>Usuwanie</strong>
            <span>laser, remover i plan etapowy</span>
          </div>
        </div>
      </section>

      <section class="guide-situation-section">
        <div class="container guide-situation-grid">
          <div class="guide-situation-copy">
            <p class="section-kicker">Najczęstsze sytuacje</p>
            <h2>Jedno pytanie zwykle prowadzi do kolejnego: przed zabiegiem, w czasie gojenia albo przy korekcie.</h2>
            <p>
              Jedna osoba chce wiedzieć, czy brwi permanentne będą wyglądały naturalnie.
              Druga martwi się strupkami, myciem albo smarowaniem po zabiegu.
              Ktoś inny ma stary, zbyt ciemny pigment i nie wie, czy można go poprawić,
              czy najpierw trzeba go rozjaśnić.
            </p>
          </div>

          <div class="guide-situation-list">
            {situationCards.map((item) => (
              <article class="guide-situation-item">
                <span>{item.number}</span>
                <div>
                  <strong>{item.title}</strong>
                  <p>{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-articles-section" id="poradniki-pmu">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Najważniejsze poradniki PMU</p>
            <h2>Wybierz temat, który najlepiej pasuje do Twojej sytuacji.</h2>
            <p>
              Każdy poradnik prowadzi przez konkretny problem: przygotowanie do zabiegu,
              gojenie brwi, naturalny włos maszynowy, rysunek wstępny, rozjaśnianie starego PMU,
              kolor ust, kreski permanentne albo wybór szkolenia PMU.
            </p>
          </div>

          <div class="guide-article-grid">
            {articleCards.map((article) => (
              <a
                class:list={["guide-article-card", { "guide-article-card--strong": article.featured }]}
                href={article.href}
              >
                <span class="guide-article-number">{article.number}</span>
                <p class="guide-article-category">{article.category}</p>
                <h3>{article.title}</h3>
                <p>{article.text}</p>
                <strong>Czytaj poradnik</strong>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-categories-section">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Oferta i tematy powiązane</p>
            <h2>Poradnik prowadzi dalej do konkretnych usług i decyzji.</h2>
            <p>
              Jeśli po przeczytaniu poradnika chcesz zobaczyć pełny opis zabiegu, metody pracy,
              zakres usuwania PMU albo szkolenia — przejdź do odpowiedniej podstrony.
            </p>
          </div>

          <div class="guide-category-grid">
            {categoryCards.map((item) => (
              <a class="guide-category-card" href={item.href}>
                <span>{item.number}</span>
                <p>{item.label}</p>
                <h3>{item.title}</h3>
                <em>{item.text}</em>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-faq-section">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Od czego zacząć w poradniku PMU?</h2>
          </div>

          <div class="guide-faq-grid">
            {faqItems.map((item) => (
              <article class="guide-faq-card">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-final-cta">
        <div class="container guide-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Nie wiesz, od którego tematu zacząć?</h2>
          <p>
            Jeśli planujesz pierwszy zabieg, zacznij od przygotowania do makijażu permanentnego brwi.
            Jeśli jesteś już po pigmentacji, wybierz temat o gojeniu.
            A jeśli masz stary makijaż permanentny, sprawdź najpierw, kiedy korekta jest możliwa,
            a kiedy lepiej rozpocząć od rozjaśniania pigmentu.
          </p>

          <a class="button-primary" href="/poradnik/jak-przygotowac-sie-do-makijazu-permanentnego-brwi/">
            Zacznij od przygotowania do brwi
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .guide-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.12), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.12), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .guide-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    padding: 0 13px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .guide-page .section-kicker-light {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
  }

  .guide-hero {
    position: relative;
    padding: 150px 0 88px;
    overflow: hidden;
  }

  .guide-orb {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .guide-orb-one {
    right: -12rem;
    top: 4rem;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.2), transparent 68%);
  }

  .guide-orb-two {
    left: -10rem;
    bottom: -12rem;
    width: 38rem;
    height: 38rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.18), transparent 68%);
  }

  .guide-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.98fr);
    gap: 24px;
    align-items: stretch;
  }

  .guide-hero-copy,
  .guide-hero-card,
  .guide-situation-copy,
  .guide-situation-list,
  .guide-article-card,
  .guide-category-card,
  .guide-faq-card,
  .guide-final-card {
    border: 1px solid rgba(183, 101, 118, 0.16);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .guide-hero-copy {
    display: flex;
    min-height: 640px;
    flex-direction: column;
    justify-content: center;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    background:
      radial-gradient(circle at 92% 14%, rgba(56, 187, 181, 0.10), transparent 16rem),
      rgba(255, 255, 255, 0.78);
  }

  .guide-hero-copy h1 {
    max-width: 1080px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(3.05rem, 5.45vw, 6.35rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .pmu-hero-turquoise-text {
    display: inline;
    color: #0f7773;
    background:
      linear-gradient(
        120deg,
        #0d6a67 0%,
        #0f7773 22%,
        #1aa5a0 46%,
        #74e0d7 68%,
        #138a86 86%,
        #0d6a67 100%
      );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .guide-lead {
    max-width: 820px;
    margin: 28px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: 1.12rem;
    line-height: 1.68;
  }

  .guide-lead-small {
    margin-top: 14px;
    font-size: 1.02rem;
  }

  .guide-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .guide-hero-card {
    position: relative;
    display: flex;
    min-height: 640px;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.34), transparent 13rem),
      radial-gradient(circle at 86% 86%, rgba(13, 106, 103, 0.28), transparent 20rem),
      linear-gradient(145deg, #74e0d7 0%, #38bbb5 26%, #159a96 58%, #0f7773 100%);
    box-shadow: 0 28px 76px rgba(35, 156, 150, 0.24);
  }

  .guide-shine-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.06) 22%, rgba(255, 255, 255, 0.28) 47%, rgba(255, 255, 255, 0.06) 72%, transparent 100%);
    transform: translateX(-72%);
    animation: guide-panel-shine 8s ease-in-out infinite;
    pointer-events: none;
  }

  .guide-big-mark {
    position: absolute;
    top: clamp(24px, 3vw, 46px);
    left: clamp(28px, 4vw, 58px);
    z-index: 1;
    color: rgba(255, 255, 255, 0.18);
    font-size: clamp(5.6rem, 9vw, 11rem);
    font-weight: 850;
    line-height: 0.78;
    letter-spacing: -0.085em;
    pointer-events: none;
  }

  .guide-hero-card-content {
    position: relative;
    z-index: 2;
  }

  .guide-hero-card h2 {
    max-width: 680px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.2rem, 3.8vw, 4.55rem);
    font-weight: 780;
    line-height: 0.98;
    letter-spacing: -0.078em;
    text-shadow: 0 16px 42px rgba(5, 53, 51, 0.24);
  }

  .guide-hero-card p:not(.section-kicker) {
    max-width: 650px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.90);
    font-size: 1.06rem;
    line-height: 1.66;
