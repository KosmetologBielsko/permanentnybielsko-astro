<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/poradnik/"
  structuredData={structuredData}
>
  <div class="guide-page">
    <Header />

    <main>
      <section class="guide-hero">
        <div class="container guide-hero-grid">
          <div class="guide-hero-copy">
            <p class="section-kicker">Poradnik PMU</p>
            <h1><span>Poradnik PMU</span> dla osób, które chcą podjąć spokojną i świadomą decyzję.</h1>
            <p class="guide-lead">
              Zanim zdecydujesz się na makijaż permanentny brwi, ust, kresek albo korektę starej pigmentacji,
              warto wiedzieć, co naprawdę wpływa na efekt: skóra, rysunek wstępny, technika, pigment,
              gojenie, pielęgnacja po zabiegu, cena i spokojna kwalifikacja.
            </p>
            <p class="guide-lead guide-lead-small">
              Ten poradnik porządkuje najważniejsze pytania przed wizytą i po zabiegu: ile kosztuje PMU,
              jak przygotować się do zabiegu, jak wygląda gojenie brwi i ust, czego nie wolno po zabiegu,
              co zrobić przy opryszczce, jak dobrać metodę brwi, jaka kreska pasuje do oka i kiedy starego pigmentu nie warto przykrywać kolejną pigmentacją.
            </p>
            <div class="guide-actions">
              <a class="button-primary" href="#poradniki-pmu">Zobacz poradniki</a>
              <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę przez Booksy</a>
            </div>
          </div>

          <aside class="guide-hero-card">
            <span class="guide-big-mark" aria-hidden="true">PMU</span>
            <div>
              <p class="section-kicker section-kicker-light">Centrum wiedzy</p>
              <h2>Jedno miejsce na pytania, które warto zadać przed zabiegiem.</h2>
              <p>Brwi, usta, kreski, ceny, gojenie, pielęgnacja, usuwanie PMU i szkolenia — opisane spokojnie, po ludzku i z perspektywy praktyki gabinetowej.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="guide-proof-section">
        <div class="container guide-proof-grid">
          <div><strong>Ceny</strong><span>brwi, kreski, odświeżenia i szkolenia</span></div>
          <div><strong>Brwi</strong><span>przygotowanie, metody i gojenie</span></div>
          <div><strong>Usta</strong><span>kolor, opryszczka i pielęgnacja</span></div>
          <div><strong>Kreski</strong><span>zagęszczenie rzęs i analiza powieki</span></div>
        </div>
      </section>

      <section class="guide-situation-section">
        <div class="container guide-situation-grid">
          <div class="guide-situation-copy">
            <p class="section-kicker">Najczęstsze sytuacje</p>
            <h2>Jedno pytanie zwykle prowadzi do kolejnego.</h2>
            <p>Jedna osoba chce wiedzieć, czy brwi permanentne będą wyglądały naturalnie. Druga pyta o cenę, korektę albo odświeżenie. Ktoś inny martwi się strupkami, myciem, smarowaniem albo starym, zbyt ciemnym pigmentem.</p>
          </div>

          <div class="guide-situation-list">
            {situationCards.map((item) => (
              <article class="guide-situation-item">
                <span>{item.number}</span>
                <div>
                  <strong>{item.title}</strong>
                  <p>{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-quick-section" aria-labelledby="szybki-spis-tresci">
        <div class="container guide-quick-card">
          <div>
            <p class="section-kicker">Szybki spis treści</p>
            <h2 id="szybki-spis-tresci">Wybierz kategorię poradnika.</h2>
            <p>Na telefonie możesz przesuwać wpisy palcem albo używać strzałek. Na większym ekranie strzałki pomagają szybko przechodzić między kartami w każdej kategorii.</p>
          </div>
          <nav class="guide-topic-strip" aria-label="Kategorie poradnika PMU">
            {categorySections.map((section) => (
              <a href={`#${section.id}`}>{section.label}</a>
            ))}
          </nav>
        </div>
      </section>

      <section class="guide-articles-section" id="poradniki-pmu">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Najważniejsze poradniki PMU</p>
            <h2>Wybierz temat, który najlepiej pasuje do Twojej sytuacji.</h2>
            <p>Wpisy podzieliliśmy na krótkie kategorie: ceny, brwi, gojenie, usta, kreski, korekta i szkolenia. Dzięki temu poradnik nie robi się jedną długą listą, tylko działa jak centrum wiedzy PMU.</p>
          </div>

          <div class="guide-topic-list">
            {articlesByCategory.map((section) => (
              <section class="guide-topic-block" id={section.id} data-guide-slider>
                <div class="guide-topic-heading">
                  <div>
                    <p class="guide-topic-label">{section.label}</p>
                    <h3>{section.title}</h3>
                    <p>{section.text}</p>
                  </div>
                  <div class="guide-slider-controls" aria-hidden="false">
                    <button type="button" class="guide-slider-button" data-slider-prev aria-label={`Przewiń kategorię ${section.label} w lewo`}>
                      ←
                    </button>
                    <button type="button" class="guide-slider-button" data-slider-next aria-label={`Przewiń kategorię ${section.label} w prawo`}>
                      →
                    </button>
                  </div>
                </div>

                <div class="guide-slider-shell">
                  <div class="guide-article-row" data-slider-track>
                    {section.articles.map((article) => (
                      <a class:list={["guide-article-card", { "guide-article-card--strong": article.featured }]} href={article.href}>
                        <span class="guide-article-number">{article.number}</span>
                        <p class="guide-article-category">{article.category}</p>
                        <h3>{article.title}</h3>
                        <p>{article.text}</p>
                        <strong>Czytaj poradnik</strong>
                      </a>
                    ))}
                  </div>
                </div>
              </section>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-categories-section">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Oferta i tematy powiązane</p>
            <h2>Poradnik prowadzi dalej do konkretnych usług i decyzji.</h2>
            <p>Po przeczytaniu poradnika możesz przejść do pełnego opisu zabiegu, metody pracy, usuwania PMU albo szkoleń.</p>
          </div>

          <div class="guide-category-grid">
            {categoryCards.map((item) => (
              <a class="guide-category-card" href={item.href}>
                <span>{item.number}</span>
                <p>{item.label}</p>
                <h3>{item.title}</h3>
                <em>{item.text}</em>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-faq-section">
        <div class="container">
          <div class="guide-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Od czego zacząć w poradniku PMU?</h2>
          </div>

          <div class="guide-faq-grid">
            {faqItems.map((item) => (
              <article class="guide-faq-card">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="guide-final-cta">
        <div class="container guide-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Nie wiesz, od którego tematu zacząć?</h2>
          <p>Jeśli dopiero porównujesz możliwości, zacznij od cennika i poradnika o cenie brwi. Jeśli planujesz pierwszy zabieg, przejdź do przygotowania do makijażu permanentnego brwi. Jeśli jesteś już po pigmentacji, wybierz temat o gojeniu albo pielęgnacji.</p>
          <div class="guide-final-actions">
            <a class="button-primary" href="/poradnik/makijaz-permanentny-brwi-cena/">Zacznij od ceny brwi</a>
            <a class="button-secondary" href="/cennik-makijaz-permanentny/">Zobacz cennik PMU</a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline>
    (() => {
      const sliderSections = document.querySelectorAll("[data-guide-slider]");

      sliderSections.forEach((section) => {
        const track = section.querySelector("[data-slider-track]");
        const previousButton = section.querySelector("[data-slider-prev]");
        const nextButton = section.querySelector("[data-slider-next]");

        if (!track || !previousButton || !nextButton) {
          return;
        }

        const getScrollAmount = () => Math.min(track.clientWidth * 0.86, 760);

        previousButton.addEventListener("click", () => {
          track.scrollBy({ left: -getScrollAmount(), behavior: "smooth" });
        });

        nextButton.addEventListener("click", () => {
          track.scrollBy({ left: getScrollAmount(), behavior: "smooth" });
        });
      });
    })();
  </script>
</Layout>

