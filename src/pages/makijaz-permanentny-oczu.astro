---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/makijaz-permanentny-oczu/";
const pageTitle = "Makijaż permanentny oczu Bielsko-Biała | Kreski permanentne";
const pageDescription =
  "Makijaż permanentny oczu Bielsko-Biała: kreski permanentne, zagęszczenie linii rzęs, subtelne podkreślenie oka i naturalny efekt bez ciężkiej kreski.";

const eyeGalleryImages = Array.from({ length: 12 }, (_, index) => {
  const number = String(index + 1).padStart(2, "0");

  return {
    src: `/images/makijaz-permanentny-oczu-bielsko-biala-efekt-${number}.webp`,
    alt: `Makijaż permanentny oczu Bielsko-Biała — efekt kreski permanentnej ${number}`,
  };
});

const forWhoItems = [
  {
    title: "Jasna linia rzęs",
    text: "gdy oko potrzebuje subtelnego podkreślenia bez efektu mocnej, widocznej kreski",
    image: "/images/01-jasna-linia-rzes.webp",
  },
  {
    title: "Codzienna kreska",
    text: "gdy klientka regularnie maluje linię rzęs i chce skrócić poranną rutynę",
    image: "/images/02-codzienna-kreska.webp",
  },
  {
    title: "Mało wyraziste oko",
    text: "gdy oprawa oka wymaga delikatnego uporządkowania i optycznego zagęszczenia rzęs",
    image: "/images/03-malo-wyraziste-oko.webp",
  },
  {
    title: "Asymetria powiek",
    text: "gdy przebieg kreski trzeba dopasować do różnic między jednym i drugim okiem",
    image: "/images/04-asymetria-powiek.webp",
  },
  {
    title: "Opadająca powieka",
    text: "gdy potrzebna jest szczególnie ostrożna kwalifikacja i bardzo spokojny plan kreski",
    image: "/images/05-opadajaca-powieka.webp",
  },
  {
    title: "Naturalna zmiana",
    text: "gdy celem jest świeższe spojrzenie bez ciężkiego, graficznego efektu",
    image: "/images/06-naturalna-zmiana.webp",
  },
];

const methodItems = [
  {
    title: "Zagęszczenie linii rzęs",
    text: "najsubtelniejszy wariant, który wzmacnia oprawę oka bez efektu klasycznej kreski",
  },
  {
    title: "Kreska górna",
    text: "delikatne lub bardziej widoczne podkreślenie powieki górnej, dopasowane do oka",
  },
  {
    title: "Kreska dekoracyjna",
    text: "bardziej wyrazisty efekt wykonywany tylko wtedy, gdy pozwala na to budowa powieki",
  },
  {
    title: "Korekta kreski",
    text: "indywidualna praca przy starej pigmentacji, nierówności albo zbyt ciężkim efekcie",
  },
  {
    title: "Odświeżenie spojrzenia",
    text: "przywrócenie wyrazistości oku z zachowaniem miękkości i naturalnego charakteru",
  },
];

const processItems = [
  {
    title: "Konsultacja",
    text: "rozmowa o oczekiwaniach, codziennym makijażu, wrażliwości oczu i możliwym efekcie",
  },
  {
    title: "Analiza oka",
    text: "ocena powieki, asymetrii, linii rzęs, opadania skóry i naturalnego kształtu oka",
  },
  {
    title: "Rysunek wstępny",
    text: "omówienie przebiegu kreski, jej długości, grubości i intensywności przed pigmentacją",
  },
  {
    title: "Dobór intensywności",
    text: "ustalenie, czy efekt ma być bardzo subtelny, czy bardziej widoczny",
  },
  {
    title: "Pigmentacja",
    text: "precyzyjna praca przy linii rzęs z kontrolą kształtu, symetrii i reakcji skóry",
  },
  {
    title: "Gojenie",
    text: "etap stabilizacji skóry, w którym kreska stopniowo pokazuje finalny kierunek efektu",
  },
  {
    title: "Dopigmentowanie",
    text: "finalne dopracowanie nasycenia, równości i stabilności kreski po wygojeniu",
  },
];

const avoidItems = [
  {
    title: "Nie robimy kreski na siłę",
    text: "kształt kreski musi wynikać z budowy oka, powieki, rzęs i możliwości skóry",
  },
  {
    title: "Nie każda powieka lubi kreskę dekoracyjną",
    text: "przy opadającej lub wiotkiej powiece często lepszy jest subtelniejszy wariant",
  },
  {
    title: "Nie kopiujemy trendów",
    text: "kreska ma pasować do oka i twarzy, a nie do chwilowej mody z internetu",
  },
  {
    title: "Nie pomijamy kwalifikacji",
    text: "wrażliwość oczu, stan skóry i wcześniejsze zabiegi mają znaczenie dla planu pracy",
  },
  {
    title: "Nie oceniamy efektu od razu",
    text: "finalny wygląd kreski ocenia się po wygojeniu i stabilizacji pigmentu",
  },
];

const faqItems = [
  {
    question: "Czy kreski permanentne mogą wyglądać naturalnie?",
    answer:
      "Tak. Najbardziej naturalnym wariantem jest często zagęszczenie linii rzęs, które podkreśla oko bez efektu klasycznej, mocnej kreski.",
  },
  {
    question: "Czym różni się zagęszczenie rzęs od kreski?",
    answer:
      "Zagęszczenie rzęs jest bardzo subtelne i wykonywane blisko linii rzęs. Kreska jest bardziej widoczna i daje mocniejszy efekt makijażu.",
  },
  {
    question: "Czy kreska jest dobierana do kształtu oka?",
    answer:
      "Tak. Kreska powinna być dopasowana do powieki, kształtu oka, asymetrii, naturalnej linii rzęs i tego, jak klientka maluje się na co dzień.",
  },
  {
    question: "Czy makijaż permanentny oczu boli?",
    answer:
      "Odczucia są indywidualne. Okolica oka jest wrażliwa, dlatego przed zabiegiem omawiany jest przebieg pracy i komfort klientki.",
  },
  {
    question: "Czy każda osoba może wykonać kreskę dekoracyjną?",
    answer:
      "Nie zawsze. Przy opadającej powiece, wiotkiej skórze lub szczególnej budowie oka lepszym rozwiązaniem może być subtelniejsze zagęszczenie linii rzęs.",
  },
  {
    question: "Kiedy widać finalny efekt?",
    answer:
      "Bezpośrednio po zabiegu kreska może być intensywniejsza. Finalny efekt ocenia się po wygojeniu skóry i stabilizacji pigmentu.",
  },
  {
    question: "Czy wykonuje się dopigmentowanie kresek?",
    answer:
      "Decyzja zależy od efektu po wygojeniu. Dopigmentowanie może służyć dopracowaniu nasycenia, równości i stabilności kreski.",
  },
  {
    question: "Gdzie wykonywany jest makijaż permanentny oczu?",
    answer:
      "Zabieg wykonywany jest w gabinecie Bogusławy Herda w Bielsku-Białej. Aktualne terminy i rezerwacje dostępne są przez Booksy.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: {
      "@id": "https://permanentnybielsko.com/#website",
    },
    about: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: "https://permanentnybielsko.com/images/makijaz-permanentny-oczu-bielsko-biala-efekt-01.webp",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Makijaż permanentny Bielsko-Biała",
        item: "https://permanentnybielsko.com/makijaz-permanentny-bielsko/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Makijaż permanentny oczu",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${pageUrl}#service`,
    name: "Makijaż permanentny oczu Bielsko-Biała",
    serviceType: "Makijaż permanentny oczu",
    description:
      "Makijaż permanentny oczu w Bielsku-Białej: zagęszczenie linii rzęs, kreska górna, kreska dekoracyjna i indywidualne dopasowanie do budowy oka.",
    areaServed: [
      {
        "@type": "City",
        name: "Bielsko-Biała",
      },
      {
        "@type": "AdministrativeArea",
        name: "województwo śląskie",
      },
    ],
    provider: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    brand: {
      "@type": "Brand",
      name: "Bogusława Herda Makijaż Permanentny",
    },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Zakres kreski permanentnej",
      itemListElement: [
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Zagęszczenie linii rzęs",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Kreska górna",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Kreska dekoracyjna",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Korekta lub odświeżenie kreski permanentnej",
          },
        },
      ],
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/makijaz-permanentny-oczu/"
  structuredData={structuredData}
>
  <div class="eye-page">
    <Header />

    <main>
      <section class="eye-hero">
        <div class="eye-glow eye-glow-one"></div>
        <div class="eye-glow eye-glow-two"></div>

        <div class="container eye-hero-grid">
          <div class="eye-hero-copy">
            <p class="section-kicker">Makijaż permanentny oczu Bielsko-Biała</p>

            <h1>
              <span class="pmu-hero-rose-text">Kreski permanentne</span>, które podkreślają spojrzenie bez ciężkiego efektu.
            </h1>

            <p class="eye-hero-lead">
              Makijaż permanentny oczu może subtelnie zagęścić linię rzęs,
              otworzyć spojrzenie i podkreślić oprawę oka. Celem nie jest ciężka,
              graficzna kreska, tylko efekt dopasowany do oka, powieki i codziennego stylu.
            </p>

            <div class="eye-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację
              </a>

              <a class="button-secondary" href="#zakres-kresek">
                Zobacz zakres
              </a>
            </div>
          </div>

          <aside class="eye-hero-card" aria-label="Makijaż permanentny oczu">
            <p class="eye-card-label">Eyes</p>
            <h2>Najlepsza kreska to ta, która pasuje do oka.</h2>
            <p>
              W gabinecie Bogusława Herda kreski permanentne są planowane indywidualnie:
              od bardzo subtelnego zagęszczenia linii rzęs po bardziej widoczne,
              ale nadal eleganckie podkreślenie spojrzenia.
            </p>
          </aside>
        </div>
      </section>

      <section class="eye-proof-section" aria-label="Najważniejsze elementy makijażu permanentnego oczu">
        <div class="container eye-proof-grid">
          <div>
            <strong>Zagęszczenie rzęs</strong>
            <span>delikatny efekt bez mocnej kreski</span>
          </div>

          <div>
            <strong>Analiza powieki</strong>
            <span>kształt dopasowany do budowy oka</span>
          </div>

          <div>
            <strong>Rysunek wstępny</strong>
            <span>przebieg kreski omawiany przed pigmentacją</span>
          </div>

          <div>
            <strong>Dopigmentowanie</strong>
            <span>finalne dopracowanie po wygojeniu</span>
          </div>
        </div>
      </section>

      <section class="eye-intro-section">
        <div class="container eye-natural-look-card">
          <figure class="eye-natural-look-media">
            <img
              src="/images/makijaz-permanentny-oczu-bielsko-biala-efekt-01.webp"
              alt="Makijaż permanentny oczu Bielsko-Biała — subtelne zagęszczenie linii rzęs"
              width="1400"
              height="1400"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="eye-natural-look-copy">
            <p class="section-kicker">Naturalne spojrzenie</p>

            <h2>Kreski permanentne nie muszą wyglądać ciężko.</h2>

            <p>
              Najlepszy efekt to taki, który podkreśla linię rzęs, wzmacnia oprawę oka
              i nadal wygląda lekko, czysto oraz naturalnie. Pigmentacja oczu nie powinna
              tworzyć przypadkowej, zbyt grubej kreski.
            </p>

            <p>
              W dobrze wykonanym makijażu permanentnym oczu liczy się przebieg linii,
              budowa powieki, kierunek oka, symetria i to, jak kreska będzie wyglądała
              po wygojeniu — nie tylko bezpośrednio po zabiegu.
            </p>
          </div>
        </div>

        <div class="container eye-for-who-heading">
          <p class="section-kicker">Dla kogo?</p>
          <h2>Makijaż permanentny oczu dla kobiet, które chcą bardziej wyrazistego spojrzenia bez codziennego malowania kreski.</h2>
        </div>

        <div class="container eye-for-who-grid" aria-label="Dla kogo jest makijaż permanentny oczu">
          {forWhoItems.map((item) => (
            <figure class="eye-for-who-card">
              <img
                src={item.image}
                alt={`${item.title} — ${item.text}`}
                width="1536"
                height="1024"
                loading="lazy"
                decoding="async"
              />
            </figure>
          ))}
        </div>
      </section>

      <section class="eye-types-section eye-methods-premium-section" id="zakres-kresek">
        <div class="container">
          <div class="eye-methods-heading">
            <p class="section-kicker">Zakres kreski permanentnej</p>

            <h2>
              Kreska musi wynikać z budowy oka, powieki i oczekiwanego efektu.
            </h2>

            <p>
              Nie każda klientka potrzebuje takiej samej kreski. Inaczej pracuje się przy
              delikatnym zagęszczeniu linii rzęs, inaczej przy kresce górnej, a jeszcze inaczej
              przy korekcie wcześniejszej pigmentacji albo opadającej powiece.
            </p>
          </div>

          <figure class="eye-methods-collage-card">
            <img
              src="/images/makijaz-permanentny-oczu-metody-kolaz.webp"
              alt="Kolaż efektów makijażu permanentnego oczu pokazujący różne typy kreski permanentnej"
              width="1672"
              height="941"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="eye-methods-controls" aria-label="Przewijanie metod kreski permanentnej">
            <button
              class="eye-methods-arrow"
              type="button"
              aria-label="Przewiń metody kresek w lewo"
              onclick="document.querySelector('.eye-methods-track')?.scrollBy({ left: -430, behavior: 'smooth' })"
            >
              ←
            </button>

            <button
              class="eye-methods-arrow"
              type="button"
              aria-label="Przewiń metody kresek w prawo"
              onclick="document.querySelector('.eye-methods-track')?.scrollBy({ left: 430, behavior: 'smooth' })"
            >
              →
            </button>
          </div>
        </div>

        <div class="eye-methods-track" aria-label="Metody makijażu permanentnego oczu">
          {methodItems.map((item, index) => (
            <article class={index === 1 || index === 3 ? "eye-method-premium-card eye-method-premium-card-rose" : index === 4 ? "eye-method-premium-card eye-method-premium-card-strong" : "eye-method-premium-card"}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="eye-signature-section">
        <div class="container eye-signature-card">
          <div class="eye-signature-copy">
            <p class="section-kicker section-kicker-light">Kształt i powieka</p>
            <h2>Kreska dobrana do oka, nie do chwilowego trendu.</h2>
            <p class="eye-signature-lead">
              Makijaż permanentny oczu nie polega na skopiowaniu jednej kreski dla każdej klientki.
              Celem jest świeże spojrzenie, równowaga i kreska, która współpracuje z powieką,
              linią rzęs oraz naturalną mimiką oka.
            </p>
          </div>

          <figure class="eye-signature-media eye-media-frame eye-signature-video-frame">
            <video
              class="eye-signature-video"
              poster="/video/makijaz-permanentny-oczu-efekt-01-poster.webp"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-label="Makijaż permanentny oczu — subtelne podkreślenie spojrzenia"
            >
              <source
                src="/video/makijaz-permanentny-oczu-efekt-01.mp4"
                type="video/mp4"
              />
            </video>
          </figure>

          <div class="eye-signature-points" aria-label="Cechy naturalnego makijażu permanentnego oczu">
            <div>
              <span>01</span>
              <strong>Linia rzęs</strong>
              <p>pigmentacja ma wzmacniać oprawę oka, a nie tworzyć przypadkową plamę</p>
            </div>

            <div>
              <span>02</span>
              <strong>Budowa powieki</strong>
              <p>kształt kreski musi uwzględniać skórę, opadanie i naturalny układ oka</p>
            </div>

            <div>
              <span>03</span>
              <strong>Naturalna intensywność</strong>
              <p>efekt może być subtelny albo mocniejszy, ale zawsze powinien być kontrolowany</p>
            </div>

            <div>
              <span>04</span>
              <strong>Wygojenie</strong>
              <p>finalny efekt oceniamy po stabilizacji pigmentu i skóry</p>
            </div>
          </div>
        </div>
      </section>

            <section class="eye-gallery-section" id="efekty-kresek">
        <div class="container eye-gallery-heading-row">
          <div class="eye-section-heading eye-gallery-heading">
            <p class="section-kicker">Efekty kresek</p>
            <h2>Różne oczy, jeden standard: kreska ma pasować do spojrzenia.</h2>
            <p>
              Galeria pokazuje różne kierunki pigmentacji oczu: od delikatnego zagęszczenia
              po bardziej widoczną kreskę. Zdjęcia traktujemy jako inspirację — finalny efekt
              zawsze dobierany jest indywidualnie.
            </p>
          </div>

          <div class="eye-gallery-controls" aria-label="Przewijanie galerii efektów kresek">
            <button
              class="eye-gallery-arrow eye-gallery-arrow-prev"
              type="button"
              aria-label="Przewiń efekty kresek w lewo"
              onclick="document.querySelector('.eye-gallery-viewport')?.scrollBy({ left: -430, behavior: 'smooth' })"
            >
              ←
            </button>

            <button
              class="eye-gallery-arrow eye-gallery-arrow-next"
              type="button"
              aria-label="Przewiń efekty kresek w prawo"
              onclick="document.querySelector('.eye-gallery-viewport')?.scrollBy({ left: 430, behavior: 'smooth' })"
            >
              →
            </button>
          </div>
        </div>

        <div class="eye-gallery-viewport" aria-label="Galeria efektów makijażu permanentnego oczu">
          <div class="eye-gallery-track">
            {eyeGalleryImages.map((image) => (
              <figure class="eye-gallery-card eye-media-frame">
                <img
                  src={image.src}
                  alt={image.alt}
                  width="900"
                  height="1200"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            ))}
          </div>
        </div>
      </section>

      <section class="eye-process-section">
        <div class="container">
          <div class="eye-process-visual-intro">
            <div class="eye-process-visual-copy">
              <p class="section-kicker">Proces zabiegu</p>

              <h2>Najpierw analiza oka i rysunek wstępny. Dopiero później pigmentacja.</h2>

              <p>
                Okolica oka wymaga szczególnej precyzji, ponieważ przebieg kreski wpływa
                na odbiór całej twarzy. Przed zabiegiem omawiany jest rysunek wstępny,
                zakres pigmentacji, grubość linii i intensywność efektu.
              </p>

              <p>
                Dopiero po analizie powieki, linii rzęs, asymetrii i oczekiwań dobierany jest
                sposób pigmentacji. W makijażu permanentnym oczu liczy się nie tylko sama kreska,
                ale każda decyzja podjęta przed jej wykonaniem.
              </p>
            </div>

