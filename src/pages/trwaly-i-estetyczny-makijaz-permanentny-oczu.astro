---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/trwaly-i-estetyczny-makijaz-permanentny-oczu/";
const canonicalEyesUrl = "https://permanentnybielsko.com/makijaz-permanentny-oczu/";
const pageTitle = "Trwały i estetyczny makijaż permanentny oczu | Bogusława Herda";
const pageDescription =
  "Szukasz informacji o trwałym i estetycznym makijażu permanentnym oczu? Aktualna podstrona o kreskach permanentnych i subtelnym podkreśleniu spojrzenia znajduje się na permanentnybielsko.com/makijaz-permanentny-oczu/";

const eyeBridgeLinks = [
  {
    number: "01",
    label: "Oczy",
    title: "Makijaż permanentny oczu",
    text: "Aktualna podstrona o kreskach permanentnych, zagęszczeniu linii rzęs i subtelnym podkreśleniu spojrzenia.",
    href: "/makijaz-permanentny-oczu/",
    visibleUrl: "permanentnybielsko.com/makijaz-permanentny-oczu/",
    featured: true
  },
  {
    number: "02",
    label: "Oferta",
    title: "Makijaż permanentny Bielsko-Biała",
    text: "Główna oferta PMU: brwi, usta, kreski, korekty, usuwanie i naturalny efekt dopasowany do urody.",
    href: "/makijaz-permanentny-bielsko/",
    visibleUrl: "permanentnybielsko.com/makijaz-permanentny-bielsko/"
  },
  {
    number: "03",
    label: "Cennik",
    title: "Cennik makijażu permanentnego",
    text: "Ceny konsultacji, kresek permanentnych, odświeżenia, korekt i pozostałych usług PMU.",
    href: "/cennik-makijaz-permanentny/",
    visibleUrl: "permanentnybielsko.com/cennik-makijaz-permanentny/"
  },
  {
    number: "04",
    label: "Kontakt",
    title: "Konsultacja przed zabiegiem",
    text: "Jeżeli nie wiesz, jaki rodzaj kreski będzie właściwy, zacznij od kontaktu lub konsultacji.",
    href: "/kontakt/",
    visibleUrl: "permanentnybielsko.com/kontakt/"
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "url": pageUrl,
    "name": pageTitle,
    "description": pageDescription,
    "inLanguage": "pl-PL",
    "isPartOf": {
      "@id": "https://permanentnybielsko.com/#website"
    },
    "about": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "mainEntity": {
      "@id": `${canonicalEyesUrl}#service`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Strona główna",
        "item": "https://permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Trwały i estetyczny makijaż permanentny oczu",
        "item": pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${pageUrl}#eye-bridge-links`,
    "name": "Powiązane podstrony makijażu permanentnego oczu",
    "itemListElement": eyeBridgeLinks.map((item, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": item.title,
      "description": item.text,
      "url": new URL(item.href, pageUrl).toString()
    }))
  }
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/makijaz-permanentny-oczu/"
  structuredData={structuredData}
>
  <div class="eye-bridge-page">
    <Header />

    <main>
      <section class="eye-bridge-hero">
        <div class="container eye-bridge-grid">
          <div class="eye-bridge-copy">
            <p class="section-kicker">Makijaż permanentny oczu</p>

            <h1>Trwały i estetyczny makijaż permanentny oczu — aktualne informacje.</h1>

            <p class="eye-bridge-lead">
              Jeśli szukasz informacji o kreskach permanentnych, zagęszczeniu linii rzęs
              albo subtelnym podkreśleniu spojrzenia, przejdź do aktualnej podstrony:
              <a class="eye-bridge-text-link" href="/makijaz-permanentny-oczu/">
                permanentnybielsko.com/makijaz-permanentny-oczu/
              </a>.
            </p>

            <p class="eye-bridge-lead eye-bridge-lead-small">
              W gabinecie Bogusława Herda makijaż permanentny oczu wykonywany jest z naciskiem
              na naturalny efekt, bezpieczeństwo i dopasowanie kreski do budowy oka. Nie chodzi
              o ciężką linię, ale o spokojne podkreślenie oprawy oka — tak, aby efekt był estetyczny
              również po wygojeniu.
            </p>

            <div class="eye-bridge-actions">
              <a class="button-primary" href="/makijaz-permanentny-oczu/">
                Przejdź do makijażu permanentnego oczu
              </a>

              <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów wizytę przez Booksy
              </a>
            </div>
          </div>

          <aside class="eye-bridge-card" aria-label="Aktualna podstrona makijażu permanentnego oczu">
            <span class="eye-bridge-big-mark" aria-hidden="true">EYES</span>
            <p class="eye-bridge-label">Aktualna podstrona</p>
            <h2>Makijaż permanentny oczu</h2>
            <p>
              Pełny opis zabiegu, możliwe zakresy pigmentacji, informacje o kwalifikacji i link
              do rezerwacji znajdziesz tutaj:
            </p>
            <a class="eye-bridge-card-link" href="/makijaz-permanentny-oczu/">
              permanentnybielsko.com/makijaz-permanentny-oczu/
            </a>
          </aside>
        </div>
      </section>

      <section class="eye-bridge-reason-section">
        <div class="container eye-bridge-reason-grid">
          <article class="eye-bridge-reason-card">
            <p class="section-kicker">Dla klientek</p>
            <h2>Najważniejsze informacje są na aktualnej podstronie.</h2>
            <p>
              Dawne treści o trwałym i estetycznym makijażu permanentnym oczu zostały uporządkowane.
              Obecnie pełne informacje o kreskach permanentnych znajdziesz na stronie
              <a href="/makijaz-permanentny-oczu/">permanentnybielsko.com/makijaz-permanentny-oczu/</a>.
            </p>
          </article>

          <article class="eye-bridge-reason-card eye-bridge-reason-card-rose">
            <p class="section-kicker">Naturalny efekt</p>
            <h2>Kreska ma podkreślać spojrzenie, nie dominować twarz.</h2>
            <p>
              Aktualna podstrona opisuje, kiedy sprawdza się zagęszczenie linii rzęs, kiedy warto
              rozważyć kreskę oraz dlaczego rysunek wstępny i kwalifikacja są ważne przed pigmentacją.
            </p>
          </article>
        </div>
      </section>

      <section class="eye-bridge-links-section">
        <div class="container">
          <div class="eye-bridge-section-heading">
            <p class="section-kicker">Powiązane podstrony</p>
            <h2>Wybierz właściwy kierunek.</h2>
            <p>
              Poniżej znajdziesz aktywne linki do najważniejszych podstron związanych z makijażem
              permanentnym oczu i ofertą PMU.
            </p>
          </div>

          <div class="eye-bridge-link-grid">
            {eyeBridgeLinks.map((item) => (
              <a
                class:list={["eye-bridge-link-card", { "eye-bridge-link-card-featured": item.featured }]}
                href={item.href}
              >
                {item.featured && (
                  <span class="eye-bridge-card-mark" aria-hidden="true">EYES</span>
                )}

                <span class="eye-bridge-card-number">{item.number}</span>
                <p class="eye-bridge-card-label">{item.label}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
                <span class="eye-bridge-visible-url">{item.visibleUrl}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="eye-bridge-final-cta">
        <div class="container eye-bridge-final-card">
          <p class="section-kicker">Aktualna podstrona</p>
          <h2>Zobacz pełny opis makijażu permanentnego oczu.</h2>
          <p>
            Przejdź do aktualnej strony o kreskach permanentnych i subtelnym podkreśleniu spojrzenia:
            <a href="/makijaz-permanentny-oczu/">permanentnybielsko.com/makijaz-permanentny-oczu/</a>.
          </p>

          <a class="button-primary" href="/makijaz-permanentny-oczu/">
            Zobacz makijaż permanentny oczu
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .eye-bridge-page {
    overflow: hidden;
    background:
      radial-gradient(circle at 8% 12%, rgba(56, 187, 181, 0.11), transparent 27rem),
      radial-gradient(circle at 92% 14%, rgba(243, 199, 211, 0.20), transparent 29rem),
      linear-gradient(180deg, #ffffff 0%, #fff9fb 46%, #ffffff 100%);
  }

  .eye-bridge-hero {
    position: relative;
    min-height: 74vh;
    padding: 154px 0 86px;
  }

  .eye-bridge-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(340px, 0.72fr);
    gap: clamp(26px, 4vw, 54px);
    align-items: stretch;
  }

  .eye-bridge-copy,
  .eye-bridge-card,
  .eye-bridge-reason-card,
  .eye-bridge-link-card,
  .eye-bridge-final-card {
    border: 1px solid rgba(183, 101, 118, 0.13);
    box-shadow: 0 24px 70px rgba(51, 31, 44, 0.07);
  }

  .eye-bridge-copy {
    padding: clamp(30px, 5vw, 58px);
    border-radius: 42px;
    background:
      radial-gradient(circle at 90% 10%, rgba(56, 187, 181, 0.08), transparent 15rem),
      rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(16px);
  }

  .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    padding: 0 13px;
    border-radius: 999px;
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    background: rgba(219, 246, 243, 0.72);
    border: 1px solid rgba(56, 187, 181, 0.16);
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .eye-bridge-copy h1 {
    max-width: 1080px;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(3.05rem, 5.45vw, 6.25rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .eye-bridge-lead {
    max-width: 840px;
    margin: 24px 0 0;
    color: var(--color-muted);
    font-size: 1.08rem;
    line-height: 1.72;
  }

  .eye-bridge-lead-small {
    margin-top: 14px;
    font-size: 1.02rem;
  }

  .eye-bridge-lead strong {
    color: var(--color-text);
    font-weight: 820;
  }

  .eye-bridge-text-link,
  .eye-bridge-reason-card a,
  .eye-bridge-final-card a:not(.button-primary) {
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-weight: 860;
    text-decoration: none;
    border-bottom: 1px solid rgba(56, 187, 181, 0.28);
  }

  .eye-bridge-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .eye-bridge-card {
    position: relative;
    overflow: hidden;
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(34px, 4vw, 56px);
    border-radius: 42px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 22%, #74e0d7 40%, #138a86 56%, #33c1bb 74%, #bff6f1 88%, #0d6a67 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: eye-bridge-turquoise-flow 13s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(35, 156, 150, 0.22);
  }

  .eye-bridge-card::before,
  .eye-bridge-link-card-featured::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.06) 22%, rgba(255, 255, 255, 0.24) 47%, rgba(255, 255, 255, 0.06) 72%, transparent 100%);
    transform: translateX(-72%);
    animation: eye-bridge-panel-shine 8s ease-in-out infinite;
    pointer-events: none;
  }

  .eye-bridge-big-mark {
    position: absolute;
    right: 22px;
    top: 22px;
    z-index: 1;
    color: rgba(255, 255, 255, 0.16);
    font-size: clamp(4.6rem, 7.4vw, 8.6rem);
    font-weight: 900;
    line-height: 0.78;
    letter-spacing: -0.12em;
    pointer-events: none;
  }

  .eye-bridge-label,
  .eye-bridge-card h2,
  .eye-bridge-card p,
  .eye-bridge-card-link {
    position: relative;
    z-index: 2;
  }

  .eye-bridge-label {
    display: inline-flex;
    width: fit-content;
    min-height: 32px;
    align-items: center;
    margin: 0 0 auto;
    padding: 0 13px;
    border-radius: 999px;
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.22);
  }

  .eye-bridge-card h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(1.9rem, 2.6vw, 2.85rem);
    font-weight: 740;
    line-height: 1;
    letter-spacing: -0.067em;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.24);
  }

  .eye-bridge-card p:not(.eye-bridge-label) {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.62;
  }

  .eye-bridge-card-link {
    width: fit-content;
    max-width: 100%;
    margin-top: 18px;
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
    font-size: 0.92rem;
    font-weight: 820;
    line-height: 1.35;
    text-decoration: none;
    overflow-wrap: anywhere;
    border-bottom: 1px solid rgba(255, 255, 255, 0.38);
  }

  .eye-bridge-reason-section,
  .eye-bridge-links-section,
  .eye-bridge-final-cta {
    padding: 88px 0;
  }

  .eye-bridge-reason-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .eye-bridge-reason-card,
  .eye-bridge-final-card {
    padding: clamp(28px, 4vw, 46px);
    border-radius: 36px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 14rem),
      rgba(255, 255, 255, 0.9);
  }

  .eye-bridge-reason-card-rose {
    background:
      radial-gradient(circle at 94% 12%, rgba(201, 127, 143, 0.11), transparent 14rem),
      rgba(255, 255, 255, 0.92);
  }

  .eye-bridge-reason-card h2,
  .eye-bridge-section-heading h2,
  .eye-bridge-final-card h2 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(2.35rem, 4vw, 4.2rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .eye-bridge-reason-card p,
  .eye-bridge-section-heading p,
  .eye-bridge-final-card p {
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.68;
  }

  .eye-bridge-section-heading {
    max-width: 980px;
    margin-bottom: 38px;
  }

  .eye-bridge-link-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .eye-bridge-link-card {
    position: relative;
    overflow: hidden;
    min-height: 304px;
    padding: 30px;
    border-radius: 34px;
    color: inherit;
    text-decoration: none;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 14rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 252, 0.88));
  }

  .eye-bridge-link-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid rgba(56, 187, 181, 0.34);
    pointer-events: none;
  }

  .eye-bridge-link-card-featured {
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 22%, #74e0d7 40%, #138a86 56%, #33c1bb 74%, #bff6f1 88%, #0d6a67 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: eye-bridge-turquoise-flow 13s ease-in-out infinite alternate;
  }

  .eye-bridge-link-card > *:not(.eye-bridge-card-mark) {
    position: relative;
    z-index: 2;
  }

  .eye-bridge-card-mark {
    position: absolute;
    right: 18px;
    top: 16px;
    z-index: 1;
    color: rgba(255, 255, 255, 0.16);
    font-size: clamp(3.8rem, 6vw, 6.4rem);
    font-weight: 900;
    line-height: 0.78;
    letter-spacing: -0.12em;
    pointer-events: none;
  }

  .eye-bridge-card-number {
    display: inline-flex;
    margin-bottom: 18px;
    color: var(--color-turquoise-dark);
    font-size: 0.72rem;
    font-weight: 860;
    letter-spacing: 0.18em;
  }

  .eye-bridge-card-label {
    display: inline-flex;
    width: fit-content;
    min-height: 30px;
    align-items: center;
    margin: 0 0 18px;
    padding: 0 11px;
    border-radius: 999px;
    color: var(--color-turquoise-dark);
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    background: rgba(219, 246, 243, 0.72);
    border: 1px solid rgba(56, 187, 181, 0.16);
  }

  .eye-bridge-link-card h3 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.52rem;
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .eye-bridge-link-card p:not(.eye-bridge-card-label) {
    margin: 16px 0 0;
    color: var(--color-muted);
    font-size: 0.94rem;
    line-height: 1.58;
  }

  .eye-bridge-visible-url {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    margin-top: 18px;
    color: var(--color-turquoise-dark);
    -webkit-text-fill-color: var(--color-turquoise-dark);
    font-size: 0.78rem;
    font-weight: 820;
    line-height: 1.35;
    overflow-wrap: anywhere;
    border-bottom: 1px solid rgba(56, 187, 181, 0.24);
  }

  .eye-bridge-link-card-featured,
  .eye-bridge-link-card-featured * {
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
  }

  .eye-bridge-link-card-featured .eye-bridge-card-label {
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .eye-bridge-link-card-featured p:not(.eye-bridge-card-label),
  .eye-bridge-link-card-featured .eye-bridge-visible-url {
    color: rgba(255, 255, 255, 0.86);
    -webkit-text-fill-color: rgba(255, 255, 255, 0.86);
    border-bottom-color: rgba(255, 255, 255, 0.30);
  }

  .eye-bridge-final-card .button-primary {
    margin-top: 18px;
  }

  @keyframes eye-bridge-turquoise-flow {
    0% {
      background-position: 0% 50%, 0% 50%, 0% 50%;
    }

    100% {
      background-position: 0% 50%, 0% 50%, 100% 50%;
    }
  }

  @keyframes eye-bridge-panel-shine {
    0%,
    35% {
      transform: translateX(-72%);
      opacity: 0;
    }

    52% {
      opacity: 1;
    }

    100% {
      transform: translateX(72%);
      opacity: 0;
    }
  }

  @media (max-width: 1080px) {
    .eye-bridge-grid,
    .eye-bridge-reason-grid {
      grid-template-columns: 1fr;
    }

    .eye-bridge-link-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 760px) {
    .eye-bridge-hero {
      padding: 112px 0 58px;
    }

    .eye-bridge-copy,
    .eye-bridge-card,
    .eye-bridge-reason-card,
    .eye-bridge-link-card,
    .eye-bridge-final-card {
      border-radius: 28px;
    }

    .eye-bridge-copy h1 {
      font-size: clamp(2.55rem, 11.6vw, 3.85rem);
      line-height: 1.04;
      letter-spacing: -0.068em;
    }

    .eye-bridge-card {
      min-height: 340px;
      padding: 28px 22px;
    }

    .eye-bridge-reason-section,
    .eye-bridge-links-section,
    .eye-bridge-final-cta {
      padding: 58px 0;
    }

    .eye-bridge-reason-card h2,
