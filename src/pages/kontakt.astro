---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const phone = "+48 730 900 125";
const email = "bogusia@permanentnybielsko.com";
const mapUrl = "https://share.google/r1H8ZLwSZMdRIflO9";

const contactProofCards = [
  {
    number: "01",
    label: "Lokalizacja",
    title: "Centrum Bielska-Białej",
    text: "ul. Barlickiego 5/23",
    href: mapUrl,
    cta: "Zobacz mapę",
  },
  {
    number: "02",
    label: "Rezerwacja",
    title: "Booksy",
    text: "Aktualne terminy i rezerwacja online",
    href: booksyUrl,
    cta: "Umów wizytę",
  },
  {
    number: "03",
    label: "Telefon",
    title: phone,
    text: "Kontakt w sprawach organizacyjnych",
    href: "tel:+48730900125",
    cta: "Zadzwoń",
  },
  {
    number: "04",
    label: "E-mail",
    title: email,
    text: "Pytania przed wizytą i kwalifikacją",
    href: `mailto:${email}`,
    cta: "Napisz",
  },
];

const contactCards = [
  {
    label: "Rezerwacja",
    title: "Booksy",
    text: "Najwygodniejszy sposób sprawdzenia aktualnych terminów i zapisania się na konsultację lub zabieg.",
    href: booksyUrl,
    cta: "Umów wizytę",
  },
  {
    label: "Telefon",
    title: phone,
    text: "Kontakt telefoniczny w sprawach pilnych, organizacyjnych i przy pytaniach przed wizytą.",
    href: "tel:+48730900125",
    cta: "Zadzwoń",
  },
  {
    label: "E-mail",
    title: email,
    text: "Dobry wybór, jeśli chcesz opisać sytuację, przesłać pytanie lub zapytać o kwalifikację.",
    href: `mailto:${email}`,
    cta: "Napisz",
  },
];

const visitRules = [
  "Jeśli masz stary makijaż permanentny, poinformuj o tym przed wizytą.",
  "Przy korektach i usuwaniu PMU najlepszym pierwszym krokiem jest konsultacja.",
  "Rysunek wstępny omawiany jest przed pigmentacją.",
  "Aktualne terminy i dostępność usług sprawdzisz przez Booksy.",
  "W przypadku przeciwwskazań zabieg może zostać odłożony dla bezpieczeństwa skóry.",
];

const pageUrl = "https://permanentnybielsko.com/kontakt/";
const pageTitle = "Kontakt | Bogusława Herda Makijaż Permanentny Bielsko-Biała";
const pageDescription =
  "Kontakt do gabinetu Bogusława Herda w Bielsku-Białej. Rezerwacja przez Booksy, telefon, e-mail, adres gabinetu i informacje przed wizytą.";

const faqItems = [
  {
    question: "Czy najlepiej umawiać wizytę przez Booksy?",
    answer:
      "Tak. Booksy pokazuje aktualne terminy i pozwala wygodnie zarezerwować wizytę. To najprostsza forma zapisu.",
  },
  {
    question: "Czy mogę zadzwonić przed rezerwacją?",
    answer:
      "Tak. Telefon sprawdzi się przy pytaniach organizacyjnych lub wtedy, gdy nie wiesz, od jakiej usługi zacząć.",
  },
  {
    question: "Czy przy starym PMU potrzebna jest konsultacja?",
    answer:
      "Tak. Stary makijaż permanentny wymaga oceny koloru, nasycenia, kształtu i stanu skóry. Czasem najpierw potrzebne jest rozjaśnienie lub usuwanie.",
  },
  {
    question: "Czy gabinet wykonuje też kosmetologię?",
    answer:
      "Tak, ale nowa komunikacja kosmetologiczna jest prowadzona osobno na stronie kosmetologiabielsko.com. PermanentnyBielsko pozostaje stroną PMU.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: {
      "@id": "https://permanentnybielsko.com/#website",
    },
    about: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntity: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Kontakt",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "PostalAddress",
    "@id": `${pageUrl}#address`,
    streetAddress: "ul. Barlickiego 5/23",
    postalCode: "43-300",
    addressLocality: "Bielsko-Biała",
    addressCountry: "PL",
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/kontakt/"
  structuredData={structuredData}
>
  <div class="contact-page">
    <Header />

    <main>
      <section class="contact-hero">
        <div class="contact-glow contact-glow-one"></div>
        <div class="contact-glow contact-glow-two"></div>

        <div class="container contact-hero-grid">
          <div class="contact-hero-copy">
            <p class="section-kicker">Kontakt</p>

            <h1>
              <span class="pmu-hero-turquoise-text">Umów konsultację</span> lub wizytę w gabinecie Bogusława Herda.
            </h1>

            <p class="contact-hero-lead">
              Gabinet znajduje się w centrum Bielska-Białej. Najszybszą ścieżką rezerwacji
              jest Booksy, a w sprawach organizacyjnych możesz skontaktować się telefonicznie
              lub mailowo.
            </p>

            <div class="contact-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów wizytę przez Booksy
              </a>

              <a class="button-secondary" href="#dane-kontaktowe">
                Zobacz dane kontaktowe
              </a>
            </div>
          </div>

          <aside class="contact-hero-card contact-shine-card" aria-label="Najważniejsze informacje kontaktowe">
            <p class="contact-card-label">PMU</p>

            <div class="contact-hero-card-content">
              <h2>Najpierw konsultacja. Potem świadoma decyzja.</h2>
              <p>
                Przy makijażu permanentnym, korektach i usuwaniu PMU warto zacząć od spokojnej
                rozmowy, oceny skóry i omówienia realnego efektu.
              </p>
            </div>
          </aside>
        </div>
      </section>

      <section class="contact-proof-section" aria-label="Szybkie dane kontaktowe">
        <div class="container contact-proof-grid">
          {contactProofCards.map((card) => (
            <a
              class="contact-proof-card"
              href={card.href}
              target={card.href.startsWith("http") ? "_blank" : undefined}
              rel={card.href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              <span>{card.number}</span>
              <p>{card.label}</p>
              <strong>{card.title}</strong>
              <em>{card.text}</em>
              <small>{card.cta}</small>
            </a>
          ))}
        </div>
      </section>

      <section class="contact-data-section" id="dane-kontaktowe">
        <div class="container">
          <div class="contact-section-heading">
            <p class="section-kicker">Dane kontaktowe</p>
            <h2>Wybierz najwygodniejszą formę kontaktu.</h2>
            <p>
              Rezerwacje zabiegów najlepiej wykonywać przez Booksy. Telefon i e-mail sprawdzą się
              przy pytaniach, konsultacjach organizacyjnych i sytuacjach wymagających dodatkowego wyjaśnienia.
            </p>
          </div>

          <div class="contact-card-grid">
            {contactCards.map((card) => (
              <a
                href={card.href}
                class="contact-method-card"
                target={card.href.startsWith("http") ? "_blank" : undefined}
                rel={card.href.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                <span>{card.label}</span>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
                <strong>{card.cta}</strong>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="contact-social-section">
        <div class="container">
          <div class="contact-section-heading">
            <p class="section-kicker">Social media i opinie</p>
            <h2>Obserwuj gabinet i sprawdź najważniejsze miejsca online.</h2>
            <p>
              Media społecznościowe pokazują styl pracy, efekty i aktualności, a Booksy oraz Google
              pomagają szybko umówić wizytę albo sprawdzić lokalizację gabinetu.
            </p>
          </div>

          <div class="contact-social-grid">
            <a
              href="https://www.instagram.com/permanentnybielsko"
              class="contact-social-card contact-social-card-instagram"
              target="_blank"
              rel="noopener noreferrer"
            >
              <em>IG</em>
              <span>Instagram</span>
              <h3>@PERMANENTNYBIELSKO</h3>
              <p>Zdjęcia, efekty, kulisy pracy gabinetu i aktualności z makijażu permanentnego.</p>
              <strong>Przejdź do Instagram</strong>
            </a>

            <a
              href="https://www.facebook.com/PermanentnyBielsko"
              class="contact-social-card contact-social-card-facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <em>FB</em>
              <span>Facebook</span>
              <h3>PERMANENTNYBIELSKO</h3>
              <p>Aktualności gabinetu, komunikaty, realizacje i bieżące informacje dla klientek.</p>
              <strong>Przejdź do Facebook</strong>
            </a>

            <a
              href={booksyUrl}
              class="contact-social-card contact-social-card-booksy"
              target="_blank"
              rel="noopener noreferrer"
            >
              <em>BOOKSY</em>
              <span>Booksy</span>
              <h3>REZERWACJA ONLINE</h3>
              <p>Najprostszy sposób sprawdzenia dostępnych terminów i umówienia konsultacji lub zabiegu.</p>
              <strong>Przejdź do Booksy</strong>
            </a>

            <a
              href={mapUrl}
              class="contact-social-card contact-social-card-google"
              target="_blank"
              rel="noopener noreferrer"
            >
              <em>G</em>
              <span>Google</span>
              <h3>MAPA I OPINIE</h3>
              <p>Sprawdź lokalizację gabinetu, trasę dojazdu oraz opinie klientek w Google.</p>
              <strong>Przejdź do Google</strong>
            </a>
          </div>
        </div>
      </section>

      <section class="contact-location-section">
        <div class="container contact-location-grid">
          <div class="contact-location-card">
            <p class="section-kicker">Adres gabinetu</p>
            <h2>Bogusława Herda Permanent Makeup & Kosmetologia Estetyczna</h2>

            <div class="contact-address">
              <p>
                ul. Barlickiego 5/23<br />
                43-300 Bielsko-Biała
              </p>

              <p>
                Gabinet znajduje się w centrum Bielska-Białej, blisko deptaku, Galerii Sfera
                i Ratusza.
              </p>
            </div>

            <div class="contact-location-actions">
              <a class="button-primary" href={mapUrl} target="_blank" rel="noopener noreferrer">
                Zobacz trasę dojazdu
              </a>

              <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Rezerwuj przez Booksy
              </a>
            </div>
          </div>

          <div class="contact-hours-card">
            <p class="section-kicker">Godziny pracy</p>

            <div class="contact-hours-list">
              <div>
                <strong>Poniedziałek – piątek</strong>
                <span>9:00–18:00</span>
              </div>

              <div>
                <strong>Sobota</strong>
                <span>10:00–14:00</span>
              </div>

              <div>
                <strong>Niedziela</strong>
                <span>zamknięte</span>
              </div>
            </div>

            <p class="contact-hours-note">
              Godziny pracy mogą zależeć od zapisów i dostępnych terminów. Najbardziej aktualne
              terminy wizyt znajdują się w Booksy.
            </p>
          </div>
        </div>
      </section>

      <section class="contact-before-section">
        <div class="container contact-before-grid">
          <div class="contact-before-card">
            <p class="section-kicker">Przed wizytą</p>
            <h2>Co warto przygotować przed konsultacją PMU?</h2>
            <p>
              Przy pierwszej wizycie najważniejsza jest rozmowa: o oczekiwanym efekcie,
              wcześniejszych pigmentacjach, skórze, przeciwwskazaniach i codziennym stylu.
            </p>
          </div>

          <div class="contact-rules-card premium-points-list" aria-label="Informacje przed wizytą PMU">
            {visitRules.map((rule) => (
              <div class="premium-point">
                <span class="premium-point__dot" aria-hidden="true"></span>
                <p>{rule}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="contact-offer-section">
        <div class="container">
          <div class="contact-section-heading">
            <p class="section-kicker">Oferta PMU</p>
            <h2>Najważniejsze podstrony makijażu permanentnego.</h2>
          </div>

          <div class="contact-offer-grid">
            <a href="/makijaz-permanentny-bielsko/" class="contact-offer-card">
              <span>PMU</span>
              <h3>Makijaż permanentny Bielsko-Biała</h3>
              <p>Główna podstrona o makijażu permanentnym, konsultacji, rysunku wstępnym i naturalnym efekcie.</p>
            </a>

            <a href="/makijaz-permanentny-brwi/" class="contact-offer-card contact-offer-card-turquoise">
              <span>Brwi</span>
              <h3>Brwi permanentne</h3>
              <p>Naturalne brwi, metoda włoskowa, włos z cieniem i Silky Hairstroke Brows.</p>
            </a>

            <a href="/makijaz-permanentny-oczu/" class="contact-offer-card">
              <span>Oczy</span>
              <h3>Makijaż permanentny oczu</h3>
              <p>Kreski permanentne, zagęszczenie linii rzęs i subtelne podkreślenie spojrzenia.</p>
            </a>

            <a href="/cennik-makijaz-permanentny/" class="contact-offer-card contact-offer-card-rose">
              <span>Cennik</span>
              <h3>Cennik PMU</h3>
              <p>Aktualne ceny makijażu permanentnego, odświeżeń, usuwania i konsultacji.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="contact-faq-section">
        <div class="container">
          <div class="contact-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Jak najlepiej umówić wizytę?</h2>
          </div>

          <div class="contact-faq-grid">
            {faqItems.map((item) => (
              <article>
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="contact-final-cta" id="kontakt">
        <div class="container contact-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
          <p>
            Umów konsultację i zobacz, jak może wyglądać naturalny efekt dopasowany
            do Twojej urody, skóry i codzienności.
          </p>

          <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
            Umów wizytę przez Booksy
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .contact-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.11), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .contact-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    padding: 0 13px;
    border: 1px solid rgba(56, 187, 181, 0.16);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.72);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .contact-hero {
    position: relative;
    padding: 150px 0 88px;
    overflow: hidden;
  }

  .contact-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .contact-glow-one {
    right: -12rem;
    top: 4rem;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.2), transparent 68%);
  }

  .contact-glow-two {
    left: -10rem;
    bottom: -12rem;
    width: 38rem;
    height: 38rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.16), transparent 68%);
  }

  .contact-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    gap: 24px;
    align-items: stretch;
  }

  .contact-hero-copy,
  .contact-hero-card,
  .contact-proof-card,
  .contact-method-card,
  .contact-location-card,
  .contact-hours-card,
  .contact-before-card,
  .contact-rules-card,
  .contact-offer-card,
  .contact-faq-grid article,
  .contact-final-card {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .contact-hero-copy {
    display: flex;
    min-height: 620px;
    flex-direction: column;
    justify-content: center;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    background:
      radial-gradient(circle at 92% 14%, rgba(56, 187, 181, 0.10), transparent 16rem),
      rgba(255, 255, 255, 0.78);
  }

  .contact-hero-copy h1 {
    max-width: 1080px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(3.05rem, 5.45vw, 6.35rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .pmu-hero-turquoise-text {
    display: inline;
    color: #0f7773;
    background:
      linear-gradient(
        120deg,
        #0d6a67 0%,
        #0f7773 22%,
        #1aa5a0 46%,
        #74e0d7 68%,
        #138a86 86%,
        #0d6a67 100%
      );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .contact-hero-lead {
    max-width: 760px;
    margin: 28px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: 1.12rem;
    line-height: 1.68;
  }

  .contact-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .contact-hero-card {
    position: relative;
    display: flex;
    min-height: 620px;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: clamp(38px, 5vw, 72px);
    border-radius: 44px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 22%, #74e0d7 40%, #138a86 56%, #33c1bb 74%, #bff6f1 88%, #0d6a67 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: contact-turquoise-flow 13s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(35, 156, 150, 0.22);
  }

  .contact-shine-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.05) 22%, rgba(255, 255, 255, 0.24) 47%, rgba(255, 255, 255, 0.05) 72%, transparent 100%);
    transform: translateX(-72%);
    animation: contact-panel-shine 8.5s ease-in-out infinite;
    pointer-events: none;
  }

  .contact-card-label {
    position: absolute;
    top: clamp(26px, 3vw, 46px);
    left: clamp(30px, 4vw, 58px);
    z-index: 1;
    margin: 0;
    color: rgba(255, 255, 255, 0.18);
    font-size: clamp(5.6rem, 9vw, 11rem);
    font-weight: 850;
    line-height: 0.78;
    letter-spacing: -0.085em;
    pointer-events: none;
  }

  .contact-hero-card-content {
    position: relative;
    z-index: 2;
  }

  .contact-hero-card h2 {
    max-width: 620px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.15rem, 3.7vw, 4.35rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.075em;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.24);
  }

  .contact-hero-card p:not(.contact-card-label) {
    max-width: 620px;
    margin: 22px 0 0;
