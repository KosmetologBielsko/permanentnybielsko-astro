    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding: 20px;
    border-bottom: 1px solid rgba(56, 187, 181, 0.15);
    background: rgba(255, 255, 255, 0.68);
  }

  .contact-hours-list div:last-child {
