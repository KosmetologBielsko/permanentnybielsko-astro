---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const phone = "+48 730 900 125";
const email = "bogusia@permanentnybielsko.com";
const mapUrl = "https://share.google/r1H8ZLwSZMdRIflO9";

const pageUrl = "https://www.permanentnybielsko.com/kontakt/";
const pageTitle = "Kontakt | Bogusława Herda Makijaż Permanentny Bielsko-Biała";
const pageDescription =
  "Kontakt do gabinetu Bogusława Herda Permanent Makeup w Bielsku-Białej. Rezerwacja przez Booksy, telefon, e-mail, adres gabinetu i najważniejsze informacje przed wizytą.";

const contactCards = [
  {
    number: "01",
    label: "Rezerwacja",
    title: "Booksy",
    text: "Najszybsza forma sprawdzenia wolnych terminów i umówienia konsultacji lub zabiegu.",
    href: booksyUrl,
    cta: "Umów wizytę",
    type: "primary"
  },
  {
    number: "02",
    label: "Telefon",
    title: phone,
    text: "Kontakt w sprawach organizacyjnych, pilnych lub wtedy, gdy nie wiesz, od czego zacząć.",
    href: "tel:+48730900125",
    cta: "Zadzwoń",
    type: "soft"
  },
  {
    number: "03",
    label: "E-mail",
    title: email,
    text: "Pytania przed wizytą, kwalifikacją, korektą albo przy starym makijażu permanentnym.",
    href: `mailto:${email}`,
    cta: "Napisz",
    type: "soft"
  },
  {
    number: "04",
    label: "Mapa",
    title: "ul. Barlickiego 5/23",
    text: "Gabinet w centrum Bielska-Białej, blisko deptaku, Galerii Sfera i Ratusza.",
    href: mapUrl,
    cta: "Zobacz trasę",
    type: "map"
  }
];

const socialLinks = [
  {
    label: "Instagram",
    title: "@permanentnybielsko",
    href: "https://www.instagram.com/permanentnybielsko",
    short: "IG"
  },
  {
    label: "Facebook",
    title: "PermanentnyBielsko",
    href: "https://www.facebook.com/PermanentnyBielsko",
    short: "FB"
  },
  {
    label: "Booksy",
    title: "Rezerwacja online",
    href: booksyUrl,
    short: "BOOKSY"
  },
  {
    label: "Google",
    title: "Mapa i opinie",
    href: mapUrl,
    short: "G"
  }
];

const faqItems = [
  {
    question: "Czy najlepiej umawiać wizytę przez Booksy?",
    answer:
      "Tak. Booksy pokazuje aktualne terminy i pozwala wygodnie zarezerwować konsultację lub zabieg."
  },
  {
    question: "Czy przy starym PMU potrzebna jest konsultacja?",
    answer:
      "Tak. Stary makijaż permanentny wymaga oceny koloru, nasycenia, kształtu i stanu skóry. Czasem najpierw potrzebne jest rozjaśnienie lub usuwanie."
  },
  {
    question: "Czy mogę zadzwonić przed rezerwacją?",
    answer:
      "Tak. Telefon sprawdzi się przy pytaniach organizacyjnych albo wtedy, gdy nie wiesz, którą usługę wybrać."
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: {
      "@id": "https://www.permanentnybielsko.com/#website"
    },
    about: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntity: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Kontakt",
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "PostalAddress",
    "@id": `${pageUrl}#address`,
    streetAddress: "ul. Barlickiego 5/23",
    postalCode: "43-300",
    addressLocality: "Bielsko-Biała",
    addressCountry: "PL"
  }
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/kontakt/"
  structuredData={structuredData}
>
  <div class="contact-page">
    <Header />

    <main>
      <section class="contact-hero" id="kontakt">
        <div class="contact-glow contact-glow-one" aria-hidden="true"></div>
        <div class="contact-glow contact-glow-two" aria-hidden="true"></div>

        <div class="container contact-hero-grid">
          <div class="contact-hero-copy">
            <p class="section-kicker">Kontakt</p>

            <h1>
              <span>Umów konsultację</span> lub wizytę w gabinecie Bogusława Herda.
            </h1>

            <p class="contact-hero-lead">
              Najszybszą formą rezerwacji jest Booksy. W sprawach organizacyjnych możesz
              skontaktować się telefonicznie lub mailowo. Gabinet znajduje się w centrum Bielska-Białej.
            </p>

            <div class="contact-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów wizytę przez Booksy
              </a>

              <a class="button-secondary" href="tel:+48730900125">
                Zadzwoń
              </a>
            </div>
          </div>

          <aside class="contact-hero-panel" aria-label="Najważniejsze dane gabinetu">
            <p class="contact-hero-mark" aria-hidden="true">PMU</p>

            <div class="contact-hero-panel-content">
              <p class="section-kicker section-kicker-light">Bielsko-Biała</p>
              <h2>ul. Barlickiego 5/23</h2>
              <p>
                Naturalny makijaż permanentny, konsultacje, korekty i usuwanie PMU w spokojnej,
                kameralnej przestrzeni.
              </p>

              <div class="contact-mini-list">
                <a href={mapUrl} target="_blank" rel="noopener noreferrer">Zobacz mapę</a>
                <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Rezerwuj online</a>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="contact-fast-section" aria-label="Szybki kontakt">
        <div class="container contact-fast-grid">
          {contactCards.map((card) => (
            <a
              class:list={["contact-fast-card", `contact-fast-card--${card.type}`]}
              href={card.href}
              target={card.href.startsWith("http") ? "_blank" : undefined}
              rel={card.href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              <span class="contact-fast-number">{card.number}</span>
              <p class="contact-fast-label">{card.label}</p>
              <h2>{card.title}</h2>
              <em>{card.text}</em>
              <strong>{card.cta}</strong>
            </a>
          ))}
        </div>
      </section>

      <section class="contact-location-section">
        <div class="container contact-location-grid">
          <article class="contact-location-card">
            <p class="section-kicker">Adres gabinetu</p>
            <h2>Bogusława Herda Permanent Makeup & Kosmetologia Estetyczna</h2>

            <div class="contact-address">
              <p>
                ul. Barlickiego 5/23<br />
                43-300 Bielsko-Biała
              </p>

              <p>
                Gabinet znajduje się w centrum miasta. Przed wizytą najlepiej sprawdzić trasę
                w mapach Google i aktualny termin w Booksy.
              </p>
            </div>

            <div class="contact-location-actions">
              <a class="button-primary" href={mapUrl} target="_blank" rel="noopener noreferrer">
                Zobacz trasę dojazdu
              </a>

              <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Rezerwuj przez Booksy
              </a>
            </div>
          </article>

          <article class="contact-hours-card">
            <p class="section-kicker">Godziny i organizacja</p>

            <div class="contact-hours-list">
              <div>
                <strong>Poniedziałek – piątek</strong>
                <span>9:00–18:00</span>
              </div>

              <div>
                <strong>Sobota</strong>
                <span>10:00–14:00</span>
              </div>

              <div>
                <strong>Niedziela</strong>
                <span>zamknięte</span>
              </div>
            </div>

            <p class="contact-hours-note">
              Godziny mogą zależeć od zapisów i dostępnych terminów. Najbardziej aktualne informacje
              o wolnych wizytach znajdziesz w Booksy.
            </p>
          </article>
        </div>
      </section>

      <section class="contact-social-strip-section">
        <div class="container contact-social-strip-card">
          <div>
            <p class="section-kicker">Online</p>
            <h2>Social media, opinie i rezerwacja w jednym miejscu.</h2>
          </div>

          <div class="contact-social-strip">
            {socialLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noopener noreferrer">
                <span>{item.short}</span>
                <div>
                  <strong>{item.label}</strong>
                  <p>{item.title}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="contact-faq-section">
        <div class="container">
          <div class="contact-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Jak najlepiej zacząć kontakt z gabinetem?</h2>
          </div>

          <div class="contact-faq-grid">
            {faqItems.map((item) => (
              <article>
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="contact-final-cta">
        <div class="container contact-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Chcesz sprawdzić, jaki efekt będzie najlepszy dla Ciebie?</h2>
          <p>
            Umów konsultację i spokojnie omów kształt, kolor, metodę oraz realny efekt makijażu permanentnego.
          </p>

          <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
            Umów wizytę przez Booksy
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .contact-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.11), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .contact-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    padding: 0 13px;
    border: 1px solid rgba(56, 187, 181, 0.16);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.72);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.7rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .contact-page .section-kicker-light {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    -webkit-text-fill-color: #ffffff;
  }

  .contact-hero {
    position: relative;
    padding: 150px 0 72px;
    overflow: hidden;
  }

  .contact-glow {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
  }

  .contact-glow-one {
    right: -12rem;
    top: 4rem;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.18), transparent 68%);
  }

  .contact-glow-two {
    left: -10rem;
    bottom: -12rem;
    width: 38rem;
    height: 38rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.14), transparent 68%);
  }

  .contact-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: 24px;
    align-items: stretch;
  }

  .contact-hero-copy,
  .contact-hero-panel,
  .contact-fast-card,
  .contact-location-card,
  .contact-hours-card,
  .contact-social-strip-card,
  .contact-faq-grid article,
  .contact-final-card {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .contact-hero-copy {
    display: flex;
    min-height: 560px;
    flex-direction: column;
    justify-content: center;
    padding: clamp(38px, 5vw, 70px);
    border-radius: 44px;
    background:
      radial-gradient(circle at 92% 14%, rgba(56, 187, 181, 0.10), transparent 16rem),
      rgba(255, 255, 255, 0.80);
  }

  .contact-hero-copy h1 {
    max-width: 980px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(3.05rem, 5.45vw, 6.05rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .contact-hero-copy h1 span {
    background:
      linear-gradient(
        120deg,
        #0d6a67 0%,
        #0f7773 22%,
        #1aa5a0 46%,
        #74e0d7 68%,
        #138a86 86%,
        #0d6a67 100%
      );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .contact-hero-lead {
    max-width: 760px;
    margin: 28px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: 1.1rem;
    line-height: 1.68;
  }

  .contact-hero-actions,
  .contact-location-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .contact-hero-panel {
    position: relative;
    display: flex;
    min-height: 560px;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: clamp(38px, 5vw, 64px);
    border-radius: 44px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 26%, #74e0d7 42%, #138a86 66%, #0d6a67 100%);
    box-shadow: 0 28px 76px rgba(35, 156, 150, 0.22);
  }

  .contact-hero-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.06) 22%, rgba(255, 255, 255, 0.24) 47%, rgba(255, 255, 255, 0.06) 72%, transparent 100%);
    transform: translateX(-72%);
    animation: contact-panel-shine 8.5s ease-in-out infinite;
    pointer-events: none;
  }

  .contact-hero-mark {
    position: absolute;
    top: clamp(26px, 3vw, 46px);
    left: clamp(30px, 4vw, 58px);
    z-index: 1;
    margin: 0;
    color: rgba(255, 255, 255, 0.18);
    font-size: clamp(5.6rem, 9vw, 11rem);
    font-weight: 850;
    line-height: 0.78;
    letter-spacing: -0.085em;
    pointer-events: none;
  }

  .contact-hero-panel-content {
    position: relative;
    z-index: 2;
  }

  .contact-hero-panel h2 {
    max-width: 640px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.25rem, 3.9vw, 4.25rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.075em;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.24);
  }

  .contact-hero-panel p:not(.section-kicker):not(.contact-hero-mark) {
    max-width: 620px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .contact-mini-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }

  .contact-mini-list a {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    padding: 0 15px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .contact-fast-section {
    padding: 22px 0 68px;
  }

  .contact-fast-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .contact-fast-card {
    position: relative;
    min-height: 210px;
    overflow: hidden;
    padding: 24px;
    border-radius: 30px;
    color: inherit;
    text-decoration: none;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 12rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 252, 0.9));
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .contact-fast-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid rgba(56, 187, 181, 0.34);
    pointer-events: none;
  }

  .contact-fast-card::after {
    content: "";
    position: absolute;
    right: -58px;
    top: -58px;
    width: 138px;
    height: 138px;
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.68);
    pointer-events: none;
  }

  .contact-fast-card:hover {
    transform: translateY(-4px);
    border-color: rgba(201, 127, 143, 0.26);
    box-shadow: 0 24px 62px rgba(89, 53, 67, 0.095);
  }

  .contact-fast-card--primary {
    border-color: rgba(56, 187, 181, 0.28);
    background:
      radial-gradient(circle at 96% 8%, rgba(116, 224, 215, 0.24), transparent 12rem),
      linear-gradient(145deg, rgba(219, 246, 243, 0.88), rgba(255, 255, 255, 0.94));
  }

  .contact-fast-card--map::before {
    border-top-color: rgba(201, 127, 143, 0.34);
  }

  .contact-fast-card--map::after {
    background: rgba(246, 220, 227, 0.72);
  }

  .contact-fast-number,
  .contact-fast-label,
  .contact-fast-card h2,
  .contact-fast-card em,
  .contact-fast-card strong {
    position: relative;
    z-index: 2;
  }

  .contact-fast-number {
    display: inline-flex;
    margin-bottom: 28px;
    color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.72rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.18em;
  }

  .contact-fast-label {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    margin: 0 0 14px;
    padding: 0 11px;
    border: 1px solid rgba(56, 187, 181, 0.16);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.72);
    color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .contact-fast-card h2 {
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(1.25rem, 1.5vw, 1.72rem);
    font-weight: 760;
    line-height: 1.05;
    letter-spacing: -0.055em;
    overflow-wrap: anywhere;
  }

  .contact-fast-card em {
    display: block;
    margin-top: 10px;
    color: var(--color-muted, #6e6670);
    font-size: 0.92rem;
    font-style: normal;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .contact-fast-card strong {
    display: inline-flex;
    margin-top: 18px;
    color: var(--color-text, #17151d);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .contact-location-section,
  .contact-social-strip-section,
  .contact-faq-section,
  .contact-final-cta {
    padding: 76px 0;
  }

  .contact-location-section,
  .contact-faq-section {
    background:
      radial-gradient(circle at 12% 20%, rgba(56, 187, 181, 0.08), transparent 24rem),
      radial-gradient(circle at 90% 72%, rgba(201, 127, 143, 0.08), transparent 24rem),
      rgba(255, 255, 255, 0.62);
  }

  .contact-location-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(340px, 0.92fr);
    gap: 24px;
    align-items: stretch;
  }

  .contact-location-card,
  .contact-hours-card,
  .contact-social-strip-card {
    padding: clamp(32px, 4vw, 52px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.08), transparent 14rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 252, 0.9));
  }

  .contact-section-heading {
    max-width: 920px;
    margin-bottom: 36px;
  }

  .contact-section-heading h2,
  .contact-location-card h2,
  .contact-final-card h2,
  .contact-social-strip-card h2 {
