const faqItems = [
  {
    "question": "Czy szkolenie jest dla osób początkujących?",
    "answer": "Tak, zakres Step by Step może być przygotowany dla osób, które potrzebują uporządkowanych podstaw. Poziom szkolenia powinien być dopasowany do doświadczenia uczestniczki."
  },
  {
    "question": "Czy można szkolić się z samej techniki włosa?",
    "answer": "Tak, szkolenie Silky Hairstroke Brows koncentruje się na naturalnym efekcie włosa maszynowego, kierunku linii, miękkości i precyzji."
  },
  {
    "question": "Czy szkolenie obejmuje rysunek wstępny?",
    "answer": "Tak. Rysunek wstępny jest jednym z kluczowych elementów pracy w PMU, ponieważ wpływa na proporcje, efekt końcowy i bezpieczeństwo estetyczne zabiegu."
  },
  {
    "question": "Czy szkolenie może dotyczyć korekt i błędów?",
    "answer": "Tak. Przy osobach już pracujących w branży ważnym elementem może być analiza błędów, praca ze starym pigmentem, kwalifikacja i plan naprawczy."
  },
  {
    "question": "Czy terminy szkoleń są stałe?",
    "answer": "Terminy i zakres szkolenia najlepiej ustalić indywidualnie. Najwygodniejszą ścieżką kontaktu jest wiadomość lub konsultacja organizacyjna."
  },
  {
    "question": "Gdzie odbywają się szkolenia?",
    "answer": "Szkolenia organizowane są w Bielsku-Białej. Szczegóły miejsca, zakresu i organizacji ustalane są indywidualnie przed szkoleniem."
  }
