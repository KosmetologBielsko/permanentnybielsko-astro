<script>
  const trainingVideoFrames = document.querySelectorAll("[data-training-video-frame]");

  trainingVideoFrames.forEach((frame) => {
    const video = frame.querySelector("video");
    const button = frame.querySelector("[data-training-sound-toggle]");

    if (!video || !button) return;

    button.addEventListener("click", async () => {
      video.muted = !video.muted;
      video.volume = video.muted ? 0 : 1;

      if (!video.muted) {
        button.textContent = "Wyłącz dźwięk";
        button.classList.add("is-sound-on");

        try {
          await video.play();
        } catch {
          // przeglądarka może chwilowo zablokować autoplay
        }
      } else {
        button.textContent = "Włącz dźwięk";
        button.classList.remove("is-sound-on");
      }
    });
  });
</script>

