---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProcessVideo from "../components/ProcessVideo.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/makijaz-permanentny-bielsko/";
const pageTitle = "Makijaż permanentny Bielsko-Biała | Naturalne brwi, usta i kreski";
const pageDescription =
  "Makijaż permanentny Bielsko-Biała: naturalne brwi permanentne, usta permanentne, kreski permanentne, Silky Hairstroke Brows, korekty i konsultacje u Bogusławy Herda.";

const faqItems = [
  {
    "question": "Czy makijaż permanentny może wyglądać naturalnie?",
    "answer": "Tak. Naturalny efekt zależy od rysunku wstępnego, koloru, techniki, skóry i doświadczenia osoby wykonującej zabieg. Celem nie musi być mocny makijaż — często najlepszy efekt jest subtelny, miękki i dopasowany do twarzy."
  },
  {
    "question": "Czy przed zabiegiem wykonywany jest rysunek wstępny?",
    "answer": "Tak. Rysunek wstępny jest jednym z najważniejszych etapów. Kształt, proporcje i kierunek pracy są omawiane przed pigmentacją, aby klientka wiedziała, jaki efekt planujemy uzyskać."
  },
  {
    "question": "Czym różni się rysunek wstępny od samej pigmentacji?",
    "answer": "Rysunek wstępny pokazuje plan: kształt, proporcje i kierunek pracy. Pigmentacja jest dopiero kolejnym etapem, wykonywanym po omówieniu i zaakceptowaniu planu zabiegu."
  },
  {
    "question": "Czy kolor pigmentu jest dobierany indywidualnie?",
    "answer": "Tak. Kolor powinien pasować do typu urody, skóry, naturalnej oprawy twarzy i oczekiwanego efektu. Przy naturalnym PMU zbyt ciemny lub zbyt chłodny odcień może wyglądać ciężko."
  },
  {
    "question": "Czy makijaż permanentny boli?",
    "answer": "Odczucia są indywidualne i zależą od progu wrażliwości, okolicy zabiegowej oraz stanu skóry. Podczas konsultacji omawiany jest przebieg zabiegu i komfort klientki."
  },
  {
    "question": "Jak długo utrzymuje się makijaż permanentny?",
    "answer": "Trwałość zależy od skóry, techniki, koloru, pielęgnacji, ekspozycji na słońce i metabolizmu pigmentu. Z czasem pigment stopniowo się rozjaśnia, dlatego możliwe są odświeżenia."
  },
  {
    "question": "Kiedy wykonuje się dopigmentowanie?",
    "answer": "Dopigmentowanie wykonuje się po wygojeniu skóry, gdy można ocenić kolor, nasycenie i równomierność efektu. To etap dopracowania, a nie powtarzania całego zabiegu od początku."
  },
  {
    "question": "Czy efekt od razu po zabiegu jest finalny?",
    "answer": "Nie. Bezpośrednio po zabiegu kolor może być intensywniejszy. Finalny efekt ocenia się po procesie gojenia i stabilizacji pigmentu w skórze."
  },
  {
    "question": "Czy można poprawić stary makijaż permanentny?",
    "answer": "Czasem tak, ale wymaga to oceny starego pigmentu. Niekiedy konieczne jest wcześniejsze rozjaśnienie, usuwanie PMU albo zaplanowanie pracy etapami."
  },
  {
    "question": "Kiedy lepiej najpierw usunąć lub rozjaśnić stary PMU?",
    "answer": "Gdy stary pigment jest zbyt ciemny, zbyt chłodny, nierówny albo ma niekorzystny kształt, nowa pigmentacja może nie dać naturalnego efektu bez wcześniejszego przygotowania skóry."
  },
  {
    "question": "Jak przygotować się do konsultacji?",
    "answer": "Warto przemyśleć, czy oczekiwany efekt ma być bardzo naturalny, czy bardziej widoczny. Dobrze też poinformować o wcześniejszych pigmentacjach, zabiegach, lekach i wrażliwości skóry."
  },
  {
    "question": "Gdzie wykonywany jest zabieg?",
    "answer": "Zabiegi wykonywane są w gabinecie Bogusławy Herda w Bielsku-Białej. Rezerwacje i aktualne terminy są dostępne przez Booksy."
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "url": pageUrl,
    "name": pageTitle,
    "description": pageDescription,
    "inLanguage": "pl-PL",
    "isPartOf": {
      "@id": "https://permanentnybielsko.com/#website"
    },
    "about": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "primaryImageOfPage": {
      "@type": "ImageObject",
      "url": "https://permanentnybielsko.com/images/hero-boguslawa-herda-pmu-cutout.webp"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Strona główna",
        "item": "https://permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Makijaż permanentny Bielsko-Biała",
        "item": pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${pageUrl}#service`,
    "name": "Makijaż permanentny Bielsko-Biała",
    "serviceType": "Makijaż permanentny",
    "description":
      "Naturalny makijaż permanentny brwi, ust i kresek w Bielsku-Białej, poprzedzony konsultacją, analizą urody i rysunkiem wstępnym.",
    "areaServed": [
      {
        "@type": "City",
        "name": "Bielsko-Biała"
      },
      {
        "@type": "AdministrativeArea",
        "name": "województwo śląskie"
      }
    ],
    "provider": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "brand": {
      "@type": "Brand",
      "name": "Bogusława Herda Makijaż Permanentny"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Oferta makijażu permanentnego",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Brwi permanentne"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Makijaż permanentny ust"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Kreski permanentne"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Korekta lub odświeżenie makijażu permanentnego"
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];

---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/makijaz-permanentny-bielsko/"
  structuredData={structuredData}
>
  <div class="pmu-service-page">
    <Header />

    <main>
      <section class="pmu-hero">
        <div class="pmu-glow pmu-glow-one"></div>
        <div class="pmu-glow pmu-glow-two"></div>

        <div class="container pmu-hero-grid">
          <div class="pmu-hero-copy">
            <p class="section-kicker">Makijaż permanentny Bielsko-Biała</p>

            <h1> 
              <span class="pmu-hero-gold-text">Naturalny makijaż permanentny</span> dopasowany do twarzy, nie do schematu.
            </h1>

            <p class="pmu-hero-lead">
              Brwi permanentne, usta permanentne i kreski permanentne wykonywane z myślą
              o harmonii twarzy, naturalnym efekcie i spokojnym podkreśleniu urody.
            </p>

            <div class="pmu-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację
              </a>

              <a class="button-secondary" href="#zakres-zabiegow">
                Zobacz zakres
              </a>
            </div>
          </div>

          <aside class="pmu-hero-card" aria-label="Najważniejsze informacje">
            <p class="pmu-card-label">PMU</p>
            <h2>Efekt ma być widoczny, ale nie powinien krzyczeć.</h2>
            <p>
              W gabinecie Bogusławy Herda makijaż permanentny zaczyna się od rozmowy,
              analizy urody i rysunku wstępnego. Dopiero później wybierana jest technika, kolor
              i intensywność pigmentacji.
            </p>
          </aside>
        </div>
      </section>

      <section class="pmu-proof-section">
        <div class="container pmu-proof-grid">
          <div>
            <strong>Wicemistrzyni świata</strong>
            <span>doświadczenie konkursowe PMU</span>
          </div>

          <div>
            <strong>Trenerka Long-Time-Liner®</strong>
            <span>standard edukacji i precyzji</span>
          </div>

          <div>
            <strong>Silky Hairstroke Brows</strong>
            <span>autorskie podejście do brwi</span>
          </div>

          <div>
            <strong>Naturalny efekt</strong>
            <span>bez ciężkiej, graficznej formy</span>
          </div>
        </div>
      </section>

      <section class="pmu-intro-section">
        <div class="container pmu-two-column">
          <div>
            <p class="section-kicker">Dla kogo jest PMU?</p>
            <h2>Makijaż permanentny dla kobiet, które chcą wyglądać świeżo, ale nadal czuć się sobą.</h2>
          </div>

          <div class="pmu-text-card">
            <p>
              Dobrze wykonany makijaż permanentny nie powinien dominować nad twarzą.
              Jego zadaniem jest uporządkowanie proporcji, subtelne podkreślenie oprawy oka,
              odświeżenie ust albo dodanie spojrzeniu wyrazistości w sposób dopasowany
              do codziennego stylu klientki.
            </p>

            <p>
              Każdy zabieg poprzedza konsultacja i rysunek wstępny. Omawiany jest kształt, kolor,
              intensywność, możliwy sposób gojenia oraz oczekiwany efekt końcowy.
              To ważne szczególnie wtedy, gdy klientka chce naturalnego rezultatu,
              a nie mocnego makijażu widocznego z daleka.
            </p>
          </div>
        </div>
      </section>

      <section class="pmu-portrait-section" aria-label="Naturalny makijaż permanentny i analiza urody">
        <div class="container pmu-portrait-card">
          <div class="pmu-portrait-copy">
            <p class="section-kicker">Naturalny efekt</p>
            <h2>Naturalny makijaż permanentny zaczyna się od właściwej decyzji.</h2>
            <p>
              Makijaż permanentny nie powinien być przypadkowym zabiegiem ani kopią zdjęcia
              z internetu. Najpierw analizowana jest twarz, mimika, kolor skóry, oprawa oka
              i oczekiwania klientki.
            </p>
            <p>
              Dopiero później powstaje rysunek wstępny i decyzja o pigmentacji. Dzięki temu
              efekt może być widoczny, ale nadal subtelny — dopasowany do urody, wieku, skóry
              i codziennego stylu życia.
            </p>

            <div class="pmu-portrait-points" aria-label="Etapy naturalnego makijażu permanentnego">
              <span>analiza twarzy</span>
              <span>rysunek wstępny</span>
              <span>naturalny efekt</span>
              <span>bez przerysowania</span>
            </div>
          </div>

          <figure class="pmu-portrait-photo">
            <img
              src="/images/portret-boguslawa-herda-naturalny-pmu.webp"
              alt="Bogusława Herda – naturalny makijaż permanentny Bielsko-Biała, subtelny efekt i elegancki portret PMU"
              width="1024"
              height="1536"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
      </section>

      <section class="pmu-services-section" id="zakres-zabiegow">
        <div class="container">
          <div class="pmu-section-heading">
            <p class="section-kicker">Zakres zabiegów</p>
            <h2>Brwi, usta i kreski — każda strefa wymaga innej decyzji.</h2>
            <p>
              W makijażu permanentnym nie ma jednej techniki dobrej dla wszystkich.
              Liczy się skóra, uroda, mimika, wiek, wcześniejsze pigmentacje i oczekiwany efekt.
            </p>
          </div>

          <figure class="pmu-services-collage" aria-label="Zakres makijazu permanentnego: brwi, usta i kreski">
            <img
              src="/images/zakres-zabiegow-pmu-boguslawa-herda.webp"
              alt="Zakres zabiegow makijazu permanentnego Boguslawa Herda - brwi permanentne, usta permanentne i kreski permanentne"
              width="1672"
              height="941"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="pmu-service-grid">
            <article class="pmu-service-card">
              <span>01</span>
              <h3>Brwi permanentne</h3>
              <p>
                Miękka oprawa oka, naturalny kształt i kolor dobrany do urody.
                Brwi mają porządkować twarz, ale nie tworzyć ciężkiej ramy.
              </p>
            </article>

            <article class="pmu-service-card pmu-service-card-turquoise pmu-premium-mark-card">
              <span class="pmu-big-mark" aria-hidden="true">SHB</span>
              <span>02</span>
              <h3>Silky Hairstroke Brows</h3>
              <p>
                Autorskie podejście do techniki włosa maszynowego. Efekt dla klientek,
                które szukają naturalnego kierunku włosa, lekkości i precyzji.
              </p>
            </article>

            <article class="pmu-service-card">
              <span>03</span>
              <h3>Usta permanentne</h3>
              <p>
                Delikatne odświeżenie koloru, wyrównanie czerwieni wargowej i poprawa konturu
                bez efektu przerysowanych ust.
              </p>
            </article>

            <article class="pmu-service-card">
              <span>04</span>
              <h3>Kreski permanentne</h3>
              <p>
                Subtelne zagęszczenie linii rzęs albo bardziej widoczne podkreślenie oka,
                dopasowane do kształtu powieki i stylu klientki.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="pmu-process-section">
        <div class="container">
             <div class="pmu-process-feature-row">
            <div class="pmu-process-feature-card">
              <p class="section-kicker">Proces</p>
              <h2>Nie zaczynamy od pigmentu. Zaczynamy od rozmowy i rysunku wstępnego.</h2>
              <p>
                Konsultacja pozwala ustalić, czy zabieg jest właściwym rozwiązaniem,
                jaki efekt będzie realny i jak zaplanować rysunek wstępny oraz pigmentację,
                żeby nie przesadzić z kształtem, kolorem ani intensywnością.
              </p>
            </div>

            <ProcessVideo />

            <div class="pmu-process-mini-list">
              <div>
                <strong>Konsultacja</strong>
                <span>rozmowa o oczekiwaniach, stylu, skórze i przeciwwskazaniach</span>
              </div>

              <div>
                <strong>Rysunek wstępny</strong>
                <span>kształt, proporcje i kierunek pracy omawiane przed pigmentacją</span>
              </div>

              <div>
                <strong>Pigmentacja i gojenie</strong>
                <span>kontrola nasycenia, reakcji skóry i finalnego dopigmentowania</span>
              </div>
            </div>
          </div>

          <div class="pmu-process-grid">
            <article>
              <span>01</span>
              <h3>Konsultacja</h3>
              <p>Rozmowa o oczekiwaniach, stylu, skórze i przeciwwskazaniach.</p>
            </article>

            <article>
              <span>02</span>
              <h3>Analiza urody</h3>
              <p>Ocena proporcji twarzy, mimiki, koloru skóry i naturalnej oprawy.</p>
            </article>

            <article>
              <span>03</span>
              <h3>Rysunek wstępny</h3>
              <p>Kształt, proporcje i kierunek pracy są omawiane w rysunku wstępnym przed rozpoczęciem pigmentacji.</p>
            </article>

            <article>
              <span>04</span>
              <h3>Pigmentacja</h3>
              <p>Precyzyjna praca warstwowa z kontrolą nasycenia i reakcji skóry.</p>
            </article>

            <article>
              <span>05</span>
              <h3>Gojenie</h3>
              <p>Kolor i intensywność stabilizują się po czasie, zgodnie z procesem skóry.</p>
            </article>

            <article>
              <span>06</span>
              <h3>Dopigmentowanie</h3>
              <p>Finalne dopracowanie detalu, równowagi i nasycenia pigmentu.</p>
            </article>
        
          </div>
        </div>
      </section>

      <section class="pmu-expert-section" aria-label="Dlaczego Bogusława Herda">
        <div class="container pmu-expert-card">
          <figure class="pmu-expert-photo">
            <img
              src="/images/dlaczego-boguslawa-herda-pmu.webp"
              alt="Bogusława Herda – ekspertka makijażu permanentnego w Bielsku-Białej"
              width="1024"
              height="1536"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="pmu-expert-copy">
            <div class="pmu-expert-heading">
              <p class="section-kicker">Dlaczego Bogusława Herda</p>

              <h2>
                  Makijaż permanentny wymaga doświadczenia, precyzji i wyczucia naturalnego efektu.
              </h2>

              <p>
                  W pracy Bogusławy Herda liczy się nie tylko technika pigmentacji, ale też decyzja:
                  kiedy wzmocnić rysunek, kiedy zostawić lekkość, kiedy odmówić zbyt mocnego efektu
                  i kiedy zaplanować pracę etapami.
              </p>

              <p>
                  Dlatego każda pigmentacja zaczyna się od analizy twarzy, skóry, oczekiwań i rysunku
                  wstępnego — tak, aby efekt był widoczny, ale nadal spokojny, kobiecy i dopasowany
                  do codzienności.
              </p>
            </div>

            <div class="pmu-expert-grid" aria-label="Najważniejsze wyróżniki Bogusławy Herda">
              <article>
                <span>01</span>
                <strong>Wicemistrzyni świata</strong>
                <p>doświadczenie konkursowe i wysoki standard pracy w makijażu permanentnym</p>
              </article>

              <article>
                <span>02</span>
                <strong>8-krotna mistrzyni</strong>
                <p>lata rozwoju, praktyki i konsekwentnego budowania jakości zabiegów PMU</p>
              </article>

              <article>
                <span>03</span>
                <strong>Trenerka Long-Time-Liner®</strong>
                <p>praca w standardzie marki, która mocno wpłynęła na jej rozwój zawodowy</p>
              </article>

              <article>
                <span>04</span>
                <strong>Silky Hairstroke Brows</strong>
                <p>autorskie podejście do naturalnych brwi i lekkiego efektu włosa maszynowego</p>
              </article>

              <article>
                <span>05</span>
                <strong>Doświadczenie międzynarodowe</strong>
                <p>udział w wydarzeniach, szkoleniach, konkursach i projektach branżowych PMU</p>
              </article>

              <article>
                <span>06</span>
                <strong>Naturalny efekt</strong>
                <p>makijaż permanentny dopasowany do twarzy, skóry i codziennego stylu klientki</p>
              </article>
            </div>
          </div>
        </div>
      </section>
      <section class="pmu-safety-section">
        <div class="container pmu-safety-grid">
          <div class="pmu-safety-card">
            <p class="section-kicker">Bezpieczeństwo i kwalifikacja</p>
            <h2>Nie każdy zabieg trzeba wykonać od razu.</h2>
            <p>
              Czasem najlepszą decyzją jest odłożenie pigmentacji, rozjaśnienie starego PMU,
              korekta koloru albo spokojne przygotowanie skóry. Naturalny efekt wymaga nie tylko
              umiejętności, ale też odpowiedzialnej kwalifikacji.
            </p>
          </div>

          <div class="pmu-list-card">
            <div>
              <strong>Stare pigmentacje</strong>
              <span>ocena koloru, nasycenia i możliwości wykonania nowej pracy</span>
            </div>

            <div>
              <strong>Dobór techniki</strong>
              <span>brwi pudrowe, włos maszynowy, usta, kreski lub korekta</span>
            </div>

            <div>
              <strong>Naturalna intensywność</strong>
              <span>efekt dopasowany do twarzy, nie do chwilowego trendu</span>
            </div>

            <div>
              <strong>Zalecenia po zabiegu</strong>
              <span>pielęgnacja i gojenie omawiane indywidualnie po pigmentacji</span>
            </div>
          </div>
        </div>
      </section>
      <section class="pmu-next-section" aria-label="Wybierz obszar makijażu permanentnego">
        <div class="container">
          <div class="pmu-next-heading">
            <p class="section-kicker">Wybierz obszar PMU</p>

            <h2>
              Każda strefa twarzy potrzebuje innej decyzji.
            </h2>

            <p>
              Brwi, usta, kreski, korekta starego pigmentu albo szkolenia PMU — każda ścieżka
              ma własny rytm, inne potrzeby i inny sposób prowadzenia klientki lub kursantki.
            </p>
          </div>

