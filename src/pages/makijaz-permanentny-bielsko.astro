<script>
  const pmuNextScroll = document.querySelector("#pmuNextScroll");
  const pmuNextLeft = document.querySelector(".pmu-next-arrow-left");
  const pmuNextRight = document.querySelector(".pmu-next-arrow-right");

  if (pmuNextScroll && pmuNextLeft && pmuNextRight) {
    const getScrollAmount = () => {
      const firstCard = pmuNextScroll.querySelector(".pmu-next-card");
      if (!firstCard) return 320;

      const cardWidth = firstCard.getBoundingClientRect().width;
      return cardWidth + 18;
    };

    pmuNextLeft.addEventListener("click", () => {
      pmuNextScroll.scrollBy({
        left: -getScrollAmount(),
        behavior: "smooth",
      });
    });

    pmuNextRight.addEventListener("click", () => {
      pmuNextScroll.scrollBy({
        left: getScrollAmount(),
        behavior: "smooth",
      });
    });
  }
</script>

