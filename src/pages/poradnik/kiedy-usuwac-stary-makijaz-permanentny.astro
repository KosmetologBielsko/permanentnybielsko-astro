---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

/*
  SZABLON ARTYKUŁU PORADNIKA PMU

  Jak używać:
  1. Skopiuj ten plik.
  2. Zmień nazwę pliku na docelowy adres, np.
     jak-przygotowac-sie-do-makijazu-permanentnego-brwi.astro
  3. Wklej do:
     src/pages/poradnik/
  4. Uzupełnij dane poniżej: title, description, slug, lead, sekcje, FAQ, zdjęcia.

  Założenie:
  - tekst jest najważniejszy,
  - układ jest spokojny, czytelny i powtarzalny,
  - zdjęcia są opcjonalne: 0, 1 albo 2,
  - kafelki są proste, bez ciężkich efektów.
*/

const article = {
  "slug": "kiedy-usuwac-stary-makijaz-permanentny",
  "title": "Kiedy nie poprawiać starego PMU, tylko najpierw je rozjaśnić?",
  "eyebrow": "Poradnik PMU",
  "category": "Usuwanie PMU",
  "datePublished": "2026-06-08",
  "dateModified": "2026-06-08",
  "readingTime": "8–10 minut",
  "description": "Kiedy usuwać stary makijaż permanentny, a kiedy można go poprawić? Sprawdź, kiedy potrzebne jest laserowe usuwanie PMU, remover, korekta lub plan etapowy.",
  "lead": "Stary makijaż permanentny nie zawsze da się bezpiecznie przykryć nową pigmentacją. Jeśli pigment jest zbyt ciemny, nierówny, szary, czerwony, granatowy albo wyszedł poza dobry kształt, najlepszym pierwszym krokiem może być rozjaśnienie, a nie kolejna warstwa koloru.",
  "shortAnswer": "Starego PMU nie warto poprawiać na siłę, gdy pigment jest zbyt ciemny, chłodny, czerwony, szary, szeroki, nierówny albo nie pasuje do planowanego kształtu. Wtedy lepszym początkiem bywa laserowe rozjaśnianie, remover albo etapowa korekta. Nowy makijaż permanentny powinien być wykonany dopiero wtedy, gdy skóra i pigment dają warunki do dobrego efektu.",
  "canonicalPath": "/poradnik/kiedy-usuwac-stary-makijaz-permanentny/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie PMU"
  },
  "faqHeading": "Pytania o usuwanie i korektę starego PMU"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#kiedy-nie-przykrywac",
    "title": "Kiedy nie przykrywać"
  },
  {
    "href": "#laser-remover",
    "title": "Laser i remover"
  },
  {
    "href": "#plan",
    "title": "Plan etapowy"
  },
  {
    "href": "#nowa-pigmentacja",
    "title": "Nowy zabieg"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Ciemnego, szerokiego lub nierównego PMU nie warto przykrywać kolejną warstwą pigmentu.",
  "Laser i remover mają inne zastosowania — decyzja wymaga kwalifikacji.",
  "Rozjaśnianie starego pigmentu często jest etapem przygotowania do nowego, naturalnego efektu.",
  "Najważniejsze jest bezpieczeństwo skóry i realna możliwość uzyskania lepszego kształtu."
];

const sections = [
  {
    "id": "kiedy-nie-przykrywac",
    "eyebrow": "Kiedy nie przykrywać?",
    "title": "Kolejna pigmentacja nie zawsze rozwiązuje problem.",
    "paragraphs": [
      "Jeśli stary makijaż permanentny jest zbyt ciemny, zimny, szary, czerwony, granatowy, nierówny albo ma niekorzystny kształt, przykrycie go nowym kolorem może tylko pogłębić problem. Skóra ma swoją pojemność, a kolejne warstwy pigmentu nie zawsze dają czystszy efekt.",
      "Najczęstszy błąd to próba szybkiej korekty bez rozjaśnienia starego koloru. Przy zbyt mocnym pigmencie naturalny efekt brwi, ust czy kresek może być niemożliwy bez wcześniejszego przygotowania skóry."
    ],
    "cards": [
      {
        "title": "Za ciemny pigment",
        "text": "Czerń, grafit, granat albo mocny chłodny odcień często wymagają rozjaśnienia."
      },
      {
        "title": "Zły kształt",
        "text": "Jeśli stary PMU wychodzi poza dobry projekt, nowa pigmentacja może go nie ukryć."
      }
    ]
  },
  {
    "id": "laser-remover",
    "eyebrow": "Laser i remover",
    "title": "Metodę rozjaśniania dobiera się do pigmentu i skóry.",
    "paragraphs": [
      "Laserowe usuwanie makijażu permanentnego i remover to różne narzędzia. Ich wybór zależy od koloru pigmentu, głębokości, obszaru, historii wcześniejszych zabiegów i reakcji skóry. Nie istnieje jedna odpowiedź dobra dla wszystkich przypadków.",
      "Celem często nie jest całkowite usunięcie pigmentu za wszelką cenę, ale takie rozjaśnienie, które pozwoli wykonać nowy, czystszy i bardziej naturalny projekt. To dlatego konsultacja przed usuwaniem PMU jest tak ważna."
    ],
    "cards": [
      {
        "title": "Laser",
        "text": "Może być stosowany przy określonych kolorach i typach pigmentu, po kwalifikacji."
      },
      {
        "title": "Remover",
        "text": "Bywa rozważany w innych sytuacjach, zależnie od skóry i rodzaju starej pigmentacji."
      }
    ]
  },
  {
    "id": "plan",
    "eyebrow": "Plan etapowy",
    "title": "Stary PMU często wymaga cierpliwości.",
    "paragraphs": [
      "Rozjaśnianie starego makijażu permanentnego rzadko jest decyzją na jeden dzień. Czasem potrzebny jest plan kilku etapów, przerwy na regenerację skóry i stopniowa ocena, jak pigment reaguje.",
      "To podejście może wydawać się dłuższe, ale często daje większą szansę na dobry efekt końcowy. Przy naturalnej pigmentacji najważniejsze jest to, żeby nie dokładać problemu do problemu."
    ],
    "cards": [
      {
        "title": "Etapy",
        "text": "Między sesjami skóra musi mieć czas na regenerację."
      },
      {
        "title": "Kontrola efektu",
        "text": "Po każdym etapie ocenia się, czy można przejść dalej."
      }
    ]
  },
  {
    "id": "nowa-pigmentacja",
    "eyebrow": "Nowa pigmentacja",
    "title": "Nowy makijaż permanentny powinien być wykonany dopiero na dobrych warunkach.",
    "paragraphs": [
      "Po rozjaśnieniu starego pigmentu można wrócić do rysunku wstępnego i zaplanować nowy efekt. Wtedy łatwiej dobrać kształt, kolor i technikę bez konieczności przykrywania zbyt mocnej poprzedniej pracy.",
      "Właśnie dlatego czasem najlepsza korekta zaczyna się od decyzji: jeszcze nie pigmentujemy. Najpierw tworzymy warunki, które pozwolą uzyskać lżejszy, bardziej estetyczny i bezpieczniejszy rezultat."
    ],
    "cards": [
      {
        "title": "Nowy projekt",
        "text": "Po rozjaśnieniu łatwiej zaplanować brwi, usta lub kreski od nowa."
      },
      {
        "title": "Naturalniejszy efekt",
        "text": "Mniejsza ilość starego pigmentu daje większą szansę na lekkość."
      }
    ]
  }
];

const warningBox = {
  "title": "Nie usuwaj i nie przykrywaj PMU bez kwalifikacji.",
  "text": "Stary makijaż permanentny wymaga obejrzenia na żywo. Zdjęcie pomaga, ale nie zawsze pokazuje głębokość pigmentu, stan skóry i realne możliwości korekty. Decyzję o laserze, removerze albo nowej pigmentacji najlepiej podjąć po konsultacji."
};

const relatedLinks = [
  {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie makijażu permanentnego",
    "text": "Zobacz ofertę rozjaśniania i usuwania starego PMU."
  },
  {
    "href": "/poradnik/rysunek-wstepny-przed-makijazem-permanentnym/",
    "title": "Rysunek wstępny",
    "text": "Sprawdź, jak projekt pomaga ocenić ograniczenia starego pigmentu."
  },
  {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Brwi permanentne",
    "text": "Zobacz, jak planuje się nowy efekt po rozjaśnieniu starego PMU."
  }
];

const faqItems = [
  {
    "question": "Czy każdy stary makijaż permanentny trzeba usuwać?",
    "answer": "Nie każdy. Czasem możliwa jest korekta, ale przy zbyt ciemnym, szerokim albo niekorzystnym pigmencie rozjaśnienie może być lepszym początkiem."
  },
  {
    "question": "Czy laserowe usuwanie PMU usuwa pigment całkowicie?",
    "answer": "To zależy od pigmentu, skóry, głębokości i liczby sesji. Często celem jest rozjaśnienie pozwalające na nową pigmentację."
  },
  {
    "question": "Czym różni się laser od removera?",
    "answer": "To różne metody pracy z pigmentem. Wybór zależy od rodzaju starego PMU, koloru, skóry i kwalifikacji."
  },
  {
    "question": "Kiedy można zrobić nowy makijaż permanentny po rozjaśnianiu?",
    "answer": "Dopiero po regeneracji skóry i ocenie efektu rozjaśnienia. Termin ustala się indywidualnie."
  },
  {
    "question": "Czy można przykryć czerwone lub szare brwi?",
    "answer": "Nie zawsze. Przy niekorzystnym kolorze najpierw może być potrzebne rozjaśnienie albo neutralizacja według indywidualnego planu."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-sidebar-card nav,
  .article-sidebar-card {
    display: grid;
    gap: 8px;
  }

  .article-sidebar-card a {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.94rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .article-sidebar-card a:hover {
    color: #0f7773;
  }

  .article-sidebar-card-soft {
    background: rgba(219, 246, 243, 0.46);
  }

  .article-main {
    display: grid;
    gap: 22px;
    min-width: 0;
  }

  .article-answer-card,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
