---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "kurs-makijazu-permanentnego-cena",
  "title": "Kurs makijażu permanentnego cena — od czego zależy koszt szkolenia PMU?",
  "eyebrow": "Poradnik PMU",
  "category": "Szkolenia PMU",
  "datePublished": "2026-06-21",
  "dateModified": "2026-06-21",
  "readingTime": "9–11 minut",
  "description": "Kurs makijażu permanentnego cena. Sprawdź, od czego zależy koszt szkolenia PMU, co powinno obejmować dobre szkolenie i dlaczego doświadczenie trenera ma znaczenie.",
  "lead": "Cena kursu makijażu permanentnego zależy od zakresu szkolenia, poziomu zaawansowania, liczby dni, pracy praktycznej, opieki trenera oraz tego, czy kursantka uczy się wyłącznie teorii, czy realnej pracy zabiegowej pod okiem doświadczonej linergistki.",
  "shortAnswer": "Cena kursu makijażu permanentnego nie powinna być oceniana tylko jako liczba godzin szkolenia. Ważne jest, kto prowadzi kurs, jaki jest zakres praktyki, czy szkolenie obejmuje pracę na modelkach, analizę skóry, technikę, rysunek, gojenie, bezpieczeństwo i wsparcie po szkoleniu. W przypadku szkoleń PMU u Bogusławy Herda zakres i cena powinny być ustalane zgodnie z poziomem kursantki i celem edukacyjnym.",
  "canonicalPath": "/poradnik/kurs-makijazu-permanentnego-cena/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/szkolenie-makijaz-permanentny/",
    "title": "Szkolenie makijażu permanentnego"
  },
  "faqHeading": "Pytania o cenę kursu makijażu permanentnego"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#od-czego-zalezy-cena",
    "title": "Od czego zależy cena?"
  },
  {
    "href": "#co-powinno-byc-w-kursie",
    "title": "Co obejmuje kurs?"
  },
  {
    "href": "#autorytet-trenera",
    "title": "Autorytet trenera"
  },
  {
    "href": "#tani-kurs",
    "title": "Tani kurs PMU"
  },
  {
    "href": "#dla-kogo",
    "title": "Dla kogo?"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Cena kursu PMU zależy od zakresu, praktyki, poziomu szkolenia i opieki trenera.",
  "Najważniejsze są realne umiejętności po szkoleniu, a nie sama liczba godzin w opisie oferty.",
  "Doświadczenie trenera ma ogromne znaczenie, szczególnie przy technice, rysunku, skórze i bezpieczeństwie.",
  "Szkolenie powinno prowadzić do samodzielniejszej, odpowiedzialnej pracy, a nie tylko do otrzymania certyfikatu."
];

const sections = [
  {
    "id": "od-czego-zalezy-cena",
    "eyebrow": "Cena kursu",
    "title": "Od czego zależy cena kursu makijażu permanentnego?",
    "paragraphs": [
      "Cena szkolenia PMU zależy od wielu elementów: zakresu tematycznego, liczby dni, poziomu zaawansowania, pracy praktycznej, liczby uczestników, jakości materiałów, doświadczenia trenera i wsparcia po szkoleniu. Tego nie da się dobrze ocenić tylko po haśle: kurs makijażu permanentnego cena.",
      "Inaczej wyceniane będzie szkolenie podstawowe, inaczej masterclass z konkretnej techniki, a jeszcze inaczej indywidualne szkolenie dopasowane do problemów kursantki. Najważniejsze pytanie brzmi: co realnie potrafisz po szkoleniu i czy masz wsparcie w dalszym rozwoju."
    ],
    "cards": [
      {
        "title": "Zakres szkolenia",
        "text": "Cena zależy od tego, czy kurs obejmuje podstawy PMU, konkretną technikę, korekty, rysunek czy zaawansowaną pracę zabiegową."
      },
      {
        "title": "Praktyka",
        "text": "Szkolenie z realną praktyką i analizą pracy kursantki ma inną wartość niż sama teoria."
      },
      {
        "title": "Doświadczenie trenera",
        "text": "Im większe doświadczenie trenera, tym więcej kursantka może zyskać z korekty błędów i prowadzenia technicznego."
      },
      {
        "title": "Wsparcie po kursie",
        "text": "W PMU bardzo ważne jest, czy kursantka dostaje kierunek dalszego rozwoju, a nie tylko certyfikat."
      }
    ]
  },
  {
    "id": "co-powinno-byc-w-kursie",
    "eyebrow": "Zakres szkolenia",
    "title": "Co powinno obejmować dobre szkolenie PMU?",
    "paragraphs": [
      "Dobre szkolenie z makijażu permanentnego powinno łączyć teorię, praktykę, analizę skóry, rysunek wstępny, dobór pigmentu, pracę z urządzeniem, zasady bezpieczeństwa, higienę, gojenie oraz omówienie błędów, które najczęściej pojawiają się u początkujących i zaawansowanych linergistek.",
      "W praktyce kursantka potrzebuje nie tylko informacji, ale także korekty ręki, obserwacji pracy trenera, pracy na modelkach i uczciwego omówienia swoich mocnych oraz słabszych stron. To właśnie te elementy często decydują o realnej wartości szkolenia."
    ],
    "cards": [
      {
        "title": "Rysunek wstępny",
        "text": "Bez dobrego projektu trudno uzyskać harmonijny efekt PMU."
      },
      {
        "title": "Technika pracy",
        "text": "Ruch ręki, tempo, nacisk i prowadzenie igły mają ogromne znaczenie dla efektu i gojenia."
      },
      {
        "title": "Analiza skóry",
        "text": "Skóra decyduje o tym, jaka technika będzie bezpieczna i przewidywalna."
      },
      {
        "title": "Praca z błędami",
        "text": "Najcenniejsze szkolenia uczą nie tylko wykonywania zabiegu, ale też rozpoznawania i korygowania błędów."
      }
    ]
  },
  {
    "id": "autorytet-trenera",
    "eyebrow": "Trener PMU",
    "title": "Dlaczego doświadczenie trenera wpływa na wartość szkolenia?",
    "paragraphs": [
      "W makijażu permanentnym trener przekazuje nie tylko schemat zabiegu. Dobry trener uczy myślenia: jak kwalifikować skórę, jak projektować efekt, jak unikać błędów, jak reagować na trudności i jak prowadzić klientkę przed oraz po zabiegu.",
      "Bogusława Herda to dyplomowana linergistka i trenerka makijażu permanentnego, Elite Top Linergist Long-Time-Liner®, trenerka i prelegentka międzynarodowa, wicemistrzyni świata oraz mistrzyni Polski. Wieloletnia praca zabiegowa, szkoleniowa i sceniczna pozwala prowadzić kursantki nie tylko przez technikę, ale też przez standard pracy, odpowiedzialność i estetykę naturalnego efektu."
    ],
    "cards": [
      {
        "title": "Doświadczenie zabiegowe",
        "text": "Trener, który pracuje z klientkami, zna realne problemy skóry, gojenia i oczekiwań."
      },
      {
        "title": "Doświadczenie szkoleniowe",
        "text": "Umiejętność wykonania zabiegu to jedno, a umiejętność nauczenia tej pracy to drugi poziom kompetencji."
      },
      {
        "title": "Standard pracy",
        "text": "Szkolenie powinno uczyć jakości, odpowiedzialności i przewidywalności efektu."
      },
      {
        "title": "Rozwój kursantki",
        "text": "Dobry kurs pomaga zobaczyć, co poprawić, jak ćwiczyć i w jakim kierunku rozwijać technikę."
      }
    ]
  },
  {
    "id": "tani-kurs",
    "eyebrow": "Cena a jakość",
    "title": "Czy tani kurs makijażu permanentnego to dobry wybór?",
    "paragraphs": [
      "Niska cena kursu może być kusząca, ale w PMU najważniejsze jest to, co kursantka potrafi po szkoleniu. Jeżeli brakuje praktyki, korekty ręki, pracy na modelkach, omówienia skóry i wsparcia po kursie, pozorna oszczędność może szybko stać się problemem.",
      "Makijaż permanentny to praca na twarzy klientki. Błędy techniczne, zły rysunek, zły dobór pigmentu lub brak zrozumienia skóry mogą mieć konsekwencje dla efektu, opinii i dalszej pracy zawodowej. Dlatego cena kursu powinna być oceniana razem z zakresem i jakością nauczania."
    ],
    "cards": [
      {
        "title": "Nie tylko certyfikat",
        "text": "Certyfikat jest ważny, ale nie zastępuje realnej umiejętności pracy z klientką."
      },
      {
        "title": "Praktyka ma znaczenie",
        "text": "W PMU najwięcej uczysz się wtedy, gdy ktoś doświadczony widzi Twoją pracę i potrafi ją skorygować."
      }
    ]
  },
  {
    "id": "dla-kogo",
    "eyebrow": "Dla kogo?",
    "title": "Dla kogo może być szkolenie z makijażu permanentnego?",
    "paragraphs": [
      "Szkolenie PMU może być kierunkiem dla osób, które chcą rozpocząć pracę w makijażu permanentnym, ale także dla linergistek, które już pracują i chcą poprawić technikę, rysunek, naturalność efektu albo konkretną metodę.",
      "Najlepszy zakres szkolenia zależy od punktu startowego. Inaczej prowadzi się osobę początkującą, inaczej osobę po pierwszych kursach, a jeszcze inaczej linergistkę, która chce wejść na wyższy poziom techniczny."
    ],
    "cards": [
      {
        "title": "Początkujące linergistki",
        "text": "Potrzebują podstaw, bezpieczeństwa, rysunku, pracy z urządzeniem i zrozumienia skóry."
      },
      {
        "title": "Osoby po kursach",
        "text": "Często potrzebują uporządkowania techniki, korekty błędów i większej pewności w pracy."
      },
      {
        "title": "Zaawansowane linergistki",
        "text": "Mogą szukać masterclass, konkretnej techniki albo indywidualnej analizy pracy."
      },
      {
        "title": "Gabinet beauty",
        "text": "Szkolenie PMU może być elementem rozwoju oferty, ale wymaga odpowiedzialnego przygotowania."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy warto zapytać o indywidualny zakres szkolenia?",
  "text": "Indywidualny zakres szkolenia jest szczególnie ważny, jeśli kursantka ma już doświadczenie, ale chce poprawić konkretny problem: rysunek, brwi, usta, kreski, pracę ręki, tempo, dobór pigmentu, gojenie albo naturalność efektu. Wtedy cena powinna wynikać z realnego celu szkolenia."
};

const relatedLinks = [
  {
    "href": "/szkolenie-makijaz-permanentny/",
    "title": "Szkolenie makijażu permanentnego",
    "text": "Poznaj ofertę szkoleń PMU z Bogusławą Herda."
  },
  {
    "href": "/poradnik/",
    "title": "Poradnik PMU",
    "text": "Zobacz poradniki o makijażu permanentnym, szkoleniach i przygotowaniu do zabiegów."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Zobacz ceny zabiegów PMU i odświeżeń."
  },
  {
    "href": "/makijaz-permanentny-bielsko/",
    "title": "Makijaż permanentny Bielsko-Biała",
    "text": "Zobacz standard pracy gabinetu i filozofię naturalnego efektu."
  }
];

const faqItems = [
  {
    "question": "Ile kosztuje kurs makijażu permanentnego?",
    "answer": "Cena kursu zależy od zakresu szkolenia, liczby dni, poziomu zaawansowania, praktyki, pracy na modelkach, opieki trenera i wsparcia po szkoleniu. Najlepiej ustalić ją po określeniu celu edukacyjnego."
  },
  {
    "question": "Od czego zależy cena szkolenia PMU?",
    "answer": "Od zakresu materiału, poziomu kursantki, rodzaju techniki, liczby uczestników, praktyki, materiałów szkoleniowych, doświadczenia trenera i wsparcia po kursie."
  },
  {
    "question": "Czy warto wybrać najtańszy kurs makijażu permanentnego?",
    "answer": "Nie zawsze. W PMU najważniejsze są realne umiejętności, praktyka, korekta błędów i bezpieczeństwo pracy z klientką. Najniższa cena może oznaczać mniejszy zakres nauki."
  },
  {
    "question": "Czy kurs PMU powinien obejmować praktykę?",
    "answer": "Tak. Praktyka, obserwacja pracy trenera i korekta ręki są bardzo ważne, ponieważ makijaż permanentny wymaga precyzji i kontroli techniki."
  },
  {
    "question": "Czy kurs makijażu permanentnego jest dla osób początkujących?",
    "answer": "Tak, ale zakres szkolenia powinien być dopasowany do poziomu osoby początkującej. Inne potrzeby ma osoba bez doświadczenia, a inne linergistka po pierwszych szkoleniach."
  },
  {
    "question": "Dlaczego doświadczenie trenera jest ważne?",
    "answer": "Trener uczy nie tylko schematu zabiegu, ale też kwalifikacji skóry, rysunku, pracy z błędami, bezpieczeństwa, gojenia i estetyki efektu."
  },
  {
    "question": "Czy po kursie potrzebne jest dalsze wsparcie?",
    "answer": "W wielu przypadkach tak. PMU wymaga praktyki i rozwoju, dlatego wsparcie po szkoleniu może być bardzo ważne dla utrwalenia techniki i pewności pracy."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaka metoda brwi będzie najlepsza dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym brwi najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór metody, która będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

