---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "czego-nie-wolno-po-makijazu-permanentnym-brwi",
  "title": "Czego nie wolno po makijażu permanentnym brwi? Mycie, smarowanie i pielęgnacja",
  "eyebrow": "Poradnik PMU",
  "category": "Pielęgnacja po PMU brwi",
  "datePublished": "2026-06-18",
  "dateModified": "2026-06-18",
  "readingTime": "8–10 minut",
  "description": "Co robić po makijażu permanentnym brwi, a czego unikać? Mycie, smarowanie, strupki, sauna, basen, słońce i pielęgnacja po zabiegu PMU.",
  "lead": "Gojenie brwi permanentnych zależy nie tylko od samego zabiegu, ale też od tego, jak traktujesz skórę po pigmentacji. Najważniejsze jest spokojne gojenie: bez odrywania strupków, bez przypadkowych kosmetyków, bez sauny, basenu i mocnego słońca w pierwszym etapie regeneracji.",
  "shortAnswer": "Po makijażu permanentnym brwi nie należy odrywać strupków, pocierać skóry, wykonywać peelingów, używać przypadkowych kosmetyków, korzystać z sauny, basenu, solarium ani intensywnie opalać okolicy zabiegowej. Mycie i pielęgnację wykonuje się zgodnie z zaleceniami gabinetu, delikatnie i bez przyspieszania złuszczania.",
  "canonicalPath": "/poradnik/czego-nie-wolno-po-makijazu-permanentnym-brwi/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Brwi permanentne"
  },
  "faqHeading": "Pytania: pielęgnacja po pmu brwi"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#najwazniejsze-zakazy",
    "title": "Czego nie wolno"
  },
  {
    "href": "#mycie-brwi",
    "title": "Mycie brwi"
  },
  {
    "href": "#smarowanie",
    "title": "Smarowanie"
  },
  {
    "href": "#sauna-basen-slonce",
    "title": "Sauna i słońce"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Nie odrywaj strupków ani łusek — to jedna z najważniejszych zasad po PMU brwi.",
  "Nie mocz brwi długo i nie trzyj skóry w czasie gojenia.",
  "Nie używaj przypadkowych maści, olejków, peelingów i kosmetyków aktywnych.",
  "Unikaj basenu, sauny, solarium, opalania i intensywnego pocenia w pierwszym etapie regeneracji."
];

const sections = [
  {
    "id": "najwazniejsze-zakazy",
    "eyebrow": "Najważniejsze zakazy",
    "title": "Po zabiegu nie wolno przyspieszać gojenia na siłę.",
    "paragraphs": [
      "Skóra po pigmentacji potrzebuje czasu. Brwi mogą być ciemniejsze, skóra może być napięta, a po kilku dniach może pojawić się złuszczanie. W tym czasie najgorsze są działania mechaniczne: drapanie, pocieranie, odrywanie strupków i testowanie przypadkowych preparatów.",
      "Makijaż permanentny brwi nie powinien być traktowany jak zwykły makijaż do zmycia. Pigment znajduje się w skórze, dlatego każde podrażnienie może wpłynąć na gojenie, kolor i równomierność efektu."
    ],
    "cards": [
      {
        "title": "Nie odrywaj strupków",
        "text": "Strupki i łuski powinny odejść samoistnie. Odrywanie może naruszyć skórę i pigment."
      },
      {
        "title": "Nie trzyj brwi",
        "text": "Tarcie ręcznikiem, płatkiem kosmetycznym lub palcami może podrażnić świeżą pigmentację."
      },
      {
        "title": "Nie rób peelingu",
        "text": "Kwasy, peelingi, retinoidy i mocne kosmetyki zostaw poza okolicą brwi do czasu wygojenia."
      },
      {
        "title": "Nie opalaj skóry",
        "text": "Słońce i solarium mogą podrażniać skórę i wpływać na wygląd pigmentu."
      }
    ]
  },
  {
    "id": "mycie-brwi",
    "eyebrow": "Mycie brwi",
    "title": "Kiedy można myć brwi po makijażu permanentnym? Delikatnie i zgodnie z zaleceniami.",
    "paragraphs": [
      "Pytanie o mycie brwi po makijażu permanentnym pojawia się bardzo często. Najważniejsza zasada jest prosta: nie moczyć skóry w niekontrolowany sposób i nie traktować brwi agresywnie. Dokładny sposób oczyszczania powinien być zgodny z zaleceniami przekazanymi w gabinecie.",
      "Nie chodzi o całkowite ignorowanie higieny, ale o unikanie długiego moczenia, gorącej pary, silnego strumienia wody, pocierania i preparatów, które mogą szczypać albo podrażniać skórę."
    ],
    "cards": [
      {
        "title": "Bez moczenia",
        "text": "Unikaj długiego kontaktu z wodą, kąpieli parowych i celowego namaczania brwi."
      },
      {
        "title": "Bez tarcia",
        "text": "Po kontakcie z wodą okolicę brwi traktuj bardzo delikatnie, bez szorowania."
      }
    ]
  },
  {
    "id": "smarowanie",
    "eyebrow": "Smarowanie",
    "title": "Czym smarować brwi po makijażu permanentnym? Tylko tym, co zostało zalecone.",
    "paragraphs": [
      "Nie każda skóra potrzebuje takiej samej pielęgnacji po PMU. Dlatego nie warto samodzielnie dokładać maści, olejków, kremów aktywnych ani preparatów polecanych przypadkowo w internecie. Zbyt dużo kosmetyków może obciążyć skórę zamiast jej pomóc.",
      "Jeśli gabinet zaleci konkretny preparat, liczy się ilość, częstotliwość i sposób aplikacji. Więcej nie znaczy lepiej. Przy świeżej pigmentacji najczęściej wygrywa prostota i konsekwencja."
    ],
    "cards": [
      {
        "title": "Nie eksperymentuj",
        "text": "Nie testuj nowych kosmetyków na świeżej pigmentacji."
      },
      {
        "title": "Nie przesadzaj z ilością",
        "text": "Zbyt gruba warstwa preparatu może niepotrzebnie obciążać skórę."
      }
    ]
  },
  {
    "id": "sauna-basen-slonce",
    "eyebrow": "Sauna, basen, słońce",
    "title": "Sauna, basen i opalanie to częste powody problemów w gojeniu.",
    "paragraphs": [
      "W okresie gojenia warto unikać basenu, sauny, jacuzzi, solarium i intensywnego opalania. Ciepło, pot, chlor, długie moczenie i promieniowanie UV mogą podrażniać skórę i pogarszać warunki regeneracji.",
      "W praktyce lepiej zaplanować zabieg tak, aby po pigmentacji nie wypadał urlop, intensywny trening, wyjazd do spa albo okres mocnego słońca. To ma znaczenie nie tylko dla komfortu, ale też dla jakości wygojenia."
    ],
    "cards": [
      {
        "title": "Basen",
        "text": "Unikaj pływania do czasu, aż skóra zakończy pierwszy etap gojenia."
      },
      {
        "title": "Sauna",
        "text": "Wysoka temperatura i pot mogą podrażniać świeżą pigmentację."
      },
      {
        "title": "Słońce",
        "text": "Nie opalaj brwi i chroń skórę przed UV po wygojeniu."
      },
      {
        "title": "Trening",
        "text": "Intensywne pocenie w pierwszym okresie może nie sprzyjać spokojnemu gojeniu."
      }
    ]
  }
];

const warningBox = {
  "title": "Ważne: zalecenia gabinetu są ważniejsze niż porady z internetu",
  "text": "Ten poradnik porządkuje najczęstsze pytania, ale dokładny sposób pielęgnacji po zabiegu powinien wynikać z zaleceń przekazanych po pigmentacji. W razie nietypowej reakcji skóry nie działaj samodzielnie — skontaktuj się z gabinetem, a przy objawach medycznych z lekarzem."
};

const relatedLinks = [
  {
    "href": "/poradnik/jak-goja-sie-brwi-permanentne/",
    "title": "Jak goją się brwi permanentne?",
    "text": "Zobacz etapy gojenia brwi dzień po dniu."
  },
  {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Brwi permanentne",
    "text": "Poznaj naturalne podejście do pigmentacji brwi."
  },
  {
    "href": "/poradnik/jak-przygotowac-sie-do-makijazu-permanentnego-brwi/",
    "title": "Przygotowanie do PMU brwi",
    "text": "Sprawdź, jak przygotować skórę i decyzję przed zabiegiem."
  }
];

const faqItems = [
  {
    "question": "Kiedy można myć brwi po makijażu permanentnym?",
    "answer": "Mycie powinno być delikatne i zgodne z zaleceniami gabinetu. W pierwszym etapie gojenia należy unikać długiego moczenia, silnego strumienia wody, pocierania i przypadkowych kosmetyków."
  },
  {
    "question": "Czym smarować brwi po makijażu permanentnym?",
    "answer": "Najbezpieczniej stosować wyłącznie preparat zalecony po zabiegu. Nie warto samodzielnie dodawać olejków, maści, kremów aktywnych ani produktów polecanych przypadkowo w internecie."
  },
  {
    "question": "Czy trzeba natłuszczać brwi po makijażu permanentnym?",
    "answer": "To zależy od zaleceń gabinetu i reakcji skóry. Jeśli preparat został zalecony, ważna jest cienka warstwa i właściwa częstotliwość. Zbyt dużo produktu może obciążać skórę."
  },
  {
    "question": "Czy po PMU brwi można iść na basen?",
    "answer": "W okresie gojenia należy unikać basenu, sauny i długiego moczenia skóry. Chlor, ciepło i wilgoć mogą podrażniać świeżą pigmentację."
  },
  {
    "question": "Czy można malować brwi po makijażu permanentnym?",
    "answer": "W czasie gojenia należy unikać makijażu w okolicy pigmentacji. Do kosmetyków kolorowych wraca się dopiero wtedy, gdy skóra jest wygojona i gabinet nie widzi przeciwwskazań."
  },
  {
    "question": "Co zrobić, jeśli brwi swędzą podczas gojenia?",
    "answer": "Swędzenie może pojawić się w czasie regeneracji, ale nie należy drapać brwi. Jeśli dyskomfort jest duży albo reakcja wygląda nietypowo, warto skontaktować się z gabinetem."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
