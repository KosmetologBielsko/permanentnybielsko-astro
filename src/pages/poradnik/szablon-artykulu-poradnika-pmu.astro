---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

/*
  SZABLON ARTYKUŁU PORADNIKA PMU

  Jak używać:
  1. Skopiuj ten plik.
  2. Zmień nazwę pliku na docelowy adres, np.
     jak-przygotowac-sie-do-makijazu-permanentnego-brwi.astro
  3. Wklej do:
     src/pages/poradnik/
  4. Uzupełnij dane poniżej: title, description, slug, lead, sekcje, FAQ, zdjęcia.

  Założenie:
  - tekst jest najważniejszy,
  - układ jest spokojny, czytelny i powtarzalny,
  - zdjęcia są opcjonalne: 0, 1 albo 2,
  - kafelki są proste, bez ciężkich efektów.
*/

const article = {
  slug: "jak-przygotowac-sie-do-makijazu-permanentnego-brwi",
  title: "Jak przygotować się do makijażu permanentnego brwi?",
  eyebrow: "Poradnik PMU",
  category: "Brwi permanentne",
  datePublished: "2026-06-08",
  dateModified: "2026-06-08",
  readingTime: "6–8 minut",
  description:
    "Jak przygotować się do makijażu permanentnego brwi? Sprawdź, czego unikać przed zabiegiem, jak wygląda konsultacja, rysunek wstępny i dlaczego skóra ma znaczenie.",
  lead:
    "Dobre przygotowanie do makijażu permanentnego brwi pomaga spokojniej przejść przez konsultację, rysunek wstępny, pigmentację i gojenie. Najważniejsze jest nie tylko to, jak brwi wyglądają w dniu zabiegu, ale jak skóra przyjmie pigment i jak efekt będzie wyglądał po wygojeniu.",
  shortAnswer:
    "Przed makijażem permanentnym brwi warto zadbać o skórę, nie podrażniać jej zabiegami, unikać alkoholu przed wizytą, poinformować linergistkę o lekach, chorobach i wcześniejszych pigmentacjach oraz przygotować się na rysunek wstępny. To właśnie na konsultacji i projekcie brwi podejmowana jest najważniejsza decyzja estetyczna.",
  canonicalPath: "/poradnik/jak-przygotowac-sie-do-makijazu-permanentnego-brwi/",
  heroImage: {
    src: "",
    alt: "",
  },
  secondaryImage: {
    src: "",
    alt: "",
  },
};

const tableOfContents = [
  {
    href: "#najkrocej",
    title: "Najkrócej",
  },
  {
    href: "#przed-zabiegiem",
    title: "Przed zabiegiem",
  },
  {
    href: "#konsultacja",
    title: "Konsultacja i rysunek",
  },
  {
    href: "#czego-unikac",
    title: "Czego unikać",
  },
  {
    href: "#po-zabiegu",
    title: "Po zabiegu",
  },
  {
    href: "#faq",
    title: "FAQ",
  },
];

const keyPoints = [
  "Nie podrażniaj skóry przed zabiegiem i nie wykonuj intensywnych peelingów w okolicy brwi.",
  "Poinformuj o lekach, chorobach, alergiach, skłonności do bliznowców i wcześniejszych pigmentacjach.",
  "Nie oceniaj efektu tylko po zdjęciu bezpośrednio po zabiegu — ważne jest wygojenie.",
  "Przy starym, ciemnym albo niekorzystnym PMU najpierw może być potrzebna korekta lub rozjaśnienie pigmentu.",
];

const sections = [
  {
    id: "przed-zabiegiem",
    eyebrow: "Przed zabiegiem",
    title: "Skóra przed pigmentacją ma znaczenie.",
    paragraphs: [
      "Makijaż permanentny brwi to praca ze skórą, dlatego przygotowanie nie powinno ograniczać się do wyboru zdjęcia inspiracji. Skóra podrażniona, przesuszona, świeżo po mocnych zabiegach lub z aktywnymi zmianami może reagować inaczej, a to wpływa na komfort pracy i późniejsze gojenie.",
      "Przed wizytą warto unikać działań, które mogą mocno uwrażliwić okolicę brwi. Jeśli planujesz inne zabiegi kosmetologiczne, laserowe, złuszczające albo mocno drażniące skórę, najlepiej omówić ich kolejność podczas konsultacji.",
    ],
    cards: [
      {
        title: "Przygotuj informacje",
        text: "Powiedz o lekach, chorobach, alergiach, wcześniejszym PMU i reakcjach skóry po zabiegach.",
      },
      {
        title: "Nie podrażniaj skóry",
        text: "Nie eksperymentuj z mocnymi kosmetykami i zabiegami bezpośrednio przed pigmentacją.",
      },
    ],
  },
  {
    id: "konsultacja",
    eyebrow: "Konsultacja",
    title: "Rysunek wstępny jest ważniejszy niż szybka decyzja.",
    paragraphs: [
      "Dobrze wykonane brwi permanentne powinny wynikać z twarzy, naturalnego układu włosa, mimiki, asymetrii i oczekiwanego efektu. Dlatego rysunek wstępny nie jest formalnością, tylko etapem, w którym ustala się kierunek całego zabiegu.",
      "Warto przyjść z własnymi oczekiwaniami, ale też zostawić przestrzeń na analizę. Nie każda twarz potrzebuje mocnych brwi. Czasem najlepszy efekt daje subtelne uporządkowanie, delikatny cień albo naturalny włos maszynowy.",
    ],
    cards: [
      {
        title: "Naturalny efekt",
        text: "Brwi mają pasować do twarzy po wygojeniu, nie tylko wyglądać mocno w dniu zabiegu.",
      },
      {
        title: "Technika do skóry",
        text: "Metoda włoskowa, cieniowanie lub włos z cieniem powinny wynikać z warunków skóry i oczekiwanego efektu.",
      },
    ],
  },
  {
    id: "czego-unikac",
    eyebrow: "Czego unikać?",
    title: "Największym błędem jest przyspieszanie decyzji.",
    paragraphs: [
      "Przy makijażu permanentnym brwi nie warto podejmować decyzji pod wpływem trendu, promocji albo zdjęcia, które nie pasuje do Twojej urody. Brwi są bardzo widocznym elementem twarzy, dlatego ich kształt i intensywność powinny być dobrane spokojnie.",
      "Jeśli masz stary makijaż permanentny, szczególnie zbyt ciemny, chłodny, czerwony, szary albo nierówny, nowa pigmentacja nie zawsze jest pierwszym dobrym krokiem. Czasem bezpieczniej zaplanować rozjaśnianie pigmentu i dopiero później nowy projekt.",
    ],
    cards: [
      {
        title: "Nie przykrywaj problemu na siłę",
        text: "Stary pigment może wymagać rozjaśnienia laserem albo removerem przed nową pigmentacją.",
      },
      {
        title: "Nie wybieraj tylko po cenie",
        text: "W PMU płacisz za analizę, rysunek, doświadczenie, bezpieczeństwo i efekt po wygojeniu.",
      },
    ],
  },
  {
    id: "po-zabiegu",
    eyebrow: "Po zabiegu",
    title: "Efekt ocenia się po wygojeniu, nie od razu.",
    paragraphs: [
      "Bezpośrednio po zabiegu brwi mogą wydawać się ciemniejsze i bardziej wyraźne. W kolejnych dniach skóra przechodzi proces gojenia, kolor może się zmieniać, a intensywność stopniowo się stabilizuje.",
      "Właśnie dlatego tak ważna jest pielęgnacja po zabiegu i cierpliwość. Nie należy na własną rękę odrywać strupków, przyspieszać złuszczania ani oceniać efektu zbyt wcześnie. Dopigmentowanie, jeśli jest potrzebne, planuje się po wygojeniu.",
    ],
    cards: [
      {
        title: "Gojenie wymaga czasu",
        text: "Kolor i kształt stabilizują się stopniowo. Nie oceniaj brwi wyłącznie w pierwszych dniach.",
      },
      {
        title: "Pielęgnacja ma znaczenie",
        text: "Mycie, smarowanie i ochrona skóry powinny być zgodne z zaleceniami po zabiegu.",
      },
    ],
  },
];

const warningBox = {
  title: "Kiedy konieczna jest indywidualna konsultacja?",
  text:
    "Jeśli masz stary makijaż permanentny, aktywne problemy skórne, przyjmujesz leki, jesteś po świeżych zabiegach w okolicy brwi albo nie wiesz, czy obecny pigment można przykryć, najlepiej zacząć od konsultacji. Czasem najlepszą decyzją jest nie wykonywać nowej pigmentacji od razu.",
};

const relatedLinks = [
  {
    href: "/makijaz-permanentny-brwi/",
    title: "Brwi permanentne",
    text: "Zobacz podstronę zabiegu, metody pracy i naturalne podejście do brwi.",
  },
  {
    href: "/usuwanie-makijazu-permanentnego/",
    title: "Usuwanie PMU",
    text: "Sprawdź, kiedy warto rozjaśnić stary pigment przed nowym zabiegiem.",
  },
  {
    href: "/cennik-makijaz-permanentny/",
    title: "Cennik PMU",
    text: "Zobacz aktualne informacje o cenach i zakresie zabiegów.",
  },
];

const faqItems = [
  {
    question: "Czy przed makijażem permanentnym brwi można pić kawę?",
    answer:
      "Najlepiej omówić to indywidualnie podczas konsultacji i stosować się do zaleceń gabinetu. Przed zabiegiem warto unikać wszystkiego, co może zwiększać wrażliwość skóry lub wpływać na komfort pigmentacji.",
  },
  {
    question: "Czy trzeba mieć własny pomysł na kształt brwi?",
    answer:
      "Można mieć inspirację, ale ostateczny kształt powinien wynikać z twarzy, naturalnego układu brwi, asymetrii, mimiki i rysunku wstępnego.",
  },
  {
    question: "Czy stary makijaż permanentny można od razu przykryć nowym?",
    answer:
      "Nie zawsze. Przy zbyt ciemnym, chłodnym albo nierównym pigmencie najpierw może być potrzebne rozjaśnienie laserem lub removerem.",
  },
  {
    question: "Kiedy ocenia się finalny efekt brwi?",
    answer:
      "Finalny efekt ocenia się po wygojeniu i stabilizacji pigmentu. Bezpośrednio po zabiegu kolor może być intensywniejszy.",
  },
  {
    question: "Czy dopigmentowanie jest zawsze konieczne?",
    answer:
      "Nie zawsze. Decyzja zależy od efektu po wygojeniu, reakcji skóry i oczekiwanego nasycenia.",
  },
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href="/makijaz-permanentny-brwi/">Brwi permanentne</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>Pytania przed makijażem permanentnym brwi</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-sidebar-card nav,
  .article-sidebar-card {
    display: grid;
    gap: 8px;
  }

  .article-sidebar-card a {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.94rem;
    line-height: 1.45;
    text-decoration: none;
