---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "opryszczka-a-makijaz-permanentny-ust",
  "title": "Opryszczka a makijaż permanentny ust — co zrobić i jak się przygotować?",
  "eyebrow": "Poradnik PMU",
  "category": "Opryszczka i PMU ust",
  "datePublished": "2026-06-18",
  "dateModified": "2026-06-18",
  "readingTime": "9–11 minut",
  "description": "Opryszczka a makijaż permanentny ust: kiedy przełożyć zabieg, co powiedzieć przed wizytą, dlaczego nie działać samodzielnie i kiedy skonsultować lekarza.",
  "lead": "Opryszczka przy makijażu permanentnym ust to temat, którego nie można bagatelizować. Aktywna zmiana na ustach jest przeciwwskazaniem do zabiegu, a osoby ze skłonnością do nawrotów powinny powiedzieć o tym podczas kwalifikacji.",
  "shortAnswer": "Aktywna opryszczka oznacza, że makijaż permanentny ust trzeba przełożyć. Jeśli masz skłonność do opryszczki, poinformuj o tym przed zabiegiem. Ewentualna profilaktyka przeciwwirusowa powinna być ustalona z lekarzem, a nie stosowana samodzielnie na podstawie porad z internetu.",
  "canonicalPath": "/poradnik/opryszczka-a-makijaz-permanentny-ust/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-ust/",
    "title": "Makijaż permanentny ust"
  },
  "faqHeading": "Pytania: opryszczka i pmu ust"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#dlaczego-wazne",
    "title": "Dlaczego to ważne"
  },
  {
    "href": "#aktywna-opryszczka",
    "title": "Aktywna opryszczka"
  },
  {
    "href": "#profilaktyka",
    "title": "Profilaktyka"
  },
  {
    "href": "#po-zabiegu",
    "title": "Po zabiegu"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Aktywna opryszczka jest powodem do przełożenia makijażu permanentnego ust.",
  "Skłonność do opryszczki trzeba zgłosić przed zabiegiem, nawet jeśli aktualnie nie ma zmiany.",
  "Profilaktyka przeciwwirusowa powinna być omówiona z lekarzem.",
  "Po zabiegu nie należy nakładać przypadkowych preparatów ani maskować zmian kosmetykami."
];

const sections = [
  {
    "id": "dlaczego-wazne",
    "eyebrow": "Bezpieczeństwo",
    "title": "Opryszczka przy PMU ust to ważny element kwalifikacji.",
    "paragraphs": [
      "Makijaż permanentny ust wykonywany jest na delikatnej czerwieni wargowej. Zabieg narusza naskórek i może być dla tej okolicy bodźcem drażniącym.",
      "Nie chodzi o straszenie klientki, ale o rozsądny plan. Jeśli opryszczka pojawia się często, przy stresie, infekcji, słońcu albo zabiegach w okolicy ust, trzeba to omówić przed pigmentacją."
    ],
    "cards": [
      {
        "title": "Powiedz o nawrotach",
        "text": "Nawet jeśli aktualnie nie masz zmiany, historia opryszczki ma znaczenie."
      },
      {
        "title": "Nie ukrywaj objawów",
        "text": "Pieczenie, mrowienie lub pęcherzyk przed wizytą trzeba zgłosić."
      }
    ]
  },
  {
    "id": "aktywna-opryszczka",
    "eyebrow": "Przełożenie zabiegu",
    "title": "Z aktywną opryszczką nie wykonuje się makijażu permanentnego ust.",
    "paragraphs": [
      "Aktywna opryszczka, pęcherzyki, ranki, sączenie lub świeże zmiany w obrębie ust są powodem do przełożenia zabiegu.",
      "Jeśli objawy pojawią się tuż przed wizytą, najlepiej skontaktować się z gabinetem. To nie jest powód do wstydu, tylko normalna sytuacja wymagająca zmiany planu."
    ],
    "cards": [
      {
        "title": "Mrowienie i pieczenie",
        "text": "To mogą być pierwsze sygnały nawrotu — zgłoś je przed zabiegiem."
      },
      {
        "title": "Pęcherzyki i ranki",
        "text": "Przy aktywnej zmianie termin należy przełożyć."
      }
    ]
  },
  {
    "id": "profilaktyka",
    "eyebrow": "Profilaktyka lekowa",
    "title": "Profilaktykę przeciwwirusową ustala lekarz, nie internet.",
    "paragraphs": [
      "Wiele osób szuka informacji o Heviranie, acyklowirze albo lekach przeciwwirusowych przed makijażem permanentnym ust. Ważne: gabinet może przypomnieć o konieczności konsultacji, ale nie powinien zastępować lekarza w decyzji o leczeniu i dawkowaniu.",
      "Jeśli masz częste nawroty opryszczki, skonsultuj temat z lekarzem odpowiednio wcześniej."
    ],
    "cards": [
      {
        "title": "Nie dobieraj dawki sama",
        "text": "Leki przeciwwirusowe powinny być stosowane zgodnie z zaleceniem lekarza."
      },
      {
        "title": "Zapytaj wcześniej",
        "text": "Nie zostawiaj tematu opryszczki na dzień zabiegu."
      }
    ]
  },
  {
    "id": "po-zabiegu",
    "eyebrow": "Po pigmentacji",
    "title": "Co zrobić, jeśli opryszczka pojawi się po PMU ust?",
    "paragraphs": [
      "Jeśli po zabiegu pojawią się objawy opryszczki, najlepiej szybko skontaktować się z gabinetem i lekarzem. Nie warto czekać ani nakładać przypadkowych preparatów.",
      "W czasie gojenia ust ważne jest, aby nie odrywać skórek, nie drażnić czerwieni wargowej i nie próbować maskować problemu kosmetykami kolorowymi."
    ],
    "cards": [
      {
        "title": "Reaguj szybko",
        "text": "Przy pęcherzykach lub silnym pieczeniu skontaktuj się z lekarzem."
      },
      {
        "title": "Nie maskuj kosmetykami",
        "text": "Makijaż na świeżej zmianie może pogorszyć komfort i higienę."
      }
    ]
  }
];

const warningBox = {
  "title": "To poradnik informacyjny, nie zalecenie lekarskie",
  "text": "Przy aktywnej opryszczce, częstych nawrotach, lekach przeciwwirusowych lub niepokojących objawach skontaktuj się z lekarzem. Gabinet może przełożyć zabieg ze względów bezpieczeństwa."
};

const relatedLinks = [
  {
    "href": "/makijaz-permanentny-ust/",
    "title": "Makijaż permanentny ust",
    "text": "Zobacz opis zabiegu i naturalnego efektu."
  },
  {
    "href": "/poradnik/makijaz-permanentny-ust-gojenie-dzien-po-dniu/",
    "title": "Gojenie ust po PMU",
    "text": "Sprawdź, jak wygląda proces gojenia ust."
  },
  {
    "href": "/poradnik/makijaz-permanentny-ust-jak-wybrac-kolor/",
    "title": "Jak wybrać kolor ust?",
    "text": "Dowiedz się, jak dobiera się pigment."
  }
];

const faqItems = [
  {
    "question": "Czy można zrobić makijaż permanentny ust z opryszczką?",
    "answer": "Nie. Aktywna opryszczka, pęcherzyki, ranki lub świeże zmiany w okolicy ust są powodem do przełożenia zabiegu."
  },
  {
    "question": "Co zrobić, jeśli opryszczka pojawi się dzień przed zabiegiem?",
    "answer": "Należy skontaktować się z gabinetem i przełożyć termin. Warto też skonsultować się z lekarzem."
  },
  {
    "question": "Czy trzeba brać Heviran przed PMU ust?",
    "answer": "Decyzję o leku, dawkowaniu i czasie stosowania powinien podjąć lekarz."
  },
  {
    "question": "Czy opryszczka może pojawić się po PMU ust?",
    "answer": "U osób ze skłonnością do nawrotów jest to możliwe."
  },
  {
    "question": "Kiedy można wykonać PMU ust po opryszczce?",
    "answer": "Zabieg można rozważyć dopiero po pełnym wygojeniu zmian i ocenie skóry."
  },
  {
    "question": "Czy opryszczka wpływa na efekt PMU ust?",
    "answer": "Może utrudniać gojenie i wpływać na komfort oraz równomierność efektu."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-sidebar-card nav,
  .article-sidebar-card {
    display: grid;
    gap: 8px;
  }

  .article-sidebar-card a {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.94rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .article-sidebar-card a:hover {
    color: #0f7773;
  }

  .article-sidebar-card-soft {
    background: rgba(219, 246, 243, 0.46);
  }

  .article-main {
    display: grid;
    gap: 22px;
    min-width: 0;
  }

  .article-answer-card,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta {
    padding: clamp(28px, 4vw, 46px);
    border-radius: 32px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.07), transparent 14rem),
      rgba(255, 255, 255, 0.86);
  }

  .article-answer-card h2,
  .article-text-block h2,
  .article-warning-card h2,
  .article-related-section h2,
  .article-faq-section h2,
  .article-final-cta h2 {
    max-width: 900px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2rem, 3.2vw, 3.55rem);
    font-weight: 780;
    line-height: 1.03;
    letter-spacing: -0.068em;
  }

  .article-answer-card p:not(.section-kicker),
  .article-text-block p:not(.section-kicker),
  .article-warning-card p,
  .article-related-section p,
  .article-faq-section p,
  .article-final-cta p:not(.signature) {
    max-width: 900px;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1rem, 1.12vw, 1.1rem);
    line-height: 1.74;
  }

  .article-answer-card p:not(.section-kicker),
  .article-text-block p:not(.section-kicker) {
