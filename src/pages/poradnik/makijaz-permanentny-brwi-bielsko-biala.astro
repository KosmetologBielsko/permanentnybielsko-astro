---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "makijaz-permanentny-brwi-bielsko-biala",
  "title": "Makijaż permanentny brwi Bielsko-Biała — metoda włoskowa, cieniowanie czy włos z cieniem?",
  "eyebrow": "Poradnik PMU",
  "category": "Brwi permanentne Bielsko-Biała",
  "datePublished": "2026-07-05",
  "dateModified": "2026-07-05",
  "readingTime": "8–10 minut",
  "description": "Makijaż permanentny brwi Bielsko-Biała: metoda włoskowa, cieniowanie, włos z cieniem, naturalny efekt, cena, konsultacja, rysunek wstępny i gojenie brwi.",
  "lead": "Brwi permanentne są jednym z najczęściej wybieranych zabiegów PMU, ale dobry efekt nie polega na narysowaniu jednej modnej formy dla każdej twarzy. W Bielsku-Białej coraz więcej klientek szuka brwi naturalnych: miękkich, dopasowanych do mimiki, koloru włosa, skóry i tego, jak pigment będzie wyglądał po wygojeniu.",
  "shortAnswer": "Makijaż permanentny brwi w Bielsku-Białej warto zaplanować po konsultacji i rysunku wstępnym. Metoda włoskowa, cieniowanie i włos z cieniem nie są konkurującymi nazwami z cennika, tylko różnymi technikami dobieranymi do skóry, naturalnych brwi, wcześniejszego pigmentu i oczekiwanego efektu.",
  "canonicalPath": "/poradnik/makijaz-permanentny-brwi-bielsko-biala/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Brwi permanentne"
  },
  "faqHeading": "Najczęstsze pytania — brwi permanentne bielsko-biała"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#metody",
    "title": "Metody brwi"
  },
  {
    "href": "#naturalny-efekt",
    "title": "Naturalny efekt"
  },
  {
    "href": "#cena",
    "title": "Cena i korekta"
  },
  {
    "href": "#okolice",
    "title": "Bielsko i okolice"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Najważniejszy etap przed pigmentacją brwi to konsultacja, kwalifikacja skóry i rysunek wstępny.",
  "Metoda włoskowa daje naturalny efekt, ale nie każda skóra jest do niej najlepszym wyborem.",
  "Cieniowanie może wyglądać miękko i subtelnie, jeśli jest dobrze dobrane do urody.",
  "Przy starym pigmencie czasem najpierw potrzebne jest rozjaśnianie, a nie przykrywanie."
];

const sections = [
  {
    "id": "metody",
    "eyebrow": "Metody brwi PMU",
    "title": "Metoda włoskowa, cieniowanie i włos z cieniem — czym się różnią?",
    "paragraphs": [
      "Metoda włoskowa polega na stworzeniu bardzo delikatnego efektu włosków. Wymaga dobrej kwalifikacji skóry, precyzji i kontroli kierunku pracy. Nie powinna być wybierana tylko dlatego, że brzmi naturalnie — musi pasować do skóry i naturalnego układu brwi.",
      "Cieniowanie brwi może być pudrowe, miękkie i subtelne albo bardziej widoczne. Dobrze wykonane nie musi dawać ciężkiej ramy. Włos z cieniem łączy lekkość włosa z delikatnym wypełnieniem tam, gdzie brwi potrzebują większej spójności."
    ],
    "cards": [
      {
        "title": "Metoda włoskowa",
        "text": "Dla skóry i brwi, które pozwalają na lekki, naturalny efekt pojedynczych włosków."
      },
      {
        "title": "Cieniowanie",
        "text": "Dla osób, które chcą uporządkować kształt i uzyskać miękkie wypełnienie."
      },
      {
        "title": "Włos z cieniem",
        "text": "Dla brwi, które potrzebują i naturalnego kierunku włosa, i delikatnego zagęszczenia."
      },
      {
        "title": "Stary PMU",
        "text": "Przy wcześniejszej pigmentacji najpierw ocenia się kolor, nasycenie i możliwość bezpiecznej korekty."
      }
    ]
  },
  {
    "id": "naturalny-efekt",
    "eyebrow": "Naturalny efekt",
    "title": "Naturalne brwi permanentne nie powinny dominować nad twarzą.",
    "paragraphs": [
      "Naturalny efekt brwi permanentnych zaczyna się od rysunku wstępnego. To on pokazuje proporcje, wysokość łuku, długość ogonka i relację brwi do oczu, nosa oraz mimiki. Dobry projekt nie kopiuje trendu z internetu, tylko porządkuje to, co jest w twarzy.",
      "W gabinecie w Bielsku-Białej szczególnie ważne jest spokojne omówienie oczekiwań: czy brwi mają być bardzo subtelne, bardziej widoczne, włoskowe, pudrowe, czy tylko odświeżone po czasie. Efekt po wygojeniu powinien pasować do codziennej urody, nie tylko wyglądać mocno w dniu zabiegu."
    ],
    "cards": [
      {
        "title": "Rysunek wstępny",
        "text": "To etap decyzji, proporcji i akceptacji kierunku przed pigmentacją."
      },
      {
        "title": "Efekt po wygojeniu",
        "text": "Kolor i intensywność stabilizują się z czasem, dlatego nie ocenia się brwi wyłącznie w pierwszych dniach."
      }
    ]
  },
  {
    "id": "cena",
    "eyebrow": "Cena i korekta",
    "title": "Cena brwi permanentnych powinna obejmować cały proces, nie tylko pigmentację.",
    "paragraphs": [
      "Przy brwiach permanentnych cena zależy od techniki, zakresu pracy, doświadczenia linergistki i tego, czy mamy do czynienia z pierwszym zabiegiem, odświeżeniem czy korektą po innym gabinecie. Sama kwota nie mówi jeszcze, co obejmuje konsultacja, rysunek, zalecenia i praca po wygojeniu.",
      "Warto sprawdzić, czy korekta po wygojeniu jest wliczona w zabieg główny, kiedy się ją wykonuje i czym różni się od odświeżenia po roku lub dwóch. Przy starych brwiach permanentnych wycena może wymagać osobnej konsultacji."
    ],
    "cards": [
      {
        "title": "Korekta",
        "text": "Etap po wygojeniu, kiedy można ocenić przyjęcie pigmentu i ewentualnie dopracować efekt."
      },
      {
        "title": "Odświeżenie",
        "text": "Zabieg po dłuższym czasie, gdy pigment naturalnie traci intensywność."
      }
    ]
  },
  {
    "id": "okolice",
    "eyebrow": "Lokalnie",
    "title": "Brwi permanentne w Bielsku-Białej i dla klientek z regionu.",
    "paragraphs": [
      "Frazy takie jak makijaż permanentny brwi Bielsko-Biała, brwi permanentne Bielsko, metoda włoskowa Bielsko-Biała czy cieniowanie brwi Bielsko-Biała zwykle oznaczają jedną potrzebę: znaleźć miejsce, w którym brwi będą wyglądały naturalnie i bezpiecznie po wygojeniu.",
      "Na konsultacje i zabiegi do Bielska-Białej często dojeżdżają również klientki z Czechowic-Dziedzic, Jaworza, Kóz, Wilkowic, Żywca, Szczyrku, Skoczowa, Kęt, Pszczyny i okolic. Dlatego regionalny tekst powinien odpowiadać na realne pytania, a nie tylko powtarzać nazwy miejscowości."
    ],
    "cards": [
      {
        "title": "Bielsko-Biała",
        "text": "Główna lokalizacja dla makijażu permanentnego brwi i konsultacji PMU."
      },
      {
        "title": "Region",
        "text": "Czechowice-Dziedzice, Kozy, Jaworze, Żywiec, Szczyrk, Skoczów, Kęty i okolice."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy nie robić nowych brwi od razu?",
  "text": "Jeśli stary pigment jest bardzo ciemny, nierówny, czerwony, szary albo znajduje się poza prawidłowym kształtem, przykrywanie go kolejną pigmentacją może pogorszyć efekt. Wtedy lepszym pierwszym krokiem może być rozjaśnianie laserem lub removerem i dopiero późniejszy plan nowego PMU."
};

const relatedLinks = [
  {
    "href": "/poradnik/makijaz-permanentny-brwi-cena/",
    "title": "Makijaż permanentny brwi cena",
    "text": "Sprawdź, co obejmuje cena brwi permanentnych i korekta po wygojeniu."
  },
  {
    "href": "/poradnik/metody-brwi-permanentnych-ombre-pudrowe-wloskowe/",
    "title": "Metody brwi permanentnych",
    "text": "Porównanie ombre, pudrowych, włoskowych i microbladingu."
  },
  {
    "href": "/poradnik/jak-goja-sie-brwi-permanentne/",
    "title": "Jak goją się brwi?",
    "text": "Etapy gojenia, kolor, złuszczanie i pielęgnacja po zabiegu."
  },
  {
    "href": "/poradnik/makijaz-permanentny-bielsko-biala/",
    "title": "Makijaż permanentny Bielsko-Biała",
    "text": "Przewodnik po brwiach, ustach, kreskach i wyborze gabinetu PMU."
  }
];

const faqItems = [
  {
    "question": "Jaka metoda brwi permanentnych jest najbardziej naturalna?",
    "answer": "Najbardziej naturalna może być metoda włoskowa lub włos z cieniem, ale tylko wtedy, gdy pasuje do skóry, naturalnych brwi i oczekiwanego efektu."
  },
  {
    "question": "Czy cieniowanie brwi zawsze wygląda mocno?",
    "answer": "Nie. Cieniowanie może być miękkie, pudrowe i bardzo subtelne, jeśli jest dobrze dobrane do urody i wykonane z odpowiednią lekkością."
  },
  {
    "question": "Czy można przykryć stare brwi permanentne?",
    "answer": "Nie zawsze. Przy zbyt ciemnym lub źle położonym pigmencie najpierw może być potrzebne rozjaśnianie."
  },
  {
    "question": "Czy brwi permanentne są dla osób z Bielska-Białej i okolic?",
    "answer": "Tak. Gabinet w Bielsku-Białej jest wygodny również dla klientek z Czechowic-Dziedzic, Kóz, Jaworza, Żywca, Szczyrku, Skoczowa czy Kęt."
  },
  {
    "question": "Kiedy ocenia się finalny efekt brwi?",
    "answer": "Finalny efekt ocenia się po wygojeniu i stabilizacji pigmentu, a nie bezpośrednio po zabiegu."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/"
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/"
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór efektu, który będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
