---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "makijaz-permanentny-oczu-bielsko-biala",
  "title": "Makijaż permanentny oczu Bielsko-Biała — kreska permanentna i zagęszczenie linii rzęs",
  "eyebrow": "Poradnik PMU",
  "category": "Kreski permanentne Bielsko-Biała",
  "datePublished": "2026-07-05",
  "dateModified": "2026-07-05",
  "readingTime": "8–10 minut",
  "description": "Makijaż permanentny oczu Bielsko-Biała: kreska permanentna, zagęszczenie linii rzęs, kreska górna i dolna, opadająca powieka, gojenie i dobór efektu.",
  "lead": "Makijaż permanentny oczu najczęściej wybierany jest nie po to, żeby zastąpić mocny eyeliner, ale żeby subtelnie zagęścić linię rzęs i podkreślić spojrzenie. W Bielsku-Białej klientki często pytają o kreskę permanentną, kreskę w linii rzęs, kreskę górną, dolną i o to, czy taki zabieg ma sens przy opadającej powiece.",
  "shortAnswer": "Makijaż permanentny oczu w Bielsku-Białej powinien być dobrany do budowy oka, powieki, rzęs i oczekiwanego efektu. Najbezpieczniejszym i najbardziej uniwersalnym wyborem jest często subtelne zagęszczenie linii rzęs, a nie ciężka dekoracyjna kreska.",
  "canonicalPath": "/poradnik/makijaz-permanentny-oczu-bielsko-biala/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-oczu/",
    "title": "Makijaż permanentny oczu"
  },
  "faqHeading": "Najczęstsze pytania — kreski permanentne bielsko-biała"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#rodzaje",
    "title": "Rodzaje kresek"
  },
  {
    "href": "#powieka",
    "title": "Opadająca powieka"
  },
  {
    "href": "#gojenie",
    "title": "Gojenie oczu"
  },
  {
    "href": "#region",
    "title": "Bielsko i okolice"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Kreska permanentna powinna być dobrana do budowy oka, a nie kopiowana ze zdjęcia inspiracji.",
  "Zagęszczenie linii rzęs daje subtelny efekt i często pasuje większej liczbie osób niż mocny eyeliner.",
  "Przy opadającej powiece ciężka kreska może nie być najlepszym wyborem.",
  "Okolica oka jest delikatna, dlatego ważna jest kwalifikacja, higiena i spokojne omówienie gojenia."
];

const sections = [
  {
    "id": "rodzaje",
    "eyebrow": "Rodzaje kresek",
    "title": "Kreska permanentna nie zawsze oznacza mocny eyeliner.",
    "paragraphs": [
      "Najczęściej najbardziej elegancki efekt daje kreska w linii rzęs, czyli subtelne zagęszczenie, które optycznie podkreśla oko bez ciężkiej, widocznej linii. Taki efekt sprawdza się u osób, które chcą wyglądać świeżo również bez codziennego makijażu.",
      "Kreska dekoracyjna, górna, dolna albo bardziej widoczna wymaga dokładniejszej analizy. Liczy się kształt oka, powieka, asymetria, kierunek rzęs, codzienny styl makijażu i to, czy efekt będzie dobrze wyglądał także po kilku miesiącach."
    ],
    "cards": [
      {
        "title": "Zagęszczenie linii rzęs",
        "text": "Subtelny, naturalny efekt dla osób, które chcą podkreślić spojrzenie bez ciężkiej kreski."
      },
      {
        "title": "Kreska górna",
        "text": "Może być delikatna lub bardziej widoczna, ale zawsze powinna wynikać z budowy oka."
      },
      {
        "title": "Kreska dolna",
        "text": "Wymaga ostrożności i dobrego dopasowania, żeby nie obciążyć spojrzenia."
      },
      {
        "title": "Kreska dekoracyjna",
        "text": "Nie każdej osobie będzie pasować. Decyzja wymaga spokojnej analizy powieki."
      }
    ]
  },
  {
    "id": "powieka",
    "eyebrow": "Analiza oka",
    "title": "Opadająca powieka zmienia decyzję o rodzaju kreski.",
    "paragraphs": [
      "Przy opadającej powiece mocna kreska może chować się w załamaniu, optycznie obciążać oko albo wyglądać inaczej niż na inspiracji. Dlatego w wielu przypadkach lepszym kierunkiem jest subtelne zagęszczenie linii rzęs zamiast dekoracyjnego eyelinera.",
      "Dobór kreski powinien uwzględniać nie tylko to, co podoba się na zdjęciu, ale też realną budowę oka i to, jak klientka wygląda bez makijażu. Celem jest podkreślenie spojrzenia, a nie stworzenie efektu, który będzie trudny do noszenia na co dzień."
    ],
    "cards": [
      {
        "title": "Mniej może znaczyć lepiej",
        "text": "Przy oku z opadającą powieką delikatniejszy efekt bywa bardziej elegancki i bezpieczny wizualnie."
      },
      {
        "title": "Projekt i rozmowa",
        "text": "Przed zabiegiem warto omówić styl, przyzwyczajenia i ograniczenia wynikające z budowy oka."
      }
    ]
  },
  {
    "id": "gojenie",
    "eyebrow": "Po zabiegu",
    "title": "Gojenie kreski wymaga delikatności.",
    "paragraphs": [
      "Po makijażu permanentnym oczu może pojawić się tkliwość, delikatny obrzęk albo uczucie napięcia. To okolica bardzo wrażliwa, dlatego po zabiegu ważne jest przestrzeganie zaleceń, higiena i unikanie drażnienia powiek.",
      "W okresie gojenia nie należy przyspieszać złuszczania, trzeć oczu, nakładać makijażu na świeżo pigmentowaną okolicę ani używać przypadkowych kosmetyków. Ostateczny efekt ocenia się po wygojeniu, gdy pigment i skóra się ustabilizują."
    ],
    "cards": [
      {
        "title": "Bez tarcia",
        "text": "Okolica oka po pigmentacji wymaga szczególnej delikatności i czystych nawyków."
      },
      {
        "title": "Bez pośpiechu",
        "text": "Finalny efekt kreski ocenia się po wygojeniu, nie w pierwszych dniach po zabiegu."
      }
    ]
  },
  {
    "id": "region",
    "eyebrow": "Lokalnie",
    "title": "Makijaż permanentny oczu w Bielsku-Białej i regionie.",
    "paragraphs": [
      "Frazy makijaż permanentny oczu Bielsko-Biała, kreska permanentna Bielsko-Biała czy zagęszczenie linii rzęs Bielsko zwykle oznaczają potrzebę subtelnego, bezpiecznego podkreślenia spojrzenia. W tym temacie szczególnie ważna jest analiza oka, nie tylko cena.",
      "Na konsultacje i zabiegi do Bielska-Białej mogą dojechać klientki z Czechowic-Dziedzic, Kóz, Jaworza, Wilkowic, Żywca, Szczyrku, Skoczowa, Kęt, Pszczyny i okolic. Przy kreskach permanentnych warto wybrać miejsce, które umie odmówić zbyt ciężkiego efektu, jeśli nie będzie korzystny."
    ],
    "cards": [
      {
        "title": "Bielsko-Biała",
        "text": "Kreski permanentne, zagęszczenie linii rzęs i konsultacja przed pigmentacją oczu."
      },
      {
        "title": "Okolice",
        "text": "Czechowice-Dziedzice, Kozy, Jaworze, Żywiec, Szczyrk, Skoczów, Kęty i region."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy kreska permanentna może nie być dobrym wyborem?",
  "text": "Jeśli powieka jest mocno podrażniona, występuje stan zapalny, świeży zabieg w okolicy oka, problem okulistyczny albo oczekiwana kreska nie pasuje do budowy powieki, lepiej rozpocząć od konsultacji i spokojnie dobrać bezpieczniejszy wariant."
};

const relatedLinks = [
  {
    "href": "/poradnik/kreska-permanentna-jak-wybrac-rodzaj/",
    "title": "Kreska permanentna — rodzaje",
    "text": "Jak dobrać zagęszczenie linii rzęs, kreskę górną i dolną."
  },
  {
    "href": "/poradnik/kreska-permanentna-przy-opadajacej-powiece/",
    "title": "Kreska przy opadającej powiece",
    "text": "Kiedy wybrać delikatniejsze rozwiązanie i czego unikać."
  },
  {
    "href": "/poradnik/kreska-permanentna-gojenie/",
    "title": "Gojenie kreski permanentnej",
    "text": "Pielęgnacja powiek po PMU i najważniejsze ograniczenia."
  },
  {
    "href": "/poradnik/makijaz-permanentny-bielsko-biala/",
    "title": "Makijaż permanentny Bielsko-Biała",
    "text": "Przewodnik po brwiach, ustach, kreskach i wyborze gabinetu."
  }
];

const faqItems = [
  {
    "question": "Czy kreska permanentna musi być mocna?",
    "answer": "Nie. Bardzo często najlepszy efekt daje subtelne zagęszczenie linii rzęs, które podkreśla spojrzenie bez ciężkiego eyelinera."
  },
  {
    "question": "Czy kreska permanentna pasuje przy opadającej powiece?",
    "answer": "Czasem tak, ale zwykle wymaga delikatniejszego projektu. Przy opadającej powiece mocna kreska może obciążać oko."
  },
  {
    "question": "Czym różni się kreska od zagęszczenia linii rzęs?",
    "answer": "Zagęszczenie jest subtelniejsze i pracuje bliżej linii rzęs. Kreska dekoracyjna jest bardziej widoczna i wymaga większej ostrożności w doborze."
  },
  {
    "question": "Czy po PMU oczu można od razu robić makijaż?",
    "answer": "Nie należy nakładać makijażu na świeżo pigmentowaną okolicę. Trzeba przestrzegać zaleceń pozabiegowych i dać skórze czas na wygojenie."
  },
  {
    "question": "Czy klientki spoza Bielska-Białej umawiają się na kreski permanentne?",
    "answer": "Tak. Do Bielska-Białej mogą wygodnie dojechać klientki z Czechowic-Dziedzic, Jaworza, Kóz, Żywca, Szczyrku, Skoczowa, Kęt i okolic."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/"
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/"
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór efektu, który będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
