---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "makijaz-permanentny-bielsko-biala-cena",
  "title": "Makijaż permanentny Bielsko-Biała cena — ile kosztują brwi, usta i kreski?",
  "eyebrow": "Poradnik PMU",
  "category": "Ceny PMU Bielsko-Biała",
  "datePublished": "2026-07-05",
  "dateModified": "2026-07-05",
  "readingTime": "8–10 minut",
  "description": "Makijaż permanentny Bielsko-Biała cena: ile kosztują brwi permanentne, usta permanentne i kreski permanentne? Sprawdź, co obejmuje cena i od czego zależy wycena PMU.",
  "lead": "Cena makijażu permanentnego w Bielsku-Białej nie powinna być analizowana wyłącznie jako kwota za sam zabieg. Przy brwiach, ustach i kreskach liczy się konsultacja, rysunek wstępny, dobór techniki, praca ze skórą, bezpieczeństwo i ocena efektu po wygojeniu.",
  "shortAnswer": "Cena PMU w Bielsku-Białej zależy od obszaru zabiegu, metody, skóry, wcześniejszych pigmentacji i zakresu pracy. Warto porównywać nie tylko kwoty, ale też to, czy cena obejmuje konsultację, projekt, korektę, zalecenia i doświadczenie linergistki.",
  "canonicalPath": "/poradnik/makijaz-permanentny-bielsko-biala-cena/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik makijażu permanentnego"
  },
  "faqHeading": "Najczęstsze pytania — ceny pmu bielsko-biała"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#cena-i-zakres",
    "title": "Cena PMU"
  },
  {
    "href": "#brwi-usta-kreski",
    "title": "Brwi, usta, kreski"
  },
  {
    "href": "#taniej-czy-drozej",
    "title": "Porównywanie ofert"
  },
  {
    "href": "#jak-sprawdzic-cennik",
    "title": "Praktycznie"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Cena PMU powinna obejmować proces, nie tylko pigmentację.",
  "Brwi, usta i kreski mają inne wymagania techniczne i inne ryzyka.",
  "Najniższa cena nie zawsze oznacza najlepszą decyzję dla skóry i twarzy.",
  "Przy starym lub nieudanym PMU wycena często wymaga konsultacji."
];

const sections = [
  {
    "id": "cena-i-zakres",
    "eyebrow": "Cena PMU",
    "title": "Cena makijażu permanentnego to nie tylko sam moment pigmentacji.",
    "paragraphs": [
      "Kiedy klientka wpisuje w Google „makijaż permanentny Bielsko-Biała cena”, najczęściej chce szybko porównać oferty. Warto jednak wiedzieć, że cena zabiegu powinna obejmować znacznie więcej niż wprowadzenie pigmentu w skórę. To także konsultacja, rysunek wstępny, dobór techniki, dobór koloru, kwalifikacja skóry, zalecenia i kontrola efektu po wygojeniu.",
      "W profesjonalnym PMU płaci się za przewidywalność, doświadczenie i odpowiedzialność za efekt. Brwi, usta albo kreski są widoczne na twarzy codziennie, dlatego decyzja oparta wyłącznie na najniższej cenie może później oznaczać konieczność korekty, rozjaśniania albo usuwania pigmentu."
    ],
    "cards": [
      {
        "title": "Konsultacja",
        "text": "Pomaga ocenić skórę, przeciwwskazania, oczekiwania i ewentualny stary pigment."
      },
      {
        "title": "Rysunek wstępny",
        "text": "Pozwala zobaczyć kształt i proporcję przed pigmentacją."
      },
      {
        "title": "Technika",
        "text": "Metoda powinna wynikać ze skóry i oczekiwanego efektu, nie tylko z cennika."
      },
      {
        "title": "Korekta",
        "text": "W wielu usługach korekta jest elementem procesu po wygojeniu, a nie naprawą błędu."
      }
    ]
  },
  {
    "id": "brwi-usta-kreski",
    "eyebrow": "Brwi, usta, kreski",
    "title": "Od czego zależy cena brwi, ust i kresek permanentnych?",
    "paragraphs": [
      "Cena brwi permanentnych zależy między innymi od wybranej metody: cieniowania, metody włoskowej albo połączenia włosa z cieniem. Techniki dają różne efekty i mają różny poziom trudności, dlatego nie powinny być porównywane wyłącznie jako pozycje z tabeli.",
      "Przy ustach znaczenie ma dobór koloru, naturalna granica czerwieni wargowej, skłonność do opryszczki i oczekiwany efekt po wygojeniu. Przy kreskach ważna jest budowa oka, powieka, linia rzęs i to, czy lepsze będzie subtelne zagęszczenie, czy wyraźniejsza kreska. Każdy obszar wymaga innego czasu i innej odpowiedzialności."
    ],
    "cards": [
      {
        "title": "Brwi permanentne",
        "text": "Cena zależy od techniki, skóry, rysunku, wcześniejszego PMU i oczekiwanego efektu."
      },
      {
        "title": "Usta permanentne",
        "text": "Ważny jest kolor, kontur, symetria, opryszczka i naturalny efekt po wygojeniu."
      },
      {
        "title": "Kreski permanentne",
        "text": "Cena wynika z rodzaju kreski, delikatności okolicy oka i precyzji pracy."
      },
      {
        "title": "Odświeżenie",
        "text": "To inna usługa niż korekta po pierwszym zabiegu i zwykle wymaga osobnej wyceny."
      }
    ]
  },
  {
    "id": "taniej-czy-drozej",
    "eyebrow": "Porównywanie ofert",
    "title": "Czy tańszy makijaż permanentny w Bielsku-Białej może być dobry?",
    "paragraphs": [
      "Niska cena nie oznacza automatycznie złego zabiegu, a wysoka cena nie gwarantuje idealnego efektu. Ważne jest to, co faktycznie stoi za ceną: doświadczenie osoby wykonującej zabieg, jakość konsultacji, bezpieczeństwo, styl pracy i gotowość do spokojnego omówienia ograniczeń.",
      "Największe ryzyko pojawia się wtedy, gdy cena jest jedynym argumentem. Jeśli nie ma rysunku wstępnego, rozmowy o przeciwwskazaniach, kwalifikacji starego pigmentu albo informacji o gojeniu, sama promocja nie daje klientce wystarczającego bezpieczeństwa."
    ],
    "cards": [
      {
        "title": "Cena nie jest jedynym kryterium",
        "text": "Przy PMU warto oceniać proces, nie tylko kwotę."
      },
      {
        "title": "Poprawki bywają droższe",
        "text": "Naprawa nieudanego PMU może wymagać wielu etapów, rozjaśniania albo usuwania."
      }
    ]
  },
  {
    "id": "jak-sprawdzic-cennik",
    "eyebrow": "Praktycznie",
    "title": "Jak sprawdzić aktualną cenę i termin?",
    "paragraphs": [
      "Najlepiej sprawdzić aktualny cennik na stronie oraz dostępne terminy w systemie rezerwacji. Przy klasycznym pierwszym zabiegu decyzja bywa prosta, ale przy starym pigmencie, asymetrii, bliznach, wcześniejszych zabiegach albo problemach skórnych cena może wymagać indywidualnej konsultacji.",
      "Warto traktować konsultację jako inwestycję w dobrą decyzję. Czasem po rozmowie okazuje się, że trzeba zmienić metodę, przełożyć zabieg, najpierw rozjaśnić pigment albo wybrać bardziej naturalny efekt niż ten ze zdjęcia inspiracyjnego."
    ],
    "cards": [
      {
        "title": "Cennik na stronie",
        "text": "Dobry punkt startowy do porównania brwi, ust, kresek, odświeżeń i konsultacji."
      },
      {
        "title": "Booksy",
        "text": "Najprostsze miejsce do sprawdzenia dostępnych terminów i rezerwacji wizyty."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy cena nie powinna być podana automatycznie?",
  "text": "Przy starym makijażu permanentnym, bliznach, asymetrii, nietypowym kolorze pigmentu, aktywnych problemach skórnych albo konieczności rozjaśniania najpierw potrzebna jest ocena indywidualna."
};

const relatedLinks = [
  {
    "href": "/poradnik/makijaz-permanentny-bielsko-biala/",
    "title": "Makijaż permanentny Bielsko-Biała",
    "text": "Regionalny przewodnik po brwiach, ustach, kreskach i konsultacji PMU."
  },
  {
    "href": "/poradnik/makijaz-permanentny-brwi-bielsko-biala/",
    "title": "Makijaż permanentny brwi Bielsko-Biała",
    "text": "Metoda włoskowa, cieniowanie, włos z cieniem i naturalny efekt brwi."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Aktualne ceny brwi, ust, kresek, odświeżeń, konsultacji i usuwania."
  },
  {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie i korekta PMU",
    "text": "Stary pigment, laser, remover, korekta i etapowy plan działania."
  }
];

const faqItems = [
  {
    "question": "Ile kosztuje makijaż permanentny w Bielsku-Białej?",
    "answer": "Cena zależy od obszaru zabiegu, techniki i zakresu pracy. Inaczej wycenia się brwi, usta, kreski, odświeżenie i korektę starego pigmentu."
  },
  {
    "question": "Czy korekta jest w cenie zabiegu?",
    "answer": "W wielu zabiegach głównych korekta po wygojeniu jest elementem procesu, ale zawsze warto sprawdzić konkretny cennik i termin wykonania korekty."
  },
  {
    "question": "Dlaczego metoda włoskowa brwi może kosztować więcej?",
    "answer": "Wymaga bardzo precyzyjnej pracy, kwalifikacji skóry, kontroli kierunku włosa i doświadczenia w uzyskiwaniu naturalnego efektu."
  },
  {
    "question": "Czy tani makijaż permanentny to zły wybór?",
    "answer": "Nie zawsze, ale sama niska cena nie wystarczy. Trzeba sprawdzić doświadczenie, zdjęcia wygojonych efektów, higienę, konsultację i zasady korekty."
  },
  {
    "question": "Gdzie sprawdzić aktualne ceny PMU?",
    "answer": "Najlepiej w aktualnym cenniku na stronie oraz podczas konsultacji, jeśli zabieg dotyczy starego pigmentu, korekty albo indywidualnego przypadku."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/"
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/"
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór efektu, który będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
