---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "makijaz-permanentny-bielsko-biala",
  "title": "Makijaż permanentny Bielsko-Biała — jak wybrać brwi, usta albo kreski?",
  "eyebrow": "Poradnik PMU",
  "category": "Makijaż permanentny Bielsko-Biała",
  "datePublished": "2026-07-05",
  "dateModified": "2026-07-05",
  "readingTime": "9–11 minut",
  "description": "Makijaż permanentny Bielsko-Biała: brwi permanentne, makijaż permanentny ust, kreski permanentne, cena, konsultacja, rysunek wstępny, gojenie i wybór gabinetu PMU.",
  "lead": "Makijaż permanentny w Bielsku-Białej warto potraktować nie jak szybki zabieg z cennika, ale jak decyzję dotyczącą twarzy, skóry i codziennego wyglądu. Brwi, usta i kreski permanentne mogą wyglądać bardzo naturalnie, jeśli są poprzedzone konsultacją, rysunkiem wstępnym, analizą skóry i spokojnym doborem techniki.",
  "shortAnswer": "Jeśli szukasz makijażu permanentnego w Bielsku-Białej, zacznij od wyboru efektu: brwi, usta, kreski lub korekta starego PMU. Najważniejsze są nie tylko cena i wolny termin, ale doświadczenie linergistki, rysunek wstępny, kwalifikacja skóry, dobór pigmentu oraz to, jak efekt będzie wyglądał po wygojeniu.",
  "canonicalPath": "/poradnik/makijaz-permanentny-bielsko-biala/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/",
    "title": "Makijaż permanentny Bielsko-Biała"
  },
  "faqHeading": "Najczęstsze pytania — makijaż permanentny bielsko-biała"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#dla-kogo",
    "title": "Dla kogo?"
  },
  {
    "href": "#brwi-usta-oczy",
    "title": "Brwi, usta, oczy"
  },
  {
    "href": "#jak-wybrac",
    "title": "Jak wybrać gabinet?"
  },
  {
    "href": "#region",
    "title": "Bielsko i okolice"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Makijaż permanentny Bielsko-Biała to fraza ogólna — za nią stoją różne potrzeby: brwi, usta, kreski, odświeżenie albo korekta.",
  "Najbezpieczniej zacząć od konsultacji, szczególnie przy starym pigmencie, asymetrii, bliznach lub wcześniejszych zabiegach.",
  "Naturalny efekt zależy od rysunku wstępnego, skóry, techniki, pigmentu i doświadczenia osoby wykonującej zabieg.",
  "Warto porównać nie tylko ceny, ale też sposób kwalifikacji, zdjęcia wygojonych prac i podejście do pielęgnacji po zabiegu."
];

const sections = [
  {
    "id": "dla-kogo",
    "eyebrow": "Decyzja przed zabiegiem",
    "title": "Dla kogo jest makijaż permanentny?",
    "paragraphs": [
      "Makijaż permanentny może być dobrym rozwiązaniem dla osób, które chcą oszczędzić czas rano, podkreślić naturalne rysy twarzy, wyrównać asymetrię albo odzyskać pewność siebie po utracie włosków, zmianie czerwieni wargowej czy problemach z codziennym makijażem.",
      "W Bielsku-Białej klientki najczęściej szukają brwi permanentnych, makijażu permanentnego ust oraz kresek permanentnych. Każdy z tych zabiegów wymaga jednak innej analizy: przy brwiach liczy się układ włosa i skóra, przy ustach kolor i skłonność do opryszczki, a przy oczach budowa powieki i bezpieczeństwo delikatnej okolicy."
    ],
    "cards": [
      {
        "title": "Brwi permanentne",
        "text": "Dla osób, które chcą uporządkować kształt, uzupełnić ubytki albo uzyskać naturalny efekt włosa lub miękkiego cienia."
      },
      {
        "title": "Usta permanentne",
        "text": "Dla osób, które chcą odświeżyć kolor czerwieni wargowej, wyrównać kontur i uzyskać subtelny efekt bez przerysowania."
      },
      {
        "title": "Kreski permanentne",
        "text": "Dla osób, które chcą optycznie zagęścić linię rzęs i podkreślić spojrzenie bez ciężkiej kreski."
      },
      {
        "title": "Korekta starego PMU",
        "text": "Dla osób z dawnym, zbyt ciemnym, nierównym albo niekorzystnie wybarwionym pigmentem."
      }
    ]
  },
  {
    "id": "brwi-usta-oczy",
    "eyebrow": "Oferta PMU",
    "title": "Brwi, usta czy oczy — od czego zacząć?",
    "paragraphs": [
      "Najlepiej zacząć od tego, co najbardziej wpływa na codzienny wygląd. U jednych będą to brwi, bo tworzą ramę twarzy. U innych usta, bo po wygojeniu mogą wyglądać świeżej i bardziej równo. Przy oczach najczęściej wybiera się subtelne zagęszczenie linii rzęs, a nie mocny eyeliner.",
      "Dobry plan PMU nie musi oznaczać wykonania wszystkiego naraz. Czasem lepiej rozpocząć od jednego zabiegu, ocenić wygojenie, a dopiero później zdecydować o kolejnym etapie. To szczególnie ważne przy skórze wrażliwej, wcześniejszych pigmentacjach albo bardzo naturalnych oczekiwaniach."
    ],
    "cards": [
      {
        "title": "Najpierw analiza",
        "text": "Skóra, uroda, tryb życia i wcześniejsze zabiegi mają większe znaczenie niż sama nazwa usługi."
      },
      {
        "title": "Później projekt",
        "text": "Rysunek wstępny pozwala zobaczyć kierunek efektu zanim pigment zostanie wprowadzony w skórę."
      }
    ]
  },
  {
    "id": "jak-wybrac",
    "eyebrow": "Wybór gabinetu",
    "title": "Jak wybrać gabinet makijażu permanentnego w Bielsku-Białej?",
    "paragraphs": [
      "Przy wyborze gabinetu warto zwrócić uwagę na doświadczenie linergistki, zdjęcia wygojonych efektów, sposób prowadzenia konsultacji, informowanie o przeciwwskazaniach i realne podejście do ceny. Makijaż permanentny zostaje na długo, dlatego szybka promocja nie powinna być ważniejsza niż bezpieczeństwo i przewidywalność gojenia.",
      "Dobrze, jeśli gabinet pokazuje nie tylko efekt zaraz po zabiegu, ale także tłumaczy, jak kolor zmienia się w czasie, kiedy ocenia się rezultat i kiedy potrzebna jest korekta albo dopigmentowanie. To buduje spokojną decyzję, a nie presję zakupu usługi."
    ],
    "cards": [
      {
        "title": "Pytaj o wygojenie",
        "text": "Efekt po zabiegu i efekt po wygojeniu to nie zawsze to samo. Warto wiedzieć, kiedy kolor się stabilizuje."
      },
      {
        "title": "Nie wybieraj tylko ceny",
        "text": "Naprawa źle wykonanego PMU może być trudniejsza i droższa niż dobrze zaplanowany pierwszy zabieg."
      }
    ]
  },
  {
    "id": "region",
    "eyebrow": "Lokalnie",
    "title": "Makijaż permanentny dla Bielska-Białej i okolic.",
    "paragraphs": [
      "Gabinet w centrum Bielska-Białej jest wygodnym wyborem także dla osób z okolicznych miejscowości: Czechowic-Dziedzic, Kóz, Jaworza, Wilkowic, Szczyrku, Żywca, Skoczowa, Kęt, Pszczyny czy Andrychowa. W praktyce wiele klientek szuka lokalnie, ale chce dojechać tam, gdzie czuje większe zaufanie do efektu i sposobu pracy.",
      "Dlatego w regionalnym poradniku nie chodzi o powtarzanie nazw miejscowości. Chodzi o odpowiedź na realne pytania: gdzie wykonać naturalne brwi permanentne, jak dobrać kolor ust, czy kreska będzie pasować przy opadającej powiece i co zrobić ze starym pigmentem."
    ],
    "cards": [
      {
        "title": "Centrum Bielska-Białej",
        "text": "Wygodna lokalizacja dla klientek z miasta i regionu."
      },
      {
        "title": "Regionalne zapytania",
        "text": "Bielsko-Biała, Czechowice-Dziedzice, Jaworze, Kozy, Żywiec, Szczyrk, Skoczów i okolice — bez sztucznego upychania fraz."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy nie umawiać od razu zabiegu?",
  "text": "Jeśli masz aktywny stan zapalny skóry, świeży zabieg w okolicy pigmentacji, niepewność co do leków lub chorób, stary mocny pigment albo wcześniejszy nieudany PMU, najlepszym pierwszym krokiem jest konsultacja. Czasem bezpieczniej zaplanować rozjaśnianie, odczekać albo zmienić kolejność zabiegów."
};

const relatedLinks = [
  {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Makijaż permanentny brwi",
    "text": "Naturalne brwi, metoda włoskowa, włos z cieniem i cieniowanie."
  },
  {
    "href": "/makijaz-permanentny-ust/",
    "title": "Makijaż permanentny ust",
    "text": "Naturalny kolor ust, miękki kontur i odświeżenie czerwieni wargowej."
  },
  {
    "href": "/makijaz-permanentny-oczu/",
    "title": "Makijaż permanentny oczu",
    "text": "Kreski permanentne, zagęszczenie linii rzęs i subtelny efekt."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Sprawdź ceny makijażu permanentnego brwi, ust, oczu i odświeżeń."
  }
];

const faqItems = [
  {
    "question": "Czy makijaż permanentny w Bielsku-Białej może wyglądać naturalnie?",
    "answer": "Tak. Naturalny efekt zależy od rysunku wstępnego, dobrania techniki do skóry, doświadczenia linergistki, pigmentu i spokojnej oceny efektu po wygojeniu."
  },
  {
    "question": "Co najczęściej wybierają klientki: brwi, usta czy kreski?",
    "answer": "Najczęściej wybierane są brwi permanentne, ale dużo zależy od potrzeb. Usta poprawiają świeżość koloru, a kreski subtelnie podkreślają spojrzenie."
  },
  {
    "question": "Czy warto dojechać do Bielska-Białej z okolicznych miejscowości?",
    "answer": "Warto, jeśli ważne są doświadczenie, naturalny efekt, konsultacja i bezpieczeństwo. Klientki często dojeżdżają z Czechowic-Dziedzic, Jaworza, Kóz, Żywca, Szczyrku, Skoczowa czy Kęt."
  },
  {
    "question": "Czy najniższa cena PMU to dobry wybór?",
    "answer": "Nie zawsze. Cena jest ważna, ale przy PMU liczą się także doświadczenie, rysunek wstępny, higiena, kwalifikacja skóry i przewidywalność gojenia."
  },
  {
    "question": "Gdzie sprawdzić terminy makijażu permanentnego?",
    "answer": "Najwygodniej sprawdzić dostępne terminy przez Booksy albo umówić konsultację, jeśli potrzebna jest ocena skóry, starego pigmentu lub przeciwwskazań."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/"
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/"
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór efektu, który będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
