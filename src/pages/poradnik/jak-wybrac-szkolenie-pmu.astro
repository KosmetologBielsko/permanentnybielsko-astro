---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

/*
  SZABLON ARTYKUŁU PORADNIKA PMU

  Jak używać:
  1. Skopiuj ten plik.
  2. Zmień nazwę pliku na docelowy adres, np.
     jak-przygotowac-sie-do-makijazu-permanentnego-brwi.astro
  3. Wklej do:
     src/pages/poradnik/
  4. Uzupełnij dane poniżej: title, description, slug, lead, sekcje, FAQ, zdjęcia.

  Założenie:
  - tekst jest najważniejszy,
  - układ jest spokojny, czytelny i powtarzalny,
  - zdjęcia są opcjonalne: 0, 1 albo 2,
  - kafelki są proste, bez ciężkich efektów.
*/

const article = {
  "slug": "jak-wybrac-szkolenie-pmu",
  "title": "Jak wybrać szkolenie PMU i nie zgubić najważniejszych podstaw?",
  "eyebrow": "Poradnik PMU",
  "category": "Szkolenia PMU",
  "datePublished": "2026-06-08",
  "dateModified": "2026-06-08",
  "readingTime": "8–10 minut",
  "description": "Jak wybrać szkolenie PMU? Sprawdź, dlaczego liczy się rysunek wstępny, praca ze skórą, praktyka, analiza efektu po wygojeniu i standard pracy linergistki.",
  "lead": "Dobre szkolenie PMU nie powinno uczyć tylko ruchu ręki. Powinno porządkować sposób myślenia: o twarzy, skórze, rysunku wstępnym, pigmentach, technice, gojeniu i odpowiedzialności za efekt po wygojeniu. To szczególnie ważne dla osób, które chcą pracować spokojnie, dokładnie i świadomie.",
  "shortAnswer": "Wybierając szkolenie PMU, warto patrzeć nie tylko na nazwę techniki, ale na zakres praktyki, pracę na modelkach, analizę skóry, rysunek wstępny, omówienie gojenia, korekt i błędów. Dobre szkolenie powinno dać standard pracy, a nie tylko gotowy schemat do odtwarzania.",
  "canonicalPath": "/poradnik/jak-wybrac-szkolenie-pmu/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/szkolenie-makijaz-permanentny/",
    "title": "Szkolenia PMU"
  },
  "faqHeading": "Pytania o wybór szkolenia PMU"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#podstawy",
    "title": "Podstawy"
  },
  {
    "href": "#praktyka",
    "title": "Praktyka"
  },
  {
    "href": "#technika",
    "title": "Technika"
  },
  {
    "href": "#mentor",
    "title": "Mentor i standard"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Szkolenie PMU powinno uczyć decyzji, nie tylko odtwarzania ruchu.",
  "Rysunek wstępny, skóra i gojenie są tak samo ważne jak sama technika pigmentacji.",
  "Praktyka na modelkach i omówienie błędów dają więcej niż sama teoria.",
  "Dobre szkolenie pomaga budować standard pracy linergistki na lata."
];

const sections = [
  {
    "id": "podstawy",
    "eyebrow": "Podstawy",
    "title": "Najpierw myślenie, potem technika.",
    "paragraphs": [
      "W makijażu permanentnym technika bez analizy może prowadzić do powtarzania schematów. Dobre szkolenie powinno uczyć, jak patrzeć na twarz, jak analizować skórę, jak planować rysunek wstępny i jak przewidywać efekt po wygojeniu.",
      "Podstawy nie są mniej ważne niż zaawansowane techniki. To one decydują, czy linergistka potrafi świadomie pracować z różnymi klientkami, czy tylko odtwarza jeden wyuczony wzór."
    ],
    "cards": [
      {
        "title": "Rysunek wstępny",
        "text": "Bez projektu trudno mówić o odpowiedzialnej pigmentacji."
      },
      {
        "title": "Analiza skóry",
        "text": "Skóra wpływa na dobór techniki, pigmentu i oczekiwany efekt po gojeniu."
      }
    ]
  },
  {
    "id": "praktyka",
    "eyebrow": "Praktyka",
    "title": "Szkolenie powinno pokazywać realną pracę, nie tylko idealny pokaz.",
    "paragraphs": [
      "Praktyka jest kluczowa, bo dopiero podczas pracy widać, jak teoria łączy się z ruchem ręki, naciskiem, tempem, pigmentem i reakcją skóry. Dobre szkolenie powinno dawać przestrzeń na pytania, korektę i analizę decyzji podejmowanych w trakcie zabiegu.",
      "Warto zwrócić uwagę, czy szkolenie obejmuje pracę na modelkach, omawianie przypadków, błędów, przeciwwskazań i efektów po wygojeniu. To elementy, które budują realne przygotowanie do samodzielnej pracy."
    ],
    "cards": [
      {
        "title": "Modelka",
        "text": "Praca na realnym przypadku uczy więcej niż sama demonstracja."
      },
      {
        "title": "Korekta błędów",
        "text": "Ważne jest nie tylko co robić, ale też czego unikać."
      }
    ]
  },
  {
    "id": "technika",
    "eyebrow": "Technika",
    "title": "Nazwa techniki nie zastępuje standardu pracy.",
    "paragraphs": [
      "Step by Step, Masterclass, metoda włoskowa, cieniowanie, usta czy kreski — każda forma szkolenia powinna mieć jasny zakres i poziom. Innego wsparcia potrzebuje osoba początkująca, a innego linergistka, która chce dopracować konkretną technikę.",
      "Dobre szkolenie nie obiecuje, że jedna technika rozwiąże wszystko. Uczy, kiedy dana metoda ma sens, kiedy lepiej wybrać inne rozwiązanie i kiedy nie wykonywać zabiegu od razu."
    ],
    "cards": [
      {
        "title": "Zakres szkolenia",
        "text": "Sprawdź, czy szkolenie odpowiada Twojemu poziomowi i celowi."
      },
      {
        "title": "Świadomy wybór",
        "text": "Technika powinna wynikać z twarzy, skóry i efektu, a nie z mody."
      }
    ]
  },
  {
    "id": "mentor",
    "eyebrow": "Mentor i standard",
    "title": "Wybierasz nie tylko kurs, ale sposób pracy.",
    "paragraphs": [
      "Mentor w PMU przekazuje nie tylko wiedzę techniczną, ale też standard estetyczny, podejście do klientki i odpowiedzialność za decyzję. Dlatego warto patrzeć na doświadczenie, efekty po wygojeniu, sposób komunikacji i to, czy szkolenie daje realne uporządkowanie pracy.",
      "Dobre szkolenie powinno zostawić uczestniczkę z jasnym procesem: konsultacja, analiza, rysunek, pigmentacja, zalecenia, gojenie, dopigmentowanie i dalszy rozwój. To baza, którą można później doskonalić."
    ],
    "cards": [
      {
        "title": "Standard pracy",
        "text": "Proces jest ważniejszy niż jednorazowy efekt na zdjęciu."
      },
      {
        "title": "Rozwój",
        "text": "Szkolenie powinno dawać fundament do dalszej praktyki i świadomego doskonalenia."
      }
    ]
  }
];

const warningBox = {
  "title": "Na co uważać przy wyborze szkolenia PMU?",
  "text": "Uważaj na szkolenia obiecujące szybki efekt bez praktyki, bez rysunku wstępnego, bez omówienia skóry, przeciwwskazań i gojenia. W PMU najważniejsze jest bezpieczeństwo, powtarzalność i odpowiedzialność za efekt po wygojeniu."
};

const relatedLinks = [
  {
    "href": "/szkolenie-makijaz-permanentny/",
    "title": "Szkolenie makijaż permanentny",
    "text": "Zobacz główną podstronę szkoleń PMU."
  },
  {
    "href": "/szkolenia/",
    "title": "Szkolenia PMU",
    "text": "Sprawdź zakres edukacji, poziomy i kierunki rozwoju."
  },
  {
    "href": "/poradnik/rysunek-wstepny-przed-makijazem-permanentnym/",
    "title": "Rysunek wstępny",
    "text": "Zobacz, dlaczego projekt jest fundamentem pracy linergistki."
  }
];

const faqItems = [
  {
    "question": "Czy szkolenie PMU dla początkujących powinno obejmować rysunek wstępny?",
    "answer": "Tak. Rysunek wstępny jest podstawą świadomej pigmentacji i powinien być omawiany już na początku nauki."
  },
  {
    "question": "Czy warto wybrać szkolenie 1:1?",
    "answer": "Szkolenie indywidualne może dać więcej czasu na korektę, pytania i dopasowanie tempa, ale najważniejszy jest zakres i jakość praktyki."
  },
  {
    "question": "Czym różni się Step by Step od Masterclass?",
    "answer": "Step by Step zwykle porządkuje podstawy i proces pracy, a Masterclass rozwija konkretną technikę lub bardziej zaawansowany obszar."
  },
  {
    "question": "Czy sama teoria wystarczy do nauki PMU?",
    "answer": "Nie. Teoria jest ważna, ale PMU wymaga praktyki, obserwacji skóry, pracy ręką i analizy efektów."
  },
  {
    "question": "Na co patrzeć przy wyborze trenerki PMU?",
    "answer": "Na doświadczenie, styl pracy, efekty po wygojeniu, sposób tłumaczenia, praktykę i standard bezpieczeństwa."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-sidebar-card nav,
  .article-sidebar-card {
    display: grid;
    gap: 8px;
  }

  .article-sidebar-card a {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.94rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .article-sidebar-card a:hover {
    color: #0f7773;
  }

  .article-sidebar-card-soft {
    background: rgba(219, 246, 243, 0.46);
  }

  .article-main {
    display: grid;
    gap: 22px;
    min-width: 0;
  }

  .article-answer-card,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta {
    padding: clamp(28px, 4vw, 46px);
    border-radius: 32px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.07), transparent 14rem),
