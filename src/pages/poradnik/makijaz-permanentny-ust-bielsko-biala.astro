---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "makijaz-permanentny-ust-bielsko-biala",
  "title": "Makijaż permanentny ust Bielsko-Biała — naturalny kolor, miękki kontur i gojenie",
  "eyebrow": "Poradnik PMU",
  "category": "Usta permanentne Bielsko-Biała",
  "datePublished": "2026-07-05",
  "dateModified": "2026-07-05",
  "readingTime": "8–10 minut",
  "description": "Makijaż permanentny ust Bielsko-Biała: naturalny kolor ust, miękki kontur, pigmentacja ust, opryszczka, gojenie, pielęgnacja i wybór pigmentu.",
  "lead": "Makijaż permanentny ust nie musi oznaczać mocnego konturu ani efektu pomadki. Coraz częściej klientki w Bielsku-Białej szukają delikatnego odświeżenia czerwieni wargowej, wyrównania koloru i miękkiego efektu, który po wygojeniu wygląda świeżo, kobieco i naturalnie.",
  "shortAnswer": "Makijaż permanentny ust w Bielsku-Białej warto poprzedzić konsultacją, doborem koloru i omówieniem gojenia. Najważniejsze są naturalny efekt po wygojeniu, profilaktyka opryszczki przy skłonności do nawrotów, pielęgnacja po zabiegu i realistyczna ocena, jak pigment zachowa się w czerwieni wargowej.",
  "canonicalPath": "/poradnik/makijaz-permanentny-ust-bielsko-biala/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-ust/",
    "title": "Makijaż permanentny ust"
  },
  "faqHeading": "Najczęstsze pytania — usta permanentne bielsko-biała"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#kolor",
    "title": "Dobór koloru"
  },
  {
    "href": "#gojenie",
    "title": "Gojenie ust"
  },
  {
    "href": "#opryszczka",
    "title": "Opryszczka"
  },
  {
    "href": "#region",
    "title": "Bielsko i okolice"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Usta permanentne mogą wyglądać naturalnie, jeśli kolor jest dobrany do czerwieni wargowej, urody i oczekiwań.",
  "Efekt bezpośrednio po zabiegu zwykle jest intensywniejszy niż efekt po wygojeniu.",
  "Przy skłonności do opryszczki temat profilaktyki trzeba omówić przed zabiegiem z lekarzem.",
  "Miękki kontur i subtelne wypełnienie często wyglądają bardziej elegancko niż mocne obrysowanie ust."
];

const sections = [
  {
    "id": "kolor",
    "eyebrow": "Dobór koloru",
    "title": "Kolor ust po wygojeniu powinien wyglądać jak Twoja lepsza czerwień wargowa.",
    "paragraphs": [
      "Najładniejszy makijaż permanentny ust to często taki, który nie wygląda jak ciężka pomadka. Celem może być odświeżenie koloru, wyrównanie asymetrii czerwieni wargowej, delikatne nasycenie i poprawa konturu bez przerysowania.",
      "Dobór pigmentu zależy od naturalnego koloru ust, karnacji, oczekiwań i tego, czy klientka chce efekt bardzo subtelny, czy wyraźniejszy. Warto pamiętać, że kolor po zabiegu zmienia się w procesie gojenia i stabilizacji."
    ],
    "cards": [
      {
        "title": "Naturalne odświeżenie",
        "text": "Dla osób, które chcą wyglądać świeżej bez codziennego podkreślania ust."
      },
      {
        "title": "Miękki kontur",
        "text": "Kontur ma porządkować kształt ust, a nie tworzyć widocznej, ciężkiej obwódki."
      },
      {
        "title": "Wyrównanie koloru",
        "text": "Pigmentacja może pomóc przy nierównej czerwieni wargowej lub utracie naturalnej intensywności."
      },
      {
        "title": "Efekt po wygojeniu",
        "text": "Ostateczny kolor ocenia się dopiero po stabilizacji, nie w dniu zabiegu."
      }
    ]
  },
  {
    "id": "gojenie",
    "eyebrow": "Gojenie ust",
    "title": "Usta po pigmentacji zmieniają kolor etapami.",
    "paragraphs": [
      "Bezpośrednio po zabiegu usta mogą być intensywniejsze, cieplejsze i bardziej wyraźne. Później przechodzą proces gojenia, złuszczania i czasowego rozjaśnienia. To normalne, że efekt w pierwszych dniach nie jest finalnym rezultatem.",
      "W czasie gojenia ważna jest delikatna pielęgnacja, unikanie drażnienia, nieodrywanie złuszczającego się naskórka i przestrzeganie zaleceń gabinetu. Dzięki temu skóra ma lepsze warunki do spokojnej regeneracji."
    ],
    "cards": [
      {
        "title": "Nie oceniaj zbyt szybko",
        "text": "Kolor ust stabilizuje się po czasie. Pierwsze dni mogą być mylące."
      },
      {
        "title": "Pielęgnacja",
        "text": "Usta po PMU wymagają delikatności, higieny i unikania mechanicznego drażnienia."
      }
    ]
  },
  {
    "id": "opryszczka",
    "eyebrow": "Bezpieczeństwo",
    "title": "Opryszczka a makijaż permanentny ust — temat trzeba omówić wcześniej.",
    "paragraphs": [
      "Pigmentacja ust może aktywować opryszczkę u osób ze skłonnością do nawrotów. Dlatego przed zabiegiem należy powiedzieć o takich epizodach i skonsultować z lekarzem ewentualną profilaktykę lekową. Gabinet nie powinien zastępować decyzji medycznej.",
      "Aktywna opryszczka, świeże uszkodzenia skóry, stan zapalny albo podrażnienie ust są powodem do przełożenia wizyty. Bezpieczniej wykonać zabieg wtedy, gdy skóra jest spokojna i dobrze przygotowana."
    ],
    "cards": [
      {
        "title": "Powiedz o nawrotach",
        "text": "Informacja o opryszczce jest ważna przed kwalifikacją do zabiegu ust."
      },
      {
        "title": "Aktywna zmiana = przełożenie",
        "text": "Nie wykonuje się pigmentacji na aktywnie podrażnionych lub chorobowo zmienionych ustach."
      }
    ]
  },
  {
    "id": "region",
    "eyebrow": "Lokalnie",
    "title": "Makijaż permanentny ust w Bielsku-Białej i okolicach.",
    "paragraphs": [
      "Osoby wpisujące w Google makijaż permanentny ust Bielsko-Biała zwykle chcą zobaczyć naturalne efekty, cenę, informacje o gojeniu i bezpieczeństwie. To ważne, bo pigmentacja ust wymaga innej decyzji niż brwi — tutaj kluczowe są kolor, delikatność i reakcja czerwieni wargowej.",
      "Do gabinetu w Bielsku-Białej mogą wygodnie dojechać także klientki z Czechowic-Dziedzic, Jaworza, Kóz, Wilkowic, Żywca, Szczyrku, Skoczowa, Kęt, Pszczyny i okolic, szczególnie jeśli zależy im na naturalnym, eleganckim efekcie po wygojeniu."
    ],
    "cards": [
      {
        "title": "Bielsko-Biała",
        "text": "Makijaż permanentny ust, konsultacja, dobór koloru i omówienie pielęgnacji."
      },
      {
        "title": "Okolice",
        "text": "Czechowice-Dziedzice, Jaworze, Kozy, Żywiec, Szczyrk, Skoczów, Kęty i region."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy przełożyć makijaż permanentny ust?",
  "text": "Zabieg należy przełożyć przy aktywnej opryszczce, stanie zapalnym, świeżych uszkodzeniach skóry, mocnym podrażnieniu ust lub niepewności dotyczącej przeciwwskazań. Przy skłonności do opryszczki profilaktykę lekową ustala się z lekarzem."
};

const relatedLinks = [
  {
    "href": "/poradnik/makijaz-permanentny-ust-jak-wybrac-kolor/",
    "title": "Jak wybrać kolor ust?",
    "text": "Więcej o pigmentach, kolorze i naturalnym efekcie po wygojeniu."
  },
  {
    "href": "/poradnik/makijaz-permanentny-ust-gojenie-dzien-po-dniu/",
    "title": "Gojenie ust dzień po dniu",
    "text": "Etapy gojenia ust po PMU i pielęgnacja po zabiegu."
  },
  {
    "href": "/poradnik/opryszczka-a-makijaz-permanentny-ust/",
    "title": "Opryszczka a PMU ust",
    "text": "Kiedy przełożyć zabieg i o czym powiedzieć przed wizytą."
  },
  {
    "href": "/poradnik/makijaz-permanentny-bielsko-biala/",
    "title": "Makijaż permanentny Bielsko-Biała",
    "text": "Przewodnik po brwiach, ustach, kreskach i wyborze gabinetu."
  }
];

const faqItems = [
  {
    "question": "Czy makijaż permanentny ust wygląda jak pomadka?",
    "answer": "Nie musi. Można uzyskać bardzo naturalne odświeżenie koloru i miękki kontur bez efektu ciężkiej pomadki."
  },
  {
    "question": "Czy usta po zabiegu są od razu finalne?",
    "answer": "Nie. Bezpośrednio po pigmentacji kolor może być intensywniejszy, a finalny efekt ocenia się po wygojeniu i stabilizacji."
  },
  {
    "question": "Czy opryszczka jest przeciwwskazaniem?",
    "answer": "Aktywna opryszczka jest powodem do przełożenia zabiegu. Przy skłonności do nawrotów profilaktykę należy omówić z lekarzem."
  },
  {
    "question": "Dla kogo jest makijaż permanentny ust?",
    "answer": "Dla osób, które chcą odświeżyć kolor czerwieni wargowej, wyrównać kontur i uzyskać bardziej świeży wygląd bez codziennego malowania."
  },
  {
    "question": "Czy można dojechać na PMU ust spoza Bielska-Białej?",
    "answer": "Tak. Lokalizacja jest wygodna również dla klientek z Czechowic-Dziedzic, Jaworza, Kóz, Żywca, Szczyrku, Skoczowa, Kęt i okolic."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/"
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/"
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór efektu, który będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

