---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "nieudany-makijaz-permanentny-bielsko-biala",
  "title": "Nieudany makijaż permanentny Bielsko-Biała — korekta, rozjaśnianie czy usuwanie?",
  "eyebrow": "Poradnik PMU",
  "category": "Korekta PMU Bielsko-Biała",
  "datePublished": "2026-07-05",
  "dateModified": "2026-07-05",
  "readingTime": "9–12 minut",
  "description": "Nieudany makijaż permanentny Bielsko-Biała: co zrobić ze starym, zbyt ciemnym lub nierównym PMU? Sprawdź, kiedy możliwa jest korekta, a kiedy lepsze jest rozjaśnianie laserem lub removerem.",
  "lead": "Nieudany makijaż permanentny wymaga spokojnej oceny, a nie szybkiego przykrywania kolejnym pigmentem. Jeśli brwi, usta albo kreski po wygojeniu mają niekorzystny kolor, kształt albo nasycenie, najpierw trzeba ustalić, czy możliwa jest korekta, rozjaśnianie czy usuwanie.",
  "shortAnswer": "Przy nieudanym PMU w Bielsku-Białej najpierw potrzebna jest konsultacja. Trzeba ocenić kolor, kształt, nasycenie i stan skóry. Czasem możliwa jest korekta, ale przy zbyt ciemnym albo źle położonym pigmencie lepszym pierwszym krokiem jest rozjaśnianie laserem lub removerem.",
  "canonicalPath": "/poradnik/nieudany-makijaz-permanentny-bielsko-biala/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie i korekta PMU"
  },
  "faqHeading": "Najczęstsze pytania — korekta pmu bielsko-biała"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#co-jest-nieudane",
    "title": "Nieudany PMU"
  },
  {
    "href": "#konsultacja",
    "title": "Pierwszy krok"
  },
  {
    "href": "#korekta-czy-usuwanie",
    "title": "Korekta czy usuwanie?"
  },
  {
    "href": "#czego-nie-robic",
    "title": "Bezpieczeństwo"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Nie oceniaj finalnego efektu w pierwszych dniach po zabiegu — PMU musi się wygoić.",
  "Po wygojeniu problemem może być kolor, kształt, nasycenie albo położenie pigmentu.",
  "Nie każdy stary pigment da się bezpiecznie przykryć nową pigmentacją.",
  "Domowe sposoby usuwania PMU mogą uszkodzić skórę i utrudnić korektę."
];

const sections = [
  {
    "id": "co-jest-nieudane",
    "eyebrow": "Nieudany PMU",
    "title": "Nie każdy niepokój po zabiegu oznacza nieudany makijaż permanentny.",
    "paragraphs": [
      "Bezpośrednio po zabiegu brwi, usta albo kreski mogą wyglądać intensywniej niż po wygojeniu. Kolor bywa ciemniejszy, cieplejszy albo bardziej widoczny. To normalne, że efekt zmienia się w czasie. Dlatego nie warto oceniać PMU w pierwszych dniach tak, jakby był już finalny.",
      "O nieudanym makijażu permanentnym częściej mówimy wtedy, gdy po wygojeniu kształt jest niekorzystny, pigment jest zbyt ciemny, szary, czerwony, nierówny, za szeroki albo położony poza właściwą strefą. Wtedy potrzebna jest spokojna diagnostyka, nie domowe sposoby i nie szybkie przykrywanie problemu."
    ],
    "cards": [
      {
        "title": "Naturalne gojenie",
        "text": "Ciemniejszy kolor po zabiegu nie musi oznaczać błędu."
      },
      {
        "title": "Problem po wygojeniu",
        "text": "Nierówny kształt, niekorzystny kolor i zbyt mocny pigment wymagają konsultacji."
      }
    ]
  },
  {
    "id": "konsultacja",
    "eyebrow": "Pierwszy krok",
    "title": "Najpierw konsultacja, później decyzja o korekcie albo usuwaniu.",
    "paragraphs": [
      "Przy nieudanym PMU w Bielsku-Białej najlepszym pierwszym krokiem jest konsultacja. Trzeba ocenić kolor, głębokość, nasycenie, kształt, stan skóry i oczekiwania klientki. Dopiero potem można wybrać: korektę, neutralizację koloru, odświeżenie, rozjaśnianie laserem, remover albo plan etapowy.",
      "Najgorszym rozwiązaniem bywa przykrywanie problemu kolejnym pigmentem bez analizy. Jeśli stary pigment jest zbyt ciemny albo położony poza właściwym kształtem, dokładanie koloru może tylko pogłębić problem i utrudnić późniejsze usuwanie."
    ],
    "cards": [
      {
        "title": "Ocena koloru",
        "text": "Szary, czerwony, pomarańczowy albo zbyt chłodny pigment wymaga innego planu."
      },
      {
        "title": "Ocena kształtu",
        "text": "Jeśli pigment jest poza prawidłową linią, samo odświeżenie może nie wystarczyć."
      },
      {
        "title": "Ocena skóry",
        "text": "Blizny, podrażnienia i świeże zabiegi mogą zmienić kolejność działań."
      },
      {
        "title": "Plan etapowy",
        "text": "Czasem bezpieczniej działać powoli: rozjaśnić, odczekać i dopiero pigmentować ponownie."
      }
    ]
  },
  {
    "id": "korekta-czy-usuwanie",
    "eyebrow": "Korekta czy usuwanie?",
    "title": "Kiedy korygować, a kiedy rozjaśniać albo usuwać pigment?",
    "paragraphs": [
      "Korekta może być dobrym rozwiązaniem, gdy pigment jest wystarczająco jasny, położony w dobrej strefie i wymaga dopracowania koloru albo nasycenia. Wtedy można planować nowy kształt lub delikatne odświeżenie bez nadmiernego obciążania skóry.",
      "Rozjaśnianie albo usuwanie warto rozważyć, gdy pigment jest bardzo ciemny, zbyt szeroki, nisko położony, mocno czerwony, grafitowy, nierówny albo nie pasuje do twarzy. W takich przypadkach najpierw trzeba stworzyć przestrzeń na nowy, lżejszy efekt."
    ],
    "cards": [
      {
        "title": "Korekta",
        "text": "Możliwa przy jaśniejszym, dobrze położonym pigmencie."
      },
      {
        "title": "Laser",
        "text": "Pomaga rozjaśniać wybrane pigmenty, szczególnie gdy trzeba zmniejszyć nasycenie."
      },
      {
        "title": "Remover",
        "text": "Może być jedną z metod pracy ze starym pigmentem, zależnie od przypadku."
      },
      {
        "title": "Nowa pigmentacja",
        "text": "Najlepiej planować ją dopiero wtedy, gdy stary pigment nie blokuje naturalnego efektu."
      }
    ]
  },
  {
    "id": "czego-nie-robic",
    "eyebrow": "Bezpieczeństwo",
    "title": "Czego nie robić przy nieudanym makijażu permanentnym?",
    "paragraphs": [
      "Nie warto próbować usuwać PMU domowymi sposobami, mocnymi kosmetykami, kwasami, mechanicznym tarciem albo przypadkowymi preparatami z internetu. Skóra po pigmentacji wymaga ostrożności, a nie agresywnego działania bez kontroli.",
      "Nie warto też umawiać się od razu na „naprawę” bez obejrzenia skóry. Dobra korekta zaczyna się od diagnozy. Czasem najlepszą decyzją jest nie robić pigmentacji od razu i najpierw przygotować skórę lub rozjaśnić wcześniejszy efekt."
    ],
    "cards": [
      {
        "title": "Nie działaj domowo",
        "text": "Domowe usuwanie może uszkodzić skórę i utrudnić późniejszą korektę."
      },
      {
        "title": "Nie przykrywaj na siłę",
        "text": "Dołożenie pigmentu do zbyt ciemnego PMU często daje jeszcze cięższy efekt."
      }
    ]
  }
];

const warningBox = {
  "title": "Nie próbuj usuwać PMU domowymi sposobami.",
  "text": "Kwasy, tarcie, przypadkowe preparaty i agresywne działanie mogą podrażnić lub uszkodzić skórę. Nieudany PMU wymaga konsultacji i planu dobranego do pigmentu oraz skóry."
};

const relatedLinks = [
  {
    "href": "/poradnik/makijaz-permanentny-bielsko-biala/",
    "title": "Makijaż permanentny Bielsko-Biała",
    "text": "Regionalny przewodnik po brwiach, ustach, kreskach i konsultacji PMU."
  },
  {
    "href": "/poradnik/makijaz-permanentny-brwi-bielsko-biala/",
    "title": "Makijaż permanentny brwi Bielsko-Biała",
    "text": "Metoda włoskowa, cieniowanie, włos z cieniem i naturalny efekt brwi."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Aktualne ceny brwi, ust, kresek, odświeżeń, konsultacji i usuwania."
  },
  {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie i korekta PMU",
    "text": "Stary pigment, laser, remover, korekta i etapowy plan działania."
  }
];

const faqItems = [
  {
    "question": "Co zrobić z nieudanym makijażem permanentnym w Bielsku-Białej?",
    "answer": "Najpierw umówić konsultację. Trzeba ocenić kolor, kształt, nasycenie, położenie pigmentu i stan skóry, a dopiero potem wybrać korektę, rozjaśnianie albo usuwanie."
  },
  {
    "question": "Czy nieudany PMU można przykryć nowym pigmentem?",
    "answer": "Czasem tak, ale nie zawsze. Zbyt ciemny, szeroki albo źle położony pigment często wymaga wcześniejszego rozjaśniania."
  },
  {
    "question": "Kiedy lepszy jest laser albo remover?",
    "answer": "Gdy pigment jest zbyt ciemny, nierówny, poza właściwym kształtem albo blokuje możliwość uzyskania naturalnego efektu."
  },
  {
    "question": "Czy domowe sposoby usuwania PMU są bezpieczne?",
    "answer": "Nie. Mogą podrażnić skórę, doprowadzić do przebarwień lub blizn i utrudnić profesjonalną korektę."
  },
  {
    "question": "Kiedy ocenić, czy PMU naprawdę jest nieudany?",
    "answer": "Dopiero po wygojeniu i stabilizacji pigmentu, chyba że wystąpią objawy wymagające szybkiego kontaktu z gabinetem lub lekarzem."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/"
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/"
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór efektu, który będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
