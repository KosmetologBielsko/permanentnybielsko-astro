---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

/*
  SZABLON ARTYKUŁU PORADNIKA PMU

  Jak używać:
  1. Skopiuj ten plik.
  2. Zmień nazwę pliku na docelowy adres, np.
     jak-przygotowac-sie-do-makijazu-permanentnego-brwi.astro
  3. Wklej do:
     src/pages/poradnik/
  4. Uzupełnij dane poniżej: title, description, slug, lead, sekcje, FAQ, zdjęcia.

  Założenie:
  - tekst jest najważniejszy,
  - układ jest spokojny, czytelny i powtarzalny,
  - zdjęcia są opcjonalne: 0, 1 albo 2,
  - kafelki są proste, bez ciężkich efektów.
*/

const article = {
  "slug": "jak-goja-sie-brwi-permanentne",
  "title": "Jak goją się brwi permanentne i czego nie robić po zabiegu?",
  "eyebrow": "Poradnik PMU",
  "category": "Gojenie PMU",
  "datePublished": "2026-06-08",
  "dateModified": "2026-06-18",
  "readingTime": "7–9 minut",
  "description": "Jak goją się brwi permanentne? Zobacz etapy gojenia, pielęgnację po zabiegu, czego unikać i kiedy oceniać finalny efekt makijażu permanentnego brwi.",
  "lead": "Gojenie brwi permanentnych to proces, który wymaga cierpliwości. Bezpośrednio po zabiegu brwi mogą być ciemniejsze i bardziej wyraźne, później skóra może się łuszczyć, a kolor chwilowo wydawać się nierówny. To, co najważniejsze, ocenia się dopiero po wygojeniu i stabilizacji pigmentu.",
  "shortAnswer": "Brwi permanentne po zabiegu zwykle przechodzą przez kilka etapów: większą intensywność koloru, delikatne napięcie skóry, złuszczanie, chwilowe osłabienie pigmentu i stopniową stabilizację. Nie wolno odrywać strupków, przyspieszać złuszczania, moczyć skóry w niekontrolowany sposób ani oceniać efektu zbyt wcześnie. Dopigmentowanie planuje się dopiero po wygojeniu.",
  "canonicalPath": "/poradnik/jak-goja-sie-brwi-permanentne/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Brwi permanentne"
  },
  "faqHeading": "Pytania o gojenie brwi permanentnych"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#etapy-gojenia",
    "title": "Etapy gojenia"
  },
  {
    "href": "#pierwsze-dni",
    "title": "Pierwsze dni"
  },
  {
    "href": "#zluszczanie",
    "title": "Złuszczanie"
  },
  {
    "href": "#pielegnacja",
    "title": "Pielęgnacja"
  },
  {
    "href": "#dopigmentowanie",
    "title": "Dopigmentowanie"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Nie oceniaj brwi tylko po pierwszym dniu — kolor po zabiegu zwykle jest mocniejszy.",
  "Nie odrywaj strupków i nie przyspieszaj złuszczania, bo może to wpłynąć na pigment.",
  "Pielęgnacja po zabiegu powinna być prosta i zgodna z zaleceniami gabinetu.",
  "Dopigmentowanie planuje się po wygojeniu, kiedy widać realną reakcję skóry."
];
const sections = [
  {
    "id": "etapy-gojenia",
    "eyebrow": "Etapy gojenia",
    "title": "Etapy gojenia brwi permanentnych dzień po dniu.",
    "paragraphs": [
      "Brwi permanentne nie goją się w jeden dzień. To proces, w którym kolor, nasycenie i wygląd skóry mogą się zmieniać. Dlatego nie warto oceniać efektu ani po pierwszej dobie, ani w momencie złuszczania.",
      "Najczęstszy błąd to panika w połowie gojenia. Brwi mogą najpierw wydawać się zbyt ciemne, później zbyt jasne albo nierówne. Dopiero po stabilizacji skóry można ocenić, jak pigment przyjął się naprawdę."
    ],
    "cards": [
      {
        "title": "Dzień 1–2",
        "text": "Kolor zwykle jest mocniejszy, a brwi mogą wyglądać intensywniej niż finalny efekt."
      },
      {
        "title": "Dzień 3–5",
        "text": "Skóra może być sucha, napięta albo lekko tkliwa. To moment, w którym trzeba zachować delikatność."
      },
      {
        "title": "Dzień 5–10",
        "text": "Może pojawić się łuszczenie. Nie wolno odrywać strupków, drapać ani przyspieszać złuszczania."
      },
      {
        "title": "Po 4–8 tygodniach",
        "text": "Dopiero wtedy ocenia się efekt i podejmuje decyzję o ewentualnym dopigmentowaniu."
      }
    ]
  },
  {
    "id": "pierwsze-dni",
    "eyebrow": "Pierwsze dni",
    "title": "Brwi po zabiegu mogą być ciemniejsze niż finalny efekt.",
    "paragraphs": [
      "Bezpośrednio po pigmentacji brwi zwykle są intensywniejsze, bardziej wyraźne i mogą wydawać się mocniejsze niż efekt, którego oczekujesz po wygojeniu. To naturalny etap po zabiegu, a nie ostateczny rezultat. Skóra pracuje, a pigment potrzebuje czasu, żeby się ustabilizować.",
      "W pierwszych dniach ważny jest spokój i obserwacja skóry. Nie należy porównywać świeżych brwi ze zdjęciami wygojonych efektów, bo to dwa różne etapy. Dobra pigmentacja ma być oceniana po procesie gojenia, a nie tylko w dniu zabiegu."
    ],
    "cards": [
      {
        "title": "Świeży kolor",
        "text": "Może być ciemniejszy i bardziej nasycony niż finalny efekt po wygojeniu."
      },
      {
        "title": "Reakcja skóry",
        "text": "Delikatne napięcie, tkliwość albo uczucie suchości mogą pojawić się w pierwszych dniach."
      }
    ]
  },
  {
    "id": "zluszczanie",
    "eyebrow": "Złuszczanie",
    "title": "Największy błąd to odrywanie strupków.",
    "paragraphs": [
      "Podczas gojenia skóra może się delikatnie złuszczać. To moment, w którym wiele osób zaczyna się niepokoić, bo kolor może wyglądać nierówno, a fragmenty pigmentu wydają się jaśniejsze. Nie należy jednak przyspieszać tego procesu.",
      "Odrywanie strupków, pocieranie brwi, drapanie albo mechaniczne usuwanie łusek może zaburzyć gojenie i wpłynąć na to, jak pigment zostanie w skórze. Jeśli coś wygląda niepokojąco, lepiej skontaktować się z gabinetem niż działać samodzielnie."
    ],
    "cards": [
      {
        "title": "Nie drap",
        "text": "Swędzenie bywa elementem gojenia, ale drapanie może uszkodzić skórę."
      },
      {
        "title": "Nie odrywaj",
        "text": "Strupki powinny odejść samoistnie. To jeden z najważniejszych punktów pielęgnacji."
      }
    ]
  },
  {
    "id": "pielegnacja",
    "eyebrow": "Pielęgnacja",
    "title": "Po zabiegu mniej znaczy często lepiej.",
    "paragraphs": [
      "Pielęgnacja po makijażu permanentnym brwi powinna być zgodna z zaleceniami gabinetu. Nie chodzi o nakładanie wielu kosmetyków, ale o ochronę skóry i unikanie działań, które mogą ją podrażnić.",
      "W okresie gojenia zwykle trzeba uważać na saunę, basen, intensywne opalanie, mocny makijaż w okolicy brwi i agresywne kosmetyki. Każda skóra reaguje trochę inaczej, dlatego najbezpieczniej trzymać się zaleceń przekazanych po zabiegu."
    ],
    "cards": [
      {
        "title": "Ochrona skóry",
        "text": "Nie obciążaj okolicy brwi przypadkowymi kosmetykami i nie testuj nowych preparatów."
      },
      {
        "title": "Spokojny rytm",
        "text": "Daj skórze czas. Gojenie to proces, którego nie warto przyspieszać."
      }
    ]
  },
  {
    "id": "dopigmentowanie",
    "eyebrow": "Dopigmentowanie",
    "title": "Dopigmentowanie nie jest poprawką po błędzie, tylko etapem oceny.",
    "paragraphs": [
      "Po wygojeniu można realnie ocenić, jak pigment przyjął się w skórze, czy nasycenie jest odpowiednie i czy potrzebne jest dopracowanie. U jednej osoby efekt może być równy i wystarczający, u innej skóra może oddać więcej pigmentu.",
      "Dopigmentowanie, jeśli jest potrzebne, pozwala dopracować efekt po wygojeniu. Nie powinno się go planować zbyt wcześnie, bo skóra musi zakończyć pierwszy etap regeneracji."
    ],
    "cards": [
      {
        "title": "Ocena po czasie",
        "text": "Dopiero wygojone brwi pokazują, czy potrzebne jest dodatkowe nasycenie."
      },
      {
        "title": "Indywidualna reakcja",
        "text": "Typ skóry, pielęgnacja i wcześniejsze pigmentacje wpływają na efekt po gojeniu."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy skontaktować się z gabinetem?",
  "text": "Jeśli pojawia się silny niepokój, nietypowa reakcja skóry, duży dyskomfort albo nie wiesz, czy gojenie przebiega prawidłowo, najlepiej skontaktować się z gabinetem. Nie warto samodzielnie usuwać strupków, nakładać przypadkowych preparatów ani szukać szybkich rozwiązań w internecie."
};

const relatedLinks = [
  {
    "href": "/poradnik/jak-przygotowac-sie-do-makijazu-permanentnego-brwi/",
    "title": "Przygotowanie do PMU brwi",
    "text": "Zobacz, jak przygotować skórę i decyzję przed zabiegiem."
  },
  {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Brwi permanentne",
    "text": "Poznaj ofertę makijażu permanentnego brwi w Bielsku-Białej."
  },
  {
    "href": "/poradnik/rysunek-wstepny-przed-makijazem-permanentnym/",
    "title": "Rysunek wstępny",
    "text": "Sprawdź, dlaczego projekt brwi jest kluczowy przed pigmentacją."
  }
];

const faqItems = [
  {
    "question": "Jak długo goją się brwi permanentne?",
    "answer": "Pierwszy etap gojenia trwa zwykle kilkanaście dni, ale pełniejszą ocenę efektu wykonuje się dopiero po stabilizacji skóry. W praktyce dopigmentowanie planuje się najczęściej po kilku tygodniach, kiedy widać, jak pigment przyjął się w skórze."
  },
  {
    "question": "Czy brwi permanentne po zabiegu zawsze są bardzo ciemne?",
    "answer": "Często są wyraźniejsze niż efekt końcowy, ale intensywność zależy od techniki, skóry i koloru pigmentu. Świeży kolor nie jest ostatecznym rezultatem, dlatego brwi ocenia się dopiero po wygojeniu."
  },
  {
    "question": "Kiedy zaczyna się łuszczenie brwi permanentnych?",
    "answer": "Łuszczenie może pojawić się po kilku dniach od zabiegu. U każdej osoby przebiega trochę inaczej. Najważniejsze jest to, aby nie odrywać łusek ani strupków i nie przyspieszać procesu gojenia."
  },
  {
    "question": "Czy łuszczenie się brwi permanentnych jest normalne?",
    "answer": "Tak, delikatne łuszczenie może być naturalnym etapem gojenia. W tym czasie kolor może wyglądać nierówno albo wydawać się jaśniejszy. Nie zawsze oznacza to problem z pigmentacją."
  },
  {
    "question": "Czy podczas gojenia pigment może wyglądać nierówno?",
    "answer": "Tak, w trakcie złuszczania kolor może wydawać się nierówny lub jaśniejszy. To nie zawsze oznacza problem. Pełniejsza ocena możliwa jest dopiero po wygojeniu."
  },
  {
    "question": "Czy można odrywać strupki z brwi permanentnych?",
    "answer": "Nie. Odrywanie strupków może naruszyć skórę i wpłynąć na przyjęcie pigmentu. Strupki i łuski powinny odejść samoistnie."
  },
  {
    "question": "Jak wygląda gojenie brwi po korekcie?",
    "answer": "Gojenie po korekcie może być łagodniejsze lub podobne do pierwszego zabiegu, ale nadal wymaga ostrożności. Skórę trzeba traktować delikatnie i stosować się do zaleceń pozabiegowych."
  },
  {
    "question": "Kiedy można zrobić dopigmentowanie brwi?",
    "answer": "Dopigmentowanie wykonuje się po wygojeniu, zgodnie z zaleceniami gabinetu i po ocenie efektu. Nie powinno się go robić zbyt wcześnie, bo skóra musi zakończyć pierwszy etap regeneracji."
  },
  {
    "question": "Czy po zabiegu można malować brwi?",
    "answer": "W okresie gojenia należy unikać makijażu w okolicy pigmentacji, jeśli takie są zalecenia pozabiegowe. Dokładne zasady ustala gabinet."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
