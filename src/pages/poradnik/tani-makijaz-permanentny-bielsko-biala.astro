---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "tani-makijaz-permanentny-bielsko-biala",
  "title": "Tani makijaż permanentny Bielsko-Biała — na co uważać przed zabiegiem?",
  "eyebrow": "Poradnik PMU",
  "category": "PMU Bielsko-Biała",
  "datePublished": "2026-07-05",
  "dateModified": "2026-07-05",
  "readingTime": "8–10 minut",
  "description": "Tani makijaż permanentny Bielsko-Biała: czy warto wybierać najniższą cenę? Sprawdź, na co uważać przed PMU brwi, ust i kresek oraz kiedy lepiej zacząć od konsultacji.",
  "lead": "Tani makijaż permanentny w Bielsku-Białej może kusić, zwłaszcza gdy różnice w cenach są duże. Warto jednak sprawdzić, co dokładnie obejmuje oferta: konsultację, rysunek wstępny, korektę, kwalifikację skóry, zalecenia i doświadczenie osoby wykonującej zabieg.",
  "shortAnswer": "Najniższa cena PMU nie zawsze jest złą decyzją, ale nie powinna być jedynym kryterium. Przed zabiegiem sprawdź konsultację, rysunek, zdjęcia wygojonych efektów, zasady korekty, higienę, doświadczenie i sposób kwalifikacji starego pigmentu.",
  "canonicalPath": "/poradnik/tani-makijaz-permanentny-bielsko-biala/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU"
  },
  "faqHeading": "Najczęstsze pytania — pmu bielsko-biała"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#co-oznacza-tanio",
    "title": "Cena i ryzyko"
  },
  {
    "href": "#na-co-uwazac",
    "title": "Checklista"
  },
  {
    "href": "#dobry-kompromis",
    "title": "Rozsądny wybór"
  },
  {
    "href": "#kiedy-doplacic",
    "title": "Decyzja"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Niska cena nie oznacza automatycznie złej usługi, ale wymaga dokładnego sprawdzenia.",
  "Przy PMU liczy się proces: konsultacja, rysunek, kwalifikacja skóry i korekta po wygojeniu.",
  "Największe ryzyko dotyczy starego pigmentu przykrywanego bez wcześniejszej oceny.",
  "Poprawa źle wykonanego PMU może kosztować więcej niż dobrze zaplanowany pierwszy zabieg."
];

const sections = [
  {
    "id": "co-oznacza-tanio",
    "eyebrow": "Cena i ryzyko",
    "title": "Tani makijaż permanentny nie musi być zły, ale wymaga uważnego sprawdzenia.",
    "paragraphs": [
      "Fraza „tani makijaż permanentny Bielsko-Biała” pojawia się naturalnie, bo wiele osób porównuje ceny przed zabiegiem. To zrozumiałe. Problem zaczyna się wtedy, gdy cena staje się jedynym kryterium, a klientka nie sprawdza kwalifikacji, stylu pracy, zdjęć po wygojeniu i zasad korekty.",
      "Makijaż permanentny jest zabiegiem, który zostaje w skórze na długo i wpływa na codzienny wygląd twarzy. Oszczędność przy pierwszym zabiegu może później oznaczać koszt poprawy, rozjaśniania albo usuwania pigmentu, jeśli kształt, kolor lub technika nie zostały dobrze dobrane."
    ],
    "cards": [
      {
        "title": "Niska cena",
        "text": "Może wynikać z promocji, doświadczenia, modelki szkoleniowej albo krótszego zakresu usługi — warto dopytać, co obejmuje."
      },
      {
        "title": "Ukryte koszty",
        "text": "Dopłata do korekty, brak konsultacji lub konieczność późniejszego rozjaśniania mogą zmienić realny koszt decyzji."
      }
    ]
  },
  {
    "id": "na-co-uwazac",
    "eyebrow": "Checklista",
    "title": "Na co uważać przy bardzo taniej ofercie PMU?",
    "paragraphs": [
      "Przy bardzo niskiej cenie warto zapytać, czy zabieg obejmuje konsultację, rysunek wstępny, korektę po wygojeniu, zalecenia pozabiegowe i kwalifikację skóry. Brak któregoś z tych elementów nie musi automatycznie przekreślać oferty, ale powinien zapalić lampkę kontrolną.",
      "Szczególnie ostrożnie trzeba podejść do starego pigmentu. Jeśli ktoś obiecuje przykrycie każdego PMU bez konsultacji, bez oceny koloru i nasycenia, to ryzyko nieudanego efektu rośnie. Czasem najlepszą decyzją jest najpierw rozjaśnianie albo odmowa pigmentacji od razu."
    ],
    "cards": [
      {
        "title": "Brak konsultacji",
        "text": "Przy PMU rozmowa przed zabiegiem jest ważna, bo pozwala ocenić przeciwwskazania i oczekiwania."
      },
      {
        "title": "Brak rysunku",
        "text": "Rysunek wstępny jest zabezpieczeniem przed przypadkowym kształtem."
      },
      {
        "title": "Brak informacji o gojeniu",
        "text": "Klientka powinna wiedzieć, jak kolor będzie się zmieniał i czego unikać po zabiegu."
      },
      {
        "title": "Brak kwalifikacji starego PMU",
        "text": "Stary pigment wymaga oceny przed przykryciem, a nie obietnicy natychmiastowej poprawy."
      }
    ]
  },
  {
    "id": "dobry-kompromis",
    "eyebrow": "Rozsądny wybór",
    "title": "Jak znaleźć dobry kompromis między ceną a jakością?",
    "paragraphs": [
      "Dobry kompromis nie polega na wybraniu najdroższej oferty, tylko na sprawdzeniu, co za daną cenę otrzymuje klientka. Warto porównać doświadczenie, estetykę prac, proces konsultacji, korektę, warunki higieniczne, sposób tłumaczenia gojenia i podejście do naturalnego efektu.",
      "Przy makijażu permanentnym cena powinna iść w parze z odpowiedzialnością. Dobry gabinet nie obiecuje każdej metody każdej osobie, nie przykrywa bezrefleksyjnie starego pigmentu i nie przyspiesza decyzji, jeśli skóra albo oczekiwania wymagają spokojniejszego planu."
    ],
    "cards": [
      {
        "title": "Porównuj proces",
        "text": "Sprawdź, jak wygląda droga od konsultacji do oceny po wygojeniu."
      },
      {
        "title": "Patrz na naturalność",
        "text": "Efekt powinien pasować do twarzy, nie tylko wyglądać mocno w dniu zabiegu."
      }
    ]
  },
  {
    "id": "kiedy-doplacic",
    "eyebrow": "Decyzja",
    "title": "Kiedy warto zapłacić więcej?",
    "paragraphs": [
      "Warto zapłacić więcej wtedy, gdy masz trudniejszą skórę, stary makijaż permanentny, asymetrię, blizny, bardzo naturalne oczekiwania albo zależy Ci na technice wymagającej dużej precyzji, na przykład metodzie włoskowej. W takich przypadkach doświadczenie i planowanie mają ogromne znaczenie.",
      "Dopłata do dobrze zaplanowanego zabiegu często jest mniejszym kosztem niż późniejsza naprawa. Laserowe rozjaśnianie, remover, korekty koloru i wieloetapowa poprawa mogą być czasochłonne, droższe i bardziej obciążające psychicznie niż spokojna decyzja od początku."
    ],
    "cards": [
      {
        "title": "Stary pigment",
        "text": "To najczęstszy powód, dla którego warto zacząć od konsultacji, nie od promocji."
      },
      {
        "title": "Naturalny efekt",
        "text": "Subtelny PMU wymaga precyzji, wyczucia i doświadczenia, nie tylko szybkiego wykonania."
      }
    ]
  }
];

const warningBox = {
  "title": "Nie wybieraj PMU tylko dlatego, że jest tanio.",
  "text": "Przy makijażu permanentnym twarzy najważniejsze są bezpieczeństwo, przewidywalność gojenia i naturalny efekt. Cena jest ważna, ale nie może zastąpić kwalifikacji i doświadczenia."
};

const relatedLinks = [
  {
    "href": "/poradnik/makijaz-permanentny-bielsko-biala/",
    "title": "Makijaż permanentny Bielsko-Biała",
    "text": "Regionalny przewodnik po brwiach, ustach, kreskach i konsultacji PMU."
  },
  {
    "href": "/poradnik/makijaz-permanentny-brwi-bielsko-biala/",
    "title": "Makijaż permanentny brwi Bielsko-Biała",
    "text": "Metoda włoskowa, cieniowanie, włos z cieniem i naturalny efekt brwi."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Aktualne ceny brwi, ust, kresek, odświeżeń, konsultacji i usuwania."
  },
  {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie i korekta PMU",
    "text": "Stary pigment, laser, remover, korekta i etapowy plan działania."
  }
];

const faqItems = [
  {
    "question": "Czy tani makijaż permanentny w Bielsku-Białej może być dobry?",
    "answer": "Może, ale warto dokładnie sprawdzić, co obejmuje cena: konsultację, rysunek, korektę, zalecenia, kwalifikację skóry i doświadczenie linergistki."
  },
  {
    "question": "Na co uważać przy promocyjnej cenie PMU?",
    "answer": "Na brak konsultacji, brak rysunku wstępnego, brak jasnych zasad korekty, brak informacji o gojeniu oraz obietnicę przykrycia każdego starego pigmentu."
  },
  {
    "question": "Czy najniższa cena może oznaczać większe koszty później?",
    "answer": "Tak. Jeśli efekt będzie wymagał poprawy, rozjaśniania laserem albo removerem, całkowity koszt może być większy niż przy dobrze zaplanowanym zabiegu od początku."
  },
  {
    "question": "Czy cena powinna obejmować korektę?",
    "answer": "Warto to sprawdzić przed zabiegiem. Korekta po wygojeniu bywa elementem procesu, ale zasady i terminy powinny być jasno określone."
  },
  {
    "question": "Kiedy lepiej nie korzystać z promocji?",
    "answer": "Gdy masz stary pigment, aktywne problemy skórne, przeciwwskazania, blizny albo nie masz pewności, jaka metoda będzie bezpieczna. Wtedy najpierw potrzebna jest konsultacja."
  }
];

const pageUrl = `https://www.permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://www.permanentnybielsko.com/"
    },
    publisher: {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://www.permanentnybielsko.com/poradnik/"
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href="/cennik-makijaz-permanentny/">Cennik PMU</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Chcesz sprawdzić, jaki makijaż permanentny będzie najlepszy dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsze są spokojna decyzja,
                analiza skóry, rysunek wstępny i dobór efektu, który będzie pasować do Twojej urody.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
