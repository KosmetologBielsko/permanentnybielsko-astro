---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

/*
  SZABLON ARTYKUŁU PORADNIKA PMU

  Jak używać:
  1. Skopiuj ten plik.
  2. Zmień nazwę pliku na docelowy adres, np.
     jak-przygotowac-sie-do-makijazu-permanentnego-brwi.astro
  3. Wklej do:
     src/pages/poradnik/
  4. Uzupełnij dane poniżej: title, description, slug, lead, sekcje, FAQ, zdjęcia.

  Założenie:
  - tekst jest najważniejszy,
  - układ jest spokojny, czytelny i powtarzalny,
  - zdjęcia są opcjonalne: 0, 1 albo 2,
  - kafelki są proste, bez ciężkich efektów.
*/

const article = {
  "slug": "makijaz-permanentny-ust-jak-wybrac-kolor",
  "title": "Makijaż permanentny ust — jak wybrać kolor, żeby wyglądał naturalnie?",
  "eyebrow": "Poradnik PMU",
  "category": "Usta permanentne",
  "datePublished": "2026-06-08",
  "dateModified": "2026-06-08",
  "readingTime": "8–10 minut",
  "description": "Jak wybrać kolor makijażu permanentnego ust? Zobacz, dlaczego liczy się naturalna czerwień wargowa, gojenie, kontur, pigment i oczekiwany efekt po wygojeniu.",
  "lead": "Kolor w makijażu permanentnym ust nie powinien być wybierany jak pomadka z półki. Usta mają własny odcień, temperaturę, granicę czerwieni wargowej i naturalną asymetrię. Dobry kolor ma odświeżyć usta, wyrównać je i podkreślić, a nie stworzyć przypadkowy efekt, który po wygojeniu będzie zbyt ciężki.",
  "shortAnswer": "Kolor makijażu permanentnego ust dobiera się do naturalnej czerwieni wargowej, karnacji, oczekiwanego efektu i tego, jak pigment może zachować się po wygojeniu. Świeży kolor zwykle wygląda intensywniej niż finalny rezultat. Najważniejsze jest naturalne dopasowanie, a nie kopiowanie koloru ze zdjęcia.",
  "canonicalPath": "/poradnik/makijaz-permanentny-ust-jak-wybrac-kolor/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-ust/",
    "title": "Usta permanentne"
  },
  "faqHeading": "Pytania o makijaż permanentny ust"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#naturalny-kolor",
    "title": "Naturalny kolor"
  },
  {
    "href": "#po-wygojeniu",
    "title": "Po wygojeniu"
  },
  {
    "href": "#kontur",
    "title": "Kontur i kształt"
  },
  {
    "href": "#przygotowanie",
    "title": "Przygotowanie ust"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Kolor ust dobiera się do naturalnej czerwieni wargowej, a nie wyłącznie do zdjęcia inspiracji.",
  "Świeży makijaż permanentny ust może być znacznie intensywniejszy niż efekt po wygojeniu.",
  "Kontur ust powinien porządkować kształt, ale nie tworzyć sztucznej granicy.",
  "Przy skłonności do opryszczki przygotowanie należy omówić indywidualnie z gabinetem i lekarzem."
];

const sections = [
  {
    "id": "naturalny-kolor",
    "eyebrow": "Naturalny kolor",
    "title": "Usta mają swój odcień wyjściowy.",
    "paragraphs": [
      "Każde usta mają inną czerwień wargową: mogą być jasne, chłodne, sine, blade, malinowe, cieplejsze albo nierówne kolorystycznie. Dlatego pigment nie zachowuje się identycznie u każdej osoby. Ten sam kolor może wyglądać inaczej na różnych ustach.",
      "Dobór koloru powinien uwzględniać naturalną bazę, karnację, oczekiwany efekt i to, czy klientka chce subtelnego odświeżenia, czy bardziej widocznego nasycenia. Naturalny efekt nie oznacza braku koloru — oznacza kolor, który pasuje do twarzy."
    ],
    "cards": [
      {
        "title": "Nie jak pomadka",
        "text": "Pigment w skórze zachowuje się inaczej niż kosmetyk nałożony na powierzchnię ust."
      },
      {
        "title": "Kolor bazowy",
        "text": "Naturalna czerwień wargowa wpływa na to, jak efekt będzie wyglądał po wygojeniu."
      }
    ]
  },
  {
    "id": "po-wygojeniu",
    "eyebrow": "Po wygojeniu",
    "title": "Świeży kolor nie jest finalnym kolorem.",
    "paragraphs": [
      "Bezpośrednio po zabiegu usta mogą być intensywne, mocniejsze i bardziej wyraźne. W procesie gojenia kolor stopniowo mięknie, a nasycenie się stabilizuje. To normalne, że efekt po kilku tygodniach różni się od pierwszego dnia.",
      "Dlatego kolor ust trzeba planować z myślą o wygojeniu. Zbyt pochopne ocenianie świeżej pigmentacji może prowadzić do niepotrzebnego niepokoju, a zbyt agresywne oczekiwania kolorystyczne mogą dać efekt, który po czasie będzie zbyt ciężki."
    ],
    "cards": [
      {
        "title": "Kolor mięknie",
        "text": "Po wygojeniu nasycenie zwykle jest łagodniejsze niż bezpośrednio po zabiegu."
      },
      {
        "title": "Cierpliwość",
        "text": "Ostateczny efekt ocenia się po stabilizacji pigmentu."
      }
    ]
  },
  {
    "id": "kontur",
    "eyebrow": "Kontur i kształt",
    "title": "Makijaż permanentny ust nie powinien udawać powiększania.",
    "paragraphs": [
      "Pigmentacja ust może optycznie odświeżyć czerwień wargową, wyrównać kolor i delikatnie uporządkować kształt. Nie jest jednak zabiegiem powiększania ust i nie powinna wychodzić daleko poza naturalną granicę czerwieni wargowej.",
      "Najbardziej elegancki efekt zwykle wynika z pracy w naturalnym obszarze ust. Kontur ma być miękki i spójny, a nie odcięty jak kredka. Dzięki temu usta wyglądają świeżo również bez pomadki."
    ],
    "cards": [
      {
        "title": "Naturalna granica",
        "text": "Praca powinna szanować realny kształt czerwieni wargowej."
      },
      {
        "title": "Miękki kontur",
        "text": "Dobrze wykonany kontur porządkuje usta, ale nie tworzy sztucznej ramy."
      }
    ]
  },
  {
    "id": "przygotowanie",
    "eyebrow": "Przygotowanie ust",
    "title": "Usta przed zabiegiem powinny być spokojne i nawilżone.",
    "paragraphs": [
      "Przesuszone, popękane albo podrażnione usta mogą gorzej reagować podczas pigmentacji i gojenia. Przed zabiegiem warto zadbać o prostą pielęgnację, nawilżenie i unikanie działań, które mocno drażnią czerwień wargową.",
      "Bardzo ważny jest temat opryszczki. Jeśli masz skłonność do opryszczki, trzeba powiedzieć o tym przed zabiegiem. Postępowanie profilaktyczne powinno być ustalone indywidualnie, zgodnie z zaleceniami specjalisty lub lekarza."
    ],
    "cards": [
      {
        "title": "Nawilżenie",
        "text": "Spokojne, niepopękane usta są lepszą bazą do pigmentacji."
      },
      {
        "title": "Opryszczka",
        "text": "Skłonność do opryszczki wymaga wcześniejszego omówienia i odpowiedniego przygotowania."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy lepiej przełożyć makijaż permanentny ust?",
  "text": "Jeśli usta są aktywnie podrażnione, popękane, pojawiła się opryszczka, stan zapalny albo nie wiesz, czy skóra jest gotowa do pigmentacji, lepiej skonsultować termin. Zabieg powinien być wykonany na spokojnej i dobrze przygotowanej czerwieni wargowej."
};

const relatedLinks = [
  {
    "href": "/makijaz-permanentny-ust/",
    "title": "Makijaż permanentny ust",
    "text": "Zobacz ofertę pigmentacji ust i naturalne podejście do koloru."
  },
  {
    "href": "/poradnik/rysunek-wstepny-przed-makijazem-permanentnym/",
    "title": "Rysunek wstępny",
    "text": "Sprawdź, dlaczego projekt ust i konturu jest ważny przed zabiegiem."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Zobacz informacje o cenach i zakresie makijażu permanentnego."
  }
];

const faqItems = [
  {
    "question": "Czy kolor ust po zabiegu będzie taki sam jak po wygojeniu?",
    "answer": "Nie. Świeży kolor zwykle jest intensywniejszy, a po wygojeniu staje się łagodniejszy i bardziej stabilny."
  },
  {
    "question": "Czy makijaż permanentny ust powiększa usta?",
    "answer": "Nie jest to zabieg powiększania. Może optycznie odświeżyć kolor i uporządkować kształt, ale nie zastępuje modelowania ust."
  },
  {
    "question": "Czy można wybrać bardzo mocny kolor ust?",
    "answer": "Można omówić oczekiwany efekt, ale kolor powinien być dobrany do czerwieni wargowej, karnacji i efektu po wygojeniu."
  },
  {
    "question": "Czy opryszczka jest ważna przed PMU ust?",
    "answer": "Tak. Skłonność do opryszczki trzeba zgłosić przed zabiegiem i omówić odpowiednie przygotowanie."
  },
  {
    "question": "Kiedy ocenia się finalny efekt ust?",
    "answer": "Po wygojeniu i stabilizacji pigmentu, nie w dniu zabiegu."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-sidebar-card nav,
  .article-sidebar-card {
    display: grid;
    gap: 8px;
  }

  .article-sidebar-card a {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.94rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .article-sidebar-card a:hover {
    color: #0f7773;
  }

  .article-sidebar-card-soft {
    background: rgba(219, 246, 243, 0.46);
  }

  .article-main {
    display: grid;
    gap: 22px;
    min-width: 0;
  }

