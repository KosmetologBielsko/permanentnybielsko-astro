---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "kreska-permanentna-przy-opadajacej-powiece",
  "title": "Kreska permanentna przy opadającej powiece — kiedy ma sens, a kiedy lepiej wybrać zagęszczenie rzęs?",
  "eyebrow": "Poradnik PMU",
  "category": "Kreska przy opadającej powiece",
  "datePublished": "2026-06-18",
  "dateModified": "2026-06-18",
  "readingTime": "9–11 minut",
  "description": "Kreska permanentna przy opadającej powiece: kiedy wybrać zagęszczenie linii rzęs, kiedy unikać kreski dekoracyjnej i jak dobrać efekt do oka.",
  "lead": "Opadająca powieka nie wyklucza makijażu permanentnego oczu, ale bardzo mocno wpływa na wybór kreski. Przy takiej budowie oka często lepiej sprawdza się subtelne zagęszczenie linii rzęs niż długa, gruba kreska dekoracyjna.",
  "shortAnswer": "Przy opadającej powiece rodzaj kreski permanentnej dobiera się po analizie oka. Często najlepszym wyborem jest zagęszczenie linii rzęs albo bardzo cienka kreska, bo zbyt gruba i długa kreska może optycznie obciążyć oko, schować się w załamaniu powieki albo zaburzyć proporcje spojrzenia.",
  "canonicalPath": "/poradnik/kreska-permanentna-przy-opadajacej-powiece/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-oczu/",
    "title": "Makijaż permanentny oczu"
  },
  "faqHeading": "Pytania: kreska przy opadającej powiece"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#czy-mozna",
    "title": "Czy można"
  },
  {
    "href": "#zageszczenie",
    "title": "Zagęszczenie rzęs"
  },
  {
    "href": "#dekoracyjna",
    "title": "Kreska dekoracyjna"
  },
  {
    "href": "#cieniowana",
    "title": "Kreska cieniowana"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Opadająca powieka wymaga oceny przy otwartym oku i naturalnej mimice.",
  "Zagęszczenie linii rzęs często daje najdelikatniejszy efekt.",
  "Zbyt gruba kreska dekoracyjna może optycznie obciążyć oko.",
  "Kreska cieniowana lub softliner wymagają dobrej kwalifikacji powieki."
];

const sections = [
  {
    "id": "czy-mozna",
    "eyebrow": "Kwalifikacja oka",
    "title": "Opadająca powieka nie przekreśla kreski, ale wymaga ostrożnego projektu.",
    "paragraphs": [
      "Przy opadającej powiece najważniejsze jest to, ile rzeczywiście widać na ruchomej powiece i jak układa się skóra przy otwartym oku.",
      "Dlatego decyzja nie powinna wynikać z inspiracji zdjęciem. Najpierw trzeba ocenić oko, powiekę, rzęsy i napięcie skóry."
    ],
    "cards": [
      {
        "title": "Otwarte oko",
        "text": "Projekt trzeba oceniać przy naturalnie otwartym oku."
      },
      {
        "title": "Załamanie powieki",
        "text": "Może ukrywać lub załamywać zbyt mocną kreskę."
      }
    ]
  },
  {
    "id": "zageszczenie",
    "eyebrow": "Najbezpieczniejszy kierunek",
    "title": "Zagęszczenie linii rzęs często wygląda najlepiej przy trudniejszej powiece.",
    "paragraphs": [
      "Zagęszczenie linii rzęs nie musi wyglądać jak eyeliner. To subtelna pigmentacja przy nasadzie rzęs, która wzmacnia oprawę oka bez ciężkiej graficznej kreski.",
      "Celem jest otwarcie spojrzenia, a nie dociążenie powieki."
    ],
    "cards": [
      {
        "title": "Naturalne podkreślenie",
        "text": "Efekt wzmacnia rzęsy, ale nie dominuje nad twarzą."
      },
      {
        "title": "Mniej ryzyka ciężkości",
        "text": "Cienka pigmentacja rzadziej optycznie zamyka oko."
      }
    ]
  },
  {
    "id": "dekoracyjna",
    "eyebrow": "Kreska dekoracyjna",
    "title": "Kreska dekoracyjna nie zawsze jest dobrym wyborem przy opadającej powiece.",
    "paragraphs": [
      "Mocna kreska z wyciągnięciem może wyglądać atrakcyjnie na zdjęciu, ale przy opadającej powiece bywa trudna do zaplanowania.",
      "Nie oznacza to, że mocniejszy efekt jest zawsze niemożliwy. Oznacza to, że musi być oceniony indywidualnie."
    ],
    "cards": [
      {
        "title": "Za gruba kreska",
        "text": "Może skrócić optycznie przestrzeń powieki."
      },
      {
        "title": "Za długi ogonek",
        "text": "Może załamywać się pod fałdem skóry."
      }
    ]
  },
  {
    "id": "cieniowana",
    "eyebrow": "Softliner i cień",
    "title": "Kreska cieniowana może być piękna, ale wymaga dobrej anatomii i rozsądnych oczekiwań.",
    "paragraphs": [
      "Kreski cieniowane i softliner są popularne, bo wyglądają miękko. Przy opadającej powiece trzeba jednak ocenić, czy cień będzie widoczny i czy nie zamknie oka.",
      "W okolicy oka niewielka różnica w grubości, długości lub kącie może zmienić cały wyraz twarzy."
    ],
    "cards": [
      {
        "title": "Miękki efekt",
        "text": "Może być dobry, jeśli powieka daje na to przestrzeń."
      },
      {
        "title": "Precyzja",
        "text": "Przy oku każdy milimetr ma znaczenie."
      }
    ]
  }
];

const warningBox = {
  "title": "Nie każda inspiracja z internetu pasuje do każdej powieki",
  "text": "Przy opadającej powiece decyzja o kresce powinna wynikać z anatomii oka, a nie z samego zdjęcia."
};

const relatedLinks = [
  {
    "href": "/makijaz-permanentny-oczu/",
    "title": "Makijaż permanentny oczu",
    "text": "Zobacz warianty kresek i zagęszczenia linii rzęs."
  },
  {
    "href": "/poradnik/kreska-permanentna-jak-wybrac-rodzaj/",
    "title": "Jak wybrać rodzaj kreski?",
    "text": "Porównaj kreskę górną, dolną i dekoracyjną."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Sprawdź orientacyjne ceny makijażu permanentnego."
  }
];

const faqItems = [
  {
    "question": "Czy można zrobić kreskę permanentną przy opadającej powiece?",
    "answer": "Często można, ale rodzaj kreski trzeba dobrać ostrożnie."
  },
  {
    "question": "Jaka kreska jest najlepsza przy opadającej powiece?",
    "answer": "Najczęściej najbezpieczniejszym kierunkiem jest delikatne zagęszczenie linii rzęs."
  },
  {
    "question": "Czy kreska dekoracyjna pasuje do opadającej powieki?",
    "answer": "Nie zawsze. Zbyt gruba lub długa kreska może schować się w załamaniu powieki."
  },
  {
    "question": "Czy kreska dolna jest dobrym pomysłem?",
    "answer": "Kreska dolna wymaga osobnej kwalifikacji, bo może optycznie pomniejszyć oko."
  },
  {
    "question": "Czy zagęszczenie linii rzęs wygląda naturalnie?",
    "answer": "Tak, jeśli jest dobrze wykonane. Celem jest subtelne przyciemnienie nasady rzęs."
  },
  {
    "question": "Czy kreska cieniowana jest dla każdego?",
    "answer": "Nie. Softliner wymaga odpowiedniej powieki i realnych oczekiwań."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-sidebar-card nav,
  .article-sidebar-card {
    display: grid;
    gap: 8px;
  }

  .article-sidebar-card a {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.94rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .article-sidebar-card a:hover {
    color: #0f7773;
  }

  .article-sidebar-card-soft {
    background: rgba(219, 246, 243, 0.46);
  }

  .article-main {
    display: grid;
    gap: 22px;
    min-width: 0;
  }

  .article-answer-card,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta {
    padding: clamp(28px, 4vw, 46px);
    border-radius: 32px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.07), transparent 14rem),
      rgba(255, 255, 255, 0.86);
  }

  .article-answer-card h2,
  .article-text-block h2,
  .article-warning-card h2,
  .article-related-section h2,
  .article-faq-section h2,
  .article-final-cta h2 {
    max-width: 900px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2rem, 3.2vw, 3.55rem);
    font-weight: 780;
    line-height: 1.03;
    letter-spacing: -0.068em;
  }

  .article-answer-card p:not(.section-kicker),
  .article-text-block p:not(.section-kicker),
  .article-warning-card p,
  .article-related-section p,
  .article-faq-section p,
  .article-final-cta p:not(.signature) {
    max-width: 900px;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1rem, 1.12vw, 1.1rem);
    line-height: 1.74;
  }

  .article-answer-card p:not(.section-kicker),
  .article-text-block p:not(.section-kicker) {
    margin: 20px 0 0;
  }

  .article-keypoints {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    overflow: hidden;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-keypoints div {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    padding: 22px;
    border-right: 1px solid rgba(56, 187, 181, 0.13);
    border-bottom: 1px solid rgba(56, 187, 181, 0.13);
  }

  .article-keypoints div:nth-child(2n) {
