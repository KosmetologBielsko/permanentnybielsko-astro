---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "kreska-permanentna-jak-wybrac-rodzaj",
  "title": "Kreska permanentna — jak wybrać rodzaj kreski do oka?",
  "eyebrow": "Poradnik PMU",
  "category": "Kreski permanentne",
  "datePublished": "2026-06-08",
  "dateModified": "2026-06-18",
  "readingTime": "8–10 minut",
  "description": "Jak wybrać kreskę permanentną? Zobacz różnicę między zagęszczeniem linii rzęs, kreską górną, dekoracyjną i dolną oraz dlaczego budowa powieki ma znaczenie.",
  "lead": "Makijaż permanentny oczu może delikatnie zagęścić linię rzęs albo stworzyć bardziej widoczną kreskę. Najważniejsze jest jednak to, żeby rodzaj kreski wynikał z budowy oka, powieki, rzęs, skóry i oczekiwanego efektu. Nie każda powieka dobrze wygląda z mocną kreską dekoracyjną.",
  "shortAnswer": "Rodzaj kreski permanentnej wybiera się po analizie oka i powieki. Najsubtelniejsze jest zagęszczenie linii rzęs, bardziej widoczna może być kreska górna lub dekoracyjna, a kreska dolna wymaga szczególnej ostrożności. Celem jest podkreślenie oka, a nie jego optyczne obciążenie.",
  "canonicalPath": "/poradnik/kreska-permanentna-jak-wybrac-rodzaj/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/makijaz-permanentny-oczu/",
    "title": "Kreski permanentne"
  },
  "faqHeading": "Pytania o kreski permanentne"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#porownanie",
    "title": "Porównanie"
  },
  {
    "href": "#rodzaje",
    "title": "Rodzaje kresek"
  },
  {
    "href": "#powieka",
    "title": "Budowa powieki"
  },
  {
    "href": "#efekt",
    "title": "Naturalny efekt"
  },
  {
    "href": "#gojenie",
    "title": "Gojenie oczu"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Zagęszczenie linii rzęs jest najsubtelniejszym wariantem makijażu permanentnego oczu.",
  "Kreska dekoracyjna nie pasuje do każdej budowy powieki.",
  "Kreska dolna wymaga ostrożnej kwalifikacji, żeby nie obciążyć oka.",
  "Efekt powinien podkreślać spojrzenie, a nie dominować nad twarzą."
];

const sections = [
  {
    "id": "porownanie",
    "eyebrow": "Porównanie",
    "title": "Rodzaje kresek permanentnych — najprostsze porównanie.",
    "paragraphs": [
      "Kreska permanentna nie oznacza jednego konkretnego efektu. U jednej osoby najlepszym wyborem będzie niemal niewidoczne zagęszczenie linii rzęs, u innej cienka kreska górna, a u kolejnej bardziej dekoracyjny efekt.",
      "Najważniejsze jest dopasowanie kreski do oka, powieki i codziennego stylu. Przy makijażu permanentnym oczu nie warto kierować się wyłącznie zdjęciem inspiracji, bo ta sama kreska może zupełnie inaczej wyglądać na innej powiece."
    ],
    "cards": [
      {
        "title": "Zagęszczenie linii rzęs",
        "text": "Najdelikatniejszy wariant. Optycznie wzmacnia nasadę rzęs i daje naturalne podkreślenie oka."
      },
      {
        "title": "Cienka kreska górna",
        "text": "Bardziej widoczna niż samo zagęszczenie, ale nadal może wyglądać lekko i elegancko."
      },
      {
        "title": "Kreska dekoracyjna",
        "text": "Mocniejszy efekt przypominający eyeliner. Wymaga dobrej budowy powieki i świadomej decyzji."
      },
      {
        "title": "Kreska dolna",
        "text": "Nie jest dla każdego. Może podkreślić oko, ale źle dobrana potrafi je optycznie obciążyć."
      }
    ]
  },
  {
    "id": "rodzaje",
    "eyebrow": "Rodzaje kresek",
    "title": "Nie każda kreska daje ten sam efekt.",
    "paragraphs": [
      "Najdelikatniejszą formą makijażu permanentnego oczu jest zagęszczenie linii rzęs. Taki zabieg nie musi wyglądać jak klasyczny eyeliner. Celem jest optyczne przyciemnienie nasady rzęs i subtelne podkreślenie spojrzenia.",
      "Kreska górna lub dekoracyjna jest bardziej widoczna i wymaga dokładniejszej analizy powieki. Kreska dolna może uzupełniać efekt, ale nie powinna być wykonywana automatycznie u każdej osoby, bo może optycznie pomniejszyć lub obciążyć oko."
    ],
    "cards": [
      {
        "title": "Zagęszczenie rzęs",
        "text": "Najbardziej subtelny wariant, który wzmacnia oprawę oka bez efektu mocnej kreski."
      },
      {
        "title": "Kreska dekoracyjna",
        "text": "Bardziej widoczna forma, którą trzeba dopasować do powieki i stylu klientki."
      }
    ]
  },
  {
    "id": "powieka",
    "eyebrow": "Budowa powieki",
    "title": "Powieka decyduje o tym, co będzie wyglądało dobrze.",
    "paragraphs": [
      "Przy kreskach permanentnych ogromne znaczenie ma budowa powieki: jej napięcie, załamanie, opadanie, ilość widocznej przestrzeni i naturalny kierunek oka. Kreska, która pięknie wygląda na zdjęciu, może nie pasować do innej anatomii.",
      "Dlatego przed zabiegiem trzeba ocenić, czy lepsze będzie delikatne zagęszczenie, cienka kreska, czy mocniejszy efekt. Przy trudniejszej powiece zbyt gruba lub zbyt długa kreska może wyglądać ciężko."
    ],
    "cards": [
      {
        "title": "Opadająca powieka",
        "text": "Wymaga szczególnej ostrożności przy długości i grubości kreski."
      },
      {
        "title": "Widoczna przestrzeń",
        "text": "Im mniej miejsca na powiece, tym ostrożniej trzeba planować mocniejszą kreskę."
      }
    ]
  },
  {
    "id": "efekt",
    "eyebrow": "Naturalny efekt",
    "title": "Dobra kreska ma otwierać spojrzenie, nie je zamykać.",
    "paragraphs": [
      "Makijaż permanentny oczu powinien podkreślać rzęsy i spojrzenie. Nie zawsze mocniejsza kreska oznacza lepszy efekt. U wielu osób najbardziej elegancko wygląda cienka, precyzyjna pigmentacja przy linii rzęs.",
      "Jeśli klientka na co dzień nie nosi mocnego eyelinera, bardzo graficzna kreska permanentna może po czasie okazać się zbyt dominująca. Warto myśleć o efekcie, który będzie pasował do twarzy również bez pełnego makijażu."
    ],
    "cards": [
      {
        "title": "Codzienność",
        "text": "Kreska ma wyglądać dobrze także bez mocnego makijażu dziennego."
      },
      {
        "title": "Precyzja",
        "text": "Przy oku milimetry mają znaczenie dla całego wyrazu twarzy."
      }
    ]
  },
  {
    "id": "gojenie",
    "eyebrow": "Gojenie oczu",
    "title": "Okolica oka wymaga delikatnego traktowania.",
    "paragraphs": [
      "Po zabiegu oczy mogą być wrażliwsze, a powieka może reagować indywidualnie. Pielęgnacja i ograniczenia po zabiegu powinny być zgodne z zaleceniami gabinetu. Nie warto samodzielnie przyspieszać gojenia ani nakładać przypadkowych kosmetyków w okolicy oczu.",
      "Efekt kreski ocenia się po wygojeniu. Świeża pigmentacja może być bardziej wyraźna, a skóra potrzebuje czasu, żeby się uspokoić."
    ],
    "cards": [
      {
        "title": "Bez tarcia",
        "text": "Okolicy oka nie należy pocierać ani podrażniać w trakcie gojenia."
      },
      {
        "title": "Ocena po czasie",
        "text": "Finalny efekt kreski ocenia się dopiero po wygojeniu."
      }
    ]
  }
];

const warningBox = {
  "title": "Kiedy kreska dekoracyjna może nie być dobrym wyborem?",
  "text": "Jeśli powieka jest mocno opadająca, skóra jest wiotka, oko ma mało widocznej przestrzeni albo klientka oczekuje bardzo mocnego efektu mimo trudnej anatomii, lepiej rozważyć subtelniejsze zagęszczenie linii rzęs. Decyzja powinna wynikać z kwalifikacji, nie z samej inspiracji."
};

const relatedLinks = [
  {
    "href": "/makijaz-permanentny-oczu/",
    "title": "Makijaż permanentny oczu",
    "text": "Zobacz ofertę kresek permanentnych i warianty zabiegu."
  },
  {
    "href": "/makijaz-permanentny-bielsko/",
    "title": "Makijaż permanentny",
    "text": "Poznaj naturalne podejście do PMU w Bielsku-Białej."
  },
  {
    "href": "/cennik-makijaz-permanentny/",
    "title": "Cennik PMU",
    "text": "Sprawdź zakres usług i informacje o cenach."
  }
];

const faqItems = [
  {
    "question": "Jaki rodzaj kreski permanentnej wybrać?",
    "answer": "Rodzaj kreski wybiera się po analizie oka, powieki, rzęs, skóry i oczekiwanego efektu. Najbezpieczniejszym kierunkiem dla wielu osób jest subtelne zagęszczenie linii rzęs, ale u części klientek można rozważyć cienką kreskę górną lub bardziej dekoracyjny efekt."
  },
  {
    "question": "Czym różni się zagęszczenie linii rzęs od kreski dekoracyjnej?",
    "answer": "Zagęszczenie jest subtelniejsze i pracuje przy nasadzie rzęs. Nie musi wyglądać jak eyeliner. Kreska dekoracyjna jest bardziej widoczna i przypomina efekt klasycznej kreski makijażowej."
  },
  {
    "question": "Czy zagęszczenie linii rzęs wygląda naturalnie?",
    "answer": "Tak, to zwykle najbardziej naturalny wariant makijażu permanentnego oczu. Daje efekt optycznie gęstszych rzęs i delikatnie mocniejszej oprawy oka, bez wrażenia ciężkiej kreski."
  },
  {
    "question": "Czy kreska permanentna pasuje do każdej powieki?",
    "answer": "Nie każdy rodzaj kreski pasuje do każdej budowy oka. Przy opadającej, wiotkiej lub mało widocznej powiece trzeba bardzo ostrożnie planować grubość, długość i kierunek kreski."
  },
  {
    "question": "Czy kreska dekoracyjna pasuje do opadającej powieki?",
    "answer": "Nie zawsze. Przy opadającej powiece zbyt gruba lub zbyt długa kreska może optycznie zamykać oko. Czasem lepszym wyborem jest cienka kreska albo samo zagęszczenie linii rzęs."
  },
  {
    "question": "Czy można zrobić kreskę dolną?",
    "answer": "Można ją rozważyć, ale wymaga ostrożności. U niektórych osób kreska dolna może optycznie obciążyć lub pomniejszyć oko, dlatego nie powinna być wykonywana automatycznie u każdej klientki."
  },
  {
    "question": "Czy kreska po zabiegu będzie bardzo czarna?",
    "answer": "Świeża pigmentacja może być intensywna. Efekt po wygojeniu zależy od techniki, pigmentu i reakcji skóry. Finalny wygląd ocenia się po uspokojeniu skóry."
  },
  {
    "question": "Jak goi się kreska permanentna na powiece?",
    "answer": "Okolica oka jest delikatna, dlatego po zabiegu może pojawić się wrażliwość, napięcie lub czasowa intensywność koloru. W trakcie gojenia nie należy pocierać powiek ani nakładać przypadkowych kosmetyków w okolicy pigmentacji."
  },
  {
    "question": "Czy oczy mogą być wrażliwe po zabiegu?",
    "answer": "Tak, okolica oka jest delikatna. Należy stosować się do zaleceń pozabiegowych i nie podrażniać powieki."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---


<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
