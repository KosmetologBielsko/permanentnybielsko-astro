---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const article = {
  "slug": "nieudany-makijaz-permanentny-brwi-co-zrobic",
  "title": "Nieudany makijaż permanentny brwi — co zrobić, kiedy rozjaśniać, a kiedy korygować?",
  "eyebrow": "Poradnik PMU",
  "category": "Nieudany PMU brwi",
  "datePublished": "2026-06-18",
  "dateModified": "2026-06-18",
  "readingTime": "9–11 minut",
  "description": "Nieudany makijaż permanentny brwi: zbyt ciemne brwi, zły kształt, chłodny odcień, rozjaśnianie laserem lub removerem i plan korekty PMU.",
  "lead": "Nieudany makijaż permanentny brwi to nie tylko kwestia estetyki. Zbyt ciemny pigment, niekorzystny kształt, chłodny odcień albo źle położona wcześniejsza pigmentacja mogą ograniczać możliwość wykonania nowego, naturalnego efektu.",
  "shortAnswer": "Przy nieudanym makijażu permanentnym brwi nie należy działać domowymi sposobami ani przykrywać problemu kolejną pigmentacją bez kwalifikacji. Najpierw trzeba ocenić kolor, głębokość, kształt i stan skóry. Czasem możliwa jest korekta, a czasem potrzebne jest etapowe rozjaśnianie laserem lub removerem.",
  "canonicalPath": "/poradnik/nieudany-makijaz-permanentny-brwi-co-zrobic/",
  "heroImage": {
    "src": "",
    "alt": ""
  },
  "secondaryImage": {
    "src": "",
    "alt": ""
  },
  "mainService": {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie makijażu permanentnego"
  },
  "faqHeading": "Pytania: nieudany pmu brwi"
};

const tableOfContents = [
  {
    "href": "#najkrocej",
    "title": "Najkrócej"
  },
  {
    "href": "#co-oznacza",
    "title": "Co oznacza nieudany PMU"
  },
  {
    "href": "#czego-nie-robic",
    "title": "Czego nie robić"
  },
  {
    "href": "#korekta-czy-usuwanie",
    "title": "Korekta czy usuwanie"
  },
  {
    "href": "#laser-remover",
    "title": "Laser i remover"
  },
  {
    "href": "#faq",
    "title": "FAQ"
  }
];

const keyPoints = [
  "Nieudany makijaż permanentny brwi wymaga oceny pigmentu, skóry i kształtu.",
  "Nie stosuj domowych metod rozjaśniania, kwasów, peelingów ani mechanicznego ścierania.",
  "Nie każdy stary PMU można od razu przykryć nową pigmentacją.",
  "Czasem najlepszym pierwszym krokiem jest rozjaśnianie laserem albo removerem."
];

const sections = [
  {
    "id": "co-oznacza",
    "eyebrow": "Ocena sytuacji",
    "title": "Nieudany PMU może oznaczać różne problemy — i każdy wymaga innego planu.",
    "paragraphs": [
      "Dla jednej osoby problemem jest zbyt ciemny kolor, dla innej zbyt gruby kształt, asymetria, chłodny odcień albo pigment, który po czasie zmienił barwę.",
      "Nowy makijaż permanentny nie zawsze przykryje starą pracę. Jeśli pigment jest zbyt ciemny, głęboki lub źle ułożony, kolejna pigmentacja może pogłębić problem."
    ],
    "cards": [
      {
        "title": "Zbyt ciemne brwi",
        "text": "Mogą wymagać rozjaśnienia przed nowym projektem."
      },
      {
        "title": "Nieodpowiedni kształt",
        "text": "Stary rysunek może blokować naturalną korektę."
      },
      {
        "title": "Chłodny odcień",
        "text": "Szary lub sinawy pigment wymaga oceny."
      },
      {
        "title": "Nierówna praca",
        "text": "Nierówny kolor może wymagać planu etapowego."
      }
    ]
  },
  {
    "id": "czego-nie-robic",
    "eyebrow": "Nie działaj samodzielnie",
    "title": "Domowe rozjaśnianie brwi permanentnych może zrobić więcej szkody niż pożytku.",
    "paragraphs": [
      "W internecie można znaleźć porady o kwasach, peelingach, rozjaśniaczach, olejkach albo agresywnym ścieraniu skóry. To nie są bezpieczne metody usuwania PMU.",
      "Jeśli brwi po PMU nie wyglądają dobrze, nie należy panikować ani działać na świeżej skórze."
    ],
    "cards": [
      {
        "title": "Nie używaj kwasów",
        "text": "Agresywne preparaty mogą uszkodzić skórę."
      },
      {
        "title": "Nie ścieraj skóry",
        "text": "Mechaniczne tarcie nie usuwa pigmentu w kontrolowany sposób."
      },
      {
        "title": "Nie przykrywaj od razu",
        "text": "Nowy pigment na starym może pogłębić problem."
      },
      {
        "title": "Nie oceniaj zbyt wcześnie",
        "text": "Świeże brwi różnią się od efektu po wygojeniu."
      }
    ]
  },
  {
    "id": "korekta-czy-usuwanie",
    "eyebrow": "Plan pracy",
    "title": "Kiedy korygować, a kiedy najpierw rozjaśniać?",
    "paragraphs": [
      "Korekta ma sens wtedy, gdy stary pigment nie jest zbyt ciemny, kształt daje możliwość poprawy, a skóra pozwala na bezpieczną pracę.",
      "Jeśli stara pigmentacja dominuje nad twarzą, jest chłodna, gruba lub źle położona, często lepszym pierwszym krokiem jest rozjaśnienie."
    ],
    "cards": [
      {
        "title": "Korekta",
        "text": "Gdy stary pigment pozwala na bezpieczne dopracowanie."
      },
      {
        "title": "Rozjaśnianie",
        "text": "Gdy pigment blokuje nowy kształt."
      }
    ]
  },
  {
    "id": "laser-remover",
    "eyebrow": "Metody rozjaśniania",
    "title": "Laser i remover to różne narzędzia — wybór zależy od pigmentu i skóry.",
    "paragraphs": [
      "Laserowe rozjaśnianie i remover nie są tym samym. Ważny jest kolor pigmentu, głębokość, obszar, stan skóry i plan dalszej korekty.",
      "Usuwanie PMU zwykle wymaga etapów, przerw i obserwacji reakcji skóry."
    ],
    "cards": [
      {
        "title": "Laser",
        "text": "Może rozbijać wybrane pigmenty, ale wymaga kwalifikacji i przerw."
      },
      {
        "title": "Remover",
        "text": "Może być rozwiązaniem w wybranych przypadkach punktowej pracy."
      }
    ]
  }
];

const warningBox = {
  "title": "Nie próbuj usuwać pigmentu domowymi sposobami",
  "text": "Domowe rozjaśnianie, kwasy, peelingi i agresywne ścieranie skóry mogą doprowadzić do podrażnień, przebarwień lub blizn. Przy nieudanym PMU zacznij od kwalifikacji."
};

const relatedLinks = [
  {
    "href": "/usuwanie-makijazu-permanentnego/",
    "title": "Usuwanie makijażu permanentnego",
    "text": "Zobacz, jak wygląda kwalifikacja do laserowego rozjaśniania lub removera."
  },
  {
    "href": "/poradnik/kiedy-usuwac-stary-makijaz-permanentny/",
    "title": "Kiedy rozjaśniać stary PMU?",
    "text": "Przeczytaj, kiedy nie przykrywać starego pigmentu."
  },
  {
    "href": "/makijaz-permanentny-brwi/",
    "title": "Brwi permanentne",
    "text": "Sprawdź naturalne podejście do nowego projektu brwi."
  }
];

const faqItems = [
  {
    "question": "Co zrobić, jeśli makijaż permanentny brwi się nie udał?",
    "answer": "Najpierw trzeba poczekać na wygojenie, jeśli zabieg był świeży. Potem warto wykonać kwalifikację."
  },
  {
    "question": "Czy można rozjaśnić brwi permanentne domowym sposobem?",
    "answer": "Nie należy stosować domowych metod, kwasów, peelingów ani mechanicznego ścierania skóry."
  },
  {
    "question": "Czy nieudane brwi permanentne można przykryć nowymi?",
    "answer": "Czasem tak, ale nie zawsze. Jeśli pigment jest zbyt ciemny lub źle ułożony, bezpieczniej może być najpierw go rozjaśnić."
  },
  {
    "question": "Co jest lepsze: laser czy remover?",
    "answer": "Nie ma jednej odpowiedzi dla każdej osoby. Metodę dobiera się po ocenie pigmentu i skóry."
  },
  {
    "question": "Ile zabiegów potrzeba, żeby rozjaśnić stary PMU?",
    "answer": "Liczba zabiegów zależy od pigmentu, głębokości, nasycenia, koloru i reakcji skóry."
  },
  {
    "question": "Kiedy można zrobić nowe brwi po usuwaniu PMU?",
    "answer": "Dopiero po wygojeniu skóry i ocenie stopnia rozjaśnienia."
  }
];

const pageUrl = `https://permanentnybielsko.com${article.canonicalPath}`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${pageUrl}#article`,
    url: pageUrl,
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.dateModified,
    inLanguage: "pl-PL",
    author: {
      "@type": "Person",
      name: "Bogusława Herda",
      url: "https://permanentnybielsko.com/",
    },
    publisher: {
      "@id": "https://permanentnybielsko.com/#localbusiness",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Poradnik PMU",
        item: "https://permanentnybielsko.com/poradnik/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={`${article.title} | Poradnik PMU Bogusława Herda`}
  description={article.description}
  canonicalPath={article.canonicalPath}
  structuredData={structuredData}
>
  <div class="article-page">
    <Header />

    <main>
      <section class="article-hero">
        <div class="container article-hero-grid">
          <div class="article-hero-copy">
            <p class="section-kicker">{article.eyebrow}</p>

            <div class="article-meta">
              <span>{article.category}</span>
              <span>{article.readingTime}</span>
            </div>

            <h1>{article.title}</h1>

            <p class="article-lead">{article.lead}</p>
          </div>

          <aside class="article-hero-summary" aria-label="Krótka odpowiedź">
            <p class="summary-label">Najkrócej</p>
            <h2>Co warto wiedzieć?</h2>
            <p>{article.shortAnswer}</p>
          </aside>
        </div>
      </section>

      <section class="article-content-section">
        <div class="container article-layout">
          <aside class="article-sidebar" aria-label="Spis treści">
            <div class="article-sidebar-card">
              <p>W artykule</p>
              <nav>
                {tableOfContents.map((item) => (
                  <a href={item.href}>{item.title}</a>
                ))}
              </nav>
            </div>

            <div class="article-sidebar-card article-sidebar-card-soft">
              <p>Powiązane</p>
              <a href="/poradnik/">Poradnik PMU</a>
              <a href={article.mainService.href}>{article.mainService.title}</a>
              <a href={booksyUrl} target="_blank" rel="noopener noreferrer">Umów wizytę</a>
            </div>
          </aside>

          <article class="article-main">
            <section class="article-answer-card" id="najkrocej">
              <p class="section-kicker">Krótka odpowiedź</p>
              <h2>Najważniejsze w kilku zdaniach</h2>
              <p>{article.shortAnswer}</p>
            </section>

            <section class="article-keypoints" aria-label="Najważniejsze punkty">
              {keyPoints.map((point) => (
                <div>
                  <span></span>
                  <p>{point}</p>
                </div>
              ))}
            </section>

            {article.heroImage.src && (
              <figure class="article-image article-image-wide">
                <img
                  src={article.heroImage.src}
                  alt={article.heroImage.alt}
                  width="1400"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            )}

            {sections.map((section, index) => (
              <section class="article-text-block" id={section.id}>
                <p class="section-kicker">{section.eyebrow}</p>
                <h2>{section.title}</h2>

                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.cards && (
                  <div class="article-simple-cards">
                    {section.cards.map((card) => (
                      <article>
                        <h3>{card.title}</h3>
                        <p>{card.text}</p>
                      </article>
                    ))}
                  </div>
                )}

                {index === 1 && article.secondaryImage.src && (
                  <figure class="article-image">
                    <img
                      src={article.secondaryImage.src}
                      alt={article.secondaryImage.alt}
                      width="1200"
                      height="900"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                )}
              </section>
            ))}

            <section class="article-warning-card">
              <h2>{warningBox.title}</h2>
              <p>{warningBox.text}</p>
            </section>

            <section class="article-related-section">
              <p class="section-kicker">Powiązane tematy</p>
              <h2>Co warto przeczytać dalej?</h2>

              <div class="article-related-grid">
                {relatedLinks.map((item) => (
                  <a href={item.href}>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </a>
                ))}
              </div>
            </section>

            <section class="article-faq-section" id="faq">
              <p class="section-kicker">Najczęstsze pytania</p>
              <h2>{article.faqHeading}</h2>

              <div class="article-faq-list">
                {faqItems.map((item) => (
                  <article>
                    <h3>{item.question}</h3>
                    <p>{item.answer}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="article-final-cta">
              <p class="signature cta-signature">Powrót do natury</p>
              <h2>Nie masz pewności, czy zabieg jest dla Ciebie?</h2>
              <p>
                Zacznij od konsultacji. Przy makijażu permanentnym najważniejsza jest spokojna decyzja:
                analiza skóry, oczekiwań, naturalnej urody i możliwości uzyskania dobrego efektu po wygojeniu.
              </p>

              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację przez Booksy
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .article-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 82% 10%, rgba(56, 187, 181, 0.10), transparent 28rem),
      radial-gradient(circle at 12% 42%, rgba(201, 127, 143, 0.10), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 48%, #ffffff 100%);
  }

  .article-page .section-kicker {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 30px;
    align-items: center;
    justify-content: center;
    margin: 0 0 16px;
    padding: 0 12px;
    border: 1px solid rgba(56, 187, 181, 0.18);
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.76);
    color: var(--color-turquoise-dark, #0f7773);
    -webkit-text-fill-color: var(--color-turquoise-dark, #0f7773);
    font-size: 0.68rem;
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .article-hero {
    padding: 150px 0 72px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 24px;
    align-items: stretch;
  }

  .article-hero-copy,
  .article-hero-summary,
  .article-sidebar-card,
  .article-answer-card,
  .article-keypoints,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta,
  .article-image {
    border: 1px solid rgba(183, 101, 118, 0.14);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.065);
  }

  .article-hero-copy {
    padding: clamp(34px, 5vw, 64px);
    border-radius: 38px;
    background: rgba(255, 255, 255, 0.80);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-meta span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255, 248, 251, 0.92);
    color: var(--color-muted, #6e6670);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .article-lead {
    max-width: 920px;
    margin: 26px 0 0;
    color: var(--color-muted, #6e6670);
    font-size: clamp(1.06rem, 1.35vw, 1.24rem);
    line-height: 1.72;
  }

  .article-hero-summary {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(30px, 4vw, 48px);
    border-radius: 38px;
    background:
      radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.26), transparent 13rem),
      linear-gradient(145deg, #38bbb5 0%, #159a96 48%, #0f7773 100%);
    color: #ffffff;
  }

  .summary-label {
    margin: 0 auto auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .article-hero-summary h2 {
    margin: 58px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3.3vw, 3.7rem);
    font-weight: 780;
    line-height: 1;
    letter-spacing: -0.072em;
  }

  .article-hero-summary p:not(.summary-label) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.02rem;
    line-height: 1.66;
  }

  .article-content-section {
    padding: 28px 0 88px;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .article-sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 14px;
  }

  .article-sidebar-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.82);
  }

  .article-sidebar-card p {
    margin: 0 0 14px;
    color: var(--color-text, #17151d);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-sidebar-card nav,
  .article-sidebar-card {
    display: grid;
    gap: 8px;
  }

  .article-sidebar-card a {
    display: block;
    color: var(--color-muted, #6e6670);
    font-size: 0.94rem;
    line-height: 1.45;
    text-decoration: none;
  }

  .article-sidebar-card a:hover {
    color: #0f7773;
  }

  .article-sidebar-card-soft {
    background: rgba(219, 246, 243, 0.46);
  }

  .article-main {
    display: grid;
    gap: 22px;
    min-width: 0;
  }

  .article-answer-card,
  .article-text-block,
  .article-warning-card,
  .article-related-section,
  .article-faq-section,
  .article-final-cta {
    padding: clamp(28px, 4vw, 46px);
    border-radius: 32px;
    background:
      radial-gradient(circle at 94% 12%, rgba(56, 187, 181, 0.07), transparent 14rem),
      rgba(255, 255, 255, 0.86);
  }

  .article-answer-card h2,
  .article-text-block h2,
  .article-warning-card h2,
  .article-related-section h2,
  .article-faq-section h2,
  .article-final-cta h2 {
    max-width: 900px;
    margin: 0;
    color: var(--color-text, #17151d);
    font-size: clamp(2rem, 3.2vw, 3.55rem);
    font-weight: 780;
    line-height: 1.03;
    letter-spacing: -0.068em;
  }

  .article-answer-card p:not(.section-kicker),
  .article-text-block p:not(.section-kicker),
  .article-warning-card p,
  .article-related-section p,
  .article-faq-section p,
  .article-final-cta p:not(.signature) {
