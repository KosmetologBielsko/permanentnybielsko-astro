    "serviceType": "Usuwanie i rozjaśnianie makijażu permanentnego",
    "description":
      "Usuwanie i rozjaśnianie starego makijażu permanentnego w Bielsku-Białej, kwalifikacja skóry, korekta nieudanego PMU i przygotowanie do nowej pigmentacji.",
    "areaServed": [
      {
        "@type": "City",
        "name": "Bielsko-Biała"
      },
      {
        "@type": "AdministrativeArea",
        "name": "województwo śląskie"
      }
    ],
    "provider": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "brand": {
      "@type": "Brand",
      "name": "Bogusława Herda Makijaż Permanentny"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Usuwanie i naprawa PMU",
      "itemListElement": [
        {
          "@type": "Offer",
