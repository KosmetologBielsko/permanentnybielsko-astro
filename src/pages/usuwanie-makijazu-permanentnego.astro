---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/usuwanie-makijazu-permanentnego/";
const pageTitle = "Usuwanie makijażu permanentnego Bielsko-Biała | Laser i remover";
const pageDescription =
  "Usuwanie makijażu permanentnego Bielsko-Biała: rozjaśnianie starego PMU laserem GLOVCON Q-Switch Nd:YAG lub removerem Bye-Bye Pigment Long-Time-Liner.";

const proofItems = [
  { title: "Kwalifikacja", text: "ocena starego pigmentu i skóry" },
  { title: "Laser / remover", text: "dobór metody do sytuacji" },
  { title: "Korekta PMU", text: "czasem dopiero po rozjaśnieniu" },
  { title: "Plan etapowy", text: "bez pośpiechu i bez pogłębiania problemu" },
];

const decisionItems = [
  {
    title: "Liczba zabiegów",
    text: "zależy od koloru, głębokości, nasycenia i reakcji skóry",
  },
  {
    title: "Przerwy między etapami",
    text: "są potrzebne do regeneracji i oceny efektu rozjaśnienia",
  },
  {
    title: "Realne oczekiwania",
    text: "nie każdy pigment da się usunąć szybko i w pełni przewidywalnie",
  },
  {
    title: "Plan korekty",
    text: "nowe brwi planujemy dopiero wtedy, gdy skóra daje do tego warunki",
  },
];

const indicationsItems = [
  {
    title: "Zbyt ciemny pigment",
    text: "gdy brwi, usta albo kreska są za mocne i nie współpracują z urodą",
    image: "/images/01-zbyt-ciemny-pigment.webp",
  },
  {
    title: "Nieodpowiedni kształt",
    text: "gdy stary rysunek zaburza proporcje twarzy albo ogranicza nowy projekt",
    image: "/images/02-nieodpowiedni-ksztalt.webp",
  },
  {
    title: "Chłodny odcień",
    text: "gdy pigment po czasie zmienił ton i wymaga oceny przed dalszą pracą",
    image: "/images/03-chlodny-odcien.webp",
  },
  {
    title: "Nierówna pigmentacja",
    text: "gdy kolor nie rozłożył się równomiernie albo wymaga etapowego rozjaśniania",
    image: "/images/04-nierowna-pigmentacja.webp",
  },
  {
    title: "Plan nowego PMU",
    text: "gdy przed korektą trzeba przygotować skórę i stworzyć miejsce na nowy efekt",
    image: "/images/05-plan-nowego-pmu.webp",
  },
  {
    title: "Stara praca w skórze",
    text: "gdy nie da się odpowiedzialnie przykryć starego pigmentu kolejną pigmentacją",
    image: "/images/06-stara-praca-w-skorze.webp",
  },
];

const processItems = [
  {
    title: "Konsultacja",
    text: "rozmowa o historii pigmentacji, oczekiwanym efekcie i możliwych ograniczeniach",
  },
  {
    title: "Ocena pigmentu",
    text: "analiza koloru, głębokości, nasycenia, kształtu i stanu skóry",
  },
  {
    title: "Dobór metody",
    text: "wybór między laserem, removerem albo etapowym przygotowaniem do korekty",
  },
  {
    title: "Zabieg",
    text: "precyzyjna praca wyłącznie w zakresie, który daje skórze bezpieczne warunki",
  },
  {
    title: "Gojenie",
    text: "czas na regenerację, obserwację skóry i stopniowe rozjaśnianie pigmentu",
  },
  {
    title: "Dalszy plan",
    text: "kolejny etap, przerwa albo przygotowanie do nowego makijażu permanentnego",
  },
];

const faqItems = [
  {
    question: "Czy jeden zabieg usuwania makijażu permanentnego wystarczy?",
    answer:
      "Nie zawsze. Liczba zabiegów zależy od koloru, głębokości, nasycenia pigmentu, rodzaju użytych barwników i indywidualnej reakcji skóry.",
  },
  {
    question: "Co jest lepsze: laser czy remover?",
    answer:
      "Nie ma jednej odpowiedzi dla każdej klientki. Metodę dobiera się po ocenie pigmentu, skóry, miejsca zabiegowego i planu dalszej korekty.",
  },
  {
    question: "Czy można od razu przykryć stary makijaż permanentny nowym?",
    answer:
      "Czasem tak, ale bardzo często najpierw trzeba rozjaśnić starą pigmentację. Przykrywanie zbyt ciemnego lub źle ułożonego pigmentu może pogłębić problem.",
  },
  {
    question: "Kiedy można planować nowy makijaż permanentny po rozjaśnianiu?",
    answer:
      "Dopiero po wygojeniu skóry i ocenie efektu rozjaśnienia. Plan nowego PMU powinien wynikać z realnego stanu skóry, a nie z pośpiechu.",
  },
  {
    question: "Czy usuwanie makijażu permanentnego boli?",
    answer:
      "Odczucia są indywidualne. Przed zabiegiem omawiany jest przebieg pracy, możliwe reakcje skóry i zalecenia po zabiegu.",
  },
  {
    question: "Czy można usuwać pigment z brwi, ust i kresek?",
    answer:
      "Każda okolica wymaga osobnej kwalifikacji. Szczególnej ostrożności wymagają usta i okolica oka, dlatego decyzja o metodzie zapada po analizie przypadku.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: pageTitle,
    description: pageDescription,
    inLanguage: "pl-PL",
    isPartOf: { "@id": "https://permanentnybielsko.com/#website" },
    about: { "@id": "https://permanentnybielsko.com/#localbusiness" },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: "https://permanentnybielsko.com/images/usuwanie-pmu-glovcon-q-switch-nd-yag.webp",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Strona główna",
        item: "https://permanentnybielsko.com/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Makijaż permanentny Bielsko-Biała",
        item: "https://permanentnybielsko.com/makijaz-permanentny-bielsko/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Usuwanie makijażu permanentnego",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${pageUrl}#service`,
    name: "Usuwanie makijażu permanentnego Bielsko-Biała",
    serviceType: "Usuwanie makijażu permanentnego",
    description:
      "Usuwanie i rozjaśnianie starego makijażu permanentnego w Bielsku-Białej: kwalifikacja, laser GLOVCON Q-Switch Nd:YAG, remover Bye-Bye Pigment Long-Time-Liner i plan korekty PMU.",
    areaServed: [
      { "@type": "City", name: "Bielsko-Biała" },
      { "@type": "AdministrativeArea", name: "województwo śląskie" },
    ],
    provider: { "@id": "https://permanentnybielsko.com/#localbusiness" },
    brand: { "@type": "Brand", name: "Bogusława Herda Makijaż Permanentny" },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Metody usuwania makijażu permanentnego",
      itemListElement: [
        {
          "@type": "Offer",
          itemOffered: { "@type": "Service", name: "Laserowe usuwanie makijażu permanentnego" },
        },
        {
          "@type": "Offer",
          itemOffered: { "@type": "Service", name: "Remover Bye-Bye Pigment Long-Time-Liner" },
        },
        {
          "@type": "Offer",
          itemOffered: { "@type": "Service", name: "Korekta makijażu permanentnego po rozjaśnieniu" },
        },
      ],
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/usuwanie-makijazu-permanentnego/"
  structuredData={structuredData}
>
  <div class="removal-page">
    <Header />

    <main>
      <section class="removal-hero">
        <div class="removal-glow removal-glow-one"></div>
        <div class="removal-glow removal-glow-two"></div>

        <div class="container removal-hero-grid">
          <div class="removal-hero-copy">
            <p class="section-kicker">Usuwanie makijażu permanentnego Bielsko-Biała</p>

            <h1>
              Stary makijaż permanentny czasem trzeba najpierw
              <span class="pmu-hero-turquoise-text">rozjaśnić</span>, a dopiero potem poprawiać.
            </h1>

            <p class="removal-hero-lead">
              Zbyt ciemne brwi, niekorzystny kształt, chłodny odcień albo nierówna pigmentacja
              wymagają spokojnej oceny. Czasem najlepszym pierwszym krokiem nie jest nowy zabieg,
              ale bezpieczne rozjaśnienie starego PMU.
            </p>

            <div class="removal-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację
              </a>

              <a class="button-secondary" href="#kwalifikacja">
                Jak wygląda kwalifikacja?
              </a>
            </div>
          </div>

          <aside class="removal-hero-card" aria-label="Usuwanie PMU">
            <p class="removal-card-label">PMU</p>
            <h2>Nie przykrywamy problemu. Najpierw sprawdzamy, co jest w skórze.</h2>
            <p>
              Przed decyzją o korekcie lub usuwaniu oceniany jest kolor, nasycenie,
              głębokość pigmentu, stan skóry i realna możliwość uzyskania naturalnego efektu.
            </p>
          </aside>
        </div>
      </section>

      <section class="removal-proof-section" aria-label="Najważniejsze etapy usuwania PMU">
        <div class="container removal-proof-grid">
          {proofItems.map((item) => (
            <div>
              <strong>{item.title}</strong>
              <span>{item.text}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="removal-intro-section" id="kwalifikacja">
        <div class="container removal-assessment-card">
          <figure class="removal-assessment-media">
            <img
  src="/images/szkolenia-pmu-praktyka-zabiegowa-long-time-liner.webp"
  alt="Bogusława Herda podczas pracy zabiegowej — kwalifikacja i precyzyjna praca z makijażem permanentnym"
  width="1200"
  height="1800"
  loading="lazy"
  decoding="async"
/>
          </figure>

          <div class="removal-assessment-copy">
            <p class="section-kicker">Kwalifikacja</p>

            <h2>Najpierw ocena starego pigmentu. Dopiero potem decyzja o metodzie.</h2>

            <p>
              Usuwanie makijażu permanentnego nie powinno być przypadkowe. Inaczej pracuje się
              przy zbyt ciemnych brwiach, inaczej przy chłodnym odcieniu, a jeszcze inaczej
              przy wcześniejszej pigmentacji ust lub kresek.
            </p>

            <p>
              Celem jest bezpieczne przygotowanie skóry do dalszego planu: rozjaśnienia,
              korekty albo nowego makijażu permanentnego. Dlatego liczy się nie tylko sam zabieg,
              ale również przerwy, gojenie i realna ocena efektu po każdym etapie.
            </p>
          </div>
        </div>
      </section>

      <section class="removal-methods-section">
        <div class="container">
          <div class="removal-section-heading">
            <p class="section-kicker">Dwie ścieżki pracy</p>
            <h2>Laser albo remover — metoda musi wynikać z tego, co jest w skórze.</h2>
            <p>
              Nie każdy pigment zachowuje się tak samo. Dlatego przed zabiegiem oceniany jest kolor,
              nasycenie, głębokość, okolica zabiegowa i to, czy celem jest pełniejsze rozjaśnienie,
              czy przygotowanie skóry do korekty.
            </p>
          </div>

          <div class="removal-methods-grid">
            <article class="removal-method-card">
              <figure class="removal-method-media">
                <img
                  src="/images/usuwanie-pmu-bye-bye-pigment-zestaw.webp"
                  alt="Remover Bye-Bye Pigment Long-Time-Liner do usuwania makijażu permanentnego"
                  width="1600"
                  height="1200"
                  loading="lazy"
                  decoding="async"
                />
              </figure>

              <div class="removal-method-copy">
                <p class="section-kicker">Remover Long-Time-Liner®</p>
                <h3>Bye-Bye Pigment jako delikatna alternatywa dla wybranych przypadków.</h3>
                <p>
                  Remover może być rozwiązaniem przy wybranych pigmentacjach, gdy potrzebna jest
                  precyzyjna praca w konkretnym obszarze. Preparat dobierany jest do sytuacji
                  po wcześniejszej ocenie skóry, pigmentu i planu dalszej korekty.
                </p>
              </div>
            </article>

            <article class="removal-method-card removal-method-card-turquoise">
              <figure class="removal-method-media">
                <img
                  src="/images/usuwanie-pmu-glovcon-q-switch-nd-yag.webp"
                  alt="Glovcon MED Q-Switch Nd:YAG — technologia laserowa do rozjaśniania pigmentu"
                  width="1800"
                  height="1200"
                  loading="lazy"
                  decoding="async"
                />
              </figure>

              <div class="removal-method-copy">
                <p class="section-kicker">Laserowe rozjaśnianie</p>
                <h3>GLOVCON® Q-Switch Nd:YAG jako wsparcie przy usuwaniu starego PMU.</h3>
                <p>
                  Laser działa impulsowo, rozbijając cząsteczki pigmentu w skórze.
                  Rozjaśnianie zwykle wymaga etapów, przerw i obserwacji reakcji skóry,
                  dlatego plan zabiegowy ustalany jest indywidualnie.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="removal-knowledge-section">
        <div class="container removal-knowledge-grid">
          <div class="removal-knowledge-heading">
            <p class="section-kicker">Co warto wiedzieć?</p>
            <h2>Usuwanie pigmentu wymaga cierpliwości, planu i realnej oceny.</h2>
            <p>
              To nie jest zabieg, w którym warto działać na skróty. Skóra potrzebuje czasu,
              pigment reaguje indywidualnie, a dobry efekt końcowy zależy od rozsądnych decyzji
              podejmowanych etap po etapie.
            </p>
          </div>

          <div class="premium-points-list premium-points-list--turquoise" aria-label="Najważniejsze zasady usuwania makijażu permanentnego">
            {decisionItems.map((item) => (
              <div class="premium-point">
                <span class="premium-point__dot" aria-hidden="true"></span>
                <div class="premium-point__content">
                  <strong class="premium-point__title">{item.title}</strong>
                  <span class="premium-point__text">{item.text}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="removal-indications-section">
        <div class="container">
          <div class="removal-section-heading">
            <p class="section-kicker">Kiedy rozważyć usuwanie?</p>
            <h2>Czasem najlepsza korekta zaczyna się od rozjaśnienia starej pracy.</h2>
            <p>
              Jeśli pigment jest zbyt mocny, ma niekorzystny kolor albo blokuje nowy projekt,
              odpowiedzialna korekta może wymagać wcześniejszego przygotowania skóry.
            </p>
          </div>

          <div
            class="removal-indications-grid"
            aria-label="Kiedy warto rozważyć usuwanie makijażu permanentnego"
          >
            {indicationsItems.map((item) => (
              <article class="removal-mini-card removal-mini-card-image">
                <img
                  src={item.image}
                  alt={`${item.title} — ${item.text}`}
                  title={item.title}
                  width="1536"
                  height="1024"
                  loading="lazy"
                  decoding="async"
                />
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="removal-product-section">
        <div class="container removal-product-card">
          <div class="removal-product-copy">
            <p class="section-kicker">Bye-Bye Pigment</p>
            <h2>Remover stosujemy wtedy, gdy jest do tego dobra kwalifikacja.</h2>
            <p>
              Nie każda pigmentacja wymaga lasera. W wybranych przypadkach remover pozwala
              pracować punktowo i etapowo, szczególnie gdy ważna jest bardzo spokojna ocena
              reakcji skóry oraz późniejszy plan korekty.
            </p>
          </div>

          <figure class="removal-product-media">
            <img
              src="/images/usuwanie-pmu-bye-bye-pigment.webp"
              alt="Bye-Bye Pigment Long-Time-Liner — remover do makijażu permanentnego"
              width="1200"
              height="1200"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
      </section>

      <section class="removal-process-section">
        <div class="container">
          <div class="removal-section-heading">
            <p class="section-kicker">Proces pracy</p>
            <h2>Najpierw plan. Potem zabieg. Na końcu decyzja, czy skóra jest gotowa na korektę.</h2>
            <p>
              Przy usuwaniu PMU najważniejsze jest, żeby nie pogłębić problemu. Dlatego każdy etap
              powinien być zaplanowany z uwzględnieniem skóry, pigmentu i docelowego efektu.
            </p>
          </div>

          <div class="removal-process-grid">
            {processItems.map((item, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="removal-price-section">
        <div class="container removal-price-card">
          <div>
            <p class="section-kicker">Cennik orientacyjny</p>
            <h2>Cena zależy od metody, obszaru i planu pracy.</h2>
            <p>
              Dokładny koszt i liczba etapów ustalane są po kwalifikacji. Przy starym makijażu
              permanentnym ważniejsza od szybkiej decyzji jest dobra ocena skóry i pigmentu.
            </p>
          </div>

          <div class="removal-price-list">
            <div>
              <strong>Laserowe usuwanie PMU</strong>
              <span>200–400 zł</span>
            </div>

            <div>
              <strong>Remover Bye-Bye Pigment</strong>
              <span>200–400 zł</span>
            </div>

            <div>
              <strong>Konsultacja i plan korekty</strong>
              <span>ustalane indywidualnie</span>
            </div>
          </div>
        </div>
      </section>

      <section class="removal-related-section">
        <div class="container">
          <div class="removal-section-heading">
            <p class="section-kicker">Oferta PMU</p>
            <h2>Zobacz również inne podstrony makijażu permanentnego.</h2>
          </div>

          <div class="removal-related-grid">
            <a href="/makijaz-permanentny-bielsko/" class="removal-related-card">
              <span>PMU</span>
              <h3>Makijaż permanentny Bielsko-Biała</h3>
              <p>Główna podstrona o makijażu permanentnym: brwi, usta, kreski, konsultacja i naturalny efekt.</p>
            </a>

            <a href="/makijaz-permanentny-brwi/" class="removal-related-card removal-related-card-turquoise">
              <span>Brwi</span>
              <h3>Brwi permanentne</h3>
              <p>Naturalne brwi, metoda włoskowa, włos z cieniem i Silky Hairstroke Brows.</p>
            </a>

            <a href="/makijaz-permanentny-ust/" class="removal-related-card">
              <span>Usta</span>
              <h3>Usta permanentne</h3>
              <p>Naturalny kolor ust, miękki kontur i świeży efekt bez przerysowania.</p>
            </a>

            <a href="/makijaz-permanentny-oczu/" class="removal-related-card removal-related-card-rose">
              <span>Kreski</span>
              <h3>Makijaż permanentny oczu</h3>
              <p>Zagęszczenie linii rzęs i kreski dopasowane do budowy oka.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="removal-faq-section">
        <div class="container">
          <div class="removal-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Co warto wiedzieć przed usuwaniem makijażu permanentnego?</h2>
          </div>

          <div class="removal-faq-grid">
            {faqItems.map((item) => (
              <article>
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="removal-final-cta" id="kontakt">
        <div class="container removal-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Chcesz sprawdzić, czy stary makijaż permanentny wymaga rozjaśnienia?</h2>
          <p>
            Umów konsultację i zobacz, jaki plan będzie najbezpieczniejszy dla Twojej skóry:
            laser, remover, etapowe rozjaśnianie albo przygotowanie do korekty PMU.
          </p>

          <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
            Umów wizytę przez Booksy
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .removal-page {
    min-height: 100vh;
    overflow-x: hidden;
