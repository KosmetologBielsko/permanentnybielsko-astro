---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const bridgeCards = [
  {
    number: "01",
    title: "Step by Step",
    text: "Szkolenia podstawowe dla wybranego obszaru: brwi, usta albo oczy.",
    href: "/szkolenie-makijaz-permanentny/"
  },
  {
    number: "02",
    title: "Masterclass",
    text: "Szkolenia doszkalające dla osób, które chcą poprawić konkretną technikę.",
    href: "/szkolenie-makijaz-permanentny/"
  },
  {
    number: "03",
    title: "Silky Hairstroke Brows",
    text: "Autorski kierunek pracy z naturalnym włosem maszynowym.",
    href: "/szkolenie-makijaz-permanentny/",
    featured: true
  },
  {
    number: "04",
    title: "Kontakt w sprawie szkolenia",
    text: "Najlepsza ścieżka, jeżeli chcesz dobrać zakres szkolenia do poziomu i celu.",
    href: "/kontakt/"
  }
];

const photoSlots = [
  {
    label: "Zdjęcie szkoleniowe",
    title: "Praca z kursantką",
    text: "Miejsce na zdjęcie pokazujące atmosferę szkolenia, pracę przy stanowisku albo konsultację techniczną."
  },
  {
    label: "Detal PMU",
    title: "Technika i precyzja",
    text: "Miejsce na kadr detalu: rysunek wstępny, pigmentacja, skórki treningowe albo praca na modelce."
  },
  {
    label: "Autorytet",
    title: "Bogusława Herda",
    text: "Miejsce na zdjęcie prowadzącej szkolenie, najlepiej portretowe lub w naturalnej pracy z kursantką."
  }
];
---

<Layout
  title="Szkolenia PMU Bielsko-Biała | Bogusława Herda"
  description="Szkolenia PMU Bogusława Herda w Bielsku-Białej. Step by Step, Masterclass, Silky Hairstroke Brows i szkolenia Long-Time-Liner®. Przejdź do pełnej oferty szkoleń makijażu permanentnego."
>
  <div class="trainings-bridge-page">
    <Header />

    <main>
      <section class="trainings-bridge-hero">
        <div class="trainings-bridge-glow trainings-bridge-glow-one"></div>
        <div class="trainings-bridge-glow trainings-bridge-glow-two"></div>

        <div class="container trainings-bridge-grid">
          <div class="trainings-bridge-copy">
            <p class="section-kicker">Szkolenia PMU Bielsko-Biała</p>

            <h1>Szkolenia makijażu permanentnego prowadzone przez Bogusława Herda.</h1>

            <p class="trainings-bridge-lead">
              Edukacja w PMU powinna rozwijać nie tylko technikę, ale też sposób myślenia:
              o twarzy, skórze, rysunku wstępnym, kolorze, gojeniu i odpowiedzialnej pracy z klientką.
            </p>

            <div class="trainings-bridge-actions">
              <a class="button-primary" href="/szkolenie-makijaz-permanentny/">
                Zobacz pełną ofertę szkoleń
              </a>

              <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Zapytaj przez Booksy
              </a>
            </div>
          </div>

          <aside class="trainings-bridge-card" aria-label="Szkolenia PMU">
            <p class="trainings-bridge-label">EDU</p>
            <h2>Technika. Decyzja. Standard pracy.</h2>
            <p>
              Szkolenia prowadzą do świadomej pracy: od rysunku wstępnego i kwalifikacji,
              przez dobór techniki, aż po analizę efektu po wygojeniu.
            </p>
          </aside>
        </div>
      </section>

      <section class="trainings-bridge-intro-section">
        <div class="container trainings-bridge-two-column">
          <div>
            <p class="section-kicker">Kierunek szkoleniowy</p>
            <h2>Jedna uporządkowana ścieżka do pełnej oferty szkoleń PMU.</h2>
          </div>

          <div class="trainings-bridge-text-card">
            <p>
              W tej części strony znajdziesz najważniejsze kierunki edukacyjne: szkolenia podstawowe,
              szkolenia doszkalające, technikę Silky Hairstroke Brows oraz kontakt w sprawie organizacji.
            </p>

            <p>
              Szczegółowy program, ceny, warunki uczestnictwa i opis poszczególnych szkoleń znajdują się
              na pełnej podstronie szkolenia makijażu permanentnego.
            </p>

            <a class="text-link" href="/szkolenie-makijaz-permanentny/">
              Przejdź do szczegółów szkoleń →
            </a>
          </div>
        </div>
      </section>

      <section class="trainings-bridge-links-section">
        <div class="container">
          <div class="trainings-bridge-heading">
            <p class="section-kicker">Wybierz kierunek</p>
            <h2>Najważniejsze obszary szkoleń makijażu permanentnego.</h2>
            <p>
              Każdy kafelek prowadzi do właściwego miejsca — pełnej oferty szkoleń albo kontaktu,
              jeżeli chcesz najpierw zapytać o zakres i termin.
            </p>
          </div>

          <div class="trainings-bridge-link-grid">
            {bridgeCards.map((item) => (
              <a href={item.href} class:list={["trainings-bridge-link-card", { "trainings-bridge-link-card-featured": item.featured }]}>
                {item.featured && (
                  <span class="trainings-bridge-big-mark" aria-hidden="true">SHB</span>
                )}

                <span>{item.number}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="trainings-bridge-photos-section">
        <div class="container">
          <div class="trainings-bridge-heading">
            <p class="section-kicker">Miejsce na zdjęcia</p>
            <h2>Strona jest przygotowana pod późniejsze zdjęcia ze szkoleń.</h2>
            <p>
              Na tym etapie zostawiamy eleganckie miejsca pod zdjęcia. Później wystarczy podmienić
              placeholdery na właściwe kadry: pracę z kursantką, detal techniczny i portret prowadzącej.
            </p>
          </div>

          <div class="trainings-photo-grid">
            {photoSlots.map((slot) => (
              <article class="trainings-photo-card">
                <div class="trainings-photo-placeholder">
                  <span>{slot.label}</span>
                </div>

                <h3>{slot.title}</h3>
                <p>{slot.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="trainings-bridge-feature-section">
        <div class="container trainings-bridge-feature-card">
          <span class="trainings-bridge-big-mark trainings-bridge-big-mark-large" aria-hidden="true">MENTOR</span>

          <div>
            <p class="section-kicker">Rozwój i autorytet</p>
            <h2>Szkolenia są częścią zawodowej historii Bogusława Herda.</h2>
          </div>

          <p>
            Doświadczenie trenerskie, praca w standardzie Long-Time-Liner® oraz autorska technika
            Silky Hairstroke Brows tworzą zaplecze edukacyjne, które wykracza poza samą instrukcję zabiegu.
          </p>
        </div>
      </section>

      <section class="trainings-bridge-final-cta">
        <div class="container trainings-bridge-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Chcesz sprawdzić pełną ofertę szkoleń PMU?</h2>
          <p>
            Przejdź do głównej podstrony szkoleniowej, gdzie znajdziesz programy, zakres,
            ceny i informacje organizacyjne.
          </p>

          <a class="button-primary" href="/szkolenie-makijaz-permanentny/">
            Przejdź do pełnej oferty szkoleń
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .trainings-bridge-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.12), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.12), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .trainings-bridge-hero {
    position: relative;
    padding: 150px 0 88px;
    overflow: hidden;
  }

  .trainings-bridge-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .trainings-bridge-glow-one {
    right: -12rem;
    top: 4rem;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.2), transparent 68%);
  }

  .trainings-bridge-glow-two {
    left: -10rem;
    bottom: -12rem;
    width: 38rem;
    height: 38rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.18), transparent 68%);
  }

  .trainings-bridge-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    gap: 24px;
    align-items: stretch;
  }

  .trainings-bridge-copy,
  .trainings-bridge-card,
  .trainings-bridge-text-card,
  .trainings-bridge-link-card,
  .trainings-photo-card,
  .trainings-bridge-feature-card,
  .trainings-bridge-final-card {
    border: 1px solid rgba(183, 101, 118, 0.16);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .trainings-bridge-copy {
    padding: clamp(38px, 5vw, 72px);
    border-radius: 42px;
    background: rgba(255, 255, 255, 0.76);
  }

  .trainings-bridge-copy h1 {
    max-width: 1040px;
    margin: 0;
    font-size: clamp(3.05rem, 5.45vw, 6.35rem);
    font-weight: 750;
    line-height: 1.02;
    letter-spacing: -0.078em;
  }

  .trainings-bridge-lead {
    max-width: 780px;
    margin: 28px 0 0;
    color: var(--color-muted);
    font-size: 1.12rem;
  }

  .trainings-bridge-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .trainings-bridge-card {
    position: relative;
    overflow: hidden;
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(34px, 4vw, 56px);
    border-radius: 42px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.3), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(255, 245, 215, 0.3), transparent 13rem),
      linear-gradient(140deg, #6f5730 0%, #b9924d 18%, #f4e0a4 34%, #8e6b36 50%, #d1aa63 67%, #fff0c8 82%, #8a6731 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: trainings-bridge-gold-flow 14s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(125, 95, 45, 0.24);
  }

  .trainings-bridge-card::before,
  .trainings-bridge-link-card-featured::after,
  .trainings-bridge-feature-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.06) 22%, rgba(255, 255, 255, 0.26) 47%, rgba(255, 255, 255, 0.06) 72%, transparent 100%);
    transform: translateX(-72%);
    animation: trainings-bridge-panel-shine 8.5s ease-in-out infinite;
    pointer-events: none;
  }

  .trainings-bridge-label {
    position: relative;
    z-index: 2;
    margin: 0 0 auto;
    color: rgba(255, 248, 230, 0.22);
    font-size: clamp(4.5rem, 7vw, 7.8rem);
    font-weight: 800;
    line-height: 0.8;
    letter-spacing: -0.09em;
  }

  .trainings-bridge-card h2,
  .trainings-bridge-card p:not(.trainings-bridge-label) {
    position: relative;
    z-index: 2;
  }

  .trainings-bridge-card h2 {
    margin: 40px 0 0;
    color: #ffffff;
    font-size: clamp(2rem, 3vw, 3.2rem);
    font-weight: 740;
    line-height: 0.96;
    letter-spacing: -0.075em;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.26);
  }

  .trainings-bridge-card p:not(.trainings-bridge-label) {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.88);
  }

  .trainings-bridge-intro-section,
  .trainings-bridge-links-section,
  .trainings-bridge-photos-section,
  .trainings-bridge-feature-section,
  .trainings-bridge-final-cta {
    padding: 88px 0;
  }

  .trainings-bridge-two-column {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 54px;
    align-items: start;
  }

  .trainings-bridge-two-column h2,
  .trainings-bridge-heading h2,
  .trainings-bridge-feature-card h2,
  .trainings-bridge-final-card h2 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(2.45rem, 4.2vw, 4.45rem);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.074em;
  }

  .trainings-bridge-text-card {
    padding: 34px;
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.78);
  }

  .trainings-bridge-heading {
    max-width: 940px;
    margin-bottom: 38px;
  }

  .trainings-bridge-heading .section-kicker {
    color: var(--color-turquoise-dark);
    font-size: 0.78rem;
    font-weight: 820;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .trainings-bridge-heading p,
  .trainings-bridge-final-card p:not(.signature) {
    max-width: 880px;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.68;
  }

  .text-link {
    display: inline-flex;
    margin-top: 10px;
    color: var(--color-turquoise-dark);
    font-weight: 760;
    text-decoration: none;
  }

  .trainings-bridge-link-grid,
  .trainings-photo-grid {
    display: grid;
    gap: 18px;
  }

  .trainings-bridge-link-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .trainings-photo-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .trainings-bridge-link-card,
  .trainings-photo-card {
    position: relative;
    min-height: 275px;
    padding: 28px;
    overflow: hidden;
    border-radius: 32px;
    background:
      radial-gradient(circle at 92% 10%, rgba(219, 246, 243, 0.72), transparent 7rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 252, 0.86));
    text-decoration: none;
    color: inherit;
  }

  .trainings-bridge-link-card::before,
  .trainings-photo-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid rgba(56, 187, 181, 0.34);
    pointer-events: none;
  }

  .trainings-bridge-link-card::after,
  .trainings-photo-card::after {
    content: "";
    position: absolute;
    right: -58px;
    top: -58px;
    width: 138px;
    height: 138px;
    border-radius: 999px;
    background: rgba(219, 246, 243, 0.68);
    pointer-events: none;
  }

  .trainings-bridge-link-card-featured {
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 22%, #74e0d7 40%, #138a86 56%, #33c1bb 74%, #bff6f1 88%, #0d6a67 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: trainings-bridge-turquoise-flow 13s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(35, 156, 150, 0.22);
  }

  .trainings-bridge-link-card-featured::before {
    border-top-color: rgba(255, 255, 255, 0.28);
  }

  .trainings-bridge-link-card-featured::after {
    z-index: 1;
    width: auto;
    height: auto;
    border-radius: 0;
  }

  .trainings-bridge-big-mark {
    position: absolute !important;
    right: clamp(14px, 2.4vw, 32px) !important;
    top: clamp(12px, 2vw, 26px) !important;
    z-index: 1 !important;
    color: rgba(255, 255, 255, 0.16) !important;
    font-size: clamp(3.6rem, 7vw, 7.9rem) !important;
    font-weight: 850 !important;
    line-height: 0.78 !important;
    letter-spacing: -0.12em !important;
    pointer-events: none !important;
    user-select: none !important;
  }

  .trainings-bridge-big-mark-large {
    color: rgba(255, 255, 255, 0.14) !important;
    font-size: clamp(3.8rem, 7vw, 8rem) !important;
  }

  .trainings-bridge-link-card > *:not(.trainings-bridge-big-mark),
  .trainings-bridge-feature-card > *:not(.trainings-bridge-big-mark),
  .trainings-photo-card > * {
    position: relative;
    z-index: 2;
  }

  .trainings-bridge-link-card span:not(.trainings-bridge-big-mark) {
    position: relative;
    z-index: 2;
    display: inline-flex;
    margin-bottom: 44px;
    color: var(--color-turquoise-dark);
    font-size: 0.72rem;
    font-weight: 760;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .trainings-bridge-link-card h3,
  .trainings-photo-card h3 {
    position: relative;
    z-index: 2;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.45rem, 1.9vw, 2.1rem);
    font-weight: 740;
    line-height: 1;
    letter-spacing: -0.065em;
  }

  .trainings-bridge-link-card p,
  .trainings-photo-card p {
    position: relative;
    z-index: 2;
    margin: 14px 0 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.62;
  }

  .trainings-bridge-link-card-featured span:not(.trainings-bridge-big-mark),
  .trainings-bridge-link-card-featured h3,
  .trainings-bridge-link-card-featured p {
    color: rgba(255, 255, 255, 0.92);
  }

  .trainings-bridge-link-card-featured h3 {
    color: #ffffff;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.24);
  }

  .trainings-photo-placeholder {
    position: relative;
    display: grid;
    min-height: 220px;
    margin: -4px -4px 22px;
    place-items: center;
    overflow: hidden;
    border-radius: 24px;
    background:
      radial-gradient(circle at 25% 20%, rgba(56, 187, 181, 0.22), transparent 12rem),
      radial-gradient(circle at 78% 86%, rgba(201, 127, 143, 0.18), transparent 12rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.82), rgba(255, 247, 250, 0.92));
    border: 1px dashed rgba(56, 187, 181, 0.28);
  }

  .trainings-photo-placeholder span {
    color: var(--color-turquoise-dark);
    font-size: 0.72rem;
    font-weight: 820;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .trainings-bridge-photos-section,
  .trainings-bridge-feature-section {
    background:
      radial-gradient(circle at 12% 20%, rgba(56, 187, 181, 0.1), transparent 24rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 247, 250, 0.72));
  }

  .trainings-bridge-feature-card {
    position: relative;
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 34px;
    align-items: center;
    overflow: hidden;
    padding: clamp(32px, 4vw, 54px);
    border-radius: 38px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.34), transparent 10rem),
      radial-gradient(circle at 82% 24%, rgba(255, 219, 231, 0.4), transparent 13rem),
      linear-gradient(145deg, #9d4f68 0%, #d7899f 38%, #a85b73 64%, #6f3046 100%);
    background-size: 100% 100%, 100% 100%, 220% 220%;
    animation: trainings-bridge-rose-flow 12s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(157, 79, 104, 0.22);
  }

  .trainings-bridge-feature-card h2,
  .trainings-bridge-feature-card .section-kicker,
  .trainings-bridge-feature-card p {
    color: rgba(255, 255, 255, 0.9);
  }

  .trainings-bridge-feature-card h2 {
    color: #ffffff;
    text-shadow: 0 16px 42px rgba(55, 23, 35, 0.24);
  }

  .trainings-bridge-final-card {
    padding: clamp(34px, 6vw, 70px);
    border-radius: 42px;
    text-align: center;
    background:
      linear-gradient(145deg, rgba(219, 246, 243, 0.7), rgba(255, 242, 246, 0.82)),
      rgba(255, 255, 255, 0.7);
  }

  .trainings-bridge-final-card p:not(.signature) {
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .trainings-bridge-final-card .button-primary {
    margin-top: 18px;
  }

  @keyframes trainings-bridge-panel-shine {
    0% {
      transform: translateX(-72%);
      opacity: 0.28;
    }

    45% {
      opacity: 0.88;
    }

    100% {
      transform: translateX(88%);
      opacity: 0.28;
    }
  }

  @keyframes trainings-bridge-gold-flow {
    0% {
      background-position: 0% 50%, 0% 50%, 0% 50%;
    }

    100% {
      background-position: 0% 50%, 0% 50%, 100% 50%;
    }
  }

  @keyframes trainings-bridge-turquoise-flow {
    0% {
      background-position: 0% 50%, 0% 50%, 0% 50%;
    }

    100% {
      background-position: 0% 50%, 0% 50%, 100% 50%;
    }
  }

  @keyframes trainings-bridge-rose-flow {
    0% {
      background-position: 0% 50%, 0% 50%, 0% 50%;
    }

    100% {
      background-position: 0% 50%, 0% 50%, 100% 50%;
    }
  }

  @media (max-width: 1260px) {
    .trainings-bridge-link-grid,
    .trainings-photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 1080px) {
    .trainings-bridge-grid,
    .trainings-bridge-two-column,
    .trainings-bridge-feature-card {
