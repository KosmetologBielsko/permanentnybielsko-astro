---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const priceGroups = [
  {
    label: "Konsultacja",
    title: "Konsultacja",
    note: "Pierwszy krok przed decyzją o zabiegu, korekcie albo usuwaniu PMU.",
    items: [
      {
        name: "Konsultacja makijażu permanentnego",
        time: "30 min",
        price: "50 zł",
        highlight: false
      }
    ]
  },
  {
    label: "Brwi",
    title: "Makijaż permanentny brwi",
    note: "Cena zawiera zabieg główny wraz z korektą w terminie 1–3 miesiące.",
    items: [
      {
        name: "Makijaż permanentny brwi — cieniowanie*",
        time: "120 min",
        price: "1200 zł",
        highlight: false
      },
      {
        name: "Makijaż permanentny brwi — metoda włoskowa*",
        time: "130 min",
        price: "1400 zł",
        highlight: true
      },
      {
        name: "Makijaż permanentny brwi — włoski + cień*",
        time: "130 min",
        price: "1400 zł",
        highlight: true
      }
    ]
  },
  {
    label: "Oczy",
    title: "Makijaż permanentny oczu",
    note: "Kreska dobierana jest do budowy oka, powieki, linii rzęs i oczekiwanego efektu.",
    items: [
      {
        name: "Kreska zagęszczająca*",
        time: "120 min",
        price: "800 zł",
        highlight: false
      },
      {
        name: "Kreska dekoracyjna — eyeliner lub cieniowana*",
        time: "120 min",
        price: "1100 zł",
        highlight: true
      },
      {
        name: "Kreska dolna*",
        time: "90 min",
        price: "500 zł",
        highlight: false
      },
      {
        name: "Kreska dolna + górna zagęszczająca*",
        time: "120 min",
        price: "1100 zł",
        highlight: false
      },
      {
        name: "Kreska dolna + kreska dekoracyjna*",
        time: "120 min",
        price: "1400 zł",
        highlight: true
      }
    ]
  },
  {
    label: "Usta",
    title: "Makijaż permanentny ust",
    note: "Pigmentacja ust odświeża kolor i kontur. Nie jest zabiegiem powiększania ust.",
    items: [
      {
        name: "Makijaż permanentny ust*",
        time: "120 min",
        price: "1400 zł",
        highlight: true
      },
      {
        name: "LIP LIGHT",
        time: "20 min",
        price: "150 zł",
        highlight: false
      }
    ]
  },
  {
    label: "Odświeżenie",
    title: "Odświeżenie makijażu permanentnego",
    note: "Cena dotyczy odświeżenia makijażu wykonanego w naszym gabinecie do 2 lat.",
    items: [
      {
        name: "Odświeżenie makijażu permanentnego brwi**",
        time: "60 min",
        price: "500–700 zł",
        highlight: false
      },
      {
        name: "Odświeżenie makijażu permanentnego oczu**",
        time: "60 min",
        price: "350–600 zł",
        highlight: false
      },
      {
        name: "Odświeżenie makijażu permanentnego ust**",
        time: "60 min",
        price: "700 zł",
        highlight: false
      }
    ]
  },
  {
    label: "Usuwanie",
    title: "Usuwanie i naprawa PMU",
    note: "Przy starych pigmentacjach najważniejsza jest kwalifikacja i realny plan pracy.",
    items: [
      {
        name: "Laserowe usuwanie makijażu permanentnego",
        time: "40 min",
        price: "200–400 zł",
        highlight: false
      },
      {
        name: "Bye-Bye pigment remover — usuwanie makijażu",
        time: "60 min",
        price: "200–400 zł",
        highlight: false
      },
      {
        name: "Naprawa makijażu po innym gabinecie",
        time: "wycena po konsultacji",
        price: "indywidualna wycena",
        highlight: true
      }
    ]
  },
  {
    label: "Specjalne",
    title: "Usługi specjalne",
    note: "Pozycje dodatkowe, wymagające indywidualnej kwalifikacji lub dostępności terminu.",
    items: [
      {
        name: "Sercem malowane",
        time: "misja gabinetu",
        price: "0 zł",
        highlight: true
      },
      {
        name: "Usługa VIP* — przyjęcie bez wcześniejszej rezerwacji",
        time: "według dostępności",
        price: "150% ceny podstawowej",
        highlight: false
      }
    ]
  }
];

const featuredPrices = [
  {
    label: "Brwi",
    title: "Makijaż permanentny brwi",
    price: "od 1200 zł",
    href: "/makijaz-permanentny-brwi/"
  },
  {
    label: "Oczy",
    title: "Kreski permanentne",
    price: "od 500 zł",
    href: "/makijaz-permanentny-oczu/"
  },
  {
    label: "Usta",
    title: "Makijaż permanentny ust",
    price: "1400 zł",
    href: "/makijaz-permanentny-ust/"
  },
  {
    label: "Usuwanie",
    title: "Usuwanie PMU",
    price: "200–400 zł",
    href: "/usuwanie-makijazu-permanentnego/"
  }
];

const pageUrl = "https://www.permanentnybielsko.com/cennik-makijaz-permanentny/";
const pageTitle = "Cennik makijażu permanentnego Bielsko-Biała | Brwi, usta, kreski";
const pageDescription =
  "Cennik makijażu permanentnego Bielsko-Biała: brwi permanentne cena, metoda włoskowa, kreski permanentne, makijaż permanentny ust, odświeżenie PMU, korekta i usuwanie.";

const faqItems = [
  {
    question: "Ile kosztuje makijaż permanentny brwi w Bielsku-Białej?",
    answer: "Makijaż permanentny brwi w gabinecie Bogusława Herda kosztuje od 1200 zł przy cieniowaniu. Metoda włoskowa oraz połączenie włoska z cieniem kosztują 1400 zł. Cena obejmuje zabieg główny wraz z korektą w terminie 1–3 miesiące."
  },
  {
    question: "Ile kosztują brwi permanentne metodą włoskową?",
    answer: "Brwi permanentne metodą włoskową kosztują 1400 zł. Jest to technika wymagająca bardzo precyzyjnej pracy, odpowiedniego rysunku wstępnego i indywidualnego dopasowania do skóry, naturalnego włosa oraz oczekiwanego efektu."
  },
  {
    question: "Dlaczego metoda włoskowa jest droższa niż cieniowanie brwi?",
    answer: "Metoda włoskowa jest bardziej wymagająca technicznie i czasowo. Wymaga precyzyjnego prowadzenia pojedynczych włosków, analizy kierunku naturalnego owłosienia, skóry i proporcji twarzy. Dlatego jej cena jest wyższa niż klasycznego cieniowania."
  },
  {
    question: "Czy cena makijażu permanentnego obejmuje korektę?",
    answer: "Tak, ceny oznaczone gwiazdką obejmują zabieg główny wraz z korektą w terminie 1–3 miesiące. Korekta pozwala dopracować kolor, nasycenie i równowagę efektu po wygojeniu skóry."
  },
  {
    question: "Czym różni się korekta od odświeżenia makijażu permanentnego?",
    answer: "Korekta jest etapem dopracowania świeżo wykonanego zabiegu po wygojeniu skóry. Odświeżenie dotyczy starszego makijażu permanentnego, najczęściej wykonanego wcześniej w gabinecie, gdy kolor po czasie wymaga ponownego nasycenia."
  },
  {
    question: "Ile kosztuje odświeżenie brwi permanentnych?",
    answer: "Odświeżenie brwi permanentnych wykonanych w naszym gabinecie do 2 lat kosztuje 500–700 zł. Ostateczna cena zależy od techniki, aktualnego nasycenia pigmentu i zakresu pracy potrzebnej do przywrócenia estetycznego efektu."
  },
  {
    question: "Ile kosztuje makijaż permanentny ust?",
    answer: "Makijaż permanentny ust kosztuje 1400 zł. Zabieg jest ukierunkowany na odświeżenie koloru, wyrównanie czerwieni wargowej i subtelne podkreślenie konturu. Nie jest to zabieg powiększania ust."
  },
  {
    question: "Ile kosztuje kreska permanentna?",
    answer: "Cena kreski permanentnej zależy od rodzaju kreski. Kreska zagęszczająca kosztuje 800 zł, kreska dekoracyjna 1100 zł, kreska dolna 500 zł, a wybrane połączenia kreski górnej i dolnej kosztują od 1100 do 1400 zł."
  },
  {
    question: "Czy konsultacja jest płatna?",
    answer: "Tak. Konsultacja makijażu permanentnego trwa 30 minut i kosztuje 50 zł. To ważny etap przed decyzją o zabiegu, korekcie, usuwaniu albo naprawie starego makijażu permanentnego."
  },
  {
    question: "Dlaczego naprawa po innym gabinecie ma indywidualną wycenę?",
    answer: "Naprawa makijażu permanentnego po innym gabinecie wymaga oceny starego pigmentu, koloru, nasycenia, kształtu, głębokości pracy i możliwości bezpiecznej korekty. Czasem przed nową pigmentacją potrzebne jest wcześniejsze rozjaśnienie lub usuwanie."
  },
  {
    question: "Ile kosztuje usuwanie makijażu permanentnego?",
    answer: "Laserowe usuwanie makijażu permanentnego oraz usuwanie removerem kosztuje 200–400 zł za wizytę. Liczba spotkań zależy od koloru, nasycenia, głębokości pigmentu i reakcji skóry."
  },
  {
    question: "Czy usługa VIP ma stałą cenę?",
    answer: "Usługa VIP, czyli przyjęcie bez wcześniejszej rezerwacji, wynosi 150% ceny podstawowej i zależy od dostępności terminu."
  },
  {
    question: "Czy odświeżenie PMU dotyczy każdej pigmentacji?",
    answer: "Podane ceny odświeżenia dotyczą makijażu wykonanego w naszym gabinecie do 2 lat. Pigmentacje wykonane w innych miejscach, bardzo stare prace albo makijaż wymagający zmiany kształtu trzeba ocenić indywidualnie."
  },
  {
    question: "Gdzie sprawdzić dostępne terminy?",
    answer: "Aktualne terminy, rezerwacje i dostępność usług można sprawdzić przez Booksy."
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "url": pageUrl,
    "name": pageTitle,
    "description": pageDescription,
    "inLanguage": "pl-PL",
    "isPartOf": {
      "@id": "https://www.permanentnybielsko.com/#website"
    },
    "about": {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Strona główna",
        "item": "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Cennik makijażu permanentnego",
        "item": pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "OfferCatalog",
    "@id": `${pageUrl}#offer-catalog`,
    "name": "Cennik makijażu permanentnego Bielsko-Biała",
    "url": pageUrl,
    "itemListElement": priceGroups.map((group) => ({
      "@type": "OfferCatalog",
      "name": group.title,
      "description": group.note,
      "itemListElement": group.items.map((item) => ({
        "@type": "Offer",
        "name": item.name,
        "price": item.price.replace(" zł", "").replace("od ", "").replace(",", "."),
        "priceCurrency": "PLN",
        "availability": "https://schema.org/InStock",
        "itemOffered": {
          "@type": "Service",
          "name": item.name,
          "serviceType": group.title,
          "provider": {
            "@id": "https://www.permanentnybielsko.com/#localbusiness"
          }
        }
      }))
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];

---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/cennik-makijaz-permanentny/"
  structuredData={structuredData}
>
  <div class="price-page">
    <Header />

    <main>
      <section class="price-hero">
        <div class="price-glow price-glow-one"></div>
        <div class="price-glow price-glow-two"></div>

        <div class="container price-hero-grid">
          <div class="price-hero-copy">
            <p class="section-kicker">Cennik makijażu permanentnego</p>

            <h1>
                <span class="pmu-hero-turquoise-text">Ceny zabiegów PMU</span> w gabinecie Bogusława Herda.
            </h1>

            <p class="price-hero-lead">
              Cennik obejmuje konsultację, makijaż permanentny brwi, oczu i ust, odświeżenie,
              usuwanie PMU oraz usługi specjalne. Przy części usług ostateczna decyzja zależy
              od kwalifikacji, stanu skóry i zakresu pracy.
            </p>

            <div class="price-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Sprawdź terminy w Booksy
              </a>

              <a class="button-secondary" href="#cennik-pmu">
                Zobacz cennik
              </a>
            </div>
          </div>

          <aside class="price-hero-card" aria-label="Najważniejsze informacje o cenniku">
            <p class="price-card-label">PMU</p>
            <h2>Transparentnie, ale z kwalifikacją.</h2>
            <p>
              Cennik pokazuje ceny podstawowe. Przy korektach, starych pigmentacjach,
              usuwaniu i naprawie PMU zakres pracy ustalany jest indywidualnie po konsultacji.
            </p>
          </aside>
        </div>
      </section>

      <section class="price-proof-section">
        <div class="container price-proof-grid">
          <div>
            <strong>Konsultacja</strong>
            <span>50 zł / 30 min</span>
          </div>

          <div>
            <strong>Brwi permanentne</strong>
            <span>od 1200 zł</span>
          </div>

          <div>
            <strong>Usta permanentne</strong>
            <span>1400 zł</span>
          </div>

          <div>
            <strong>Usuwanie PMU</strong>
            <span>200–400 zł</span>
          </div>
        </div>
      </section>

      <section class="price-featured-section">
        <div class="container">
          <div class="price-section-heading">
            <p class="section-kicker">Najczęściej wybierane zakresy</p>
            <h2>Najważniejsze ceny makijażu permanentnego.</h2>
          </div>

          <div class="price-featured-grid">
            {featuredPrices.map((item) => (
              <a href={item.href} class="price-featured-card">
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.price}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="price-list-section" id="cennik-pmu">
        <div class="container">
          <div class="price-section-heading">
            <p class="section-kicker">Pełny cennik PMU</p>
            <h2>Cennik makijażu permanentnego, odświeżeń i usuwania PMU.</h2>
            <p>
              Ceny z gwiazdką obejmują zabieg główny wraz z korektą w terminie 1–3 miesiące.
              Ceny odświeżeń dotyczą makijażu wykonanego w naszym gabinecie.
            </p>
          </div>

          <div class="price-group-stack">
            {priceGroups.map((group) => (
              <section class="price-group-card">
                <div class="price-group-head">
                  <div>
                    <p class="section-kicker price-group-label">{group.label}</p>
                    <h3>{group.title}</h3>
                  </div>

                  <p>{group.note}</p>
                </div>

                <div class="price-items">
                  {group.items.map((item) => (
                    <div
  class:list={[
    "price-item",
    { "price-item-highlight": item.highlight },
    { "price-item-heart": item.name === "Sercem malowane" },
    { "price-item-vip": item.name.startsWith("Usługa VIP") }
  ]}
>
                      <div>
                        <h4>{item.name}</h4>
                        <span>{item.time}</span>
                      </div>

                      <strong>{item.price}</strong>
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      </section>

      <section class="price-notes-section">
        <div class="container price-notes-grid">
          <div class="price-note-card">
            <p class="section-kicker">Ważne informacje</p>
            <h2>Co obejmuje cena zabiegu?</h2>
            <p>
              Cena oznaczona gwiazdką obejmuje zabieg główny wraz z korektą wykonywaną
              w terminie 1–3 miesiące. Korekta pozwala dopracować kolor, nasycenie i równowagę
              efektu po wygojeniu skóry.
            </p>
          </div>

          <div class="price-rules-card">
            <div>
              <strong>* Zabieg główny + korekta</strong>
              <span>Cena zawiera zabieg główny wraz z korektą w terminie 1–3 miesiące.</span>
            </div>

            <div>
              <strong>** Odświeżenie do 2 lat</strong>
              <span>Cena dotyczy odświeżenia makijażu wykonanego w naszym gabinecie.</span>
            </div>

            <div>
              <strong>Naprawa po innym gabinecie</strong>
              <span>Wycena jest indywidualna, ponieważ zależy od koloru, kształtu i nasycenia starego pigmentu.</span>
            </div>
<div class="price-rules-regulations">
  <strong>Regulamin salonu</strong>
  <span>
    Przed rezerwacją wizyty warto zapoznać się z zasadami zapisów,
    odwoływania terminów, kwalifikacji do zabiegu oraz organizacji pracy gabinetu.
  </span>
  <a href="/regulamin-salonu/">Zobacz regulamin salonu</a>
</div>
            <div>
              <strong>Charakter informacyjny</strong>
              <span>Przedstawiona oferta ma charakter informacyjny i nie stanowi oferty handlowej w rozumieniu art. 66 § 1 KC.</span>
            </div>
          </div>
        </div>
      </section>

      <section class="price-related-section">
        <div class="container">
          <div class="price-section-heading">
            <p class="section-kicker">Oferta PMU</p>
            <h2>Zobacz szczegóły zabiegów makijażu permanentnego.</h2>
          </div>

          <div class="price-related-grid">
            <a href="/makijaz-permanentny-bielsko/" class="price-related-card">
              <span>PMU</span>
              <h3>Makijaż permanentny Bielsko-Biała</h3>
              <p>Główna podstrona o makijażu permanentnym, konsultacji, rysunku wstępnym i naturalnym efekcie.</p>
            </a>

            <a href="/makijaz-permanentny-brwi/" class="price-related-card price-related-card-turquoise">
              <span>Brwi</span>
              <h3>Brwi permanentne</h3>
              <p>Naturalne brwi, metoda włoskowa, włos z cieniem i Silky Hairstroke Brows.</p>
            </a>

            <a href="/makijaz-permanentny-oczu/" class="price-related-card">
              <span>Oczy</span>
              <h3>Makijaż permanentny oczu</h3>
              <p>Kreski permanentne, zagęszczenie linii rzęs i subtelne podkreślenie spojrzenia.</p>
            </a>

            <a href="/makijaz-permanentny-ust/" class="price-related-card price-related-card-rose">
              <span>Usta</span>
              <h3>Makijaż permanentny ust</h3>
              <p>Odświeżenie koloru, wyrównanie czerwieni wargowej i miękki kontur ust.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="price-faq-section">
        <div class="container">
          <div class="price-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Co warto wiedzieć o cenach makijażu permanentnego?</h2>
          </div>

          <div class="price-faq-grid">
            {faqItems.map((item) => (
              <article>
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="price-final-cta" id="kontakt">
        <div class="container price-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Chcesz sprawdzić, który zabieg będzie najlepszy dla Ciebie?</h2>
          <p>
            Umów konsultację i zobacz, jaki zakres pracy będzie odpowiedni dla Twojej urody,
            skóry, wcześniejszej pigmentacji i oczekiwanego efektu.
          </p>

          <div class="price-final-actions">
  <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
    Umów wizytę przez Booksy
  </a>

  <a class="button-secondary price-regulations-button" href="/regulamin-salonu/">
    Regulamin salonu
  </a>
</div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .price-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.12), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.12), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .price-hero {
    position: relative;
    padding: 150px 0 88px;
    overflow: hidden;
  }

  .price-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .price-glow-one {
    right: -12rem;
    top: 4rem;
