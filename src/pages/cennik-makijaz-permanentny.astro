<script>
  const priceAccordionMedia = window.matchMedia("(max-width: 760px)");
  const priceAccordionGroups = Array.from(
    document.querySelectorAll("[data-price-accordion]")
  );

  const setPriceGroupState = (group, expanded) => {
    const button = group.querySelector(".price-group-toggle");
    const panel = group.querySelector(".price-group-panel");

    if (!(button instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
      return;
    }

    button.setAttribute("aria-expanded", String(expanded));
    panel.hidden = !expanded;
    group.classList.toggle("is-open", expanded);
  };

  const syncPriceGroupsToViewport = () => {
    priceAccordionGroups.forEach((group) => {
      setPriceGroupState(group, !priceAccordionMedia.matches);
    });

    if (priceAccordionMedia.matches && window.location.hash) {
      const currentGroup = document.querySelector(window.location.hash);

      if (currentGroup?.matches("[data-price-accordion]")) {
        setPriceGroupState(currentGroup, true);
      }
    }
  };

  priceAccordionGroups.forEach((group) => {
    const button = group.querySelector(".price-group-toggle");

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    button.addEventListener("click", () => {
      const expanded = button.getAttribute("aria-expanded") === "true";
      setPriceGroupState(group, !expanded);
    });
  });

  document.querySelectorAll("[data-price-nav-link]").forEach((link) => {
    link.addEventListener("click", () => {
      const targetId = link.getAttribute("href");

      if (!targetId) {
        return;
      }

      const targetGroup = document.querySelector(targetId);

      if (targetGroup?.matches("[data-price-accordion]")) {
        setPriceGroupState(targetGroup, true);
      }
    });
  });

  syncPriceGroupsToViewport();
  priceAccordionMedia.addEventListener("change", syncPriceGroupsToViewport);
</script>
