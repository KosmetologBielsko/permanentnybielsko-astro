---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const priceGroups = [
  {
    label: "Konsultacja",
    title: "Konsultacja",
    note: "Pierwszy krok przed decyzją o zabiegu, korekcie albo usuwaniu PMU.",
    items: [
      {
        name: "Konsultacja makijażu permanentnego",
        time: "30 min",
        price: "50 zł",
        highlight: false
      }
    ]
  },
  {
    label: "Brwi",
    title: "Makijaż permanentny brwi",
    note: "Cena zawiera zabieg główny wraz z korektą w terminie 1–3 miesiące.",
    items: [
      {
        name: "Makijaż permanentny brwi — cieniowanie*",
        time: "120 min",
        price: "1200 zł",
        highlight: false
      },
      {
        name: "Makijaż permanentny brwi — metoda włoskowa*",
        time: "130 min",
        price: "1400 zł",
        highlight: true
      },
      {
        name: "Makijaż permanentny brwi — włoski + cień*",
        time: "130 min",
        price: "1400 zł",
        highlight: true
      }
    ]
  },
  {
    label: "Oczy",
    title: "Makijaż permanentny oczu",
    note: "Kreska dobierana jest do budowy oka, powieki, linii rzęs i oczekiwanego efektu.",
    items: [
      {
        name: "Kreska zagęszczająca*",
        time: "120 min",
        price: "800 zł",
        highlight: false
      },
      {
        name: "Kreska dekoracyjna — eyeliner lub cieniowana*",
        time: "120 min",
        price: "1100 zł",
        highlight: true
      },
      {
        name: "Kreska dolna*",
        time: "90 min",
        price: "500 zł",
        highlight: false
      },
      {
        name: "Kreska dolna + górna zagęszczająca*",
        time: "120 min",
        price: "1100 zł",
        highlight: false
      },
      {
        name: "Kreska dolna + kreska dekoracyjna*",
        time: "120 min",
        price: "1400 zł",
        highlight: true
      }
    ]
  },
  {
    label: "Usta",
    title: "Makijaż permanentny ust",
    note: "Pigmentacja ust odświeża kolor i kontur. Nie jest zabiegiem powiększania ust.",
    items: [
      {
        name: "Makijaż permanentny ust*",
        time: "120 min",
        price: "1400 zł",
        highlight: true
      },
      {
        name: "LIP LIGHT",
        time: "20 min",
        price: "150 zł",
        highlight: false
      }
    ]
  },
  {
    label: "Odświeżenie",
    title: "Odświeżenie makijażu permanentnego",
    note: "Cena dotyczy odświeżenia makijażu wykonanego w naszym gabinecie do 2 lat.",
    items: [
      {
        name: "Odświeżenie makijażu permanentnego brwi**",
        time: "60 min",
        price: "500–700 zł",
        highlight: false
      },
      {
        name: "Odświeżenie makijażu permanentnego oczu**",
        time: "60 min",
        price: "350–600 zł",
        highlight: false
      },
      {
        name: "Odświeżenie makijażu permanentnego ust**",
        time: "60 min",
        price: "700 zł",
        highlight: false
      }
    ]
  },
  {
    label: "Usuwanie",
    title: "Usuwanie i naprawa PMU",
    note: "Przy starych pigmentacjach najważniejsza jest kwalifikacja i realny plan pracy.",
    items: [
      {
        name: "Laserowe usuwanie makijażu permanentnego",
        time: "40 min",
        price: "200–400 zł",
        highlight: false
      },
      {
        name: "Bye-Bye pigment remover — usuwanie makijażu",
        time: "60 min",
        price: "200–400 zł",
        highlight: false
      },
      {
        name: "Naprawa makijażu po innym gabinecie",
        time: "wycena po konsultacji",
        price: "indywidualna wycena",
        highlight: true
      }
    ]
  },
  {
    label: "Specjalne",
    title: "Usługi specjalne",
    note: "Pozycje dodatkowe, wymagające indywidualnej kwalifikacji lub dostępności terminu.",
    items: [
      {
        name: "Sercem malowane",
        time: "misja gabinetu",
        price: "0 zł",
        highlight: true
      },
      {
        name: "Usługa VIP* — przyjęcie bez wcześniejszej rezerwacji",
        time: "według dostępności",
        price: "150% ceny podstawowej",
        highlight: false
      }
    ]
  }
];

const featuredPrices = [
  {
    label: "Brwi",
    title: "Makijaż permanentny brwi",
    price: "od 1200 zł",
    href: "/makijaz-permanentny-brwi/"
  },
  {
    label: "Oczy",
    title: "Kreski permanentne",
    price: "od 500 zł",
    href: "/makijaz-permanentny-oczu/"
  },
  {
    label: "Usta",
    title: "Makijaż permanentny ust",
    price: "1400 zł",
    href: "/makijaz-permanentny-ust/"
  },
  {
    label: "Usuwanie",
    title: "Usuwanie PMU",
    price: "200–400 zł",
    href: "/usuwanie-makijazu-permanentnego/"
  }
];

const pageUrl = "https://www.permanentnybielsko.com/cennik-makijaz-permanentny/";
const pageTitle = "Cennik makijażu permanentnego Bielsko-Biała | Brwi, usta, kreski";
const pageDescription =
  "Cennik makijażu permanentnego Bielsko-Biała: brwi permanentne cena, metoda włoskowa, kreski permanentne, makijaż permanentny ust, odświeżenie PMU, korekta i usuwanie.";

const faqItems = [
  {
    question: "Czy cena makijażu permanentnego obejmuje korektę?",
    answer:
      "Tak. Ceny oznaczone gwiazdką obejmują zabieg główny wraz z korektą w terminie 1–3 miesiące. Korekta pozwala dopracować kolor, nasycenie i równowagę efektu po wygojeniu skóry."
  },
  {
    question: "Czym różni się korekta od odświeżenia makijażu permanentnego?",
    answer:
      "Korekta jest etapem dopracowania świeżo wykonanego zabiegu. Odświeżenie dotyczy starszego makijażu permanentnego, gdy kolor po czasie wymaga ponownego nasycenia."
  },
  {
    question: "Czy można poprawić makijaż permanentny wykonany w innym gabinecie?",
    answer:
      "Taką pigmentację trzeba najpierw ocenić indywidualnie. Znaczenie mają kolor, nasycenie, kształt, głębokość pracy i kondycja skóry. Czasem przed nowym zabiegiem potrzebne jest rozjaśnienie lub usuwanie."
  },
  {
    question: "Dlaczego usuwanie makijażu permanentnego kosztuje 200–400 zł?",
    answer:
      "Cena jednej wizyty zależy od obszaru, koloru, nasycenia i głębokości pigmentu oraz wybranej metody. Liczba potrzebnych spotkań jest ustalana indywidualnie po kwalifikacji."
  },
  {
    question: "Czy konsultacja makijażu permanentnego jest płatna?",
    answer:
      "Tak. Konsultacja trwa 30 minut i kosztuje 50 zł. To pierwszy krok przed zabiegiem, korektą, naprawą lub usuwaniem starego makijażu permanentnego."
  }
];

const getOfferPricing = (price: string) => {
  if (price.includes("%") || price.toLowerCase().includes("indywidualna")) {
    return {
      "description": `Cena ustalana indywidualnie: ${price}`
    };
  }

  const values = price
    .match(/\d+(?:[.,]\d+)?/g)
    ?.map((value) => value.replace(",", "."));

  if (!values?.length) {
    return {
      "description": `Cena: ${price}`
    };
  }

  if (values.length >= 2) {
    return {
      "priceSpecification": {
        "@type": "PriceSpecification",
        "minPrice": values[0],
        "maxPrice": values[1],
        "priceCurrency": "PLN"
      }
    };
  }

  return {
    "price": values[0],
    "priceCurrency": "PLN"
  };
};

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "url": pageUrl,
    "name": pageTitle,
    "description": pageDescription,
    "inLanguage": "pl-PL",
    "isPartOf": {
      "@id": "https://www.permanentnybielsko.com/#website"
    },
    "about": {
      "@id": "https://www.permanentnybielsko.com/#localbusiness"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Strona główna",
        "item": "https://www.permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Cennik makijażu permanentnego",
        "item": pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "OfferCatalog",
    "@id": `${pageUrl}#offer-catalog`,
    "name": "Cennik makijażu permanentnego Bielsko-Biała",
    "url": pageUrl,
    "itemListElement": priceGroups.map((group) => ({
      "@type": "OfferCatalog",
      "name": group.title,
      "description": group.note,
      "itemListElement": group.items.map((item) => ({
        "@type": "Offer",
        "name": item.name,
        ...getOfferPricing(item.price),
        "availability": "https://schema.org/InStock",
        "itemOffered": {
          "@type": "Service",
          "name": item.name,
          "serviceType": group.title,
          "provider": {
            "@id": "https://www.permanentnybielsko.com/#localbusiness"
          }
        }
      }))
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];

---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/cennik-makijaz-permanentny/"
  structuredData={structuredData}
>
  <div class="price-page">
    <Header />

    <main>
      <section class="price-hero">
        <div class="price-glow price-glow-one"></div>
        <div class="price-glow price-glow-two"></div>

        <div class="container price-hero-grid">
          <div class="price-hero-copy">
            <p class="section-kicker">Cennik makijażu permanentnego</p>

            <h1>
                <span class="pmu-hero-turquoise-text">Ceny zabiegów PMU</span> w gabinecie Bogusława Herda.
            </h1>

            <p class="price-hero-lead">
              Cennik obejmuje konsultację, makijaż permanentny brwi, oczu i ust, odświeżenie,
              usuwanie PMU oraz usługi specjalne. Przy części usług ostateczna decyzja zależy
              od kwalifikacji, stanu skóry i zakresu pracy.
            </p>

            <div class="price-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Sprawdź terminy w Booksy
              </a>

              <a class="button-secondary" href="#cennik-pmu">
                Zobacz cennik
              </a>
            </div>
          </div>

          <aside class="price-hero-card" aria-label="Najważniejsze informacje o cenniku">
            <p class="price-card-label">PMU</p>
            <h2>Transparentnie, ale z kwalifikacją.</h2>
            <p>
              Cennik pokazuje ceny podstawowe. Przy korektach, starych pigmentacjach,
              usuwaniu i naprawie PMU zakres pracy ustalany jest indywidualnie po konsultacji.
            </p>
          </aside>
        </div>
      </section>

      <section class="price-proof-section">
        <div class="container price-proof-grid">
          <div>
            <strong>Konsultacja</strong>
            <span>50 zł / 30 min</span>
          </div>

          <div>
            <strong>Brwi permanentne</strong>
            <span>od 1200 zł</span>
          </div>

          <div>
            <strong>Usta permanentne</strong>
            <span>1400 zł</span>
          </div>

          <div>
            <strong>Usuwanie PMU</strong>
            <span>200–400 zł</span>
          </div>
        </div>
      </section>

      <section class="price-featured-section">
        <div class="container">
          <div class="price-section-heading">
            <p class="section-kicker">Najczęściej wybierane zakresy</p>
            <h2>Najważniejsze ceny makijażu permanentnego.</h2>
          </div>

          <div class="price-featured-grid">
            {featuredPrices.map((item) => (
              <a href={item.href} class="price-featured-card">
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.price}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="price-list-section" id="cennik-pmu">
        <div class="container">
          <div class="price-section-heading">
            <p class="section-kicker">Pełny cennik PMU</p>
            <h2>Cennik makijażu permanentnego, odświeżeń i usuwania PMU.</h2>
            <p>
              Ceny z gwiazdką obejmują zabieg główny wraz z korektą w terminie 1–3 miesiące.
              Ceny odświeżeń dotyczą makijażu wykonanego w naszym gabinecie.
            </p>
          </div>

          <nav class="price-category-nav" aria-label="Szybki wybór kategorii cennika">
            {priceGroups.map((group, groupIndex) => (
              <a href={`#price-group-${groupIndex}`} data-price-nav-link>
                {group.label}
              </a>
            ))}
          </nav>

          <div class="price-group-stack">
            {priceGroups.map((group, groupIndex) => (
              <article
                class="price-group-card price-group-accordion"
                id={`price-group-${groupIndex}`}
                data-price-accordion
              >
                <button
                  class="price-group-toggle"
                  type="button"
                  aria-expanded="true"
                  aria-controls={`price-group-panel-${groupIndex}`}
                >
                  <span class="price-group-main">
                    <span class="section-kicker price-group-label">{group.label}</span>
                    <span class="price-group-title">{group.title}</span>
                  </span>

                  <span class="price-group-meta">
                    <span class="price-group-note">{group.note}</span>
                    <span class="price-group-icon" aria-hidden="true"></span>
                  </span>
                </button>

                <div
                  class="price-group-panel"
                  id={`price-group-panel-${groupIndex}`}
                >
                  <div class="price-items">
                    {group.items.map((item) => (
                      <div
                        class:list={[
                          "price-item",
                          { "price-item-highlight": item.highlight },
                          { "price-item-heart": item.name === "Sercem malowane" },
                          { "price-item-vip": item.name.startsWith("Usługa VIP") }
                        ]}
                      >
                        <div>
                          <h4>{item.name}</h4>
                          <span>{item.time}</span>
                        </div>

                        <strong>{item.price}</strong>
                      </div>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="price-decision-section" aria-label="Rezerwacja wizyty">
        <div class="container price-decision-card">
          <div>
            <p class="section-kicker">Znasz już ceny</p>
            <h2>Sprawdź dostępne terminy albo zacznij od konsultacji.</h2>
            <p>
              Przy nowym zabiegu możesz od razu przejść do rezerwacji. Przy starej pigmentacji,
              korekcie lub usuwaniu najbezpieczniej rozpocząć od konsultacji i kwalifikacji.
            </p>
          </div>

          <div class="price-decision-actions">
            <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
              Sprawdź terminy w Booksy
            </a>

            <a class="button-secondary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
              Umów konsultację
            </a>
          </div>
        </div>
      </section>

      <section class="price-notes-section">
        <div class="container price-notes-grid">
          <div class="price-note-card">
            <p class="section-kicker">Ważne informacje</p>
            <h2>Co obejmuje cena zabiegu?</h2>
            <p>
              Cena oznaczona gwiazdką obejmuje zabieg główny wraz z korektą wykonywaną
              w terminie 1–3 miesiące. Korekta pozwala dopracować kolor, nasycenie i równowagę
              efektu po wygojeniu skóry.
            </p>
          </div>

          <div class="price-rules-card">
            <div>
              <strong>* Zabieg główny + korekta</strong>
              <span>Cena zawiera zabieg główny wraz z korektą w terminie 1–3 miesiące.</span>
            </div>

            <div>
              <strong>** Odświeżenie do 2 lat</strong>
              <span>Cena dotyczy odświeżenia makijażu wykonanego w naszym gabinecie.</span>
            </div>

            <div>
              <strong>Naprawa po innym gabinecie</strong>
              <span>Wycena jest indywidualna, ponieważ zależy od koloru, kształtu i nasycenia starego pigmentu.</span>
            </div>
<div class="price-rules-regulations">
  <strong>Regulamin salonu</strong>
  <span>
    Przed rezerwacją wizyty warto zapoznać się z zasadami zapisów,
    odwoływania terminów, kwalifikacji do zabiegu oraz organizacji pracy gabinetu.
  </span>
  <a href="/regulamin-salonu/">Zobacz regulamin salonu</a>
</div>
            <div>
              <strong>Charakter informacyjny</strong>
              <span>Przedstawiona oferta ma charakter informacyjny i nie stanowi oferty handlowej w rozumieniu art. 66 § 1 KC.</span>
            </div>
          </div>
        </div>
      </section>


      <section class="price-faq-section">
        <div class="container">
          <div class="price-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Co warto wiedzieć o cenach makijażu permanentnego?</h2>
          </div>

          <div class="price-faq-list">
            {faqItems.map((item, index) => (
              <details class="price-faq-item" open={index === 0}>
                <summary>
                  <span>{item.question}</span>
                  <span class="price-faq-icon" aria-hidden="true"></span>
                </summary>
                <div>
                  <p>{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>


    </main>

    <Footer />
  </div>
</Layout>

<style>
  .price-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.12), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.12), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .price-hero {
    position: relative;
    padding: 150px 0 88px;
    overflow: hidden;
  }

  .price-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .price-glow-one {
    right: -12rem;
    top: 4rem;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.2), transparent 68%);
  }

  .price-glow-two {
    left: -10rem;
    bottom: -12rem;
    width: 38rem;
    height: 38rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.18), transparent 68%);
  }

  .price-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    gap: 24px;
    align-items: stretch;
  }

  .price-hero-copy,
  .price-hero-card,
  .price-featured-card,
  .price-group-card,
  .price-note-card,
  .price-rules-card,
  .price-related-card,
  .price-faq-grid article,
  .price-final-card {
    border: 1px solid rgba(183, 101, 118, 0.16);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .price-hero-copy {
    padding: clamp(38px, 5vw, 72px);
    border-radius: 42px;
    background: rgba(255, 255, 255, 0.76);
  }

  .price-hero-copy h1 {
    max-width: 1000px;
    margin: 0;
    font-size: clamp(3.2rem, 5.8vw, 6.9rem);
    font-weight: 750;
    line-height: 0.92;
    letter-spacing: -0.085em;
  }

  .price-hero-lead {
    max-width: 780px;
    margin: 28px 0 0;
    color: var(--color-muted);
    font-size: 1.12rem;
  }

  .price-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .price-hero-card {
    position: relative;
    overflow: hidden;
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(34px, 4vw, 56px);
    border-radius: 42px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(255, 245, 215, 0.28), transparent 13rem),
      linear-gradient(140deg, #6f5730 0%, #b9924d 18%, #f4e0a4 34%, #8e6b36 50%, #d1aa63 67%, #fff0c8 82%, #8a6731 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: price-gold-flow 14s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(125, 95, 45, 0.24);
  }

  .price-hero-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.06) 22%, rgba(255, 255, 255, 0.26) 47%, rgba(255, 255, 255, 0.06) 72%, transparent 100%);
    transform: translateX(-72%);
