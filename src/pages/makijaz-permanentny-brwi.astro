---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/makijaz-permanentny-brwi/";
const pageTitle = "Brwi permanentne Bielsko-Biała | Silky Hairstroke Brows";
const pageDescription =
  "Brwi permanentne Bielsko-Biała: naturalne brwi, metoda włoskowa, cieniowanie, włos z cieniem i autorska technika Silky Hairstroke Brows u Bogusława Herda.";

const faqItems = [
  {
    "question": "Czy brwi permanentne mogą wyglądać naturalnie?",
    "answer": "Tak, jeśli kształt, kolor i technika są dobrane indywidualnie. Naturalny efekt nie oznacza braku widoczności, tylko brak ciężkiej, sztucznej formy."
  },
  {
    "question": "Czy rysunek wstępny jest wykonywany przed zabiegiem?",
    "answer": "Tak. Rysunek wstępny jest konieczny, aby omówić kształt, proporcje i kierunek brwi przed pigmentacją."
  },
  {
    "question": "Czym różni się metoda włoskowa od cieniowania?",
    "answer": "Metoda włoskowa buduje efekt pojedynczych włosków, a cieniowanie daje bardziej miękkie wypełnienie. Wybór zależy od skóry, naturalnych brwi i oczekiwanego efektu."
  },
  {
    "question": "Czy Silky Hairstroke Brows jest dla każdego?",
    "answer": "Nie zawsze. Technika włosa wymaga odpowiednich warunków skóry i dobrego planu. Podczas konsultacji oceniane jest, czy ta metoda będzie najlepszym wyborem."
  },
  {
    "question": "Czy można poprawić stare brwi permanentne?",
    "answer": "Czasem tak, ale najpierw trzeba ocenić kolor, nasycenie i kształt starej pigmentacji. Niekiedy konieczne jest wcześniejsze rozjaśnienie PMU."
  },
  {
    "question": "Kiedy widoczny jest finalny efekt?",
    "answer": "Bezpośrednio po zabiegu brwi mogą być intensywniejsze. Finalny efekt ocenia się po wygojeniu skóry i ewentualnym dopigmentowaniu."
  },
  {
    "question": "Czy brwi permanentne wymagają dopigmentowania?",
    "answer": "Zazwyczaj dopigmentowanie jest etapem finalnego dopracowania efektu po wygojeniu. Pozwala wyrównać kolor, nasycenie i szczegóły."
  },
  {
    "question": "Gdzie wykonywane są brwi permanentne?",
    "answer": "Zabieg wykonywany jest w gabinecie Bogusława Herda w Bielsku-Białej. Aktualne terminy i rezerwacje dostępne są przez Booksy."
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "url": pageUrl,
    "name": pageTitle,
    "description": pageDescription,
    "inLanguage": "pl-PL",
    "isPartOf": {
      "@id": "https://permanentnybielsko.com/#website"
    },
    "about": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "primaryImageOfPage": {
      "@type": "ImageObject",
      "url": "https://permanentnybielsko.com/images/hero-boguslawa-herda-pmu-cutout.webp"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Strona główna",
        "item": "https://permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Makijaż permanentny Bielsko-Biała",
        "item": "https://permanentnybielsko.com/makijaz-permanentny-bielsko/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Brwi permanentne",
        "item": pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${pageUrl}#service`,
    "name": "Brwi permanentne Bielsko-Biała",
    "serviceType": "Makijaż permanentny brwi",
    "description":
      "Naturalne brwi permanentne w Bielsku-Białej: metoda włoskowa, cieniowanie, włos z cieniem, korekty starych brwi oraz autorskie podejście Silky Hairstroke Brows.",
    "areaServed": [
      {
        "@type": "City",
        "name": "Bielsko-Biała"
      },
      {
        "@type": "AdministrativeArea",
        "name": "województwo śląskie"
      }
    ],
    "provider": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "brand": {
      "@type": "Brand",
      "name": "Bogusława Herda Makijaż Permanentny"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Metody brwi permanentnych",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Brwi cieniowane"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Metoda włoskowa"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Włos z cieniem"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Silky Hairstroke Brows"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Korekta starych brwi permanentnych"
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];

---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/makijaz-permanentny-brwi/"
  structuredData={structuredData}
>
  <div class="brow-page">
    <Header />

    <main>
      <section class="brow-hero">
        <div class="brow-glow brow-glow-one"></div>
        <div class="brow-glow brow-glow-two"></div>

        <div class="container brow-hero-grid">
          <div class="brow-hero-copy">
            <p class="section-kicker">Brwi permanentne Bielsko-Biała</p>

            <h1>
              <span class="pmu-hero-rose-text">Naturalne brwi permanentne</span>, które porządkują twarz bez efektu maski.
            </h1>

            <p class="brow-hero-lead">
              Brwi permanentne powinny podkreślać oprawę oka, a nie dominować nad twarzą.
              W gabinecie Bogusława Herda każdy zabieg zaczyna się od rozmowy, analizy urody
              i rysunku wstępnego.
            </p>

            <div class="brow-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację
              </a>

              <a class="button-secondary" href="#metody-brwi">
                Poznaj metody
              </a>
            </div>
          </div>

          <aside class="brow-hero-card" aria-label="Silky Hairstroke Brows">
            <p class="brow-card-label">Silky</p>
            <h2>Włos maszynowy w miękkim, realistycznym kierunku.</h2>
            <p>
              Silky Hairstroke Brows to autorskie podejście Bogusława Herda do naturalnego efektu brwi:
              lekkość, precyzja i praca dopasowana do rysów twarzy.
            </p>
          </aside>
        </div>
      </section>
      <section class="brow-natural-preview-section" aria-label="Naturalny efekt brwi permanentnych">
        <div class="container brow-natural-preview-card">
          <figure class="brow-natural-preview-photo">
            <img
              src="/images/brwi-permanentne-naturalny-wlos-zblizenie.webp"
              alt="Zbliżenie na naturalne brwi permanentne wykonane metodą włosa maszynowego"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="brow-natural-preview-copy">
            <p class="section-kicker">Naturalny włos</p>

            <h2>Brwi permanentne nie muszą wyglądać ciężko.</h2>

            <p>
              Najlepszy efekt to taki, który porządkuje oprawę oka, ale nadal wygląda lekko,
              świeżo i naturalnie. W technice włosa liczy się kierunek, rytm, odstęp między liniami
              i dopasowanie do mimiki twarzy.
            </p>
          </div>
        </div>
      </section>
      <section class="brow-proof-section">
        <div class="container brow-proof-grid">
          <div>
            <strong>Rysunek wstępny</strong>
            <span>kształt omawiany przed pigmentacją</span>
          </div>

          <div>
            <strong>Naturalny kierunek</strong>
            <span>brwi dopasowane do mimiki i urody</span>
          </div>

          <div>
            <strong>Silky Hairstroke Brows</strong>
            <span>autorskie podejście do brwi</span>
          </div>

          <div>
            <strong>Korekta starych brwi</strong>
            <span>ocena pigmentu i plan naprawczy</span>
          </div>
        </div>
      </section>

      <section class="brow-intro-section">
        <div class="container brow-two-column">
          <div>
            <p class="section-kicker">Dla kogo?</p>
            <h2>Brwi permanentne dla kobiet, które chcą wyglądać świeżo i naturalnie każdego dnia.</h2>
          </div>

          <div class="brow-text-card">
            <p>
              Brwi mają ogromny wpływ na proporcje twarzy. Mogą otworzyć spojrzenie, uporządkować rysy,
              dodać twarzy świeżości i skrócić codzienny makijaż. Źle dobrany kształt potrafi jednak
              nadać twarzy zbyt surowy lub ciężki charakter.
            </p>

            <p>
              Dlatego w gabinecie Bogusława Herda brwi permanentne nie zaczynają się od pigmentu.
              Najpierw omawiany jest efekt, analizowana jest uroda, a następnie wykonywany jest
              rysunek wstępny. Dopiero po akceptacji kształtu planowana jest pigmentacja.
            </p>
          </div>
        </div>
      </section>
            <section class="brow-for-section" aria-label="Dla kogo są brwi permanentne">
        <div class="container">
          <div class="brow-section-heading brow-for-heading">
            <p class="section-kicker">Kiedy warto?</p>

            <h2>
              Brwi permanentne są dla kobiet, które chcą uporządkować oprawę oka bez ciężkiego efektu.
            </h2>

            <p>
              Najlepszy efekt nie polega na mocnym przerysowaniu brwi, ale na świadomej decyzji:
              gdzie dodać kształt, gdzie zostawić lekkość i jak dopasować pigmentację do twarzy,
              mimiki oraz codziennego stylu.
            </p>
          </div>

          <div class="brow-for-grid">
            <article class="brow-for-card">
              <span>01</span>
              <h3>Przerzedzone brwi</h3>
              <p>
                gdy brakuje gęstości, kierunku albo regularnej oprawy oka
              </p>
            </article>

            <article class="brow-for-card">
              <span>02</span>
              <h3>Asymetria</h3>
              <p>
                gdy jedna brew różni się kształtem, wysokością lub długością
              </p>
            </article>

            <article class="brow-for-card">
              <span>03</span>
              <h3>Codzienny makijaż</h3>
              <p>
                gdy klientka codziennie dorysowuje brwi i chce skrócić poranną rutynę
              </p>
            </article>

            <article class="brow-for-card">
              <span>04</span>
              <h3>Naturalna oprawa oka</h3>
              <p>
                gdy celem jest świeży, miękki efekt bez ciężkiej ramy
              </p>
            </article>

            <article class="brow-for-card brow-for-card-rose">
              <span>05</span>
              <h3>Stare PMU</h3>
              <p>
                gdy wcześniejsza pigmentacja wymaga oceny, rozjaśnienia albo planu naprawczego
              </p>
            </article>

            <article class="brow-for-card">
              <span>06</span>
              <h3>Delikatna zmiana</h3>
              <p>
                gdy brwi mają uporządkować twarz, ale nie zmienić jej charakteru
              </p>
            </article>
          </div>
        </div>
      </section>
      <section class="brow-methods-section" id="metody-brwi">
        <div class="container">
          <div class="brow-section-heading">
            <p class="section-kicker">Metody brwi permanentnych</p>

            <h2>Technika musi wynikać z twarzy, skóry i oczekiwanego efektu.</h2>

            <p>
              Nie każda klientka potrzebuje tej samej metody. Inaczej pracuje się przy delikatnym
              uzupełnieniu brwi, inaczej przy mocniejszej oprawie oka, a jeszcze inaczej przy korekcie
              starego makijażu permanentnego.
            </p>
          </div>

          <figure class="methods-collage-frame methods-collage-frame--compact">
            <img
              src="/images/metody-brwi-permanentnych-kolaz-poziomy.webp"
              alt="Kolaż efektów brwi permanentnych pokazujący różne metody pigmentacji brwi"
              loading="lazy"
              decoding="async"
              width="1800"
              height="1122"
            />
          </figure>
          <div class="brow-method-controls" aria-label="Przewijanie metod brwi permanentnych">
            <button class="brow-method-arrow brow-method-arrow-left" type="button" aria-label="Przewiń w lewo">
              ←
            </button>

            <button class="brow-method-arrow brow-method-arrow-right" type="button" aria-label="Przewiń w prawo">
              →
            </button>
          </div>

          <div class="brow-method-scroll" id="browMethodScroll" aria-label="Metody brwi permanentnych">
            <article class="brow-method-slide-card">
              <span>01</span>
              <h3>Brwi cieniowane</h3>
              <p>
                Miękkie wypełnienie brwi, które może przypominać bardzo delikatny makijaż.
                Dobre rozwiązanie, gdy potrzebna jest większa regularność i uporządkowanie kształtu.
              </p>
            </article>

            <article class="brow-method-slide-card brow-method-slide-card-rose">
              <span>02</span>
              <h3>Metoda włoskowa</h3>
              <p>
                Technika budująca efekt pojedynczych włosków. Wymaga precyzyjnego kierunku,
                lekkości i bardzo świadomego prowadzenia linii.
              </p>
            </article>

            <article class="brow-method-slide-card">
              <span>03</span>
              <h3>Włos z cieniem</h3>
              <p>
                Połączenie struktury włosa z delikatnym cieniem. Pozwala uzyskać pełniejszy efekt
                przy zachowaniu miękkości i naturalnego charakteru.
              </p>
            </article>

            <article class="brow-method-slide-card brow-method-slide-card-turquoise">
              <span>04</span>
              <h3>Silky Hairstroke Brows</h3>
              <p>
                Autorskie podejście Bogusławy Herda do efektu włosa maszynowego: lekkość,
                naturalny kierunek i praca dopasowana do rysów twarzy.
              </p>
            </article>

            <article class="brow-method-slide-card brow-method-slide-card-gold">
              <span>05</span>
              <h3>Korekta starych brwi</h3>
              <p>
                Ocena starego pigmentu, koloru i kształtu. Czasem najlepszym pierwszym krokiem
                jest rozjaśnienie, a dopiero później nowy rysunek wstępny.
              </p>
            </article>
          </div>

                     <div class="brow-silky-feature brow-silky-signature">
            <div class="brow-silky-signature-copy">
              <p class="section-kicker">Autorska metoda Bogusławy Herda</p>

              <h3>Silky Hairstroke Brows</h3>

              <p class="brow-silky-lead">
                Włos maszynowy w miękkim, realistycznym kierunku.
              </p>

              <p>
                Silky Hairstroke Brows to autorskie podejście Bogusławy Herda do makijażu
                permanentnego brwi, w którym najważniejsze są lekkość, rytm włosa, naturalny
                kierunek i dopasowanie do rysów twarzy.
              </p>

              <p>
                Ta technika nie ma tworzyć ciężkiej, graficznej ramy. Jej celem jest efekt brwi,
                które wyglądają spokojnie, miękko i naturalnie — jak uporządkowana oprawa oka,
                a nie szablon nałożony na twarz.
              </p>
            </div>

            <div class="silky-video-row">
              <figure class="silky-motion-frame" aria-label="Silky Hairstroke Brows w zbliżeniu">
                <video
                  class="silky-motion-frame__video"
                  src="/video/brwi-permanentne-silky-zblizenie-bez-dzwieku.mp4"
                  poster="/video/brwi-permanentne-silky-zblizenie-poster.webp"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                ></video>
              </figure>
            </div>

            <div class="brow-silky-signature-points" aria-label="Cechy techniki Silky Hairstroke Brows">
              <div>
                <span>01</span>
                <strong>Naturalny kierunek włosa</strong>
                <p>linie prowadzone tak, aby wspierały mimikę i naturalny układ brwi</p>
              </div>

              <div>
                <span>02</span>
                <strong>Efekt bez maski</strong>
                <p>brwi mają porządkować twarz, ale nie dominować nad jej charakterem</p>
              </div>

              <div>
                <span>03</span>
                <strong>Precyzja maszynowa</strong>
                <p>kontrola linii, rytmu i nasycenia bez przypadkowego prowadzenia włosa</p>
              </div>

              <div>
                <span>04</span>
                <strong>Autorski podpis</strong>
                <p>technika rozwijana przez Bogusławę Herda i prezentowana także międzynarodowo</p>
              </div>
            </div>

            <div class="brow-silky-gallery" aria-label="Efekty Silky Hairstroke Brows">
              <div class="brow-silky-gallery-heading">
                <div>
                  <p class="section-kicker">Efekty Silky</p>
                  <h4>Naturalny włos, miękka oprawa oka i spokojny efekt na twarzy.</h4>
                </div>

                <div class="brow-silky-gallery-controls" aria-label="Przewijanie zdjęć Silky Hairstroke Brows">
                  <button class="brow-silky-gallery-arrow brow-silky-gallery-arrow-left" type="button" aria-label="Przewiń zdjęcia w lewo">
                    ←
                  </button>

                  <button class="brow-silky-gallery-arrow brow-silky-gallery-arrow-right" type="button" aria-label="Przewiń zdjęcia w prawo">
                    →
                  </button>
                </div>
              </div>

              <div class="brow-silky-gallery-scroll" id="browSilkyGalleryScroll">
                <figure class="brow-silky-gallery-card">
                  <img
                    src="/images/silky-hairstroke-brows-efekt-01.webp"
                    alt="Naturalny efekt brwi metodą Silky Hairstroke Brows u klientki"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption>Naturalny efekt włosa</figcaption>
                </figure>

                <figure class="brow-silky-gallery-card">
                  <img
                    src="/images/silky-hairstroke-brows-efekt-02.webp"
                    alt="Efekt naturalnych brwi permanentnych w technice Silky Hairstroke Brows"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption>Miękka oprawa oka</figcaption>
                </figure>

                <figure class="brow-silky-gallery-card">
                  <img
                    src="/images/silky-hairstroke-brows-efekt-03.webp"
                    alt="Delikatny efekt włosa maszynowego w makijażu permanentnym brwi"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption>Lekkość bez maski</figcaption>
                </figure>

                <figure class="brow-silky-gallery-card">
                  <img
                    src="/images/silky-hairstroke-brows-detal-01.webp"
                    alt="Zbliżenie na brwi wykonane metodą Silky Hairstroke Brows"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption>Detal kierunku włosa</figcaption>
                </figure>

                <figure class="brow-silky-gallery-card">
                  <img
                    src="/images/silky-hairstroke-brows-efekt-04.webp"
                    alt="Naturalny efekt brwi permanentnych po zabiegu metodą włosa maszynowego"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption>Spokojny efekt na twarzy</figcaption>
                </figure>

                <figure class="brow-silky-gallery-card">
                  <img
                    src="/images/silky-hairstroke-brows-detal-02.webp"
                    alt="Detal brwi permanentnych wykonanych techniką Silky Hairstroke Brows"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption>Realistyczny kierunek brwi</figcaption>
                </figure>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="brow-process-section">
        <div class="container">
          <div class="brow-process-visual-intro">
            <div class="brow-process-visual-copy">
              <p class="section-kicker">Proces zabiegu</p>

              <h2>Najpierw rysunek wstępny. Dopiero później pigmentacja.</h2>

              <p>
                Rysunek wstępny jest etapem, w którym omawiany jest kształt, wysokość, długość,
                grubość i charakter brwi. To moment na spokojną rozmowę i ocenę, czy planowany efekt
                naprawdę pasuje do twarzy.
              </p>

              <p>
                Dopiero po analizie urody, skóry, mimiki i oczekiwań wybierana jest technika,
                kolor oraz sposób prowadzenia pigmentacji. W makijażu permanentnym brwi liczy się
                nie tylko sama pigmentacja, ale każda decyzja podjęta przed nią.
              </p>
            </div>

            <figure class="brow-process-visual-photo">
              <img
                src="/images/silky-hairstroke-brows-boguslawa-herda.webp"
