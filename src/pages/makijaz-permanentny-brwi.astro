---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const booksyUrl =
  "https://booksy.com/pl-pl/104871_boguslawa-herda-permanentny-make-up_salon-kosmetyczny_12680_bielsko-biala";

const pageUrl = "https://permanentnybielsko.com/makijaz-permanentny-brwi/";
const pageTitle = "Brwi permanentne Bielsko-Biała | Silky Hairstroke Brows";
const pageDescription =
  "Brwi permanentne Bielsko-Biała: naturalne brwi, metoda włoskowa, cieniowanie, włos z cieniem i autorska technika Silky Hairstroke Brows u Bogusława Herda.";

const faqItems = [
  {
    "question": "Czy brwi permanentne mogą wyglądać naturalnie?",
    "answer": "Tak, jeśli kształt, kolor i technika są dobrane indywidualnie. Naturalny efekt nie oznacza braku widoczności, tylko brak ciężkiej, sztucznej formy."
  },
  {
    "question": "Czy rysunek wstępny jest wykonywany przed zabiegiem?",
    "answer": "Tak. Rysunek wstępny jest konieczny, aby omówić kształt, proporcje i kierunek brwi przed pigmentacją."
  },
  {
    "question": "Czym różni się metoda włoskowa od cieniowania?",
    "answer": "Metoda włoskowa buduje efekt pojedynczych włosków, a cieniowanie daje bardziej miękkie wypełnienie. Wybór zależy od skóry, naturalnych brwi i oczekiwanego efektu."
  },
  {
    "question": "Czy Silky Hairstroke Brows jest dla każdego?",
    "answer": "Nie zawsze. Technika włosa wymaga odpowiednich warunków skóry i dobrego planu. Podczas konsultacji oceniane jest, czy ta metoda będzie najlepszym wyborem."
  },
  {
    "question": "Czy można poprawić stare brwi permanentne?",
    "answer": "Czasem tak, ale najpierw trzeba ocenić kolor, nasycenie i kształt starej pigmentacji. Niekiedy konieczne jest wcześniejsze rozjaśnienie PMU."
  },
  {
    "question": "Kiedy widoczny jest finalny efekt?",
    "answer": "Bezpośrednio po zabiegu brwi mogą być intensywniejsze. Finalny efekt ocenia się po wygojeniu skóry i ewentualnym dopigmentowaniu."
  },
  {
    "question": "Czy brwi permanentne wymagają dopigmentowania?",
    "answer": "Zazwyczaj dopigmentowanie jest etapem finalnego dopracowania efektu po wygojeniu. Pozwala wyrównać kolor, nasycenie i szczegóły."
  },
  {
    "question": "Gdzie wykonywane są brwi permanentne?",
    "answer": "Zabieg wykonywany jest w gabinecie Bogusława Herda w Bielsku-Białej. Aktualne terminy i rezerwacje dostępne są przez Booksy."
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "url": pageUrl,
    "name": pageTitle,
    "description": pageDescription,
    "inLanguage": "pl-PL",
    "isPartOf": {
      "@id": "https://permanentnybielsko.com/#website"
    },
    "about": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "primaryImageOfPage": {
      "@type": "ImageObject",
      "url": "https://permanentnybielsko.com/images/hero-boguslawa-herda-pmu-cutout.webp"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${pageUrl}#breadcrumb`,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Strona główna",
        "item": "https://permanentnybielsko.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Makijaż permanentny Bielsko-Biała",
        "item": "https://permanentnybielsko.com/makijaz-permanentny-bielsko/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Brwi permanentne",
        "item": pageUrl
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": `${pageUrl}#service`,
    "name": "Brwi permanentne Bielsko-Biała",
    "serviceType": "Makijaż permanentny brwi",
    "description":
      "Naturalne brwi permanentne w Bielsku-Białej: metoda włoskowa, cieniowanie, włos z cieniem, korekty starych brwi oraz autorskie podejście Silky Hairstroke Brows.",
    "areaServed": [
      {
        "@type": "City",
        "name": "Bielsko-Biała"
      },
      {
        "@type": "AdministrativeArea",
        "name": "województwo śląskie"
      }
    ],
    "provider": {
      "@id": "https://permanentnybielsko.com/#localbusiness"
    },
    "brand": {
      "@type": "Brand",
      "name": "Bogusława Herda Makijaż Permanentny"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Metody brwi permanentnych",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Brwi cieniowane"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Metoda włoskowa"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Włos z cieniem"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Silky Hairstroke Brows"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Korekta starych brwi permanentnych"
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];

---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/makijaz-permanentny-brwi/"
  structuredData={structuredData}
>
  <div class="brow-page">
    <Header />

    <main>
      <section class="brow-hero">
        <div class="brow-glow brow-glow-one"></div>
        <div class="brow-glow brow-glow-two"></div>

        <div class="container brow-hero-grid">
          <div class="brow-hero-copy">
            <p class="section-kicker">Brwi permanentne Bielsko-Biała</p>

            <h1>Naturalne brwi permanentne, które porządkują twarz bez efektu maski.</h1>

            <p class="brow-hero-lead">
              Brwi permanentne powinny podkreślać oprawę oka, a nie dominować nad twarzą.
              W gabinecie Bogusława Herda każdy zabieg zaczyna się od rozmowy, analizy urody
              i rysunku wstępnego.
            </p>

            <div class="brow-hero-actions">
              <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
                Umów konsultację
              </a>

              <a class="button-secondary" href="#metody-brwi">
                Poznaj metody
              </a>
            </div>
          </div>

          <aside class="brow-hero-card" aria-label="Silky Hairstroke Brows">
            <p class="brow-card-label">Silky</p>
            <h2>Włos maszynowy w miękkim, realistycznym kierunku.</h2>
            <p>
              Silky Hairstroke Brows to autorskie podejście Bogusława Herda do naturalnego efektu brwi:
              lekkość, precyzja i praca dopasowana do rysów twarzy.
            </p>
          </aside>
        </div>
      </section>

      <section class="brow-proof-section">
        <div class="container brow-proof-grid">
          <div>
            <strong>Rysunek wstępny</strong>
            <span>kształt omawiany przed pigmentacją</span>
          </div>

          <div>
            <strong>Naturalny kierunek</strong>
            <span>brwi dopasowane do mimiki i urody</span>
          </div>

          <div>
            <strong>Silky Hairstroke Brows</strong>
            <span>autorskie podejście do brwi</span>
          </div>

          <div>
            <strong>Korekta starych brwi</strong>
            <span>ocena pigmentu i plan naprawczy</span>
          </div>
        </div>
      </section>

      <section class="brow-intro-section">
        <div class="container brow-two-column">
          <div>
            <p class="section-kicker">Dla kogo?</p>
            <h2>Brwi permanentne dla kobiet, które chcą wyglądać świeżo i naturalnie każdego dnia.</h2>
          </div>

          <div class="brow-text-card">
            <p>
              Brwi mają ogromny wpływ na proporcje twarzy. Mogą otworzyć spojrzenie, uporządkować rysy,
              dodać twarzy świeżości i skrócić codzienny makijaż. Źle dobrany kształt potrafi jednak
              nadać twarzy zbyt surowy lub ciężki charakter.
            </p>

            <p>
              Dlatego w gabinecie Bogusława Herda brwi permanentne nie zaczynają się od pigmentu.
              Najpierw omawiany jest efekt, analizowana jest uroda, a następnie wykonywany jest
              rysunek wstępny. Dopiero po akceptacji kształtu planowana jest pigmentacja.
            </p>
          </div>
        </div>
      </section>

      <section class="brow-methods-section" id="metody-brwi">
        <div class="container">
          <div class="brow-section-heading">
            <p class="section-kicker">Metody brwi permanentnych</p>
            <h2>Technika musi wynikać z twarzy, skóry i oczekiwanego efektu.</h2>
            <p>
              Nie każda klientka potrzebuje tej samej metody. Inaczej pracuje się przy delikatnym
              uzupełnieniu brwi, inaczej przy mocniejszej oprawie oka, a jeszcze inaczej przy korekcie
              starego makijażu permanentnego.
            </p>
          </div>

          <div class="brow-method-grid">
            <article class="brow-method-card">
              <span>01</span>
              <h3>Brwi cieniowane</h3>
              <p>
                Miękkie wypełnienie brwi, które może przypominać bardzo delikatny makijaż.
                Dobre rozwiązanie, gdy potrzebna jest większa regularność i uporządkowanie kształtu.
              </p>
            </article>

            <article class="brow-method-card brow-method-card-turquoise">
              <span>02</span>
              <h3>Metoda włoskowa</h3>
              <p>
                Technika budująca efekt pojedynczych włosków. Wymaga precyzyjnego kierunku,
                lekkości i bardzo świadomego prowadzenia linii.
              </p>
            </article>

            <article class="brow-method-card">
              <span>03</span>
              <h3>Włos z cieniem</h3>
              <p>
                Połączenie struktury włosa z delikatnym cieniem. Pozwala uzyskać bardziej kompletny
                efekt przy zachowaniu miękkości i naturalnego charakteru.
              </p>
            </article>
          </div>

          <div class="brow-silky-feature">
            <div>
              <p class="section-kicker">Autorska metoda</p>
              <h3>Silky Hairstroke Brows</h3>
            </div>

            <p>
              Silky Hairstroke Brows to podejście stworzone z myślą o naturalnym efekcie włosa maszynowego.
              Celem jest lekka, realistyczna oprawa oka — bez ciężkiej, graficznej brwi i bez przypadkowego
              kierunku włosków.
            </p>
          </div>
        </div>
      </section>

      <section class="brow-process-section">
        <div class="container">
          <div class="brow-two-column brow-process-intro">
            <div>
              <p class="section-kicker">Proces zabiegu</p>
              <h2>Najpierw rysunek wstępny. Dopiero później pigmentacja.</h2>
            </div>

            <div class="brow-text-card">
              <p>
                Rysunek wstępny jest etapem, w którym omawiany jest kształt, wysokość, długość,
                grubość i charakter brwi. To moment na spokojną rozmowę i ocenę, czy planowany efekt
                naprawdę pasuje do twarzy.
              </p>
            </div>
          </div>

          <div class="brow-process-grid">
            <article>
              <span>01</span>
              <h3>Konsultacja</h3>
              <p>Rozmowa o oczekiwaniach, dotychczasowym makijażu, starym PMU i stylu klientki.</p>
            </article>

            <article>
              <span>02</span>
              <h3>Analiza urody</h3>
              <p>Ocena proporcji twarzy, mimiki, naturalnego wzrostu włosa i oprawy oka.</p>
            </article>

            <article>
              <span>03</span>
              <h3>Rysunek wstępny</h3>
              <p>Kształt brwi jest omawiany przed zabiegiem, aby uniknąć przypadkowej formy.</p>
            </article>

            <article>
              <span>04</span>
              <h3>Dobór koloru</h3>
              <p>Kolor dobierany jest do skóry, włosów, urody i oczekiwanej intensywności efektu.</p>
            </article>

            <article>
              <span>05</span>
              <h3>Pigmentacja</h3>
              <p>Precyzyjna praca warstwowa z kontrolą nasycenia, kierunku i reakcji skóry.</p>
            </article>

            <article>
              <span>06</span>
              <h3>Dopigmentowanie</h3>
              <p>Finalne dopracowanie kształtu, koloru i równowagi po wygojeniu skóry.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="brow-correction-section">
        <div class="container brow-correction-grid">
          <div class="brow-correction-card">
            <p class="section-kicker">Korekta starych brwi</p>
            <h2>Nie każdą starą pigmentację można przykryć od razu.</h2>
            <p>
              Jeśli wcześniejszy makijaż permanentny jest zbyt ciemny, zbyt chłodny, nierówny albo ma
              niekorzystny kształt, nowa pigmentacja może wymagać wcześniejszego rozjaśnienia lub pracy etapami.
              Najważniejsze jest to, aby nie pogłębić problemu i nie stworzyć jeszcze cięższego efektu.
            </p>
          </div>

          <div class="brow-list-card">
            <div>
              <strong>Ocena pigmentu</strong>
              <span>kolor, nasycenie, głębokość i możliwość wykonania nowej pracy</span>
            </div>

            <div>
              <strong>Ocena kształtu</strong>
              <span>czy obecna forma pozwala zbudować naturalne brwi bez przerysowania</span>
            </div>

            <div>
              <strong>Plan etapowy</strong>
              <span>czasem najpierw rozjaśnienie, później rysunek wstępny i nowa pigmentacja</span>
            </div>

            <div>
              <strong>Realne oczekiwania</strong>
              <span>omówienie, co da się poprawić i jaki efekt będzie możliwy po wygojeniu</span>
            </div>
          </div>
        </div>
      </section>

      <section class="brow-faq-section">
        <div class="container">
          <div class="brow-section-heading">
            <p class="section-kicker">Najczęstsze pytania</p>
            <h2>Co warto wiedzieć przed wykonaniem brwi permanentnych?</h2>
          </div>

          <div class="brow-faq-grid">
            <article>
              <h3>Czy brwi permanentne mogą wyglądać naturalnie?</h3>
              <p>
                Tak, jeśli kształt, kolor i technika są dobrane indywidualnie. Naturalny efekt nie oznacza braku widoczności,
                tylko brak ciężkiej, sztucznej formy.
              </p>
            </article>

            <article>
              <h3>Czy rysunek wstępny jest wykonywany przed zabiegiem?</h3>
              <p>
                Tak. Rysunek wstępny jest konieczny, aby omówić kształt, proporcje i kierunek brwi przed pigmentacją.
              </p>
            </article>

            <article>
              <h3>Czym różni się metoda włoskowa od cieniowania?</h3>
              <p>
                Metoda włoskowa buduje efekt pojedynczych włosków, a cieniowanie daje bardziej miękkie wypełnienie.
                Wybór zależy od skóry, naturalnych brwi i oczekiwanego efektu.
              </p>
            </article>

            <article>
              <h3>Czy Silky Hairstroke Brows jest dla każdego?</h3>
              <p>
                Nie zawsze. Technika włosa wymaga odpowiednich warunków skóry i dobrego planu. Podczas konsultacji oceniane jest,
                czy ta metoda będzie najlepszym wyborem.
              </p>
            </article>

            <article>
              <h3>Czy można poprawić stare brwi permanentne?</h3>
              <p>
                Czasem tak, ale najpierw trzeba ocenić kolor, nasycenie i kształt starej pigmentacji.
                Niekiedy konieczne jest wcześniejsze rozjaśnienie PMU.
              </p>
            </article>

            <article>
              <h3>Kiedy widoczny jest finalny efekt?</h3>
              <p>
                Bezpośrednio po zabiegu brwi mogą być intensywniejsze. Finalny efekt ocenia się po wygojeniu skóry
                i ewentualnym dopigmentowaniu.
              </p>
            </article>

            <article>
              <h3>Czy brwi permanentne wymagają dopigmentowania?</h3>
              <p>
                Zazwyczaj dopigmentowanie jest etapem finalnego dopracowania efektu po wygojeniu.
                Pozwala wyrównać kolor, nasycenie i szczegóły.
              </p>
            </article>

            <article>
              <h3>Gdzie wykonywane są brwi permanentne?</h3>
              <p>
                Zabieg wykonywany jest w gabinecie Bogusława Herda w Bielsku-Białej.
                Aktualne terminy i rezerwacje dostępne są przez Booksy.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="brow-final-cta" id="kontakt">
        <div class="container brow-final-card">
          <p class="signature cta-signature">Powrót do natury</p>
          <h2>Chcesz sprawdzić, jaki kształt brwi będzie najlepszy dla Twojej twarzy?</h2>
          <p>
            Umów konsultację i zobacz, jak może wyglądać naturalny efekt dopasowany
            do Twojej urody, skóry i codzienności.
          </p>

          <a class="button-primary" href={booksyUrl} target="_blank" rel="noopener noreferrer">
            Umów wizytę przez Booksy
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .brow-page {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 78% 12%, rgba(56, 187, 181, 0.12), transparent 28rem),
      radial-gradient(circle at 14% 40%, rgba(201, 127, 143, 0.12), transparent 26rem),
      linear-gradient(180deg, #fffdfd 0%, #fff8fa 52%, #ffffff 100%);
  }

  .brow-hero {
    position: relative;
    padding: 150px 0 88px;
    overflow: hidden;
  }

  .brow-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .brow-glow-one {
    right: -12rem;
    top: 4rem;
    width: 42rem;
    height: 42rem;
    background: radial-gradient(circle, rgba(56, 187, 181, 0.2), transparent 68%);
  }

  .brow-glow-two {
    left: -10rem;
    bottom: -12rem;
    width: 38rem;
    height: 38rem;
    background: radial-gradient(circle, rgba(201, 127, 143, 0.18), transparent 68%);
  }

  .brow-hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    gap: 24px;
    align-items: stretch;
  }

  .brow-hero-copy,
  .brow-hero-card,
  .brow-text-card,
  .brow-method-card,
  .brow-silky-feature,
  .brow-process-grid article,
  .brow-correction-card,
  .brow-list-card,
  .brow-faq-grid article,
  .brow-final-card {
    border: 1px solid rgba(183, 101, 118, 0.16);
    box-shadow: 0 18px 54px rgba(89, 53, 67, 0.075);
  }

  .brow-hero-copy {
    padding: clamp(38px, 5vw, 72px);
    border-radius: 42px;
    background: rgba(255, 255, 255, 0.76);
  }

  .brow-hero-copy h1 {
    max-width: 1000px;
    margin: 0;
    font-size: clamp(3.2rem, 5.8vw, 6.9rem);
    font-weight: 750;
    line-height: 0.92;
    letter-spacing: -0.085em;
  }

  .brow-hero-lead {
    max-width: 760px;
    margin: 28px 0 0;
    color: var(--color-muted);
    font-size: 1.12rem;
  }

  .brow-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .brow-hero-card {
    position: relative;
    overflow: hidden;
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(34px, 4vw, 56px);
    border-radius: 42px;
    color: #ffffff;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.34), transparent 11rem),
      radial-gradient(circle at 82% 24%, rgba(221, 247, 244, 0.24), transparent 13rem),
      linear-gradient(140deg, #0f7773 0%, #1aa5a0 22%, #74e0d7 40%, #138a86 56%, #33c1bb 74%, #bff6f1 88%, #0d6a67 100%);
    background-size: 100% 100%, 100% 100%, 240% 240%;
    animation: brow-turquoise-flow 13s ease-in-out infinite alternate;
    box-shadow: 0 28px 76px rgba(35, 156, 150, 0.22);
  }

  .brow-hero-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, transparent 0%, rgba(255, 255, 255, 0.06) 22%, rgba(255, 255, 255, 0.24) 47%, rgba(255, 255, 255, 0.06) 72%, transparent 100%);
