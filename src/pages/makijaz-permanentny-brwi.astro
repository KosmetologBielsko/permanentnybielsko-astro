</style>
<script>
  const browMethodScroll = document.querySelector("#browMethodScroll");
  const browMethodLeft = document.querySelector(".brow-method-arrow-left");
  const browMethodRight = document.querySelector(".brow-method-arrow-right");

  if (browMethodScroll && browMethodLeft && browMethodRight) {
    const getBrowMethodScrollAmount = () => {
      const firstCard = browMethodScroll.querySelector(".brow-method-slide-card");
      if (!firstCard) return 330;

      const cardWidth = firstCard.getBoundingClientRect().width;
      return cardWidth + 18;
    };

    browMethodLeft.addEventListener("click", () => {
      browMethodScroll.scrollBy({
        left: -getBrowMethodScrollAmount(),
        behavior: "smooth",
      });
    });

    browMethodRight.addEventListener("click", () => {
      browMethodScroll.scrollBy({
        left: getBrowMethodScrollAmount(),
        behavior: "smooth",
      });
    });
  }

  const browSilkyGalleryScroll = document.querySelector("#browSilkyGalleryScroll");
  const browSilkyGalleryLeft = document.querySelector(".brow-silky-gallery-arrow-left");
  const browSilkyGalleryRight = document.querySelector(".brow-silky-gallery-arrow-right");

  if (browSilkyGalleryScroll && browSilkyGalleryLeft && browSilkyGalleryRight) {
    const getBrowSilkyGalleryScrollAmount = () => {
      const firstCard = browSilkyGalleryScroll.querySelector(".brow-silky-gallery-card");
      if (!firstCard) return 310;

      const cardWidth = firstCard.getBoundingClientRect().width;
      return cardWidth + 16;
    };

    browSilkyGalleryLeft.addEventListener("click", () => {
      browSilkyGalleryScroll.scrollBy({
        left: -getBrowSilkyGalleryScrollAmount(),
        behavior: "smooth",
      });
    });

    browSilkyGalleryRight.addEventListener("click", () => {
      browSilkyGalleryScroll.scrollBy({
        left: getBrowSilkyGalleryScrollAmount(),
        behavior: "smooth",
      });
    });
  }
  
</script>
